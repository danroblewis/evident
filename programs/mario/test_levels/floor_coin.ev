-- Test level: hero on the floor, one coin to its right at the same y.
-- Holding Right for ~700ms wins. Used by `test_mario_happy_path.ev`
-- to exercise the engine's `..PlatformerMain` wiring without the
-- production level's physics complexity.

import "programs/mario/engine.ev"

claim InitFloorCoin
    state ∈ GameState
    state.hero.pos = IVec2(60, 500)
    state.hero.vel = IVec2(0, 0)
    state.hero.on_ground = true
    -- HeroPhysics quantifies over `platforms`; keep one dummy
    -- off-screen so the seq isn't empty.
    state.platforms[0].pos  = IVec2(2000, 2000)
    state.platforms[0].size = IVec2(10, 10)
    state.coins[0] = Coin(IVec2(200, 500), false)

type main(state, state_next ∈ GameState)
    #state.platforms      = 1
    #state_next.platforms = 1
    #state.coins          = 1
    #state_next.coins     = 1
    #plat_rects           = 1
    #coin_rects           = 1
    #output.rects         = 4

    floor_y    = 540
    level_w    = 800
    screen_w   = 800
    hero_w     = 30
    hero_h     = 40
    coin_size  = 18
    gravity    = 1800
    jump_speed = 700
    run_speed  = 260
    vmax       = 1100

    sky_color      ∈ Color(80, 150, 220)
    win_color      ∈ Color(120, 200, 100)
    floor_color    ∈ Color(60, 40, 20)
    platform_color ∈ Color(140, 90, 40)
    coin_color     ∈ Color(255, 220, 60)
    hero_color     ∈ Color(220, 80, 60)
    win_hero_color ∈ Color(255, 220, 80)

    state.step = 0 ⇒ InitFloorCoin
    ..PlatformerMain
