-- Physics traces for the platformer engine. These test the actual
-- per-frame behavior — hero displacement under run_speed, jump arc
-- under gravity, on_ground transitions on landing — at a fixed
-- 16ms dt so the assertions are deterministic regardless of CPU
-- speed or display refresh.
--
-- These tests exercise engine.ev's HeroPhysics/HeroEffectiveVy/
-- HeroHorizontal claims via the test_levels/floor_coin.ev wiring.
-- They DON'T render anything — the trace runner skips plugins
-- entirely and synthesizes its own input + dt. So bugs in the SDL
-- plugin (vsync jitter, missing uniform uploads, etc.) won't show
-- up here. The complementary test for those is "run the demo and
-- look at it."

-- Holding Right for ~1s should move the hero from x=60 to roughly
-- x=60 + run_speed (260) * 1.0 = 320. Integer division per frame
-- (260 * 16 / 1000 = 4 px/frame, 62 frames in 1s after settling)
-- gives 60 + 62*4 = 308.
trace right_hold_moves_x "programs/mario/test_levels/floor_coin.ev"
    advance 16ms =>
        hero.pos.x = 60                  -- starting position pinned by InitFloorCoin
    key_down "Right"
    advance 1s =>
        hero.pos.x = 308

-- Letting go of Right should freeze x. (vel.x reset to 0 by
-- HeroHorizontal when no key is held; x doesn't drift.)
trace right_release_stops "programs/mario/test_levels/floor_coin.ev"
    advance 16ms
    key_down "Right"
    advance 500ms
    key_up "Right"
    advance 500ms =>
        hero.vel.x = 0

-- Jumping from grounded sets vel.y to -jump_speed (-700) on the
-- next frame, then gravity pulls it back. Important: release Up
-- immediately after the impulse — holding it would re-trigger
-- another jump on every landing and the hero never settles.
trace jump_from_floor_returns "programs/mario/test_levels/floor_coin.ev"
    advance 16ms =>
        hero.pos.y = 500
        hero.on_ground = true
    key_down "Up"
    advance 16ms =>
        hero.vel.y = -700                -- jump impulse fired
    key_up "Up"
    advance 1500ms =>                    -- enough wall time to land
        hero.on_ground = true
        hero.pos.y = 500

-- Hero in the air keeps falling toward the floor under gravity.
-- Don't bother predicting the exact pos mid-arc; just check the
-- velocity sign is increasing (gravity pulls vy positive).
trace gravity_pulls_down "programs/mario/test_levels/floor_coin.ev"
    advance 16ms
    key_down "Up"
    advance 16ms =>
        hero.vel.y = -700
    key_up "Up"
    advance 200ms =>
        hero.on_ground = false           -- still rising
        hero.vel.y = -364                -- -700 + 12 frames * gravity (28/frame) = -364

-- The win path: holding Right for ~700ms collects the lone coin
-- (at x=200 on the floor) and flips state.won.
trace win_on_coin_pickup "programs/mario/test_levels/floor_coin.ev"
    key_down "Right"
    advance 1s =>
        coins[0].collected = true
        won = true
