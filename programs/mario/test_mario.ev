-- Tests for the platformer engine. Each `sat_*` claim should be
-- satisfiable; each `unsat_*` should be unsatisfiable. Run with:
--     evident test programs/mario/

import "programs/mario/engine.ev"

-- ── WinIfAllCollected ────────────────────────────────────────────────

claim sat_win_when_all_coins_collected
    coins ∈ Seq(Coin)
    won ∈ Bool
    #coins = 3
    coins[0].collected = true
    coins[1].collected = true
    coins[2].collected = true
    WinIfAllCollected (coins mapsto coins, won mapsto won)
    won = true

claim unsat_won_true_with_uncollected_coin
    coins ∈ Seq(Coin)
    won ∈ Bool
    #coins = 3
    coins[0].collected = true
    coins[1].collected = false
    coins[2].collected = true
    WinIfAllCollected (coins mapsto coins, won mapsto won)
    won = true            -- engine forces won = false; asserting true → UNSAT

claim sat_no_coins_means_won
    coins ∈ Seq(Coin)
    won ∈ Bool
    #coins = 0
    WinIfAllCollected (coins mapsto coins, won mapsto won)
    won = true            -- vacuously, ∀ over empty is true

-- ── CoinsStep: collection on overlap ─────────────────────────────────

claim sat_overlapping_coin_is_collected_next_frame
    cur, nxt ∈ Seq(Coin)
    hero ∈ Hero
    #cur = 1
    #nxt = 1
    hero.pos = IVec2(100, 100)
    hero.vel = IVec2(0, 0)
    hero.on_ground = true
    cur[0].pos = IVec2(110, 110)
    cur[0].collected = false
    CoinsStep (cur mapsto cur, nxt mapsto nxt, hero mapsto hero, hero_w mapsto 30, hero_h mapsto 40, coin_size mapsto 18)
    nxt[0].collected = true

claim unsat_distant_coin_unchanged
    cur, nxt ∈ Seq(Coin)
    hero ∈ Hero
    #cur = 1
    #nxt = 1
    hero.pos = IVec2(100, 100)
    hero.vel = IVec2(0, 0)
    hero.on_ground = true
    cur[0].pos = IVec2(900, 900)            -- far away
    cur[0].collected = false
    CoinsStep (cur mapsto cur, nxt mapsto nxt, hero mapsto hero, hero_w mapsto 30, hero_h mapsto 40, coin_size mapsto 18)
    nxt[0].collected = true                  -- engine carries forward false; UNSAT

claim sat_collected_coin_stays_collected
    cur, nxt ∈ Seq(Coin)
    hero ∈ Hero
    #cur = 1
    #nxt = 1
    hero.pos = IVec2(0, 0)
    hero.vel = IVec2(0, 0)
    hero.on_ground = true
    cur[0].pos = IVec2(900, 900)
    cur[0].collected = true                  -- already collected
    CoinsStep (cur mapsto cur, nxt mapsto nxt, hero mapsto hero, hero_w mapsto 30, hero_h mapsto 40, coin_size mapsto 18)
    nxt[0].collected = true                  -- monotonic — stays true

-- ── HeroEffectiveVy: jump only when grounded ─────────────────────────

claim sat_jump_when_grounded
    cur ∈ Hero
    input ∈ SDLInput
    eff_vy ∈ Int
    cur.pos = IVec2(0, 0)
    cur.vel = IVec2(0, 0)
    cur.on_ground = true
    input.up_held = true
    input.dt = 16
    HeroEffectiveVy (cur mapsto cur, input mapsto input, eff_vy mapsto eff_vy, dt mapsto input.dt, gravity mapsto 1800, jump_speed mapsto 700, vmax mapsto 1100)
    eff_vy = -700                            -- negative = upward (jump speed)

claim unsat_jump_when_airborne
    cur ∈ Hero
    input ∈ SDLInput
    eff_vy ∈ Int
    cur.pos = IVec2(0, 0)
    cur.vel = IVec2(0, 0)
    cur.on_ground = false                    -- in air
    input.up_held = true
    input.dt = 16
    HeroEffectiveVy (cur mapsto cur, input mapsto input, eff_vy mapsto eff_vy, dt mapsto input.dt, gravity mapsto 1800, jump_speed mapsto 700, vmax mapsto 1100)
    eff_vy = -700                            -- can't jump in air; gravity gives positive eff_vy

claim sat_gravity_falls_when_ungrounded_no_jump
    cur ∈ Hero
    input ∈ SDLInput
    eff_vy ∈ Int
    cur.pos = IVec2(0, 0)
    cur.vel = IVec2(0, 0)
    cur.on_ground = false
    input.up_held = false
    input.dt = 16
    HeroEffectiveVy (cur mapsto cur, input mapsto input, eff_vy mapsto eff_vy, dt mapsto input.dt, gravity mapsto 1800, jump_speed mapsto 700, vmax mapsto 1100)
    eff_vy = 28                              -- 0 + 1800 * 16 / 1000 = 28 (Int division)

-- ── HeroHorizontal: input → velocity ─────────────────────────────────

claim sat_right_held_runs_right
    nxt ∈ Hero
    input ∈ SDLInput
    input.right_held = true
    input.left_held = false
    HeroHorizontal (nxt mapsto nxt, input mapsto input, run_speed mapsto 260)
    nxt.vel.x = 260

claim sat_left_held_runs_left
    nxt ∈ Hero
    input ∈ SDLInput
    input.right_held = false
    input.left_held = true
    HeroHorizontal (nxt mapsto nxt, input mapsto input, run_speed mapsto 260)
    nxt.vel.x = -260

claim sat_no_input_stops
    nxt ∈ Hero
    input ∈ SDLInput
    input.right_held = false
    input.left_held = false
    HeroHorizontal (nxt mapsto nxt, input mapsto input, run_speed mapsto 260)
    nxt.vel.x = 0

-- ── CameraFollow: clamps to level ────────────────────────────────────

claim sat_camera_clamps_at_left_edge
    hero ∈ Hero
    camera_x ∈ Int
    hero.pos = IVec2(50, 0)                  -- near left edge
    hero.vel = IVec2(0, 0)
    hero.on_ground = true
    CameraFollow (hero mapsto hero, camera_x mapsto camera_x, level_w mapsto 1600, screen_w mapsto 800)
    camera_x = 0                             -- can't scroll past 0

claim sat_camera_clamps_at_right_edge
    hero ∈ Hero
    camera_x ∈ Int
    hero.pos = IVec2(1500, 0)                -- near right edge
    hero.vel = IVec2(0, 0)
    hero.on_ground = true
    CameraFollow (hero mapsto hero, camera_x mapsto camera_x, level_w mapsto 1600, screen_w mapsto 800)
    camera_x = 800                           -- 1600 - 800 = 800

claim sat_camera_centers_on_hero_in_middle
    hero ∈ Hero
    camera_x ∈ Int
    hero.pos = IVec2(800, 0)
    hero.vel = IVec2(0, 0)
    hero.on_ground = true
    CameraFollow (hero mapsto hero, camera_x mapsto camera_x, level_w mapsto 1600, screen_w mapsto 800)
    camera_x = 400                           -- 800 - 400 (half screen)
