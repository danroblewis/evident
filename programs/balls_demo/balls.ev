-- balls.ev — N balls drop under gravity, bounce off floor, walls, ceiling.
--
-- Time-based physics: velocity is in pixels per second, scaled by input.dt
-- (milliseconds since previous step, capped at 100). Each step:
--   gravity:   vy += 200 * dt / 1000     (clamped to ±800)
--   position:  pos += vel * dt / 1000    (per-axis)
--   bounds:    floor at y=540, ceiling at y=20, walls at x=20 and x=740
--   bounce:    on impact, clamp position and reverse the relevant velocity ×7/10
--
-- Bounds + effective_vy + render come from balls_engine.ev. Bounce
-- physics stays here because variants modify it (anchor: input from
-- dragged pos; collide: gated on overlap).
--
-- Run: evident execute programs/balls_demo/balls.ev

import "programs/balls_demo/balls_engine.ev"

type main(state, state_next ∈ WorldState)
    input  ∈ SDLInput
    output ∈ SDLOutput

    #state.balls      = 4
    #state_next.balls = 4
    #output.rects     = 4

    output.bg = Color(15, 15, 30)

    -- Engine: state-space bounds + per-step effective vy + render.
    -- ball_color is an intermediate because `mapsto` doesn't yet
    -- resolve `Type(args)` literals as mapping values (per CLAUDE.md).
    ball_color ∈ Color(220, 100, 80)
    BallStateBounds (balls ↦ state.balls, x_lo ↦ 20, x_hi ↦ 740, y_lo ↦ 20, y_hi ↦ 540, vmax ↦ 800)
    eff_vy ∈ Seq(Int)
    #eff_vy = 4
    BallEffectiveVy (balls ↦ state.balls, eff_vy ↦ eff_vy, dt ↦ input.dt, gravity ↦ 200, vmax ↦ 800)
    BallRender      (balls ↦ state.balls, rects ↦ output.rects, size ↦ 40, color ↦ ball_color)

    -- ── Y-axis: floor/ceiling clamp/bounce on the dt-stepped position.
    ∀ i ∈ {0..3} : (state.balls[i].pos.y + eff_vy[i] * input.dt / 1000) > 540 ⇒ (state_next.balls[i].pos.y = 540 ∧ state_next.balls[i].vel.y = (0 - eff_vy[i]) * 7 / 10)
    ∀ i ∈ {0..3} : (state.balls[i].pos.y + eff_vy[i] * input.dt / 1000) < 20  ⇒ (state_next.balls[i].pos.y = 20  ∧ state_next.balls[i].vel.y = (0 - eff_vy[i]) * 7 / 10)
    ∀ i ∈ {0..3} : ((state.balls[i].pos.y + eff_vy[i] * input.dt / 1000) ≥ 20 ∧ (state.balls[i].pos.y + eff_vy[i] * input.dt / 1000) ≤ 540) ⇒ (state_next.balls[i].pos.y = state.balls[i].pos.y + eff_vy[i] * input.dt / 1000 ∧ state_next.balls[i].vel.y = eff_vy[i])

    -- ── X-axis: wall clamp/bounce (no gravity, no clamp needed).
    ∀ i ∈ {0..3} : (state.balls[i].pos.x + state.balls[i].vel.x * input.dt / 1000) > 740 ⇒ (state_next.balls[i].pos.x = 740 ∧ state_next.balls[i].vel.x = (0 - state.balls[i].vel.x) * 7 / 10)
    ∀ i ∈ {0..3} : (state.balls[i].pos.x + state.balls[i].vel.x * input.dt / 1000) < 20  ⇒ (state_next.balls[i].pos.x = 20  ∧ state_next.balls[i].vel.x = (0 - state.balls[i].vel.x) * 7 / 10)
    ∀ i ∈ {0..3} : ((state.balls[i].pos.x + state.balls[i].vel.x * input.dt / 1000) ≥ 20 ∧ (state.balls[i].pos.x + state.balls[i].vel.x * input.dt / 1000) ≤ 740) ⇒ (state_next.balls[i].pos.x = state.balls[i].pos.x + state.balls[i].vel.x * input.dt / 1000 ∧ state_next.balls[i].vel.x = state.balls[i].vel.x)
