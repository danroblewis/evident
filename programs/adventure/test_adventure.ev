-- test_adventure.ev — World model invariants and execution trace tests.
--
-- Run with:  python evident.py test programs/adventure/test_adventure.ev

import "world.ev"
import "commands.ev"

-- ── Execution trace ────────────────────────────────────────────────────────────
-- Exercises every room and every exit. If any room is unreachable, missing a
-- description, or misrouted, one of these steps fails.

trace happy_path "programs/adventure/adventure.ev"
    send "look" =>
        location = "entrance"
        output ∋ "entrance"
    send "go north" => location = "forest"
    send "go east"  => location = "tower"
    send "go west"  => location = "forest"
    send "go south" => location = "entrance"
    send "go east"  => location = "cave"
    send "go down"  => location = "dungeon"
    send "look"     => location = "dungeon"
    send "go up"    => location = "cave"
    send "go west"  => location = "entrance"
    send "quit"     => output ∋ "Goodbye"

-- ── Room model ────────────────────────────────────────────────────────────────

-- All five rooms have descriptions (data completeness check)
claim sat_all_rooms_have_descriptions
    d1 ∈ String
    d2 ∈ String
    d3 ∈ String
    d4 ∈ String
    d5 ∈ String
    ("entrance", d1) ∈ room_descriptions
    ("forest",   d2) ∈ room_descriptions
    ("cave",     d3) ∈ room_descriptions
    ("tower",    d4) ∈ room_descriptions
    ("dungeon",  d5) ∈ room_descriptions

-- Only the five known rooms have descriptions
claim unsat_unknown_room_has_description
    room ∈ String
    d    ∈ String
    (room, d) ∈ room_descriptions
    room ∉ {"entrance", "forest", "cave", "tower", "dungeon"}

-- ── Exit structure ────────────────────────────────────────────────────────────

-- No room exits to itself
claim unsat_room_exits_to_itself
    room ∈ String
    dir  ∈ String
    (room, dir, room) ∈ exits_map

-- Every exit destination is a known room
claim unsat_exit_leads_to_unknown_room
    from_room ∈ String
    dir       ∈ String
    to_room   ∈ String
    (from_room, dir, to_room) ∈ exits_map
    to_room ∉ {"entrance", "forest", "cave", "tower", "dungeon"}

-- No unknown room appears as a source of exits
claim unsat_unknown_room_has_exits
    from_room ∈ String
    dir       ∈ String
    dest      ∈ String
    (from_room, dir, dest) ∈ exits_map
    from_room ∉ {"entrance", "forest", "cave", "tower", "dungeon"}

-- The dungeon has no horizontal exits — only up
claim unsat_dungeon_has_horizontal_exit
    dir  ∈ String
    dest ∈ String
    ("dungeon", dir, dest) ∈ exits_map
    dir ≠ "up"

-- ── Items ─────────────────────────────────────────────────────────────────────

-- All items are placed in known rooms
claim unsat_item_in_unknown_room
    item ∈ Item
    room ∈ String
    (item, room) ∈ initial_item_locations
    room ∉ {"entrance", "forest", "cave", "tower", "dungeon"}

-- No item starts in two different rooms
claim unsat_item_in_two_places
    item  ∈ Item
    room1 ∈ String
    room2 ∈ String
    (item, room1) ∈ initial_item_locations
    (item, room2) ∈ initial_item_locations
    room1 ≠ room2

-- ── Command vocabulary ────────────────────────────────────────────────────────

-- Invalid directions are rejected
claim unsat_northwest_is_a_direction
    d ∈ String
    ("northwest", d) ∈ direction_words
