import "stdlib/io.ev"
import "stdlib/sequences.ev"

schema NumberedDocument
    lines    ∈ Seq(String)
    contents ∈ Seq(String)
    n        ∈ Nat
    n = #lines
    n = #contents
    n ≥ 1
    ∀ (prev, next) ∈ adjacent lines: prev ∋ "\t" ∧ next ∋ "\t"
    lines[0] ⊑ "1\t"
    ∀ i ∈ {0..n-1}: lines[i] = int_to_str (i+1) ++ "\t" ++ contents[i]

schema main
    src ∈ StdinLines
    dst ∈ StdoutLines
    nd  ∈ NumberedDocument

    nd.contents = src.lines
    nd.lines    = dst.lines
