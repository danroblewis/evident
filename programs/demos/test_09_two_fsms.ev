-- 09_two_fsms — two FSMs sharing world state.
--
-- `producer` writes a counter into world.n each tick.
-- `consumer` reads world.n, formats it, and prints it.
-- Demonstrates: writer-first scheduling (consumer sees the
-- value producer just wrote, in the same tick), shared
-- mutable World, and an FSM running per-tick formatting via
-- IntToStr → Println.
--
-- COUNTEREXAMPLE NOTE: enum variant names are global. Two
-- enums in the same file can't both have `Done` (or any other
-- shared variant). Hence PEnd / CEnd / CFormat below.

import "stdlib/runtime.ev"

type World
    n ∈ Int

enum PState = PStart | PTick(Int) | PEnd
enum CState = CWait | CFormat | CEnd

claim producer(world, world_next ∈ World,
               state, state_next ∈ PState,
               last_results ∈ ResultList,
               effects ∈ EffectList)
    state_next = match state
        PStart    ⇒ PTick(3)
        PTick(k)  ⇒ (k ≤ 1 ? PEnd : PTick(k - 1))
        PEnd      ⇒ PEnd

    next_n ∈ Int
    next_n = match state
        PStart    ⇒ 3
        PTick(k)  ⇒ k
        PEnd      ⇒ 0
    world_next.n = next_n

    effects = match state
        PEnd ⇒ ⟨Println("producer done"), Exit(0)⟩
        _    ⇒ ⟨⟩

claim consumer(world ∈ World,
               state, state_next ∈ CState,
               last_results ∈ ResultList,
               effects ∈ EffectList)
    state_next = match state
        CWait   ⇒ (world.n > 0 ? CFormat : CWait)
        CFormat ⇒ CWait
        CEnd    ⇒ CEnd

    n_str ∈ String
    n_str = match last_results
        ResCons(r, _) ⇒ match r
            StringResult(s) ⇒ s
            _               ⇒ "?"
        _             ⇒ "?"

    effects = match state
        CWait   ⇒ (world.n > 0 ? ⟨IntToStr(world.n)⟩ : ⟨⟩)
        CFormat ⇒ ⟨Println("consumer saw n = " ++ n_str)⟩
        CEnd    ⇒ ⟨⟩

claim sat_producer_writes_n
    world ∈ World
    world_next ∈ World
    state ∈ PState
    state_next ∈ PState
    last_results ∈ ResultList
    effects ∈ EffectList
    state = PTick(3)
    producer
    world_next.n = 3

claim sat_consumer_emits_int_to_str_when_n_positive
    world ∈ World
    state ∈ CState
    state_next ∈ CState
    last_results ∈ ResultList
    effects ∈ EffectList
    world.n = 7
    state = CWait
    consumer
    effects = ⟨IntToStr(7)⟩
