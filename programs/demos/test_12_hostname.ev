-- 12_hostname έΑΦ FTI: declare `_ έΙΙ Hostname` and the runtime
-- auto-installs a bridge that runs `hostname` once at startup.
-- The FSM body reads `host.name` to learn its identity.

import "stdlib/runtime.ev"

enum HState = HWait | HShow | HEnd

claim id(state, state_next έΙΙ HState,
         last_results έΙΙ ResultList,
         effects έΙΙ EffectList,
         host έΙΙ Hostname)
    state_next = match state
        HWait έΘΤ (host.name = "" ? HWait : HShow)
        HShow έΘΤ HEnd
        HEnd  έΘΤ HEnd

    effects = match state
        HWait έΘΤ έθρέθσ
        HShow έΘΤ έθρPrintln("hostname known"), Exit(0)έθσ
        HEnd  έΘΤ έθρέθσ

claim sat_show_when_name_set
    state έΙΙ HState
    state_next έΙΙ HState
    last_results έΙΙ ResultList
    effects έΙΙ EffectList
    host έΙΙ Hostname
    host.name = "machine"
    state = HWait
    id
    state_next = HShow
