-- Conformance: inline record literal `Type(args)` as a claim argument.
--
-- `resolve_mapping` expands `Type(arg1, arg2, …)` per field and binds
-- each `slot.field_name` directly. Works for both positional invocation
-- and explicit `mapsto`. Without this, `c.*` would be free and the
-- UNSAT cases below would solve to anything.

type Color(red, green, blue ∈ Int)

claim use_color(c ∈ Color, sum ∈ Int)
    sum = c.red + c.green + c.blue

claim sat_positional_color
    s ∈ Int
    use_color(Color(10, 20, 30), s)
    s = 60

claim unsat_positional_color
    s ∈ Int
    use_color(Color(10, 20, 30), s)
    s = 100

claim use_color_named
    c   ∈ Color
    sum ∈ Int
    sum = c.red + c.green + c.blue

claim sat_mapsto_color
    s ∈ Int
    use_color_named (c ↦ Color(7, 8, 9), sum ↦ s)
    s = 24

claim unsat_mapsto_color
    s ∈ Int
    use_color_named (c ↦ Color(7, 8, 9), sum ↦ s)
    s = 99

-- Nested record literal — `Outer(Inner(...), n)`. Should bind
-- `slot.inner.x`, `slot.inner.y`, `slot.n` per field.
type IVec2(x, y ∈ Int)
type Outer(inner ∈ IVec2, n ∈ Int)

claim use_outer(o ∈ Outer, total ∈ Int)
    total = o.inner.x + o.inner.y + o.n

claim sat_nested_record_lit
    t ∈ Int
    use_outer(Outer(IVec2(3, 4), 5), t)
    t = 12

claim unsat_nested_record_lit
    t ∈ Int
    use_outer(Outer(IVec2(3, 4), 5), t)
    t = 99
