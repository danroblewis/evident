-- Conformance tests for stdlib/io/line_io.ev — verifies effect
-- builders + extract claims work as expected.

import "stdlib/io/line_io.ev"

claim sat_read_line_builds_readline
    e ∈ Effect
    read_line
    e = ReadLine

claim sat_write_line_builds_println
    text ∈ String
    e ∈ Effect
    text = "hello"
    write_line
    e = Println("hello")

claim sat_extract_line_from_string_result
    last_results ∈ ResultList
    line ∈ String
    last_results = ResCons(StringResult("greetings"), ResNil)
    extract_line
    line = "greetings"

claim sat_extract_line_returns_empty_for_error
    last_results ∈ ResultList
    line ∈ String
    last_results = ResCons(ErrorResult("eof"), ResNil)
    extract_line
    line = ""

claim sat_extract_eof_true_on_error
    last_results ∈ ResultList
    eof ∈ Bool
    last_results = ResCons(ErrorResult("eof"), ResNil)
    extract_eof
    eof = true

claim sat_extract_eof_false_on_string
    last_results ∈ ResultList
    eof ∈ Bool
    last_results = ResCons(StringResult("hi"), ResNil)
    extract_eof
    eof = false
