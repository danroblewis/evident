-- Multi-FSM test: per-FSM halt + program-level all-halt exit.
--
-- Validates:
--   * Per-FSM halt: short_fsm halts after 3 prints; long_fsm
--     continues. Halted FSMs drop from the per-tick scheduler.
--   * Program halt: when ALL FSMs halt, the program exits cleanly.
--   * No max-steps cap needed if all FSMs halt naturally.
--
-- Expected output (--max-steps 20 — should halt before 10):
--   short
--   long
--   short
--   long
--   short
--   long
--   long
--   long
--
-- 8 lines total. After tick 2, short_fsm halts (3 prints).
-- After tick 4, long_fsm halts (5 prints). Program then exits.
--
-- Behavior to verify:
--   * Exactly 3 "short" lines (not 4 or more).
--   * Exactly 5 "long" lines.
--   * Program exits cleanly (steps < max_steps; halted_clean = true).

import "stdlib/runtime.ev"

enum ShortState =
    ST0
    ST1
    ST2
    STDone

enum LongState =
    LT0
    LT1
    LT2
    LT3
    LT4
    LTDone

claim short_fsm(state, state_next ∈ ShortState,
                last_results ∈ ResultList,
                effects ∈ EffectList)
    state_next = match state
        ST0    ⇒ ST1
        ST1    ⇒ ST2
        ST2    ⇒ STDone
        STDone ⇒ STDone

    effects = match state
        STDone ⇒ ⟨⟩
        _      ⇒ ⟨Println("short")⟩

claim long_fsm(state, state_next ∈ LongState,
               last_results ∈ ResultList,
               effects ∈ EffectList)
    state_next = match state
        LT0    ⇒ LT1
        LT1    ⇒ LT2
        LT2    ⇒ LT3
        LT3    ⇒ LT4
        LT4    ⇒ LTDone
        LTDone ⇒ LTDone

    effects = match state
        LTDone ⇒ ⟨⟩
        _      ⇒ ⟨Println("long")⟩
