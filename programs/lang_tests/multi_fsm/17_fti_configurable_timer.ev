-- FTI v2: per-instance configurable resources via type-use pin.
--
-- The Timer type accepts an `interval_ms` field configured at the
-- declaration site:
--
--     t ∈ Timer (interval_ms ↦ 20)
--
-- Each FSM declaring `t ∈ Timer (...)` gets its own bridge running
-- at the configured rate. Different FSMs can have different rates
-- — fast (20ms) reaches 5 ticks before slow (100ms) reaches 3.
--
-- This is FTI v2's per-instance config. Without it, all timers
-- ran at the runtime-global EVIDENT_TICK_MS rate.
--
-- Run:
--     evident effect-run programs/lang_tests/multi_fsm/17_fti_configurable_timer.ev
-- Expected:
--     fast: 5 ticks @ 20ms
--     slow: 3 ticks @ 100ms

import "stdlib/runtime.ev"

enum FastS = FA | FDone
enum SlowS = SA

claim fast(state, state_next ∈ FastS,
           last_results ∈ ResultList,
           effects ∈ EffectList)
    t ∈ Timer (interval_ms ↦ 20)
    state_next = match state
        FA    ⇒ (t.tick_count ≥ 5 ? FDone : FA)
        FDone ⇒ FDone
    effects = match state
        FA    ⇒ (t.tick_count ≥ 5 ? ⟨Println("fast: 5 ticks @ 20ms")⟩ : ⟨⟩)
        FDone ⇒ ⟨⟩

claim slow(state, state_next ∈ SlowS,
           last_results ∈ ResultList,
           effects ∈ EffectList)
    t ∈ Timer (interval_ms ↦ 100)
    state_next = SA
    effects = (t.tick_count ≥ 3
               ? ⟨Println("slow: 3 ticks @ 100ms"), Exit(0)⟩
               : ⟨⟩)
