-- Conformance tests for the ternary operator `cond ? a : b`.
--
-- Run with:
--     evident test programs/lang_tests/test_ternary.ev
--
-- Translates to Z3's ITE for whichever sort the branches share
-- (Int, Real, Bool, String, enum Datatype).
--
-- Precedence: ternary sits between ⇒ and ∨, right-associative.

-- ── Int branches ─────────────────────────────────────────────────

claim sat_int_then_branch
    flag ∈ Bool
    x ∈ Int
    flag = true
    x = (flag ? 7 : 99)
    x = 7

claim sat_int_else_branch
    flag ∈ Bool
    x ∈ Int
    flag = false
    x = (flag ? 7 : 99)
    x = 99

claim unsat_int_pinned_to_other_branch
    flag ∈ Bool
    x ∈ Int
    flag = true
    x = (flag ? 7 : 99)
    x = 99

-- ── String branches ──────────────────────────────────────────────

claim sat_string_picks_then
    cond ∈ Bool
    s ∈ String
    cond = true
    s = (cond ? "hi" : "bye")
    s = "hi"

-- ── Bool branches ────────────────────────────────────────────────

claim sat_bool_branches
    a ∈ Bool
    b ∈ Bool
    out ∈ Bool
    a = false
    b = true
    out = (a ? false : b)
    out = true

-- ── Enum branches ────────────────────────────────────────────────

enum Color = Red | Green | Blue

claim sat_enum_picks_else
    flag ∈ Bool
    c ∈ Color
    flag = false
    c = (flag ? Red : Blue)
    c = Blue

-- ── Nesting (right-associative) ─────────────────────────────────
-- `a ? 1 : c ? 2 : 3`  =  `a ? 1 : (c ? 2 : 3)`
-- a=false, c=true → reaches the inner-then → 2.

claim sat_right_associative
    x ∈ Int
    a ∈ Bool
    c ∈ Bool
    a = false
    c = true
    x = (a ? 1 : c ? 2 : 3)
    x = 2

-- ── Ternary in arithmetic ───────────────────────────────────────

claim sat_in_arithmetic
    x ∈ Int
    flag ∈ Bool
    flag = true
    x = (flag ? 10 : 20) + 5
    x = 15

-- ── Comparison condition ────────────────────────────────────────

claim sat_with_comparison_cond
    x ∈ Int
    n ∈ Int
    n = 4
    x = (n > 3 ? 100 : 200)
    x = 100
