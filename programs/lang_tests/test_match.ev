-- Conformance tests for the `match` expression.
--
-- Run with:
--     evident test programs/lang_tests/test_match.ev
--
-- Translates to a nested Z3 ITE chain over constructor recognizers.
-- v1 limitations:
--   - Scrutinee must be a bare identifier (Var::EnumVar in env).
--   - Payload bindings restricted to Int / Bool / String / Real.
--   - Multi-line match can't sit inside parens (lexer suppresses
--     newlines there); use an intermediate variable.

enum Result = Ok(Int) | Err(String)
enum Day = Mon | Tue | Wed | Thu | Fri | Sat | Sun

-- ── Int payload bound + used ─────────────────────────────────────

claim sat_match_ok_payload
    r ∈ Result
    score ∈ Int
    r = Ok(7)
    score = match r
        Ok(n)  ⇒ n * 10
        Err(_) ⇒ 0
    score = 70

claim sat_match_err_payload
    r ∈ Result
    msg ∈ String
    r = Err("boom")
    msg = match r
        Ok(_)  ⇒ "ok"
        Err(s) ⇒ s
    msg = "boom"

-- ── Wildcard arm ─────────────────────────────────────────────────

claim sat_wildcard_catches_remaining
    today ∈ Day
    busy ∈ Bool
    today = Wed
    busy = match today
        Sat ⇒ false
        Sun ⇒ false
        _   ⇒ true
    busy = true

-- ── Discard payload with `_` ─────────────────────────────────────

claim sat_discard_payload_with_underscore
    r ∈ Result
    label ∈ String
    r = Ok(42)
    label = match r
        Ok(_)  ⇒ "happy"
        Err(_) ⇒ "sad"
    label = "happy"

-- ── UNSAT when match result pinned to wrong branch's value ───────

claim unsat_match_result_pinned_wrong
    r ∈ Result
    score ∈ Int
    r = Ok(7)
    score = match r
        Ok(n)  ⇒ n * 10
        Err(_) ⇒ 0
    score = 999

-- ── Nullary matched against other nullary ────────────────────────

claim sat_nullary_to_nullary
    today ∈ Day
    weekend ∈ Bool
    today = Sat
    weekend = match today
        Sat ⇒ true
        Sun ⇒ true
        _   ⇒ false
    weekend = true

-- ── Phase 3.3: enum-typed pattern bindings ──────────────────────
-- A `match` arm can bind a payload field whose type is itself an
-- enum (cross-enum or self-recursive). The binding becomes a Var
-- usable in nested matches.

enum Cell = Empty | Filled(Int)
enum Pair = MakePair(Cell, Cell)

claim sat_enum_payload_binding_self
    p ∈ Pair
    n ∈ Int
    p = MakePair(Filled(7), Empty)
    n = match p
        MakePair(a, _) ⇒ match a
            Filled(x) ⇒ x
            Empty     ⇒ -1
    n = 7
