(set-logic QF_AUFLIA)
(declare-const s_arr (Array Int Int))
(declare-const s_len Int)
(declare-const x Int)
(assert (and (<= 0 s_len) (<= s_len 5)))
(assert (>= s_len 1))
(assert (or (and (< 0 s_len) (= (select s_arr 0) x)) (and (< 1 s_len) (= (select s_arr 1) x)) (and (< 2 s_len) (= (select s_arr 2) x)) (and (< 3 s_len) (= (select s_arr 3) x)) (and (< 4 s_len) (= (select s_arr 4) x))))
(assert (= x 42))
(check-sat)
