(declare-const a (Seq Int))
(declare-const b (Seq Int))
(assert (<= (seq.len a) 3))
(assert (<= (seq.len b) 3))
(assert (= (seq.len a) 2))
(assert (= (seq.len b) 2))
(assert (= (seq.nth b 0) 99))
(assert (exists ((i Int)) (and (<= 0 i) (< i (seq.len (seq.++ a b))) (= (seq.nth (seq.++ a b) i) 99))))
(check-sat)
