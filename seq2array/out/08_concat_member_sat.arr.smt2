(set-logic QF_AUFLIA)
(declare-const a_arr (Array Int Int))
(declare-const a_len Int)
(declare-const b_arr (Array Int Int))
(declare-const b_len Int)
(declare-const cat1 (Array Int Int))
(declare-const catlen2 Int)
(assert (and (<= 0 a_len) (<= a_len 3)))
(assert (and (<= 0 b_len) (<= b_len 3)))
(assert (= catlen2 (+ a_len b_len)))
(assert (=> (< 0 catlen2) (= (select cat1 0) (ite (< 0 a_len) (select a_arr 0) (select b_arr (- 0 a_len))))))
(assert (=> (< 1 catlen2) (= (select cat1 1) (ite (< 1 a_len) (select a_arr 1) (select b_arr (- 1 a_len))))))
(assert (=> (< 2 catlen2) (= (select cat1 2) (ite (< 2 a_len) (select a_arr 2) (select b_arr (- 2 a_len))))))
(assert (=> (< 3 catlen2) (= (select cat1 3) (ite (< 3 a_len) (select a_arr 3) (select b_arr (- 3 a_len))))))
(assert (=> (< 4 catlen2) (= (select cat1 4) (ite (< 4 a_len) (select a_arr 4) (select b_arr (- 4 a_len))))))
(assert (=> (< 5 catlen2) (= (select cat1 5) (ite (< 5 a_len) (select a_arr 5) (select b_arr (- 5 a_len))))))
(assert (= a_len 2))
(assert (= b_len 2))
(assert (= (select b_arr 0) 99))
(assert (or (and (< 0 catlen2) (= (select cat1 0) 99)) (and (< 1 catlen2) (= (select cat1 1) 99)) (and (< 2 catlen2) (= (select cat1 2) 99)) (and (< 3 catlen2) (= (select cat1 3) 99)) (and (< 4 catlen2) (= (select cat1 4) 99)) (and (< 5 catlen2) (= (select cat1 5) 99))))
(check-sat)
