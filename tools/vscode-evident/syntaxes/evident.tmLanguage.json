{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Evident",
  "scopeName": "source.evident",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#decls" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#carrydual" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-dash.evident", "match": "--.*$" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.evident",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.evident", "match": "\\\\." }
      ]
    },
    "decls": {
      "patterns": [
        {
          "match": "^\\s*(claim|fsm|type|schema|enum|subclaim)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.decl.evident" },
            "2": { "name": "entity.name.type.evident" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.evident",
          "match": "\\b(match|matches|in|import|external|mapsto)\\b"
        },
        {
          "name": "constant.language.boolean.evident",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.unicode.evident",
          "match": "∈|∀|∃|⇒|↦|¬|∧|∨|≤|≥|≠|∉|⟨|⟩|⟦|⟧|‖|\\.\\.|\\+\\+|=>|<=|>=|!="
        },
        {
          "name": "keyword.operator.evident",
          "match": "[=<>+\\-*/?:#|]"
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.evident", "match": "\\b[0-9]+(\\.[0-9]+)?\\b" }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.evident",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "carrydual": {
      "patterns": [
        {
          "name": "variable.other.carry-dual.evident",
          "match": "\\b_[a-z][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
