-- Evident equivalent of countdown.json — the oracle for the SMT-LIB path.
-- count = is_first_tick ? 3 : _count - 1; prints "tick" while counting,
-- then "liftoff" + Exit(0) at zero. Run via `evident effect-run`; its stdout
-- must match `evident effect-run-smtlib countdown.json` exactly.

import "stdlib/runtime.ev"

fsm countdown
    count ∈ Int
    count = (is_first_tick ? 3 : _count - 1)
    effects = (count > 0 ? ⟨Println("tick")⟩
                         : ⟨Println("liftoff"), Exit(0)⟩)
