#!/usr/bin/env bash
# evident-self — CLI for the SELF-HOSTED Evident compiler.
#
# Post-bootstrap-deletion (c19be0a). The "binary" returned by `bin`
# is now an ephemeral wrapper that runs:
#
#   flatten <file.ev> | kernel compiler.smt2
#
# The kernel + compiler.smt2 IS the compiler. There is no longer a
# bootstrap fallback. EVIDENT_SELF_VIA_SMT2 is honored for symmetry
# with prior call sites but the seam is unconditional.
#
# Usage:
#   scripts/evident-self emit   <file.ev> <claim> [-o <out.smt2>]
#   scripts/evident-self sample <file.ev> [...]
#   scripts/evident-self bin                # prints wrapper-script path
#   scripts/evident-self --help

set -e -o pipefail

here() { cd "$(dirname "$0")/.." && pwd; }
ROOT="$(here)"

KERNEL="${ROOT}/kernel/target/release/kernel"
COMPILER_SMT2="${ROOT}/compiler.smt2"

# emit_via_smt2_wrapper — write (and echo the path of) a tiny shim that
# makes `<wrapper> emit <file> <claim> [-o out]` run the SELF-HOSTED
# compiler (flatten <file> | kernel compiler.smt2) instead of bootstrap.
# This is the cutover seam: with `EVIDENT_SELF_VIA_SMT2=1` set and
# compiler.smt2 present, every script that resolves its compiler through
# `evident-self bin` switches to kernel + compiler.smt2 at once; `unset`
# reverts. compiler/compiler.ev reads its source PATH from stdin line 1
# and the optional target claim from stdin line 2 (wave 4o — per-process,
# no shared /tmp file), so the wrapper just pipes those two lines in.
emit_via_smt2_wrapper() {
    local wrapper="/tmp/evident-self-via-smt2-$$.sh"
    cat > "$wrapper" <<WRAP
#!/usr/bin/env bash
# Auto-generated by scripts/evident-self (EVIDENT_SELF_VIA_SMT2=1). Ephemeral.
set -u -o pipefail
KERNEL="${KERNEL}"
FLATTEN="${ROOT}/scripts/flatten-evident.sh"
COMPILER_SMT2="${COMPILER_SMT2}"
SAMPLE="${ROOT}/scripts/sample-via-smt2.sh"
MEM_CAP="${ROOT}/scripts/mem-cap.sh"
# sample verb (wave 4j): delegate to the self-hosted sat-check wrapper
# (kernel + compiler.smt2 emit per claim + standalone z3).
if [ "\${1:-}" = "sample" ]; then
    shift
    exec "\$SAMPLE" "\$@"
fi
[ "\${1:-}" = "emit" ] || { echo "evident-self(smt2): only 'emit' / 'sample' are supported, got '\${1:-}'" >&2; exit 2; }
shift
SRC=""; CLAIM=""; OUT=""
while [ \$# -gt 0 ]; do
    case "\$1" in
        -o) shift; OUT="\${1:-}"; shift ;;
        *)  if [ -z "\$SRC" ]; then SRC="\$1"; elif [ -z "\$CLAIM" ]; then CLAIM="\$1"; fi; shift ;;
    esac
done
[ -n "\$SRC" ] || { echo "evident-self(smt2): missing <file.ev>" >&2; exit 2; }
FLAT="\$(mktemp -t evself-flat.XXXXXX.ev)"
trap 'rm -f "\$FLAT"' EXIT
"\$FLATTEN" "\$SRC" > "\$FLAT" || { echo "evident-self(smt2): flatten failed" >&2; exit 1; }
# Per-process input (wave 4o): stdin line 1 = the flat source path,
# line 2 = the optional target claim. No shared /tmp file ⇒ no race.
# Kernel invocation is wrapped by mem-cap.sh — RSS > MEM_CAP_MB
# (default 3000) → SIGKILL. macOS doesn't honor RLIMIT_AS, so this is
# how we keep a runaway compiler.smt2 run from swapping the host.
if [ -n "\$OUT" ]; then
    printf '%s\n%s\n' "\$FLAT" "\$CLAIM" | "\$MEM_CAP" "\$KERNEL" "\$COMPILER_SMT2" > "\$OUT"
else
    printf '%s\n%s\n' "\$FLAT" "\$CLAIM" | "\$MEM_CAP" "\$KERNEL" "\$COMPILER_SMT2"
fi
WRAP
    chmod +x "$wrapper"
    echo "$wrapper"
}

usage() {
    cat >&2 <<'EOF'
evident-self — self-hosted Evident compiler CLI.

Usage:
  evident-self emit   <file.ev> <claim> [-o <out.smt2>]
  evident-self sample <file.ev> [...]
  evident-self bin                # prints the wrapper-script path
  evident-self --help

`bin` returns the path to an ephemeral shim script that runs
`kernel + compiler.smt2`. Every test/bench script resolves its
`evident` command through `evident-self bin`, so the wrapper is
the only place the compiler entry point is written down.
EOF
}

die() { echo "evident-self: $*" >&2; exit 2; }

[ -x "$KERNEL" ]        || die "kernel binary missing at $KERNEL (run ./test.sh --rust-only first)"
[ -f "$COMPILER_SMT2" ] || die "compiler.smt2 missing at $COMPILER_SMT2 (run scripts/build-compiler-smt2.sh)"

case "${1:-}" in
    -h|--help|"")
        usage; exit 0 ;;
    bin)
        emit_via_smt2_wrapper; exit 0 ;;
    emit|sample)
        ;;
    *)
        die "unknown subcommand '$1' (expected: emit | sample | bin)" ;;
esac

# emit / sample — delegate to the wrapper bin prints.
WRAPPER="$(emit_via_smt2_wrapper)"
exec "$WRAPPER" "$@"
