        : ¬((from - 18 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 18))) ? from - 17
        : ¬((from - 19 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 19))) ? from - 18
        : ¬((from - 20 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 20))) ? from - 19
        : ¬((from - 21 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 21))) ? from - 20
        : ¬((from - 22 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 22))) ? from - 21
        : ¬((from - 23 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 23))) ? from - 22
        : ¬((from - 24 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 24))) ? from - 23
        : ¬((from - 25 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 25))) ? from - 24
        : ¬((from - 26 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 26))) ? from - 25
        : ¬((from - 27 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 27))) ? from - 26
