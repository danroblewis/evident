claim AcTrimEnd(s ∈ String, out ∈ Int)
    out = (¬((char_at(s, #s - 1) = " ") ∨ (char_at(s, #s - 1) = "\t")) ? #s
        : ¬((char_at(s, #s - 2) = " ") ∨ (char_at(s, #s - 2) = "\t")) ? #s - 1
        : ¬((char_at(s, #s - 3) = " ") ∨ (char_at(s, #s - 3) = "\t")) ? #s - 2
        : ¬((char_at(s, #s - 4) = " ") ∨ (char_at(s, #s - 4) = "\t")) ? #s - 3
        : ¬((char_at(s, #s - 5) = " ") ∨ (char_at(s, #s - 5) = "\t")) ? #s - 4
        : ¬((char_at(s, #s - 6) = " ") ∨ (char_at(s, #s - 6) = "\t")) ? #s - 5
        : ¬((char_at(s, #s - 7) = " ") ∨ (char_at(s, #s - 7) = "\t")) ? #s - 6
        : ¬((char_at(s, #s - 8) = " ") ∨ (char_at(s, #s - 8) = "\t")) ? #s - 7
        : ¬((char_at(s, #s - 9) = " ") ∨ (char_at(s, #s - 9) = "\t")) ? #s - 8
