        : ¬((char_at(s, #s - 17) = " ") ∨ (char_at(s, #s - 17) = "\t")) ? #s - 16
        : ¬((char_at(s, #s - 18) = " ") ∨ (char_at(s, #s - 18) = "\t")) ? #s - 17
        : ¬((char_at(s, #s - 19) = " ") ∨ (char_at(s, #s - 19) = "\t")) ? #s - 18
        : ¬((char_at(s, #s - 20) = " ") ∨ (char_at(s, #s - 20) = "\t")) ? #s - 19
        : ¬((char_at(s, #s - 21) = " ") ∨ (char_at(s, #s - 21) = "\t")) ? #s - 20
        : ¬((char_at(s, #s - 22) = " ") ∨ (char_at(s, #s - 22) = "\t")) ? #s - 21
        : ¬((char_at(s, #s - 23) = " ") ∨ (char_at(s, #s - 23) = "\t")) ? #s - 22
        : ¬((char_at(s, #s - 24) = " ") ∨ (char_at(s, #s - 24) = "\t")) ? #s - 23
        : ¬((char_at(s, #s - 25) = " ") ∨ (char_at(s, #s - 25) = "\t")) ? #s - 24
        : ¬((char_at(s, #s - 26) = " ") ∨ (char_at(s, #s - 26) = "\t")) ? #s - 25
        : ¬((char_at(s, #s - 27) = " ") ∨ (char_at(s, #s - 27) = "\t")) ? #s - 26
        : ¬((char_at(s, #s - 28) = " ") ∨ (char_at(s, #s - 28) = "\t")) ? #s - 27
        : ¬((char_at(s, #s - 29) = " ") ∨ (char_at(s, #s - 29) = "\t")) ? #s - 28
        : ¬((char_at(s, #s - 30) = " ") ∨ (char_at(s, #s - 30) = "\t")) ? #s - 29
        : ¬((char_at(s, #s - 31) = " ") ∨ (char_at(s, #s - 31) = "\t")) ? #s - 30
        : ¬((char_at(s, #s - 32) = " ") ∨ (char_at(s, #s - 32) = "\t")) ? #s - 31
        : ¬((char_at(s, #s - 33) = " ") ∨ (char_at(s, #s - 33) = "\t")) ? #s - 32
        : ¬((char_at(s, #s - 34) = " ") ∨ (char_at(s, #s - 34) = "\t")) ? #s - 33
        : ¬((char_at(s, #s - 35) = " ") ∨ (char_at(s, #s - 35) = "\t")) ? #s - 34
        : ¬((char_at(s, #s - 36) = " ") ∨ (char_at(s, #s - 36) = "\t")) ? #s - 35
        : ¬((char_at(s, #s - 37) = " ") ∨ (char_at(s, #s - 37) = "\t")) ? #s - 36
        : ¬((char_at(s, #s - 38) = " ") ∨ (char_at(s, #s - 38) = "\t")) ? #s - 37
        : ¬((char_at(s, #s - 39) = " ") ∨ (char_at(s, #s - 39) = "\t")) ? #s - 38
        : ¬((char_at(s, #s - 40) = " ") ∨ (char_at(s, #s - 40) = "\t")) ? #s - 39
        : ¬((char_at(s, #s - 41) = " ") ∨ (char_at(s, #s - 41) = "\t")) ? #s - 40
        : ¬((char_at(s, #s - 42) = " ") ∨ (char_at(s, #s - 42) = "\t")) ? #s - 41
        : ¬((char_at(s, #s - 43) = " ") ∨ (char_at(s, #s - 43) = "\t")) ? #s - 42
        : ¬((char_at(s, #s - 44) = " ") ∨ (char_at(s, #s - 44) = "\t")) ? #s - 43
        : ¬((char_at(s, #s - 45) = " ") ∨ (char_at(s, #s - 45) = "\t")) ? #s - 44
        : ¬((char_at(s, #s - 46) = " ") ∨ (char_at(s, #s - 46) = "\t")) ? #s - 45
        : ¬((char_at(s, #s - 47) = " ") ∨ (char_at(s, #s - 47) = "\t")) ? #s - 46
        : ¬((char_at(s, #s - 48) = " ") ∨ (char_at(s, #s - 48) = "\t")) ? #s - 47
        : #s - 48)

-- One comment-strip event: from scan state (p0 = next position,
-- q0 = inside-string), resolve or advance past the next quote/dash-pair.
-- dd/qq are caller-named scratch outputs. done1 + code1 hold the result.
claim AcCommentStep(s ∈ String, p0 ∈ Int, q0 ∈ Bool, done0 ∈ Bool, code0 ∈ String, dd ∈ Int, qq ∈ Int, p1 ∈ Int, q1 ∈ Bool, done1 ∈ Bool, code1 ∈ String)
    dd = (done0 ? -1 : index_of(s, "--", p0))
    qq = (done0 ? -1 : index_of(s, "\"", p0))
    done1 = (done0 ? done0
        : q0 ? (qq < 0)
        : ((dd ≥ 0 ∧ ((qq < 0) ∨ (dd < qq))) ∨ ((dd < 0) ∧ (qq < 0))))
    code1 = (done0 ? code0
        : q0 ? s
        : (dd ≥ 0 ∧ ((qq < 0) ∨ (dd < qq))) ? substr(s, 0, dd)
        : s)
    p1 = (done0 ? p0 : qq + 1)
    q1 = (done0 ? q0 : ¬q0)

-- One paren-balance event for the injection splice point: nearest "(" or
-- ")" from p0; f tracks -2 = scanning, -1 = unbalanced, ≥ 0 = close-paren
-- index that returns depth to 0. op/cp are caller-named scratch outputs.
claim AcParenStep(s ∈ String, p0 ∈ Int, d0 ∈ Int, f0 ∈ Int, op ∈ Int, cp ∈ Int, p1 ∈ Int, d1 ∈ Int, f1 ∈ Int)
    op = (f0 > -2 ? -1 : index_of(s, "(", p0))
    cp = (f0 > -2 ? -1 : index_of(s, ")", p0))
    f1 = (f0 > -2 ? f0
        : cp < 0 ? -1
        : (op ≥ 0 ∧ op < cp) ? -2
        : (d0 = 1 ? cp : -2))
    d1 = (f0 > -2 ? d0
        : cp < 0 ? d0
        : (op ≥ 0 ∧ op < cp) ? d0 + 1
        : d0 - 1)
    p1 = (f0 > -2 ? p0
        : cp < 0 ? p0
        : (op ≥ 0 ∧ op < cp) ? op + 1
        : cp + 1)

-- One word-boundary occurrence probe of `needle` (length nlen) in body.
-- f: -2 = keep probing from o1, -1 = no occurrence, ≥ 0 = boundary hit.
-- pos is caller-named scratch.
claim AcBodyProbe(body ∈ String, needle ∈ String, nlen ∈ Int, o0 ∈ Int, f0 ∈ Int, pos ∈ Int, o1 ∈ Int, f1 ∈ Int)
    pos = (f0 > -2 ? -1 : index_of(body, needle, o0))
    f1 = (f0 > -2 ? f0
        : pos < 0 ? -1
        : ((¬str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(body, pos - 1)))
           ∧ ((pos + nlen ≥ #body) ∨ ¬str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(body, pos + nlen)))) ? pos
        : -2)
    o1 = (f0 > -2 ? o0 : pos + 1)


-- Parse the non-negative base-10 integer at s[from .. from+len); -1 when
-- len is 0 or beyond 7 digits.
claim AcParseInt(s ∈ String, from ∈ Int, len ∈ Int, out ∈ Int)
    out = (len = 1 ? index_of("0123456789", char_at(s, from + 0))
        : len = 2 ? index_of("0123456789", char_at(s, from + 0)) * 10 + index_of("0123456789", char_at(s, from + 1))
        : len = 3 ? index_of("0123456789", char_at(s, from + 0)) * 100 + index_of("0123456789", char_at(s, from + 1)) * 10 + index_of("0123456789", char_at(s, from + 2))
        : len = 4 ? index_of("0123456789", char_at(s, from + 0)) * 1000 + index_of("0123456789", char_at(s, from + 1)) * 100 + index_of("0123456789", char_at(s, from + 2)) * 10 + index_of("0123456789", char_at(s, from + 3))
        : len = 5 ? index_of("0123456789", char_at(s, from + 0)) * 10000 + index_of("0123456789", char_at(s, from + 1)) * 1000 + index_of("0123456789", char_at(s, from + 2)) * 100 + index_of("0123456789", char_at(s, from + 3)) * 10 + index_of("0123456789", char_at(s, from + 4))
        : len = 6 ? index_of("0123456789", char_at(s, from + 0)) * 100000 + index_of("0123456789", char_at(s, from + 1)) * 10000 + index_of("0123456789", char_at(s, from + 2)) * 1000 + index_of("0123456789", char_at(s, from + 3)) * 100 + index_of("0123456789", char_at(s, from + 4)) * 10 + index_of("0123456789", char_at(s, from + 5))
        : len = 7 ? index_of("0123456789", char_at(s, from + 0)) * 1000000 + index_of("0123456789", char_at(s, from + 1)) * 100000 + index_of("0123456789", char_at(s, from + 2)) * 10000 + index_of("0123456789", char_at(s, from + 3)) * 1000 + index_of("0123456789", char_at(s, from + 4)) * 100 + index_of("0123456789", char_at(s, from + 5)) * 10 + index_of("0123456789", char_at(s, from + 6))
        : -1)


-- Backward scans for the ↦-jump call-binding parser: out = the lowest
-- index reachable from `from` (exclusive) by stepping back over ws /
-- word chars. char_at at negative indexes returns "" and stops the scan.
claim AcWsBack(s ∈ String, from ∈ Int, out ∈ Int)
    out = (¬((char_at(s, from - 1) = " ") ∨ (char_at(s, from - 1) = "\t")) ? from
        : ¬((char_at(s, from - 2) = " ") ∨ (char_at(s, from - 2) = "\t")) ? from - 1
        : ¬((char_at(s, from - 3) = " ") ∨ (char_at(s, from - 3) = "\t")) ? from - 2
        : ¬((char_at(s, from - 4) = " ") ∨ (char_at(s, from - 4) = "\t")) ? from - 3
        : ¬((char_at(s, from - 5) = " ") ∨ (char_at(s, from - 5) = "\t")) ? from - 4
        : ¬((char_at(s, from - 6) = " ") ∨ (char_at(s, from - 6) = "\t")) ? from - 5
        : ¬((char_at(s, from - 7) = " ") ∨ (char_at(s, from - 7) = "\t")) ? from - 6
        : ¬((char_at(s, from - 8) = " ") ∨ (char_at(s, from - 8) = "\t")) ? from - 7
        : ¬((char_at(s, from - 9) = " ") ∨ (char_at(s, from - 9) = "\t")) ? from - 8
        : ¬((char_at(s, from - 10) = " ") ∨ (char_at(s, from - 10) = "\t")) ? from - 9
        : ¬((char_at(s, from - 11) = " ") ∨ (char_at(s, from - 11) = "\t")) ? from - 10
        : ¬((char_at(s, from - 12) = " ") ∨ (char_at(s, from - 12) = "\t")) ? from - 11
        : ¬((char_at(s, from - 13) = " ") ∨ (char_at(s, from - 13) = "\t")) ? from - 12
        : ¬((char_at(s, from - 14) = " ") ∨ (char_at(s, from - 14) = "\t")) ? from - 13
        : ¬((char_at(s, from - 15) = " ") ∨ (char_at(s, from - 15) = "\t")) ? from - 14
        : ¬((char_at(s, from - 16) = " ") ∨ (char_at(s, from - 16) = "\t")) ? from - 15
        : from - 16)

claim AcWordBack(s ∈ String, from ∈ Int, out ∈ Int)
    out = (¬((from - 1 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 1))) ? from
        : ¬((from - 2 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 2))) ? from - 1
