-- Three word-boundary occurrence probes of `needle` (length nlen) in
-- body, chained: f1 = -2 keep probing from o1, -1 = no occurrence,
-- ≥ 0 = boundary hit. Inactive (act = false) returns -1.
claim AcBodyScan3(body ∈ String, needle ∈ String, nlen ∈ Int, o0 ∈ Int, act ∈ Bool, o1 ∈ Int, f1 ∈ Int)
    bs3_f0 ∈ Int = (act ? -2 : -1)
    bs3_pos_a, bs3_o_a, bs3_f_a ∈ Int
    AcBodyProbe(body ↦ body, needle ↦ needle, nlen ↦ nlen, o0 ↦ o0, f0 ↦ bs3_f0, pos ↦ bs3_pos_a, o1 ↦ bs3_o_a, f1 ↦ bs3_f_a)
    bs3_pos_b, bs3_o_b, bs3_f_b ∈ Int
    AcBodyProbe(body ↦ body, needle ↦ needle, nlen ↦ nlen, o0 ↦ bs3_o_a, f0 ↦ bs3_f_a, pos ↦ bs3_pos_b, o1 ↦ bs3_o_b, f1 ↦ bs3_f_b)
    bs3_pos_c ∈ Int
    AcBodyProbe(body ↦ body, needle ↦ needle, nlen ↦ nlen, o0 ↦ bs3_o_b, f0 ↦ bs3_f_b, pos ↦ bs3_pos_c, o1 ↦ o1, f1 ↦ f1)
