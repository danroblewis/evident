claim AcWordEnd(s ∈ String, from ∈ Int, out ∈ Int)
    out = (¬(((from) < #s) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from))) ? from
        : ¬(((from + 1) < #s) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from + 1))) ? from + 1
        : ¬(((from + 2) < #s) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from + 2))) ? from + 2
        : ¬(((from + 3) < #s) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from + 3))) ? from + 3
