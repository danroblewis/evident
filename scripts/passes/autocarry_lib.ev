        : ¬((from - 34 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 34))) ? from - 33
        : ¬((from - 35 ≥ 0) ∧ str_contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", char_at(s, from - 35))) ? from - 34
