-- MODULE autocarry_lib — shared single-expression scan helpers for the
-- autocarry pass programs (analyze + apply).
-- CONSUMES: slot-bound (s, from/p0/…) inputs per instantiation.
-- PRODUCES: out/p1/… slot-bound outputs; no internal names, so every
--           claim is safe to instantiate many times in one body.
-- MAINTAINS: chains are lazy nested ternaries — cost is the distance
--            actually scanned, not the unroll depth (measured 2026-06-10:
--            64-deep chain over 9k ticks = 0.19 s wall, 0.0 ms z3).
-- Unroll caps: identifiers/indent ≤ 64 chars, trailing ws ≤ 48.

claim AcWsSkip(s ∈ String, from ∈ Int, out ∈ Int)
    out = (¬((char_at(s, from) = " ") ∨ (char_at(s, from) = "\t")) ? from
        : ¬((char_at(s, from + 1) = " ") ∨ (char_at(s, from + 1) = "\t")) ? from + 1
        : ¬((char_at(s, from + 2) = " ") ∨ (char_at(s, from + 2) = "\t")) ? from + 2
        : ¬((char_at(s, from + 3) = " ") ∨ (char_at(s, from + 3) = "\t")) ? from + 3
