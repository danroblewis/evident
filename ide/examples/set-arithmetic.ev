-- Set membership and range constraints.

schema PrimeUnder20
    n ∈ Nat
    n ∈ {2, 3, 5, 7, 11, 13, 17, 19}

schema CompositeUnder20
    n ∈ Nat
    n ∈ {4, 6, 8, 9, 10, 12, 14, 15, 16, 18}

schema AnyIntegerUnder20
    n ∈ Nat
    n ∈ {2, 3, 5, 7, 11, 13, 17, 19} ∪ {4, 6, 8, 9, 10, 12, 14, 15, 16, 18}

schema RangeMembership
    x ∈ Nat
    y ∈ Nat
    x ∈ {1..10}
    y ∈ {20..30}
    x + y < 35
