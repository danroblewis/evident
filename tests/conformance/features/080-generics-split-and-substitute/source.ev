import "stdlib/kernel.ev"
claim main
    g ∈ String = "Edge<Rect>"
    lt ∈ Int = index_of(g, "<")
    gt ∈ Int = index_of(g, ">")
    pre ∈ String = substr(g, 0, lt)
    arg ∈ String = substr(g, lt + 1, gt - lt - 1)
    tmpl ∈ String = "Seq(T)"
    mono ∈ String = replace(tmpl, "T", arg)
    ok ∈ Bool = (pre = "Edge" ∧ arg = "Rect" ∧ mono = "Seq(Rect)")
    effects ∈ Seq(Effect) = ⟨Exit(ok ? 0 : 1)⟩
