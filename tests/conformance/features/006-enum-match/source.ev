import "stdlib/kernel.ev"

enum Light = Red | Yellow | Green

claim main
    signal ∈ Light = Green
    word ∈ String = match signal
        Red    ⇒ "stop"
        Yellow ⇒ "slow"
        Green  ⇒ "go"
    effects ∈ Seq(Effect) = ⟨
        LibCall("libc", "puts", ⟨ArgStr(word)⟩),
        Exit(0)
    ⟩
