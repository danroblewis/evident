import "stdlib/kernel.ev"
type IVec2(x, y ∈ Int)
claim weighted_sum(scale ∈ Int, v ∈ IVec2, out ∈ Int)
    out = scale * (v.x + v.y)
claim main
    s ∈ Int
    9 < s < 11
    result ∈ Int
    s.weighted_sum((2, 3), result)
    ok ∈ Bool = (result = 50)
    effects ∈ Seq(Effect) = ⟨Exit(ok ? 0 : 1)⟩
