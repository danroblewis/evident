import "stdlib/kernel.ev"
type Item(id, kind ∈ Nat)
claim main
    a ∈ Item (id ↦ 1, kind ↦ 0)
    b ∈ Item (id ↦ 2, kind ↦ 1)
    c ∈ Item (id ↦ 3, kind ↦ 2)
    big ∈ Set(Item)
    small ∈ Set(Item)
    big = {a, b}
    small = {a, c}
    ∀ x ∈ small : x ∈ big
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
