-- stage0 toy, dispatch claim 1: token-kind classifier.
-- Fossil-subset discipline (docs/plans/fossil-subset.md): flat claim,
-- match on preamble-enum (Result) scrutinee, arms `Variant(_) ⇒ lit`
-- + `_ ⇒ name`, CASCADED two-arm matches (round-1 probe of this spike
-- showed multi-arm match miscompiles: default `_` leaks as a literal
-- underscore and the body drains — only the p46 two-arm shape works).
-- Stitched into the hand-written shell by scripts/stitch-stage0.sh;
-- instantiated 3x under prefixes lxa_/lxb_/lxc_.
--
-- Encoding contract with the shell (char class of a field's first char):
--   StringResult(_) = letter  → kind 1
--   IntResult(_)    = digit   → kind 2
--   RealResult(_)   = '='     → kind 3
--   anything else             → kind 0
import "stdlib/kernel.ev"

claim main
    lk_cls ∈ Result
    lk_ka ∈ Int = match lk_cls
        IntResult(_) ⇒ 2
        _ ⇒ 0
    lk_kb ∈ Int = match lk_cls
        RealResult(_) ⇒ 3
        _ ⇒ lk_ka
    lk_kind ∈ Int = match lk_cls
        StringResult(_) ⇒ 1
        _ ⇒ lk_kb
    lk_sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
