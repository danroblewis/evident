-- Probe: record type declaration + field access constraints.
-- expect-smt2: p declared with IVec2 shape, (= (x p) 3)-style field pins.

import "stdlib/kernel.ev"

type IVec2(x, y ∈ Int)

claim main
    p ∈ IVec2
    p.x = 3
    p.y = 4
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
