-- Probe: match whose arms are CTOR applications (Effect values) —
-- the conditional-effect candidate (p50's seq-literal arms hit <nyi>).

import "stdlib/kernel.ev"

enum Phase = Run | Halt

claim main
    ph ∈ Phase = Halt
    e0 ∈ Effect = match ph
        Halt ⇒ Exit(0)
        _ ⇒ ReadLine
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
