-- Probe: `matches` Bool recognizer on an enum value.
-- expect-smt2: is_int tied to an is-IntResult recognizer.

import "stdlib/kernel.ev"

claim main
    e ∈ Result = IntResult(7)
    is_int ∈ Bool
    is_int = (e matches IntResult(_))
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
