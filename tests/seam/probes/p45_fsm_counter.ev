-- Probe: the full compiler2 FSM skeleton in one fixture —
-- is_first_tick init, `_count` carry, ternary state update,
-- ternary conditional exit. If this compiles AND runs to exit 0,
-- a multi-tick FSM is expressible in the fossil subset.

import "stdlib/kernel.ev"

claim main
    count ∈ Int = (is_first_tick ? 1 : (_count + 1))
    _count ∈ Int
    done ∈ Bool = (count > 1)
    effects ∈ Seq(Effect) = (done ? ⟨Exit(0)⟩ : ⟨⟩)
