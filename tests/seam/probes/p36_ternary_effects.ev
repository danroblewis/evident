-- Probe: ternary over Seq literals as the effects writer
-- (`effects = (flag ? ⟨Exit(0)⟩ : ⟨⟩)`) — the conditional-exit idiom
-- compiler2 needs since guarded `cond ⇒ effects = …` drops (p25).

import "stdlib/kernel.ev"

claim main
    flag ∈ Bool
    flag = true
    effects ∈ Seq(Effect) = (flag ? ⟨Exit(0)⟩ : ⟨⟩)
    sentinel ∈ Int = 42
