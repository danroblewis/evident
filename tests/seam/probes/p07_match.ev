-- Probe: `match` on an enum (stdlib Result, no user enum decl).
-- expect-smt2: an ite/recognizer shape binding n from IntResult payload.

import "stdlib/kernel.ev"

claim main
    e ∈ Result = IntResult(7)
    n ∈ Int
    n = match e
        IntResult(v) ⇒ v
        _ ⇒ 0
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
