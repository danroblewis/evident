-- Probe: Seq literals, `++` concat, `#` cardinality.
-- expect-smt2: xs/a/b seq declares, length constraints, sentinel.

import "stdlib/kernel.ev"

claim main
    a ∈ Seq(Int) = ⟨1, 2⟩
    b ∈ Seq(Int) = ⟨3⟩
    xs ∈ Seq(Int)
    xs = a ++ b
    n ∈ Int
    n = #xs
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
