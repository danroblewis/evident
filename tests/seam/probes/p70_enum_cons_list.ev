-- Probe: cons-list enum shape (`Nil2 | Cons2(Int, LL2)`) — payloadless
-- variant first, recursive payloaded variant second. compiler.ev's
-- TokenList pattern; p67/p69 suggest payloaded variants after the
-- first position shred the enum parser.

import "stdlib/kernel.ev"

enum LL2 = Nil2 | Cons2(Int, LL2)

claim main
    l ∈ LL2 = Nil2
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
