-- Probe: chained membership forms (pin / bound / range / multi-name).
-- expect-smt2: (= x 5), (< y 10), (< 0 z) + (< z 10), bounds on a and b.

import "stdlib/kernel.ev"

claim main
    x ∈ Int = 5
    y ∈ Int < 10
    0 < z ∈ Int < 10
    a, b ∈ Int < 5
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
