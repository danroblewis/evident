-- Probe: match with LITERAL arms and no payload bindings — the only
-- candidate branching primitive left after rounds 1-3 (ternary, bool
-- RHS, ⇒-consequents, guarded effects all fail). p34 showed match
-- renders ite + recognizer but leaks unbound payload vars; literal
-- arms have no payload vars to leak.

import "stdlib/kernel.ev"

claim main
    e ∈ Result = IntResult(7)
    n ∈ Int = match e
        IntResult(_) ⇒ 1
        _ ⇒ 0
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
