-- Probe: effects written via match over an enum — the conditional-exit
-- candidate (ternary effects emitted <nyi> in p36).

import "stdlib/kernel.ev"

enum Phase = Run | Halt

claim main
    ph ∈ Phase = Halt
    effects ∈ Seq(Effect) = match ph
        Halt ⇒ ⟨Exit(0)⟩
        _ ⇒ ⟨⟩
    sentinel ∈ Int = 42
