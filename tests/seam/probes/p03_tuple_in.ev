-- Probe: `(p, q, r) ∈ ClaimName` positional binding (simple names).
-- expect-smt2: a constraint tying r to p + q; sentinel survives.

import "stdlib/kernel.ev"

claim add(a ∈ Int, b ∈ Int, out ∈ Int)
    out = a + b

claim main
    p ∈ Int = 3
    q ∈ Int = 4
    r ∈ Int
    (p, q, r) ∈ add
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
