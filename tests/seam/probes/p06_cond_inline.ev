-- Probe: `cond ⇒ ClaimName` conditional inline.
-- expect-smt2: (=> flag (= n 11)) (or equivalent); sentinel survives.

import "stdlib/kernel.ev"

claim IsEleven
    n ∈ Int
    n = 11

claim main
    n ∈ Int
    flag ∈ Bool = true
    flag ⇒ IsEleven
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
