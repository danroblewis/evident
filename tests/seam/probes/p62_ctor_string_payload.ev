-- Probe: ctor with a STRING-literal payload in a membership pin,
-- isolated (p58 rendered it but everything after vanished — this
-- fixture pins down whether the string payload itself kills the walk).

import "stdlib/kernel.ev"

claim main
    e ∈ Result = StringResult("hi")
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
