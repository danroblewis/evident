-- Probe: reading last_results via index in a membership pin
-- (`r0 ∈ Result = last_results[0]`) + literal-arm match on it —
-- the input path compiler2 would need for multi-tick IO.

import "stdlib/kernel.ev"

claim main
    r0 ∈ Result = last_results[0]
    n ∈ Int = match r0
        NoResult ⇒ 0
        _ ⇒ 1
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
