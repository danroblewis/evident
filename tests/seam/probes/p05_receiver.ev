-- Probe: `recv.subclaim(args)` receiver-prefix dispatch.
-- expect-smt2: result tied to x + 3; sentinel survives.

import "stdlib/kernel.ev"

claim add(a ∈ Int, b ∈ Int, out ∈ Int)
    out = a + b

claim main
    x ∈ Int = 7
    result ∈ Int
    x.add(3, result)
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
