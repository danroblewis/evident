-- Probe: `ClaimName(slot ↦ name)` with a SIMPLE NAME value
-- (vs the known-broken compound-expression value).
-- expect-smt2: (= greeting "hi"); sentinel survives.

import "stdlib/kernel.ev"

claim GreetsHi
    text ∈ String
    text = "hi"

claim main
    greeting ∈ String
    GreetsHi(text ↦ greeting)
    sentinel ∈ Int = 42
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
