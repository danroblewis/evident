-- Probe: explicit `_name` carry companions (compiler.ev's `_pmode` pattern).
-- The kernel's functionizer needs `_<state-field>` declared; the fossil
-- doesn't auto-emit them (p01/p15/p16 ran exit=1 without them).

import "stdlib/kernel.ev"

claim main
    x ∈ Int = 7
    _x ∈ Int
    sentinel ∈ Int = 42
    _sentinel ∈ Int
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
