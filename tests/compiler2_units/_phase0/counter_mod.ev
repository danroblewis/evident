-- Phase 0 proof, file 1 of 2: a carry-owning fsm in its OWN file.
-- Composed across a file boundary by main_2file.ev. This is the
-- separate-file analogue of tests/fsm_compose/counter_slot.ev and
-- proves the flatten-first pipeline injects cross-file carries.
fsm CounterMod
    n ∈ Int
    n = (is_first_tick ? 0 : _n + 1)
