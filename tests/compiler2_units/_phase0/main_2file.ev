-- Phase 0 proof, file 2 of 2: cross-file fsm composition carries.
--
-- main imports the carry-owning CounterMod from a SEPARATE file and
-- slot-binds it (count ↦ n). The flatten-first pipeline must:
--   1. flatten resolves the import → one translation unit,
--   2. expand-fsm-autocarry injects `_n ↦ _count` and synthesizes
--      `_count ∈ Int` in main,
-- so the kernel carries `count` across ticks and this prints 0,1,2.
-- If cross-file carry injection failed, count would not advance.
--
-- entry: main
-- expect: stdout = "0"
-- expect: stdout = "1"
-- expect: stdout = "2"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "tests/compiler2_units/_phase0/counter_mod.ev"

fsm main
    count ∈ Int
    CounterMod(n ↦ count)
    msg ∈ String = str_from_int(count)
    effects ∈ Seq(Effect) = (count ≥ 2
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩)⟩)
