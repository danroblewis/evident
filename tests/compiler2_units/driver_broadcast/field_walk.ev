-- DriverBroadcast isolation — the per-field broadcast walk.
-- Drives a record-pinned membership completion on one tick, holds the
-- claim-walk dispatch gate open with a 2-field record; the broadcast
-- must arm, reset bcast_field_i to 0, step 0→1→2 one field per tick, and
-- disarm at the last field. Reports bcast_field_i after the walk settles.
--
-- entry: main
-- expect: stdout = "2"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_broadcast.ev"

fsm main
    tc ∈ Int
    tc = (is_first_tick ? 0 : _tc + 1)
    pratt_done ∈ Bool = (tc = 1)
    pratt_kind ∈ Int
    pratt_kind = (is_first_tick ? 1 : _pratt_kind)
    pratt_rec_slot ∈ Int
    pratt_rec_slot = (is_first_tick ? 0 : _pratt_rec_slot)
    pratt_bad ∈ Bool
    pratt_bad = (is_first_tick ? false : _pratt_bad)
    pratt_decl_name ∈ String
    pratt_decl_name = (is_first_tick ? "p" : _pratt_decl_name)
    pratt_result ∈ Expr
    pratt_result = (is_first_tick ? ENoExpr : _pratt_result)
    -- Claim-walk dispatch gate: held open so the broadcast can step.
    in_claim ∈ Bool
    in_claim = (is_first_tick ? true : _in_claim)
    work_nil ∈ Bool
    work_nil = (is_first_tick ? true : _work_nil)
    param_skip ∈ Int
    param_skip = (is_first_tick ? 0 : _param_skip)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? true : _tok_ready)
    -- A 2-field record type at registry slot 0.
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ e ∈ recs : e.name = ""
    ∀ e ∈ recs : e.fnames = ""
    ∀ e ∈ recs : e.ftypes = ""
    ∀ k ∈ {0..2} : recs[k].n_fields = (k = 0 ? 2 : 0)
    ∀ e ∈ recs : e.sort = 0
    ∀ e ∈ recs : e.ctor = 0
    ∀ e ∈ recs : e.asort = 0
    ∀ e ∈ recs : e.ssort = 0
    ∀ e ∈ recs : e.accs[0] = 0
    ∀ e ∈ recs : e.accs[1] = 0
    ∀ e ∈ recs : e.accs[2] = 0
    ∀ e ∈ recs : e.accs[3] = 0
    ∀ e ∈ recs : e.accs[4] = 0
    ∀ e ∈ recs : e.accs[5] = 0
    sym_names ∈ String
    sym_names = (is_first_tick ? "" : _sym_names)
    ..DriverBroadcast
    fi_msg ∈ String = str_from_int(bcast_field_i)
    effects ∈ Seq(Effect) = (tc ≥ 5
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(fi_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
