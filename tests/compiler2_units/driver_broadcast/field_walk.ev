-- DriverBroadcast isolation — the per-field broadcast walk.
-- Drives a record-pinned membership completion on one tick, holds the
-- claim-walk dispatch gate open with a 2-field record; the broadcast
-- must arm, reset cursor to 0, step 0→1→2 one field per tick, and
-- disarm at the last field. Reports cursor after the walk settles.
--
-- entry: main
-- expect: stdout = "2"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_broadcast.ev"

fsm main
    tc ∈ Int
    tc = (is_first_tick ? 0 : _tc + 1)
    parser ∈ ParseState
    parser.kind = (is_first_tick ? 1 : _parser.kind)
    parser.ready = (tc = 1)
    parser.bad = (is_first_tick ? false : _parser.bad)
    parser.consume = (is_first_tick ? 0 : _parser.consume)
    parser.pd = (is_first_tick ? 0 : _parser.pd)
    parser.qd = (is_first_tick ? 0 : _parser.qd)
    parser.cd = (is_first_tick ? 0 : _parser.cd)
    parser.expop = (is_first_tick ? false : _parser.expop)
    parser.sort = (is_first_tick ? 0 : _parser.sort)
    parser.rec_slot = (is_first_tick ? 0 : _parser.rec_slot)
    parser.decl_name = (is_first_tick ? "p" : _parser.decl_name)
    result ∈ Expr
    result = (is_first_tick ? ENoExpr : _result)
    -- Claim-walk dispatch gate: held open so the broadcast can step.
    in_claim ∈ Bool
    in_claim = (is_first_tick ? true : _in_claim)
    nil ∈ Bool
    nil = (is_first_tick ? true : _nil)
    param_skip ∈ Int
    param_skip = (is_first_tick ? 0 : _param_skip)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? true : _can_consume)
    -- A 2-field record type at registry slot 0.
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ e ∈ recs : e.name = ""
    ∀ e ∈ recs : e.fnames = ""
    ∀ e ∈ recs : e.ftypes = ""
    ∀ k ∈ {0..2} : recs[k].n_fields = (k = 0 ? 2 : 0)
    ∀ e ∈ recs : e.sort = 0
    ∀ e ∈ recs : e.ctor = 0
    ∀ e ∈ recs : e.asort = 0
    ∀ e ∈ recs : e.ssort = 0
    ∀ e ∈ recs : e.accs[0] = 0
    ∀ e ∈ recs : e.accs[1] = 0
    ∀ e ∈ recs : e.accs[2] = 0
    ∀ e ∈ recs : e.accs[3] = 0
    ∀ e ∈ recs : e.accs[4] = 0
    ∀ e ∈ recs : e.accs[5] = 0
    symbol_index ∈ String
    symbol_index = (is_first_tick ? "" : _symbol_index)
    ..DriverBroadcast
    fi_msg ∈ String = str_from_int(cursor)
    effects ∈ Seq(Effect) = (tc ≥ 5
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(fi_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
