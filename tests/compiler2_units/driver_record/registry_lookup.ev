-- DriverRecord isolation — the registry read layer (RtIdxOf/RtSortOf).
--
-- RtIdxOf resolves a type name to its registry slot, and the "slot with
-- sort handle 0 is unfinished ⇒ never matches" invariant. RtSortOf maps a
-- field-type string to its Z3 sort handle (Nat aliases Int; a user type
-- resolves to its slot's sort; unknown ⇒ 0). If a lookup mis-resolves or
-- the unfinished-slot guard regresses, `ok` goes false and this prints BAD.
--
-- entry: main
-- expect: stdout = "ok"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/driver_record.ev"

claim main
    -- RtIdxOf: "Point" is slot 0 (sort handle 7, finished) → 0.
    i_pt ∈ Int
    RtIdxOf(nm ↦ "Point", n0 ↦ "Point", n1 ↦ "Color", n2 ↦ "",
        s0 ↦ 7, s1 ↦ 9, s2 ↦ 0, idx ↦ i_pt)
    -- "Color" is slot 1 → 1.
    i_co ∈ Int
    RtIdxOf(nm ↦ "Color", n0 ↦ "Point", n1 ↦ "Color", n2 ↦ "",
        s0 ↦ 7, s1 ↦ 9, s2 ↦ 0, idx ↦ i_co)
    -- "Point" name present but its slot is UNFINISHED (s0 = 0) → miss (-1).
    i_un ∈ Int
    RtIdxOf(nm ↦ "Point", n0 ↦ "Point", n1 ↦ "Color", n2 ↦ "",
        s0 ↦ 0, s1 ↦ 9, s2 ↦ 0, idx ↦ i_un)
    -- absent name → miss (-1).
    i_miss ∈ Int
    RtIdxOf(nm ↦ "Zzz", n0 ↦ "Point", n1 ↦ "Color", n2 ↦ "",
        s0 ↦ 7, s1 ↦ 9, s2 ↦ 0, idx ↦ i_miss)

    -- RtSortOf: Int → int_h(11); Nat aliases Int → 11; user "Color" → s1(9);
    -- unknown → 0.
    so_int ∈ Int
    RtSortOf(ty ↦ "Int", int_h ↦ 11, bool_h ↦ 12, str_h ↦ 13, real_h ↦ 14,
        iarr_h ↦ 15, n0 ↦ "Point", n1 ↦ "Color", n2 ↦ "",
        s0 ↦ 7, s1 ↦ 9, s2 ↦ 0, sort ↦ so_int)
    so_nat ∈ Int
    RtSortOf(ty ↦ "Nat", int_h ↦ 11, bool_h ↦ 12, str_h ↦ 13, real_h ↦ 14,
        iarr_h ↦ 15, n0 ↦ "Point", n1 ↦ "Color", n2 ↦ "",
        s0 ↦ 7, s1 ↦ 9, s2 ↦ 0, sort ↦ so_nat)
    so_co ∈ Int
    RtSortOf(ty ↦ "Color", int_h ↦ 11, bool_h ↦ 12, str_h ↦ 13, real_h ↦ 14,
        iarr_h ↦ 15, n0 ↦ "Point", n1 ↦ "Color", n2 ↦ "",
        s0 ↦ 7, s1 ↦ 9, s2 ↦ 0, sort ↦ so_co)
    so_un ∈ Int
    RtSortOf(ty ↦ "Widget", int_h ↦ 11, bool_h ↦ 12, str_h ↦ 13, real_h ↦ 14,
        iarr_h ↦ 15, n0 ↦ "Point", n1 ↦ "Color", n2 ↦ "",
        s0 ↦ 7, s1 ↦ 9, s2 ↦ 0, sort ↦ so_un)

    ok ∈ Bool = (i_pt = 0 ∧ i_co = 1 ∧ i_un = (0 - 1) ∧ i_miss = (0 - 1)
        ∧ so_int = 11 ∧ so_nat = 11 ∧ so_co = 9 ∧ so_un = 0)
    msg ∈ String = (ok ? "ok" : "BAD")
    effects ∈ Seq(Effect) = ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
