-- DriverClaimIdx isolation — claim-index append counter.
-- Skip pass held with a claim head (d_head_is_claim, tok1 an Ident) so
-- ci_add fires each tick; exit when the count reaches 3. The
-- BuildMemWriteLong index-write effect is not scheduled (no arena).
-- entry: main
-- expect: stdout = "3"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_expr.ev"
import "compiler2/driver_claimidx.ev"

fsm main
    d_enter_skip ∈ Bool
    d_enter_skip = (is_first_tick ? true : _d_enter_skip)
    d_head_is_claim ∈ Bool
    d_head_is_claim = (is_first_tick ? true : _d_head_is_claim)
    tok1 ∈ Token
    tok1 = (is_first_tick ? Ident("x") : _tok1)
    d_cl_name ∈ String
    d_cl_name = (is_first_tick ? "x" : _d_cl_name)
    c_eff_cond ∈ Bool
    c_eff_cond = (is_first_tick ? false : _c_eff_cond)
    claimidx_buf ∈ FtiBuffer
    claimidx_buf.base = (is_first_tick ? 0 : _claimidx_buf.base)
    d_enter_edecl ∈ Bool
    d_enter_edecl = (is_first_tick ? false : _d_enter_edecl)
    d_enter_el ∈ Bool
    d_enter_el = (is_first_tick ? false : _d_enter_el)
    d_witems_nil ∈ Bool
    d_witems_nil = (is_first_tick ? false : _d_witems_nil)
    ed_act ∈ Int
    ed_act = (is_first_tick ? 0 : _ed_act)
    ed_done_user ∈ Bool
    ed_done_user = (is_first_tick ? false : _ed_done_user)
    in_parse ∈ Bool
    in_parse = (is_first_tick ? false : _in_parse)
    p_done ∈ Bool
    p_done = (is_first_tick ? false : _p_done)
    pk_kind ∈ Int
    pk_kind = (is_first_tick ? 0 : _pk_kind)
    pmode ∈ Int
    pmode = (is_first_tick ? 0 : _pmode)
    pr_bad ∈ Bool
    pr_bad = (is_first_tick ? false : _pr_bad)
    tok_cur ∈ Int
    tok_cur = (is_first_tick ? 0 : _tok_cur)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? false : _tok_ready)
    ue_name ∈ String
    ue_name = (is_first_tick ? "" : _ue_name)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    tok2 ∈ Token
    tok2 = (is_first_tick ? EofTok : _tok2)
    tok3 ∈ Token
    tok3 = (is_first_tick ? EofTok : _tok3)
    tok4 ∈ Token
    tok4 = (is_first_tick ? EofTok : _tok4)
    tok5 ∈ Token
    tok5 = (is_first_tick ? EofTok : _tok5)
    tok6 ∈ Token
    tok6 = (is_first_tick ? EofTok : _tok6)
    z_argint_decl ∈ Int
    z_argint_decl = (is_first_tick ? 0 : _z_argint_decl)
    z_argstr_decl ∈ Int
    z_argstr_decl = (is_first_tick ? 0 : _z_argstr_decl)
    z_cell_decl ∈ Int
    z_cell_decl = (is_first_tick ? 0 : _z_cell_decl)
    z_empty_val ∈ Int
    z_empty_val = (is_first_tick ? 0 : _z_empty_val)
    z_lc_decl ∈ Int
    z_lc_decl = (is_first_tick ? 0 : _z_lc_decl)
    ..DriverClaimIdx
    c_msg ∈ String = str_from_int(claimidx_buf.count)
    effects ∈ Seq(Effect) = ((claimidx_buf.count = 3)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(c_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
