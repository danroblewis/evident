-- DriverClaimIdx isolation — claim-index append counter.
-- Skip pass held with a claim head (is_claim, tok1 an Ident) so
-- claimindex_add fires each tick; exit when the count reaches 3. The
-- BuildMemWriteLong index-write effect is not scheduled (no arena).
-- entry: main
-- expect: stdout = "3"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_expr.ev"
import "compiler2/driver_claimidx.ev"

fsm main
    enter_skip ∈ Bool
    enter_skip = (is_first_tick ? true : _enter_skip)
    is_claim ∈ Bool
    is_claim = (is_first_tick ? true : _is_claim)
    tok1 ∈ Token
    tok1 = (is_first_tick ? Ident("x") : _tok1)
    decl_name ∈ String
    decl_name = (is_first_tick ? "x" : _decl_name)
    effects_cond ∈ Bool
    effects_cond = (is_first_tick ? false : _effects_cond)
    claimindex_buf ∈ FtiBuffer
    claimindex_buf.base = (is_first_tick ? 0 : _claimindex_buf.base)
    enum_decl ∈ Bool
    enum_decl = (is_first_tick ? false : _enum_decl)
    enter_efflit ∈ Bool
    enter_efflit = (is_first_tick ? false : _enter_efflit)
    nil ∈ Bool
    nil = (is_first_tick ? false : _nil)
    decl_action ∈ Int
    decl_action = (is_first_tick ? 0 : _decl_action)
    user_decl_done ∈ Bool
    user_decl_done = (is_first_tick ? false : _user_decl_done)
    parse ∈ Bool
    parse = (is_first_tick ? false : _parse)
    parser ∈ ParseState
    parser.kind = (is_first_tick ? 0 : _parser.kind)
    parser.ready = (is_first_tick ? false : _parser.ready)
    parser.bad = (is_first_tick ? false : _parser.bad)
    parser.consume = (is_first_tick ? 0 : _parser.consume)
    parser.pd = (is_first_tick ? 0 : _parser.pd)
    parser.qd = (is_first_tick ? 0 : _parser.qd)
    parser.cd = (is_first_tick ? 0 : _parser.cd)
    parser.expop = (is_first_tick ? false : _parser.expop)
    parser.sort = (is_first_tick ? 0 : _parser.sort)
    parser.rec_slot = (is_first_tick ? 0 : _parser.rec_slot)
    parser.decl_name = (is_first_tick ? "" : _parser.decl_name)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    token_cursor ∈ Int
    token_cursor = (is_first_tick ? 0 : _token_cursor)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? false : _can_consume)
    user_enum_name ∈ String
    user_enum_name = (is_first_tick ? "" : _user_enum_name)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    tok2 ∈ Token
    tok2 = (is_first_tick ? EofTok : _tok2)
    tok3 ∈ Token
    tok3 = (is_first_tick ? EofTok : _tok3)
    tok4 ∈ Token
    tok4 = (is_first_tick ? EofTok : _tok4)
    tok5 ∈ Token
    tok5 = (is_first_tick ? EofTok : _tok5)
    tok6 ∈ Token
    tok6 = (is_first_tick ? EofTok : _tok6)
    argint_decl ∈ Int
    argint_decl = (is_first_tick ? 0 : _argint_decl)
    argstr_decl ∈ Int
    argstr_decl = (is_first_tick ? 0 : _argstr_decl)
    cell_decl ∈ Int
    cell_decl = (is_first_tick ? 0 : _cell_decl)
    empty_val ∈ Int
    empty_val = (is_first_tick ? 0 : _empty_val)
    libcall_decl ∈ Int
    libcall_decl = (is_first_tick ? 0 : _libcall_decl)
    ..DriverClaimIdx
    c_msg ∈ String = str_from_int(claimindex_buf.count)
    effects ∈ Seq(Effect) = ((claimindex_buf.count = 3)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(c_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
