-- DriverEnum isolation — the four Effect-floor enum runs walk to completion.
-- zstep held at 9 keeps enum_go_floor firing; the machine declares LibArg
-- (src 0), __SeqOf_LibArg (1), Effect (2), Result (3), advancing enum_src
-- per run until it idles at 4. Z3 build effects not scheduled (no arena).
-- entry: main
-- expect: stdout = "4"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/parser.ev"
import "compiler2/translate2_ctor.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_enum.ev"

fsm main
    zstep ∈ Int
    zstep = (is_first_tick ? 9 : _zstep)
    ec_start ∈ Bool = false
    ec_list_n ∈ EnumVariantList = EVNil
    ue_name ∈ String
    ue_name = (is_first_tick ? "" : _ue_name)
    -- Bus values the machine reads as plain handles; held live so they
    -- stay in every tick's model (a pinned `= const` simplifies out and
    -- the kernel's state carry then can't find the field).
    res_int1 ∈ Int
    res_int1 = (is_first_tick ? 0 : _res_int1)
    z3sorts ∈ Z3Sorts
    z3sorts.isort = (is_first_tick ? 0 : _z3sorts.isort)
    z3sorts.bsort = (is_first_tick ? 0 : _z3sorts.bsort)
    z3sorts.ssort = (is_first_tick ? 0 : _z3sorts.ssort)
    z3sorts.rsort = (is_first_tick ? 0 : _z3sorts.rsort)
    d_cap_int ∈ Int
    d_cap_int = (is_first_tick ? 0 : _d_cap_int)
    ..DriverEnum
    src_msg ∈ String = str_from_int(enum_src)
    effects ∈ Seq(Effect) = (enum_src = 4
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(src_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
