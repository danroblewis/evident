-- Bounded Seq→String fold: an accumulator-Seq recurrence joins a
-- Seq(String) literal's elements in order (joins[0] = ""; joins[k+1] =
-- joins[k] ++ "|" ++ names[k]; out = joins[#]). joins[3] = "|ab|c|d",
-- str_len = 7.
--
-- entry: main
-- expect: exit = 7
import "stdlib/kernel.ev"

claim main
    names ∈ Seq(String) = ⟨"ab", "c", "d"⟩
    #names ≤ 3
    joins ∈ Seq(String)
    #joins ≤ 4
    joins[0] = ""
    ∀ k ∈ {0..2} : joins[k + 1] = joins[k] ++ "|" ++ names[k]
    effects ∈ Seq(Effect) = ⟨Exit(str_len(joins[3]))⟩
