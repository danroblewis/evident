-- Literal index arithmetic under range-∀: carried Seq(Int) latches
-- read a 16-wide source at stride 2 (raw[2*k] / raw[2*k + 1]) — the
-- driver_window lat shape. Capture at tick 1; at tick 2 tags =
-- ⟨1,2,3⟩, pays = ⟨10,20,30⟩; exit = 3 + 30 + 1 = 34.
--
-- entry: main
-- expect: exit = 34
import "stdlib/kernel.ev"

fsm main
    tick ∈ Int
    tick = (is_first_tick ? 0 : _tick + 1)
    raw ∈ Seq(Int) = ⟨1, 10, 2, 20, 3, 30⟩
    #raw ≤ 6
    cap ∈ Bool = (tick = 1)
    tags ∈ Seq(Int)
    #tags ≤ 3
    pays ∈ Seq(Int)
    #pays ≤ 3
    ∀ k ∈ {0..2} : tags[k] = (is_first_tick ? 0 : cap ? raw[2*k] : _tags[k])
    ∀ k ∈ {0..2} : pays[k] = (is_first_tick ? 0 : cap ? raw[2*k + 1] : _pays[k])
    effects ∈ Seq(Effect) = (tick ≥ 2
        ? ⟨Exit(tags[2] + pays[2] + tags[0])⟩
        : ⟨LibCall("libc", "abs", ⟨ArgInt(1)⟩)⟩)
