-- The indexed-family tuple-bind `∀ (k, e) ∈ xs` lowers to per-slot
-- instantiation with k = position, e = element, _e = carry dual; the
-- transform synthesizes the dual decls (no `_xs[k]` token remains for
-- autocarry to see). A cursor write fills slot _cur each tick; the
-- coindexed pair maps a second seq off the first. Slots: ("a",1) tick1,
-- ("b",2) tick2; doubled = ⟨2, 4⟩; exit = e1.val + d0 + d1 = 2+2+4.
--
-- entry: main
-- expect: exit = 8
import "stdlib/kernel.ev"

type Cell(name ∈ String, val ∈ Int)

fsm main
    tick ∈ Int
    tick = (is_first_tick ? 0 : _tick + 1)
    cur ∈ Int
    cur = (is_first_tick ? 0 : _cur + 1)
    wnm ∈ String = (tick = 1 ? "a" : "b")
    wvl ∈ Int = (tick = 1 ? 1 : 2)
    take ∈ Bool = (tick = 1 ∨ tick = 2)
    xs ∈ Seq(Cell)
    #xs ≤ 2
    ∀ (k, e) ∈ xs : e.name = (is_first_tick ? "" : (take ∧ _cur = k) ? wnm : _e.name)
    ∀ (k, e) ∈ xs : e.val = (is_first_tick ? 0 : (take ∧ _cur = k) ? wvl : _e.val)
    doubled ∈ Seq(Int)
    #doubled ≤ 2
    ∀ (d, c) ∈ coindexed(doubled, xs) : d = (2 * c.val)
    effects ∈ Seq(Effect) = (tick ≥ 3
        ? ⟨Exit(xs[1].val + doubled[0] + doubled[1])⟩
        : ⟨LibCall("libc","abs",⟨ArgInt(1)⟩)⟩)
