-- Windowed keyed-projection PAIR: the index-form pin restricted to a
-- cursor window [lo, hi) lowers to the covered select chain with the
-- window conjuncts constant-folded per slot. Tape: "a"=7 below the
-- window, "a"=42 inside it, "b"=9 above it. The "a" read must take 42
-- (slot 0 masked by k ≥ lo); the "b" read must take the default 1
-- (slot 2 masked by k < hi). Exit 42 + 1 = 43.
-- entry: main
-- expect: exit = 43
import "stdlib/kernel.ev"

type KV(name ∈ String, handle ∈ Int)

fsm main
    tape ∈ Seq(KV)
    #tape ≤ 4
    ∀ k ∈ {0..3} : tape[k].name = (k = 0 ? "a" : k = 1 ? "a" : k = 2 ? "b" : "")
    ∀ k ∈ {0..3} : tape[k].handle = (k = 0 ? 7 : k = 1 ? 42 : k = 2 ? 9 : 0)
    lo ∈ Int = 1
    hi ∈ Int = 2
    key ∈ String = "a"
    out ∈ Int
    ∀ k ∈ {0..3} : (((k ≥ lo) ∧ (k < hi) ∧ (tape[k].name = key)) ⇒ (out = tape[k].handle))
    (¬(∃ i ∈ {0..3} : ((i ≥ lo) ∧ (i < hi) ∧ (tape[i].name = key)))) ⇒ (out = 0)
    key2 ∈ String = "b"
    out2 ∈ Int
    ∀ k ∈ {0..3} : (((k ≥ lo) ∧ (k < hi) ∧ (tape[k].name = key2)) ⇒ (out2 = tape[k].handle))
    (¬(∃ i ∈ {0..3} : ((i ≥ lo) ∧ (i < hi) ∧ (tape[i].name = key2)))) ⇒ (out2 = 1)
    effects ∈ Seq(Effect) = ⟨Exit(out + out2)⟩
