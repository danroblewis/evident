-- Keyed element update: `∀ e ∈ xs : e.f = (… _e.name = key …)` lowers
-- to per-slot covered assignments, with `_e` as the element carry dual.
-- The registry pattern split: NAME is allocated positionally (the
-- cursor is the predicate's subject — index form is honest there);
-- VAL is updated BY KEY (no index). Each field has exactly one
-- covering write — an append would double-cover val (UNSAT).
-- Ticks 1-2 allocate "a","b"; tick 3 updates the element NAMED "b"
-- to 9. exit = xs[0].val + xs[1].val = 0 + 9.
--
-- entry: main
-- expect: exit = 9
import "stdlib/kernel.ev"

type Cell(name ∈ String, val ∈ Int)

fsm main
    tick ∈ Int
    tick = (is_first_tick ? 0 : _tick + 1)
    cur ∈ Int
    cur = (is_first_tick ? 0 : take ? _cur + 1 : _cur)
    nm ∈ String = (tick = 1 ? "a" : "b")
    take ∈ Bool = (tick = 1 ∨ tick = 2)
    xs ∈ Seq(Cell)
    #xs ≤ 2
    ∀ k ∈ {0..1} : xs[k].name = (is_first_tick ? "" : (take ∧ _cur = k) ? nm : _xs[k].name)
    upd ∈ Bool = (tick = 3)
    ∀ e ∈ xs : e.val = (is_first_tick ? 0 : (upd ∧ _e.name = "b") ? 9 : _e.val)
    effects ∈ Seq(Effect) = (tick ≥ 4
        ? ⟨Exit(xs[0].val + xs[1].val)⟩
        : ⟨LibCall("libc","abs",⟨ArgInt(1)⟩)⟩)
