-- Guarded-pin-family lowering, is_pure_push-scalar form: parenthesized guarded
-- pins plus the mandatory negated-disjunction default lower to ONE
-- covered select chain. sel hits the second arm (20); sel2 matches no
-- guard and falls to the default (3). exit = 23.
--
-- entry: main
-- expect: exit = 23
import "stdlib/kernel.ev"

claim main
    sel ∈ Int = 2
    sel2 ∈ Int = 9
    a ∈ Int
    (sel = 1) ⇒ (a = 10)
    (sel = 2) ⇒ (a = 20)
    (¬((sel = 1) ∨ (sel = 2))) ⇒ (a = 30)
    b ∈ Int
    (sel2 = 1) ⇒ (b = 1)
    (sel2 = 2) ⇒ (b = 2)
    (¬((sel2 = 1) ∨ (sel2 = 2))) ⇒ (b = 3)
    effects ∈ Seq(Effect) = ⟨Exit(a + b)⟩
