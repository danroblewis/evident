-- LOUD REFUSAL: a carried hold on an enum-element Seq. Enum elements
-- have no zero default, so the hold/append/literal forms cannot lower;
-- the pass must fail loudly, naming the indexed-recurrence alternative.
--
-- entry: main
-- expect: flatten-error = enum-element Seq
import "stdlib/kernel.ev"

enum Sig2 = Quiet | Loud(Int)

fsm main
    sigs ∈ Seq(Sig2)
    #sigs ≤ 2
    sigs = (is_first_tick ? ⟨⟩ : _sigs)
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
