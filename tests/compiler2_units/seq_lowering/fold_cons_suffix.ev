-- Bounded Seq→cons fold: a Seq(enum) accumulator holds the suffix
-- programs (sfx[3] = INil; sfx[k] = guard ? ICons(xs[k], sfx[k+1]) :
-- sfx[k+1]; out = sfx[0]) — the count-guarded cons-build shape
-- (driver_compose type_pin). n = 2 keeps xs[0]/xs[1]: the walk reads
-- 4 then 7, exit = 47.
--
-- entry: main
-- expect: exit = 47
import "stdlib/kernel.ev"

enum IL = INil | ICons(Int, IL)

claim main
    xs ∈ Seq(Int) = ⟨4, 7, 9⟩
    #xs ≤ 3
    n ∈ Int = 2
    sfx ∈ Seq(IL)
    #sfx ≤ 4
    sfx[3] = INil
    ∀ k ∈ {0..2} : sfx[k] = (n ≥ k + 1 ? ICons(xs[k], sfx[k + 1]) : sfx[k + 1])
    built ∈ IL = sfx[0]
    hd ∈ Int = match built
        ICons(v, _) ⇒ v
        INil ⇒ 0
    tl ∈ IL = match built
        ICons(_, r) ⇒ r
        INil ⇒ INil
    hd2 ∈ Int = match tl
        ICons(v, _) ⇒ v
        INil ⇒ 0
    effects ∈ Seq(Effect) = ⟨Exit(hd * 10 + hd2)⟩
