-- LOUD REFUSAL: a carried append on an enum-element Seq (no zero
-- default for the empty slots). Same refusal class as the hold form.
--
-- entry: main
-- expect: flatten-error = enum-element Seq
import "stdlib/kernel.ev"

enum Sig3 = Idle | Busy(Int)

fsm main
    tick ∈ Int
    tick = (is_first_tick ? 0 : _tick + 1)
    sigs ∈ Seq(Sig3)
    #sigs ≤ 2
    sigs = (is_first_tick ? ⟨⟩ : _sigs ++ ⟨Busy(tick)⟩)
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
