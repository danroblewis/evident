-- Seq(enum) elements written by a range-∀ claim-call instantiation
-- (the driver_window FtiTok shape: one claim, ∀ k wires slot k) and
-- read back by match on literal indices. raw = ⟨0,5,0,8⟩ → sigs =
-- Lo,Hi(5),Lo,Hi(8); exit = 5 + 8 + 0 = 13.
--
-- entry: main
-- expect: exit = 13
import "stdlib/kernel.ev"

enum Sig = Lo | Hi(Int)

claim SigAt(v ∈ Int, t ∈ Sig)
    t = (v > 0 ? Hi(v) : Lo)

claim main
    raw ∈ Seq(Int) = ⟨0, 5, 0, 8⟩
    #raw ≤ 4
    sigs ∈ Seq(Sig)
    #sigs ≤ 4
    ∀ k ∈ {0..3} : SigAt(v ↦ raw[k], t ↦ sigs[k])
    a ∈ Int = match sigs[1]
        Hi(m) ⇒ m
        Lo ⇒ 0
    b ∈ Int = match sigs[3]
        Hi(m) ⇒ m
        Lo ⇒ 0
    c ∈ Int = match sigs[0]
        Hi(m) ⇒ m
        Lo ⇒ 0
    effects ∈ Seq(Effect) = ⟨Exit(a + b + c)⟩
