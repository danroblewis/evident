-- Mixed floor+registry pin family: scalar floor pins and an element-form
-- quantified registry pin share ONE output; the default guard is the
-- negated disjunction including the existential. Floor key hits a scalar
-- arm (100), registry key hits a slot arm (7 after the tick-1 append),
-- unknown key falls to the default (1). exit = 100 + 7 + 1 = 108.
--
-- entry: main
-- expect: exit = 108
import "stdlib/kernel.ev"

type Variant(name ∈ String, tester ∈ Int)

fsm main
    tick ∈ Int
    tick = (is_first_tick ? 0 : _tick + 1)
    vs ∈ Seq(Variant)
    #vs ≤ 2
    vs = (is_first_tick ? ⟨⟩ : tick = 1 ? _vs ++ ⟨Variant("Foo", 7)⟩ : _vs)
    k1 ∈ String = "IntFloor"
    k2 ∈ String = "Foo"
    k3 ∈ String = "Bar"
    out1 ∈ Int
    (k1 = "IntFloor") ⇒ (out1 = 100)
    (k1 = "StrFloor") ⇒ (out1 = 200)
    ∀ e ∈ vs : ((e.name = k1) ⇒ (out1 = e.tester))
    (¬((k1 = "IntFloor") ∨ (k1 = "StrFloor") ∨ (∃ e ∈ vs : e.name = k1))) ⇒ (out1 = 1)
    out2 ∈ Int
    (k2 = "IntFloor") ⇒ (out2 = 100)
    (k2 = "StrFloor") ⇒ (out2 = 200)
    ∀ e ∈ vs : ((e.name = k2) ⇒ (out2 = e.tester))
    (¬((k2 = "IntFloor") ∨ (k2 = "StrFloor") ∨ (∃ e ∈ vs : e.name = k2))) ⇒ (out2 = 1)
    out3 ∈ Int
    (k3 = "IntFloor") ⇒ (out3 = 100)
    (k3 = "StrFloor") ⇒ (out3 = 200)
    ∀ e ∈ vs : ((e.name = k3) ⇒ (out3 = e.tester))
    (¬((k3 = "IntFloor") ∨ (k3 = "StrFloor") ∨ (∃ e ∈ vs : e.name = k3))) ⇒ (out3 = 1)
    effects ∈ Seq(Effect) = (tick ≥ 2
        ? ⟨Exit(out1 + out2 + out3)⟩
        : ⟨LibCall("libc","abs",⟨ArgInt(1)⟩)⟩)
