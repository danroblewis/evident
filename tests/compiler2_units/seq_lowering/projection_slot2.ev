-- Regression: the keyed-projection default uses a LITERAL-range ∃; the
-- match sits at slot 2, so a mis-expanded ∃ (the off-by-one that only
-- covered slot 0) forces the default and contradicts the ∀-pin → UNSAT.
-- Correct behavior: out = slot 2's val = 30, exit 30.
--
-- entry: main
-- expect: exit = 30
import "stdlib/kernel.ev"

type Row(name ∈ String, val ∈ Int)

fsm main
    tick ∈ Int
    tick = (is_first_tick ? 0 : _tick + 1)
    rows ∈ Seq(Row)
    #rows ≤ 3
    ∀ k ∈ {0..2} : rows[k].name = (is_first_tick ? "" : (tick = 1 ∧ k = 2) ? "hit" : _rows[k].name)
    ∀ k ∈ {0..2} : rows[k].val = (is_first_tick ? 0 : (tick = 1 ∧ k = 2) ? 30 : _rows[k].val)
    out ∈ Int
    ∀ k ∈ {0..2} : ((rows[k].name = "hit") ⇒ (out = rows[k].val))
    (¬(∃ i ∈ {0..2} : rows[i].name = "hit")) ⇒ (out = 0)
    effects ∈ Seq(Effect) = (tick ≥ 2 ? ⟨Exit(out)⟩ : ⟨LibCall("libc","abs",⟨ArgInt(1)⟩)⟩)
