-- DriverPratt isolation — entry-kind latch.
-- parse_mode-3 Pratt entry with enter_pratt held and pratt_enter_kind = 5: the
-- module must latch parse_kind = 5 (which consumer the result returns to).
-- Full shift/reduce needs a fed token window; this is entry wiring only.
--
-- entry: main
-- expect: stdout = "5"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_expr.ev"
import "compiler2/driver_pratt.ev"

fsm main
    in_parse ∈ Bool
    in_parse = (is_first_tick ? true : _in_parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 3 : _parse_mode)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? true : _tok_ready)
    enter_pratt ∈ Bool
    enter_pratt = (is_first_tick ? true : _enter_pratt)
    pratt_enter_kind ∈ Int
    pratt_enter_kind = (is_first_tick ? 5 : _pratt_enter_kind)
    line_dname ∈ String
    line_dname = (is_first_tick ? "" : _line_dname)
    line_is_mem ∈ Bool
    line_is_mem = (is_first_tick ? false : _line_is_mem)
    line_is_nat ∈ Bool
    line_is_nat = (is_first_tick ? false : _line_is_nat)
    no_decl ∈ Bool
    no_decl = (is_first_tick ? false : _no_decl)
    line_pinned ∈ Bool
    line_pinned = (is_first_tick ? false : _line_pinned)
    resolved_name ∈ String
    resolved_name = (is_first_tick ? "" : _resolved_name)
    line_sort ∈ Int
    line_sort = (is_first_tick ? 0 : _line_sort)
    type_rec_slot ∈ Int
    type_rec_slot = (is_first_tick ? 0 : _type_rec_slot)
    pratt_qstop ∈ Bool
    pratt_qstop = (is_first_tick ? false : _pratt_qstop)
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ e ∈ recs : e.name = ""
    ∀ e ∈ recs : e.fnames = ""
    ∀ e ∈ recs : e.ftypes = ""
    ∀ e ∈ recs : e.n_fields = 0
    ∀ e ∈ recs : e.sort = 0
    ∀ e ∈ recs : e.ctor = 0
    ∀ e ∈ recs : e.asort = 0
    ∀ e ∈ recs : e.ssort = 0
    ∀ e ∈ recs : e.accs[0] = 0
    ∀ e ∈ recs : e.accs[1] = 0
    ∀ e ∈ recs : e.accs[2] = 0
    ∀ e ∈ recs : e.accs[3] = 0
    ∀ e ∈ recs : e.accs[4] = 0
    ∀ e ∈ recs : e.accs[5] = 0
    toks ∈ TokenList
    toks = (is_first_tick ? TLNil : _toks)
    user_variants ∈ Seq(UserEnumVariant)
    #user_variants ≤ 6
    user_variants = (is_first_tick ? ⟨⟩ : _user_variants)
    variant_names ∈ String
    variant_names = (is_first_tick ? "" : _variant_names)
    win_toks ∈ TokenList
    win_toks = (is_first_tick ? TLNil : _win_toks)
    tok0 ∈ Token = EofTok
    tok1 ∈ Token = EofTok
    tok2 ∈ Token = EofTok
    tok3 ∈ Token = EofTok
    tok4 ∈ Token = EofTok
    tok5 ∈ Token = EofTok
    tok6 ∈ Token = EofTok
    ..DriverPratt
    msg ∈ String = str_from_int(parse_kind)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
