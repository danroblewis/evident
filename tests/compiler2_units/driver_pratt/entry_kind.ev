-- DriverPratt isolation — entry-kind latch.
-- parse_mode-3 Pratt entry with enter_pratt held and enter_kind = 5: the
-- module must latch parser.kind = 5 (which consumer the result returns to).
-- Full shift/reduce needs a fed token window; this is entry wiring only.
--
-- entry: main
-- expect: stdout = "5"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/lexer.ev"
import "compiler2/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_expr.ev"
import "compiler2/driver_pratt.ev"

fsm main
    parse ∈ Bool
    parse = (is_first_tick ? true : _parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 3 : _parse_mode)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? true : _can_consume)
    enter_pratt ∈ Bool
    enter_pratt = (is_first_tick ? true : _enter_pratt)
    enter_kind ∈ Int
    enter_kind = (is_first_tick ? 5 : _enter_kind)
    line ∈ ClassifiedLine
    line.at_eof = false
    line.name = ""
    line.ty_name = ""
    line.is_nat = false
    line.enum_key = ""
    line.enum_pos = 0
    line.sort = 0
    line.end = false
    line.dname = ""
    line.items = C2INil
    is_mem ∈ Bool
    is_mem = (is_first_tick ? false : _is_mem)
    no_decl ∈ Bool
    no_decl = (is_first_tick ? false : _no_decl)
    pinned ∈ Bool
    pinned = (is_first_tick ? false : _pinned)
    effective_name ∈ String
    effective_name = (is_first_tick ? "" : _effective_name)
    type_rec_slot ∈ Int
    type_rec_slot = (is_first_tick ? 0 : _type_rec_slot)
    pratt_qstop ∈ Bool
    pratt_qstop = (is_first_tick ? false : _pratt_qstop)
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ e ∈ recs : e.name = ""
    ∀ e ∈ recs : e.fnames = ""
    ∀ e ∈ recs : e.ftypes = ""
    ∀ e ∈ recs : e.n_fields = 0
    ∀ e ∈ recs : e.sort = 0
    ∀ e ∈ recs : e.ctor = 0
    ∀ e ∈ recs : e.asort = 0
    ∀ e ∈ recs : e.ssort = 0
    ∀ e ∈ recs : e.accs[0] = 0
    ∀ e ∈ recs : e.accs[1] = 0
    ∀ e ∈ recs : e.accs[2] = 0
    ∀ e ∈ recs : e.accs[3] = 0
    ∀ e ∈ recs : e.accs[4] = 0
    ∀ e ∈ recs : e.accs[5] = 0
    toks ∈ TokenList
    toks = (is_first_tick ? TLNil : _toks)
    user_variants ∈ Seq(UserEnumVariant)
    #user_variants ≤ 6
    user_variants = (is_first_tick ? ⟨⟩ : _user_variants)
    variant_names ∈ String
    variant_names = (is_first_tick ? "" : _variant_names)
    decoded_window ∈ TokenList
    decoded_window = (is_first_tick ? TLNil : _decoded_window)
    tok0 ∈ Token = EofTok
    tok1 ∈ Token = EofTok
    tok2 ∈ Token = EofTok
    tok3 ∈ Token = EofTok
    tok4 ∈ Token = EofTok
    tok5 ∈ Token = EofTok
    tok6 ∈ Token = EofTok
    ..DriverPratt
    msg ∈ String = str_from_int(parser.kind)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
