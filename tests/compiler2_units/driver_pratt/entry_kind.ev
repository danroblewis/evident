-- DriverPratt isolation — entry-kind latch.
-- pmode-3 Pratt entry with d_enter_pratt held and d_pratt_kind0 = 5: the
-- module must latch pk_kind = 5 (which consumer the result returns to).
-- Full shift/reduce needs a fed token window; this is entry wiring only.
--
-- entry: main
-- expect: stdout = "5"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_expr.ev"
import "compiler2/driver_pratt.ev"

fsm main
    in_parse ∈ Bool
    in_parse = (is_first_tick ? true : _in_parse)
    pmode ∈ Int
    pmode = (is_first_tick ? 3 : _pmode)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? true : _tok_ready)
    d_enter_pratt ∈ Bool
    d_enter_pratt = (is_first_tick ? true : _d_enter_pratt)
    d_pratt_kind0 ∈ Int
    d_pratt_kind0 = (is_first_tick ? 5 : _d_pratt_kind0)
    c_dname ∈ String
    c_dname = (is_first_tick ? "" : _c_dname)
    c_is_mem ∈ Bool
    c_is_mem = (is_first_tick ? false : _c_is_mem)
    c_is_nat ∈ Bool
    c_is_nat = (is_first_tick ? false : _c_is_nat)
    c_nodecl ∈ Bool
    c_nodecl = (is_first_tick ? false : _c_nodecl)
    c_pinned ∈ Bool
    c_pinned = (is_first_tick ? false : _c_pinned)
    c_pn ∈ String
    c_pn = (is_first_tick ? "" : _c_pn)
    c_sc ∈ Int
    c_sc = (is_first_tick ? 0 : _c_sc)
    c_ty_rtk ∈ Int
    c_ty_rtk = (is_first_tick ? 0 : _c_ty_rtk)
    pq_qstop ∈ Bool
    pq_qstop = (is_first_tick ? false : _pq_qstop)
    rt_e0 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", nf ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        a0 ↦ 0, a1 ↦ 0, a2 ↦ 0, a3 ↦ 0, a4 ↦ 0, a5 ↦ 0)
    rt_e1 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", nf ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        a0 ↦ 0, a1 ↦ 0, a2 ↦ 0, a3 ↦ 0, a4 ↦ 0, a5 ↦ 0)
    rt_e2 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", nf ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        a0 ↦ 0, a1 ↦ 0, a2 ↦ 0, a3 ↦ 0, a4 ↦ 0, a5 ↦ 0)
    toks ∈ TokenList
    toks = (is_first_tick ? TLNil : _toks)
    user_variants ∈ Seq(UserEnumVariant)
    #user_variants ≤ 6
    user_variants = (is_first_tick ? ⟨⟩ : _user_variants)
    win_toks ∈ TokenList
    win_toks = (is_first_tick ? TLNil : _win_toks)
    ..DriverPratt
    msg ∈ String = str_from_int(pk_kind)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
