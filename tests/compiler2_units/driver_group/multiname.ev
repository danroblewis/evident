-- DriverGroup isolation — multi-name collect recognizer: parse_mode-9 group
-- walk in collect state 0 with window head `x ,` must be active (collect)
-- and recognize the multi-name continuation (take_name).
-- verdict = 1*collect + 2*take_name = 3.
-- entry: main
-- expect: stdout = "3"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/lexer.ev"
import "compiler2/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_group.ev"

fsm main
    parse ∈ Bool
    parse = (is_first_tick ? true : _parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 9 : _parse_mode)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? true : _can_consume)
    nil ∈ Bool
    nil = (is_first_tick ? true : _nil)
    tok0 ∈ Token
    tok0 = (is_first_tick ? Ident("x") : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? Comma : _tok1)
    is_mem ∈ Bool
    is_mem = (is_first_tick ? false : _is_mem)
    line ∈ ClassifiedLine
    line.at_eof = false
    line.name = ""
    line.ty_name = ""
    line.is_nat = false
    line.enum_key = ""
    line.enum_pos = 0
    line.sort = 0
    line.end = false
    line.dname = ""
    line.items = C2INil
    mem_tyname ∈ String
    mem_tyname = (is_first_tick ? "" : _mem_tyname)
    claim_params ∈ Bool
    claim_params = (is_first_tick ? false : _claim_params)
    multiname ∈ Bool
    multiname = (is_first_tick ? false : _multiname)
    tok3 ∈ Token
    tok3 = (is_first_tick ? EofTok : _tok3)
    pending_names ∈ TokenList
    walk_state ∈ Int
    is_parameter ∈ Bool
    closed ∈ Bool
    shared_sort ∈ Int
    is_nat ∈ Bool
    type_name ∈ String
    collect ∈ Bool
    take_name ∈ Bool
    type_tick ∈ Bool
    bail ∈ Bool
    draining ∈ Bool
    have_pending ∈ Bool
    last_name ∈ Bool
    type_consume ∈ Int
    done_mode ∈ Int
    exit_mode ∈ Int
    name_field ∈ String
    carry_decl ∈ String
    drain_items ∈ C2Items
    DriverGroup
    verdict ∈ Int = ((collect ? 1 : 0) + (take_name ? 2 : 0))
    v_msg ∈ String = str_from_int(verdict)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(v_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
