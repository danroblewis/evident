-- DriverGroup isolation — multi-name collect recognizer: parse_mode-9 group
-- walk in collect state 0 (walk_on) with window head `x ,` must be
-- active (collect_on) and recognize the multi-name continuation
-- (group_take2). verdict = 1*collect_on + 2*group_take2 = 3.
-- entry: main
-- expect: stdout = "3"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_group.ev"

fsm main
    in_parse ∈ Bool
    in_parse = (is_first_tick ? true : _in_parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 9 : _parse_mode)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? true : _tok_ready)
    work_nil ∈ Bool
    work_nil = (is_first_tick ? true : _work_nil)
    tok0 ∈ Token
    tok0 = (is_first_tick ? Ident("x") : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? Comma : _tok1)
    line_is_mem ∈ Bool
    line_is_mem = (is_first_tick ? false : _line_is_mem)
    line_is_nat ∈ Bool
    line_is_nat = (is_first_tick ? false : _line_is_nat)
    line_sort ∈ Int
    line_sort = (is_first_tick ? 0 : _line_sort)
    line_t0 ∈ Token
    line_t0 = (is_first_tick ? EofTok : _line_t0)
    mem_tyname ∈ String
    mem_tyname = (is_first_tick ? "" : _mem_tyname)
    enter_claim_params ∈ Bool
    enter_claim_params = (is_first_tick ? false : _enter_claim_params)
    enter_multiname ∈ Bool
    enter_multiname = (is_first_tick ? false : _enter_multiname)
    tok3 ∈ Token
    tok3 = (is_first_tick ? EofTok : _tok3)
    ..DriverGroup
    verdict ∈ Int = ((collect_on ? 1 : 0) + (group_take2 ? 2 : 0))
    v_msg ∈ String = str_from_int(verdict)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(v_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
