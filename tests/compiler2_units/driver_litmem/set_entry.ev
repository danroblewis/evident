-- DriverLitMem isolation — set-literal walk entry latches: a one-shot
-- `x ∉ { … }` entry (intset at tc = 1, line_name "x", is_notmem true)
-- must latch intset_name = "x" / neg = true and hold them. Reports
-- "<name>/<sign>"; the ∉ sign drives C2Not-wrapping of the folded Expr.
-- entry: main
-- expect: stdout = "x/neg"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_litmem.ev"

fsm main
    tc ∈ Int
    tc = (is_first_tick ? 0 : _tc + 1)
    intset ∈ Bool = (tc = 1)
    line_name ∈ String
    line_name = (is_first_tick ? "x" : _line_name)
    is_notmem ∈ Bool
    is_notmem = (is_first_tick ? true : _is_notmem)
    -- parse_mode-7 walk gate + parse_mode-8 inputs the lifted module reads (inert).
    parse ∈ Bool
    parse = (is_first_tick ? false : _parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? false : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    seqmem ∈ Bool
    seqmem = (is_first_tick ? false : _seqmem)
    line_dname ∈ String
    line_dname = (is_first_tick ? "" : _line_dname)
    elt_slot ∈ Int
    elt_slot = (is_first_tick ? 0 - 1 : _elt_slot)
    ..DriverLitMem
    e_msg ∈ String = intset_name ++ "/" ++ (neg ? "neg" : "pos")
    effects ∈ Seq(Effect) = (tc ≥ 2
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(e_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
