-- DriverLitMem isolation — set-literal walk entry latches: a one-shot
-- `x ∉ { … }` entry (intset at tc = 1, line_name "x", is_notmem true)
-- must latch bound_name = "x" / is_negated = true and hold them. Reports
-- "<name>/<sign>"; the ∉ sign drives C2Not-wrapping of the folded Expr.
-- entry: main
-- expect: stdout = "x/is_negated"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/lexer.ev"
import "compiler2/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_litmem.ev"

fsm main
    tc ∈ Int
    tc = (is_first_tick ? 0 : _tc + 1)
    intset ∈ Bool = (tc = 1)
    line ∈ ClassifiedLine
    line.at_eof = false
    line.name = "x"
    line.ty_name = ""
    line.is_nat = false
    line.enum_key = ""
    line.enum_pos = 0
    line.sort = 0
    line.end = false
    line.dname = ""
    line.items = C2INil
    is_notmem ∈ Bool
    is_notmem = (is_first_tick ? true : _is_notmem)
    -- parse_mode-7 walk gate + parse_mode-8 inputs the lifted module reads (inert).
    parse ∈ Bool
    parse = (is_first_tick ? false : _parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? false : _can_consume)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    seqmem ∈ Bool
    seqmem = (is_first_tick ? false : _seqmem)
    kind_slot ∈ Int
    kind_slot = (is_first_tick ? 0 - 1 : _kind_slot)
    ..DriverLitMem
    e_msg ∈ String = bound_name ++ "/" ++ (is_negated ? "is_negated" : "pos")
    effects ∈ Seq(Effect) = (tc ≥ 2
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(e_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
