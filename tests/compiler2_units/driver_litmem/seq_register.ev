-- DriverLitMem isolation — the seq-literal registry latches once:
-- enter_seqmem held every tick with line_dname "myseq" on the capture tick,
-- "other" after. The parse_mode-8 registry must latch seqvar_name = "myseq" on
-- first sight; if the latch-once guard (¬_seqvar_set) regresses it's "other".
-- entry: main
-- expect: stdout = "myseq"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_litmem.ev"

fsm main
    tc ∈ Int
    tc = (is_first_tick ? 0 : _tc + 1)
    enter_seqmem ∈ Bool
    enter_seqmem = (is_first_tick ? true : _enter_seqmem)
    line_dname ∈ String = (tc ≤ 1 ? "myseq" : "other")
    seq_elt_slot ∈ Int
    seq_elt_slot = (is_first_tick ? 0 - 1 : _seq_elt_slot)
    -- parse_mode-7 set-walk inputs the lifted module also reads (inert here).
    in_parse ∈ Bool
    in_parse = (is_first_tick ? false : _in_parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? false : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    enter_intset ∈ Bool
    enter_intset = (is_first_tick ? false : _enter_intset)
    line_name ∈ String
    line_name = (is_first_tick ? "" : _line_name)
    line_is_notmem ∈ Bool
    line_is_notmem = (is_first_tick ? false : _line_is_notmem)
    ..DriverLitMem
    n_msg ∈ String = seqvar_name
    effects ∈ Seq(Effect) = (tc ≥ 3
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(n_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
