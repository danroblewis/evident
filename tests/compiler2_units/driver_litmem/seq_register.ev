-- DriverLitMem isolation — the seq-literal registry latches once:
-- seqmem held every tick with line_dname "myseq" on the capture tick,
-- "other" after. The parse_mode-8 registry must latch census_var_name = "myseq" on
-- first sight; if the latch-once guard (¬_census_registered) regresses it's "other".
-- entry: main
-- expect: stdout = "myseq"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_litmem.ev"

fsm main
    tc ∈ Int
    tc = (is_first_tick ? 0 : _tc + 1)
    seqmem ∈ Bool
    seqmem = (is_first_tick ? true : _seqmem)
    line_dname ∈ String = (tc ≤ 1 ? "myseq" : "other")
    kind_slot ∈ Int
    kind_slot = (is_first_tick ? 0 - 1 : _kind_slot)
    -- parse_mode-7 set-walk inputs the lifted module also reads (inert here).
    parse ∈ Bool
    parse = (is_first_tick ? false : _parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? false : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    intset ∈ Bool
    intset = (is_first_tick ? false : _intset)
    line_name ∈ String
    line_name = (is_first_tick ? "" : _line_name)
    is_notmem ∈ Bool
    is_notmem = (is_first_tick ? false : _is_notmem)
    ..DriverLitMem
    n_msg ∈ String = census_var_name
    effects ∈ Seq(Effect) = (tc ≥ 3
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(n_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
