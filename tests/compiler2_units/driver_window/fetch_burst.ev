-- DriverWindow isolation — lookahead-need dispatch + fetch state machine.
-- Cursor held empty (tok_cur = fetch_end = 0 ⇒ win_avail = 0) under parse_mode 6
-- (⇒ win_need = 5), so every idle tick raises fetch_go and walks fetch_mode
-- 0→1→2; each arrival at fetch_mode 2 is a completed burst. Count bursts,
-- exit at 3. Pure sequencing — no __mem arena needed (the rd_* read
-- effects are not scheduled).
--
-- entry: main
-- expect: stdout = "3"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_window.ev"

fsm main
    in_parse ∈ Bool
    in_parse = (is_first_tick ? true : _in_parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 6 : _parse_mode)
    -- tok_cur/fetch_end are declared by DriverWindow but their transitions live in
    -- driver_main's cursor region (absent here), so main pins them as held
    -- carries.
    tok_cur ∈ Int
    tok_cur = (is_first_tick ? 0 : _tok_cur)
    fetch_end ∈ Int
    fetch_end = (is_first_tick ? 0 : _fetch_end)
    win_toks ∈ TokenList
    win_toks = (is_first_tick ? TLNil : _win_toks)
    tok_buf ∈ FtiBuffer
    tok_buf.base = (is_first_tick ? 0 : _tok_buf.base)
    tok_buf.count = (is_first_tick ? 0 : _tok_buf.count)
    -- Sub-state carries read only by non-parse_mode-6 win_need branches; held so
    -- the names resolve.
    rec_collect_on ∈ Bool
    rec_collect_on = (is_first_tick ? false : _rec_collect_on)
    decl_action ∈ Int
    decl_action = (is_first_tick ? 0 : _decl_action)
    callw_st ∈ Int
    callw_st = (is_first_tick ? 0 : _callw_st)
    tuple_state ∈ Int
    tuple_state = (is_first_tick ? 0 : _tuple_state)
    work_nil ∈ Bool
    work_nil = (is_first_tick ? true : _work_nil)
    vf_st ∈ Int
    vf_st = (is_first_tick ? 0 : _vf_st)
    ..DriverWindow
    bursts ∈ Int
    bursts = (is_first_tick ? 0 : (_fetch_mode = 2 ? _bursts + 1 : _bursts))
    b_msg ∈ String = str_from_int(bursts)
    effects ∈ Seq(Effect) = (bursts = 3
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(b_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
