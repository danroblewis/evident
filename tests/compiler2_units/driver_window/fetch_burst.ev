-- DriverWindow isolation — lookahead-need dispatch + fetch state machine.
-- Cursor held empty (token_cursor = coverage_end = 0 ⇒ avail = 0) under parse_mode 6
-- (⇒ need = 5), so every idle tick raises start_fetch and walks burst_phase
-- 0→1→2; each arrival at burst_phase 2 is a completed burst. Count bursts,
-- exit at 3. Pure sequencing — no __mem arena needed (the rd_* read
-- effects are not scheduled).
--
-- entry: main
-- expect: stdout = "3"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_window.ev"

fsm main
    parse ∈ Bool
    parse = (is_first_tick ? true : _parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 6 : _parse_mode)
    -- token_cursor/coverage_end are declared by DriverWindow but their transitions live in
    -- driver_main's cursor region (absent here), so main pins them as held
    -- carries.
    token_cursor ∈ Int
    token_cursor = (is_first_tick ? 0 : _token_cursor)
    coverage_end ∈ Int
    coverage_end = (is_first_tick ? 0 : _coverage_end)
    decoded_window ∈ TokenList
    decoded_window = (is_first_tick ? TLNil : _decoded_window)
    tok_buf ∈ FtiBuffer
    tok_buf.base = (is_first_tick ? 0 : _tok_buf.base)
    tok_buf.count = (is_first_tick ? 0 : _tok_buf.count)
    -- Sub-state carries read only by non-parse_mode-6 need branches; held so
    -- the names resolve.
    collect_on ∈ Bool
    collect_on = (is_first_tick ? false : _collect_on)
    decl_action ∈ Int
    decl_action = (is_first_tick ? 0 : _decl_action)
    callwalk_state ∈ Int
    callwalk_state = (is_first_tick ? 0 : _callwalk_state)
    tuple_state ∈ Int
    tuple_state = (is_first_tick ? 0 : _tuple_state)
    nil ∈ Bool
    nil = (is_first_tick ? true : _nil)
    vfield_st ∈ Int
    vfield_st = (is_first_tick ? 0 : _vfield_st)
    ..DriverWindow
    bursts ∈ Int
    bursts = (is_first_tick ? 0 : (_burst_phase = 2 ? _bursts + 1 : _bursts))
    b_msg ∈ String = str_from_int(bursts)
    effects ∈ Seq(Effect) = (bursts = 3
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(b_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
