-- FTI perf probe: FtiBuffer's `0 ≤ count ≤ cap` is re-checked every tick;
-- climb count to 800 and Exit. Must stay fully functionized (≈0 ms z3) —
-- an invariant falling to Z3 (e.g. a `≠`) blows z3/wall time; gate catches it.
-- Non-final ticks emit a cheap is_pure_push libcall (abs) so effects has a model.
--
-- entry: main
-- expect: exit = 0
-- perf: max_z3_ms = 50
-- perf: max_wall_s = 30
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    buf ∈ FtiBuffer
    buf.cap = 2048
    buf.base = (is_first_tick ? 100 : _buf.base)
    buf.count = (is_first_tick ? 0 : _buf.count + 1)
    done ∈ Bool = (buf.count ≥ 800)
    effects ∈ Seq(Effect) = (done
        ? ⟨Exit(0)⟩
        : ⟨LibCall("libc", "abs", ⟨ArgInt(1)⟩)⟩)
