-- FTI perf/functionization probe: FtiBuffer's `0 ≤ count ≤ cap` invariant
-- is re-checked every tick. Climb count to 800 (≈800 ticks) and Exit. The
-- gate asserts the run stays fully functionized (≈0 ms z3) and under a
-- wall ceiling — if a future invariant falls to Z3 (e.g. a `≠`), z3 ms
-- and wall time blow up and this fixture catches it. Each non-final tick
-- emits a cheap pure libcall (abs) so effects always has a model.
--
-- entry: main
-- expect: exit = 0
-- perf: max_z3_ms = 50
-- perf: max_wall_s = 30
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    buf ∈ FtiBuffer
    buf.cap = 2048
    buf.base = (is_first_tick ? 100 : _buf.base)
    buf.count = (is_first_tick ? 0 : _buf.count + 1)
    done ∈ Bool = (buf.count ≥ 800)
    effects ∈ Seq(Effect) = (done
        ? ⟨Exit(0)⟩
        : ⟨LibCall("libc", "abs", ⟨ArgInt(1)⟩)⟩)
