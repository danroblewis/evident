-- Record-type registry carry — the recs bounded-Seq registry travels
-- across ticks: slot 0's name latched at tick 0, its sort climbing each
-- tick. Autocarry + the bounded-Seq lowering must synthesize the _recs
-- dual; RtIdxOf (ambient recs read) must resolve "Pt" to slot 0 once
-- its sort > 0.
--
-- entry: main
-- expect: stdout = "Pt/1/0"
-- expect: stdout = "Pt/2/0"
-- expect: stdout = "Pt/3/0"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"

fsm main
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ k ∈ {0..2} : recs[k].name = (is_first_tick ? (k = 0 ? "Pt" : "") : _recs[k].name)
    ∀ k ∈ {0..2} : recs[k].sort = (is_first_tick ? (k = 0 ? 1 : 0) : (k = 0 ? _recs[k].sort + 1 : _recs[k].sort))
    ∀ e ∈ recs : e.fnames = (is_first_tick ? "" : _e.fnames)
    ∀ e ∈ recs : e.ftypes = (is_first_tick ? "" : _e.ftypes)
    ∀ e ∈ recs : e.n_fields = (is_first_tick ? 0 : _e.n_fields)
    ∀ e ∈ recs : e.ctor = (is_first_tick ? 0 : _e.ctor)
    ∀ e ∈ recs : e.asort = (is_first_tick ? 0 : _e.asort)
    ∀ e ∈ recs : e.ssort = (is_first_tick ? 0 : _e.ssort)
    ∀ e ∈ recs : e.accs[0] = (is_first_tick ? 0 : _e.accs[0])
    ∀ e ∈ recs : e.accs[1] = (is_first_tick ? 0 : _e.accs[1])
    ∀ e ∈ recs : e.accs[2] = (is_first_tick ? 0 : _e.accs[2])
    ∀ e ∈ recs : e.accs[3] = (is_first_tick ? 0 : _e.accs[3])
    ∀ e ∈ recs : e.accs[4] = (is_first_tick ? 0 : _e.accs[4])
    ∀ e ∈ recs : e.accs[5] = (is_first_tick ? 0 : _e.accs[5])
    pt_slot ∈ Int
    RtIdxOf(nm ↦ "Pt", idx ↦ pt_slot)
    msg ∈ String = recs[0].name ++ "/" ++ str_from_int(recs[0].sort) ++ "/" ++ str_from_int(pt_slot)
    effects ∈ Seq(Effect) = (recs[0].sort ≥ 3
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩)⟩)
