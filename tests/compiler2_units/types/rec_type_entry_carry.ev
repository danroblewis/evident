-- RecTypeEntry carry — one slot of the fixed ×3 rt_* registry travels
-- across ticks: name latched once, sort climbs each tick. Autocarry must
-- synthesize the record dual `_e ∈ RecTypeEntry`; RtIdxOf on the CARRIED
-- entry must resolve "Pt" to slot 0 once its sort ≠ 0.
--
-- entry: main
-- expect: stdout = "Pt/1/0"
-- expect: stdout = "Pt/2/0"
-- expect: stdout = "Pt/3/0"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"

fsm main
    e ∈ RecTypeEntry
    e.name = (is_first_tick ? "Pt" : _e.name)
    e.fnames = (is_first_tick ? "" : _e.fnames)
    e.ftypes = (is_first_tick ? "" : _e.ftypes)
    e.n_fields = (is_first_tick ? 0 : _e.n_fields)
    e.sort = (is_first_tick ? 1 : _e.sort + 1)
    e.ctor = (is_first_tick ? 0 : _e.ctor)
    e.asort = (is_first_tick ? 0 : _e.asort)
    e.ssort = (is_first_tick ? 0 : _e.ssort)
    e.acc0 = (is_first_tick ? 0 : _e.acc0)
    e.acc1 = (is_first_tick ? 0 : _e.acc1)
    e.acc2 = (is_first_tick ? 0 : _e.acc2)
    e.acc3 = (is_first_tick ? 0 : _e.acc3)
    e.acc4 = (is_first_tick ? 0 : _e.acc4)
    e.acc5 = (is_first_tick ? 0 : _e.acc5)
    -- two empty sibling slots so RtIdxOf has its full ×3 input.
    empty1 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    empty2 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    k ∈ Int
    RtIdxOf(nm ↦ "Pt", e0 ↦ e, e1 ↦ empty1, e2 ↦ empty2, idx ↦ k)
    msg ∈ String = e.name ++ "/" ++ str_from_int(e.sort) ++ "/" ++ str_from_int(k)
    effects ∈ Seq(Effect) = (e.sort ≥ 3
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩)⟩)
