-- Z3SolverCtx carry — the cfg/ctx/sol lifecycle triple travels across
-- ticks (mirrors the real zinit latch bank): each handle latches once at
-- its step, then holds. Autocarry must synthesize `_z3ctx ∈ Z3SolverCtx`;
-- without the dual a latched field resets and the final line is wrong.
--
-- entry: main
-- expect: stdout = "11/0/0"
-- expect: stdout = "100/0/0"
-- expect: stdout = "100/200/0"
-- expect: stdout = "100/200/300"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    step ∈ Int
    step = (is_first_tick ? 0 : _step + 1)
    z3ctx ∈ Z3SolverCtx
    z3ctx.cfg = (is_first_tick ? 11 : step = 1 ? 100 : _z3ctx.cfg)
    z3ctx.ctx = (is_first_tick ? 0 : step = 2 ? 200 : _z3ctx.ctx)
    z3ctx.sol = (is_first_tick ? 0 : step = 3 ? 300 : _z3ctx.sol)
    msg ∈ String = str_from_int(z3ctx.cfg) ++ "/" ++ str_from_int(z3ctx.ctx) ++ "/" ++ str_from_int(z3ctx.sol)
    effects ∈ Seq(Effect) = (step ≥ 3
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩)⟩)
