-- Z3Sorts carry — the four base-sort handles travel across ticks (mirrors
-- the real zinit latch bank): each handle latches once at its step, then
-- holds. Autocarry must synthesize `_z3sorts ∈ Z3Sorts`; without the dual
-- a latched field resets and the final line is wrong.
--
-- entry: main
-- expect: stdout = "0/0/0/0"
-- expect: stdout = "5/0/0/0"
-- expect: stdout = "5/6/0/0"
-- expect: stdout = "5/6/7/0"
-- expect: stdout = "5/6/7/8"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    step ∈ Int
    step = (is_first_tick ? 0 : _step + 1)
    z3sorts ∈ Z3Sorts
    z3sorts.isort = (is_first_tick ? 0 : step = 1 ? 5 : _z3sorts.isort)
    z3sorts.bsort = (is_first_tick ? 0 : step = 2 ? 6 : _z3sorts.bsort)
    z3sorts.ssort = (is_first_tick ? 0 : step = 3 ? 7 : _z3sorts.ssort)
    z3sorts.rsort = (is_first_tick ? 0 : step = 4 ? 8 : _z3sorts.rsort)
    msg ∈ String = str_from_int(z3sorts.isort) ++ "/" ++ str_from_int(z3sorts.bsort) ++ "/" ++ str_from_int(z3sorts.ssort) ++ "/" ++ str_from_int(z3sorts.rsort)
    effects ∈ Seq(Effect) = (step ≥ 4
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩)⟩)
