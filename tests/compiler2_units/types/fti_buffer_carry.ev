-- FtiBuffer carry — the base+cursor record element travels across ticks.
-- Autocarry must synthesize the record dual `_buf ∈ FtiBuffer` so both
-- fields carry; addr = base + 8*count proves field arithmetic reads the
-- carried record. Without the dual, count never climbs and Exit is unreached.
--
-- entry: main
-- expect: stdout = "100/0"
-- expect: stdout = "108/1"
-- expect: stdout = "116/2"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    buf ∈ FtiBuffer
    buf.cap = 2048
    buf.base = (is_first_tick ? 100 : _buf.base)
    buf.count = (is_first_tick ? 0 : _buf.count + 1)
    addr ∈ Int = buf.base + (8 * buf.count)
    msg ∈ String = str_from_int(addr) ++ "/" ++ str_from_int(buf.count)
    effects ∈ Seq(Effect) = (buf.count ≥ 2
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩)⟩)
