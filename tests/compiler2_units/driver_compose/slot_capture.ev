-- DriverCompose isolation — slot-call name capture through callw_st.
-- pmode-10 held, frame idle: tick 1, callw_cap advances callw_st 0→1; tick 2,
-- in_callw1 is live and the window head `p ↦` (Ident, OpMapsto) fires
-- callw_slot, capturing slot_name_tok into slot_names[0].name (slot index 0). Must read "p".
-- entry: main
-- expect: stdout = "p"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_compose.ev"

fsm main
    pmode ∈ Int
    pmode = (is_first_tick ? 10 : _pmode)
    in_parse ∈ Bool
    in_parse = (is_first_tick ? true : _in_parse)
    work_nil ∈ Bool
    work_nil = (is_first_tick ? true : _work_nil)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? true : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? Ident("p") : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? OpMapsto : _tok1)
    comp_bare ∈ Bool
    comp_bare = (is_first_tick ? false : _comp_bare)
    comp_call ∈ Bool
    comp_call = (is_first_tick ? false : _comp_call)
    comp_dotdot ∈ Bool
    comp_dotdot = (is_first_tick ? false : _comp_dotdot)
    comp_line ∈ Bool
    comp_line = (is_first_tick ? false : _comp_line)
    callee_pos ∈ Int
    callee_pos = (is_first_tick ? 0 : _callee_pos)
    line_name ∈ String
    line_name = (is_first_tick ? "" : _line_name)
    tymem_bare ∈ Bool
    tymem_bare = (is_first_tick ? false : _tymem_bare)
    tymem_call ∈ Bool
    tymem_call = (is_first_tick ? false : _tymem_call)
    tymem_line ∈ Bool
    tymem_line = (is_first_tick ? false : _tymem_line)
    line_ty_name ∈ String
    line_ty_name = (is_first_tick ? "" : _line_ty_name)
    claimidx_buf ∈ FtiBuffer
    claimidx_buf.base = (is_first_tick ? 0 : _claimidx_buf.base)
    claimidx_buf.count = (is_first_tick ? 0 : _claimidx_buf.count)
    d_cap_int ∈ Int
    d_cap_int = (is_first_tick ? 0 : _d_cap_int)
    d_enter_claim ∈ Bool
    d_enter_claim = (is_first_tick ? false : _d_enter_claim)
    d_enter_claimp ∈ Bool
    d_enter_claimp = (is_first_tick ? false : _d_enter_claimp)
    h_2nd ∈ Int
    h_2nd = (is_first_tick ? 0 : _h_2nd)
    h_3rd ∈ Int
    h_3rd = (is_first_tick ? 0 : _h_3rd)
    h_4th ∈ Int
    h_4th = (is_first_tick ? 0 : _h_4th)
    h_5th ∈ Int
    h_5th = (is_first_tick ? 0 : _h_5th)
    h_6th ∈ Int
    h_6th = (is_first_tick ? 0 : _h_6th)
    h_tail1 ∈ C2H
    h_tail1 = (is_first_tick ? C2HNil : _h_tail1)
    h_tail2 ∈ C2H
    h_tail2 = (is_first_tick ? C2HNil : _h_tail2)
    h_tail3 ∈ C2H
    h_tail3 = (is_first_tick ? C2HNil : _h_tail3)
    h_tail4 ∈ C2H
    h_tail4 = (is_first_tick ? C2HNil : _h_tail4)
    h_tail5 ∈ C2H
    h_tail5 = (is_first_tick ? C2HNil : _h_tail5)
    h_tail6 ∈ C2H
    h_tail6 = (is_first_tick ? C2HNil : _h_tail6)
    h_top ∈ Int
    h_top = (is_first_tick ? 0 : _h_top)
    d_hstk_in ∈ C2H
    d_hstk_in = (is_first_tick ? C2HNil : _d_hstk_in)
    guard_hit ∈ Bool
    guard_hit = (is_first_tick ? false : _guard_hit)
    guard_jump_cap ∈ Bool
    guard_jump_cap = (is_first_tick ? false : _guard_jump_cap)
    guard_jump_fire ∈ Bool
    guard_jump_fire = (is_first_tick ? false : _guard_jump_fire)
    frame_pop ∈ Bool
    frame_pop = (is_first_tick ? false : _frame_pop)
    pratt_done ∈ Bool
    pratt_done = (is_first_tick ? false : _pratt_done)
    pratt_kind ∈ Int
    pratt_kind = (is_first_tick ? 0 : _pratt_kind)
    pratt_bad ∈ Bool
    pratt_bad = (is_first_tick ? false : _pratt_bad)
    posjump_cap ∈ Bool
    posjump_cap = (is_first_tick ? false : _posjump_cap)
    posjump_fire ∈ Bool
    posjump_fire = (is_first_tick ? false : _posjump_fire)
    bindzip_act ∈ Bool
    bindzip_act = (is_first_tick ? false : _bindzip_act)
    bindzip_binds ∈ C2Binds
    bindzip_binds = (is_first_tick ? CBNil : _bindzip_binds)
    rec0 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    rec1 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    rec2 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    tok_cur ∈ Int
    tok_cur = (is_first_tick ? 0 : _tok_cur)
    ..DriverCompose
    captured ∈ Bool = (slot_names[0].name = "p")
    effects ∈ Seq(Effect) = (captured
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(slot_names[0].name)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
