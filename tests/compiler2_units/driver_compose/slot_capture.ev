-- DriverCompose isolation — slot-call name capture through cw_st.
-- pmode-10 held, frame idle: tick 1, cw_cap advances cw_st 0→1; tick 2,
-- d_in_cw1 is live and the window head `p ↦` (Ident, OpMapsto) fires
-- cw_slot, capturing cw_slot_nm into cs[0].name (slot index 0). Must read "p".
-- entry: main
-- expect: stdout = "p"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_compose.ev"

fsm main
    pmode ∈ Int
    pmode = (is_first_tick ? 10 : _pmode)
    in_parse ∈ Bool
    in_parse = (is_first_tick ? true : _in_parse)
    work_nil ∈ Bool
    work_nil = (is_first_tick ? true : _work_nil)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? true : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? Ident("p") : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? OpMapsto : _tok1)
    c_comp_bare ∈ Bool
    c_comp_bare = (is_first_tick ? false : _c_comp_bare)
    c_comp_call ∈ Bool
    c_comp_call = (is_first_tick ? false : _c_comp_call)
    c_comp_dd ∈ Bool
    c_comp_dd = (is_first_tick ? false : _c_comp_dd)
    c_comp_line ∈ Bool
    c_comp_line = (is_first_tick ? false : _c_comp_line)
    c_cur_pos ∈ Int
    c_cur_pos = (is_first_tick ? 0 : _c_cur_pos)
    c_name ∈ String
    c_name = (is_first_tick ? "" : _c_name)
    c_ty_bare ∈ Bool
    c_ty_bare = (is_first_tick ? false : _c_ty_bare)
    c_ty_call ∈ Bool
    c_ty_call = (is_first_tick ? false : _c_ty_call)
    c_ty_line ∈ Bool
    c_ty_line = (is_first_tick ? false : _c_ty_line)
    c_type_str ∈ String
    c_type_str = (is_first_tick ? "" : _c_type_str)
    claimidx_buf ∈ FtiBuffer
    claimidx_buf.base = (is_first_tick ? 0 : _claimidx_buf.base)
    claimidx_buf.count = (is_first_tick ? 0 : _claimidx_buf.count)
    d_cap_int ∈ Int
    d_cap_int = (is_first_tick ? 0 : _d_cap_int)
    d_enter_claim ∈ Bool
    d_enter_claim = (is_first_tick ? false : _d_enter_claim)
    d_enter_claimp ∈ Bool
    d_enter_claimp = (is_first_tick ? false : _d_enter_claimp)
    h_2nd ∈ Int
    h_2nd = (is_first_tick ? 0 : _h_2nd)
    h_3rd ∈ Int
    h_3rd = (is_first_tick ? 0 : _h_3rd)
    h_4th ∈ Int
    h_4th = (is_first_tick ? 0 : _h_4th)
    h_5th ∈ Int
    h_5th = (is_first_tick ? 0 : _h_5th)
    h_6th ∈ Int
    h_6th = (is_first_tick ? 0 : _h_6th)
    h_tail1 ∈ C2H
    h_tail1 = (is_first_tick ? C2HNil : _h_tail1)
    h_tail2 ∈ C2H
    h_tail2 = (is_first_tick ? C2HNil : _h_tail2)
    h_tail3 ∈ C2H
    h_tail3 = (is_first_tick ? C2HNil : _h_tail3)
    h_tail4 ∈ C2H
    h_tail4 = (is_first_tick ? C2HNil : _h_tail4)
    h_tail5 ∈ C2H
    h_tail5 = (is_first_tick ? C2HNil : _h_tail5)
    h_tail6 ∈ C2H
    h_tail6 = (is_first_tick ? C2HNil : _h_tail6)
    h_top ∈ Int
    h_top = (is_first_tick ? 0 : _h_top)
    d_hstk_in ∈ C2H
    d_hstk_in = (is_first_tick ? C2HNil : _d_hstk_in)
    gc_hit ∈ Bool
    gc_hit = (is_first_tick ? false : _gc_hit)
    gj_cap ∈ Bool
    gj_cap = (is_first_tick ? false : _gj_cap)
    gj_fire ∈ Bool
    gj_fire = (is_first_tick ? false : _gj_fire)
    il_pop ∈ Bool
    il_pop = (is_first_tick ? false : _il_pop)
    p_done ∈ Bool
    p_done = (is_first_tick ? false : _p_done)
    pk_kind ∈ Int
    pk_kind = (is_first_tick ? 0 : _pk_kind)
    pr_bad ∈ Bool
    pr_bad = (is_first_tick ? false : _pr_bad)
    ptj_cap ∈ Bool
    ptj_cap = (is_first_tick ? false : _ptj_cap)
    ptj_fire ∈ Bool
    ptj_fire = (is_first_tick ? false : _ptj_fire)
    pz_act ∈ Bool
    pz_act = (is_first_tick ? false : _pz_act)
    pz_binds ∈ C2Binds
    pz_binds = (is_first_tick ? CBNil : _pz_binds)
    rec0 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    rec1 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    rec2 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    tok_cur ∈ Int
    tok_cur = (is_first_tick ? 0 : _tok_cur)
    ..DriverCompose
    captured ∈ Bool = (cs[0].name = "p")
    effects ∈ Seq(Effect) = (captured
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(cs[0].name)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
