-- DriverCompose isolation — slot-call name capture through callwalk_state.
-- parse_mode-10 held, frame idle: tick 1, call_capacity advances callwalk_state 0→1; tick 2,
-- callw1 is live and the window head `p ↦` (Ident, OpMapsto) fires
-- call_arg_slot, capturing slot_name_tok into slot_names[0].name (slot index 0). Must read "p".
-- entry: main
-- expect: stdout = "p"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_datatypes.ev"
import "compiler2/lexer.ev"
import "compiler2/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_posbind.ev"
import "compiler2/driver_compose.ev"

fsm main
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 10 : _parse_mode)
    parse ∈ Bool
    parse = (is_first_tick ? true : _parse)
    nil ∈ Bool
    nil = (is_first_tick ? true : _nil)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? true : _can_consume)
    tok0 ∈ Token
    tok0 = (is_first_tick ? Ident("p") : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? OpMapsto : _tok1)
    is_bare_comp ∈ Bool
    is_bare_comp = (is_first_tick ? false : _is_bare_comp)
    is_comp_call ∈ Bool
    is_comp_call = (is_first_tick ? false : _is_comp_call)
    is_lift ∈ Bool
    is_lift = (is_first_tick ? false : _is_lift)
    is_comp_line ∈ Bool
    is_comp_line = (is_first_tick ? false : _is_comp_line)
    callee_pos ∈ Int
    callee_pos = (is_first_tick ? 0 : _callee_pos)
    line ∈ ClassifiedLine
    line.at_eof = false
    line.name = ""
    line.ty_name = ""
    line.is_nat = false
    line.enum_key = ""
    line.enum_pos = 0
    line.sort = 0
    line.end = false
    line.dname = ""
    line.items = C2INil
    is_bare_member ∈ Bool
    is_bare_member = (is_first_tick ? false : _is_bare_member)
    is_member_call ∈ Bool
    is_member_call = (is_first_tick ? false : _is_member_call)
    is_member_line ∈ Bool
    is_member_line = (is_first_tick ? false : _is_member_line)
    claimindex_buf ∈ FtiBuffer
    claimindex_buf.base = (is_first_tick ? 0 : _claimindex_buf.base)
    claimindex_buf.count = (is_first_tick ? 0 : _claimindex_buf.count)
    is_intresult_capture ∈ Int
    is_intresult_capture = (is_first_tick ? 0 : _is_intresult_capture)
    enter_claim ∈ Bool
    enter_claim = (is_first_tick ? false : _enter_claim)
    claim_params ∈ Bool
    claim_params = (is_first_tick ? false : _claim_params)
    prescan_reseek ∈ Bool = false
    second_handle ∈ Int
    second_handle = (is_first_tick ? 0 : _second_handle)
    third_handle ∈ Int
    third_handle = (is_first_tick ? 0 : _third_handle)
    fourth_handle ∈ Int
    fourth_handle = (is_first_tick ? 0 : _fourth_handle)
    fifth_handle ∈ Int
    fifth_handle = (is_first_tick ? 0 : _fifth_handle)
    sixth_handle ∈ Int
    sixth_handle = (is_first_tick ? 0 : _sixth_handle)
    tail1 ∈ C2H
    tail1 = (is_first_tick ? C2HNil : _tail1)
    tail2 ∈ C2H
    tail2 = (is_first_tick ? C2HNil : _tail2)
    tail3 ∈ C2H
    tail3 = (is_first_tick ? C2HNil : _tail3)
    tail4 ∈ C2H
    tail4 = (is_first_tick ? C2HNil : _tail4)
    tail5 ∈ C2H
    tail5 = (is_first_tick ? C2HNil : _tail5)
    tail6 ∈ C2H
    tail6 = (is_first_tick ? C2HNil : _tail6)
    topmost_handle ∈ Int
    topmost_handle = (is_first_tick ? 0 : _topmost_handle)
    stack_in ∈ C2H
    stack_in = (is_first_tick ? C2HNil : _stack_in)
    cond_hit ∈ Bool
    cond_hit = (is_first_tick ? false : _cond_hit)
    capture ∈ Bool
    capture = (is_first_tick ? false : _capture)
    jump_fire ∈ Bool
    jump_fire = (is_first_tick ? false : _jump_fire)
    frame_pop ∈ Bool
    frame_pop = (is_first_tick ? false : _frame_pop)
    parser ∈ ParseState
    parser.kind = (is_first_tick ? 0 : _parser.kind)
    parser.ready = (is_first_tick ? false : _parser.ready)
    parser.bad = (is_first_tick ? false : _parser.bad)
    parser.consume = (is_first_tick ? 0 : _parser.consume)
    parser.pd = (is_first_tick ? 0 : _parser.pd)
    parser.qd = (is_first_tick ? 0 : _parser.qd)
    parser.cd = (is_first_tick ? 0 : _parser.cd)
    parser.expop = (is_first_tick ? false : _parser.expop)
    parser.sort = (is_first_tick ? 0 : _parser.sort)
    parser.rec_slot = (is_first_tick ? 0 : _parser.rec_slot)
    parser.decl_name = (is_first_tick ? "" : _parser.decl_name)
    posjump_cap ∈ Bool
    posjump_cap = (is_first_tick ? false : _posjump_cap)
    posjump_fire ∈ Bool
    posjump_fire = (is_first_tick ? false : _posjump_fire)
    bindzip_act ∈ Bool
    bindzip_act = (is_first_tick ? false : _bindzip_act)
    bindzip_count ∈ Int = 0
    bindzip_binds ∈ Seq(Bind)
    #bindzip_binds ≤ 6
    ∀ k ∈ {0..5} : bindzip_binds[k].name = ""
    ∀ k ∈ {0..5} : bindzip_binds[k].handle = 0
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ e ∈ recs : e.name = ""
    ∀ e ∈ recs : e.fnames = ""
    ∀ e ∈ recs : e.ftypes = ""
    ∀ e ∈ recs : e.n_fields = 0
    ∀ e ∈ recs : e.sort = 0
    ∀ e ∈ recs : e.ctor = 0
    ∀ e ∈ recs : e.asort = 0
    ∀ e ∈ recs : e.ssort = 0
    ∀ e ∈ recs : e.accs[0] = 0
    ∀ e ∈ recs : e.accs[1] = 0
    ∀ e ∈ recs : e.accs[2] = 0
    ∀ e ∈ recs : e.accs[3] = 0
    ∀ e ∈ recs : e.accs[4] = 0
    ∀ e ∈ recs : e.accs[5] = 0
    token_cursor ∈ Int
    token_cursor = (is_first_tick ? 0 : _token_cursor)
    positional_line ∈ Bool
    positional_line = (is_first_tick ? false : _positional_line)
    guarding ∈ Bool
    guarding = (is_first_tick ? false : _guarding)
    armed_depth ∈ Int
    armed_depth = (is_first_tick ? 0 : _armed_depth)
    param_count ∈ Int
    param_count = (is_first_tick ? 0 : _param_count)
    param_names ∈ Seq(PbStr)
    #param_names ≤ 6
    ∀ k ∈ {0..5} : param_names[k].s = (is_first_tick ? "" : _param_names[k].s)
    ..DriverCompose
    captured ∈ Bool = (slot_names[0].name = "p")
    effects ∈ Seq(Effect) = (captured
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(slot_names[0].name)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
