-- DriverCompose isolation — slot-call name capture through callw_st.
-- parse_mode-10 held, frame idle: tick 1, callw_cap advances callw_st 0→1; tick 2,
-- callw1 is live and the window head `p ↦` (Ident, OpMapsto) fires
-- callw_slot, capturing slot_name_tok into slot_names[0].name (slot index 0). Must read "p".
-- entry: main
-- expect: stdout = "p"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_posbind.ev"
import "compiler2/driver_compose.ev"

fsm main
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 10 : _parse_mode)
    parse ∈ Bool
    parse = (is_first_tick ? true : _parse)
    nil ∈ Bool
    nil = (is_first_tick ? true : _nil)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? true : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? Ident("p") : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? OpMapsto : _tok1)
    comp_bare ∈ Bool
    comp_bare = (is_first_tick ? false : _comp_bare)
    comp_call ∈ Bool
    comp_call = (is_first_tick ? false : _comp_call)
    dotdot ∈ Bool
    dotdot = (is_first_tick ? false : _dotdot)
    comp_line ∈ Bool
    comp_line = (is_first_tick ? false : _comp_line)
    callee_pos ∈ Int
    callee_pos = (is_first_tick ? 0 : _callee_pos)
    line_name ∈ String
    line_name = (is_first_tick ? "" : _line_name)
    tymem_bare ∈ Bool
    tymem_bare = (is_first_tick ? false : _tymem_bare)
    tymem_call ∈ Bool
    tymem_call = (is_first_tick ? false : _tymem_call)
    tymem_line ∈ Bool
    tymem_line = (is_first_tick ? false : _tymem_line)
    line_ty_name ∈ String
    line_ty_name = (is_first_tick ? "" : _line_ty_name)
    claimindex_buf ∈ FtiBuffer
    claimindex_buf.base = (is_first_tick ? 0 : _claimindex_buf.base)
    claimindex_buf.count = (is_first_tick ? 0 : _claimindex_buf.count)
    cap_int ∈ Int
    cap_int = (is_first_tick ? 0 : _cap_int)
    enter_claim ∈ Bool
    enter_claim = (is_first_tick ? false : _enter_claim)
    claim_params ∈ Bool
    claim_params = (is_first_tick ? false : _claim_params)
    h_2nd ∈ Int
    h_2nd = (is_first_tick ? 0 : _h_2nd)
    h_3rd ∈ Int
    h_3rd = (is_first_tick ? 0 : _h_3rd)
    h_4th ∈ Int
    h_4th = (is_first_tick ? 0 : _h_4th)
    h_5th ∈ Int
    h_5th = (is_first_tick ? 0 : _h_5th)
    h_6th ∈ Int
    h_6th = (is_first_tick ? 0 : _h_6th)
    tail1 ∈ C2H
    tail1 = (is_first_tick ? C2HNil : _tail1)
    tail2 ∈ C2H
    tail2 = (is_first_tick ? C2HNil : _tail2)
    tail3 ∈ C2H
    tail3 = (is_first_tick ? C2HNil : _tail3)
    tail4 ∈ C2H
    tail4 = (is_first_tick ? C2HNil : _tail4)
    tail5 ∈ C2H
    tail5 = (is_first_tick ? C2HNil : _tail5)
    tail6 ∈ C2H
    tail6 = (is_first_tick ? C2HNil : _tail6)
    h_top ∈ Int
    h_top = (is_first_tick ? 0 : _h_top)
    stack_in ∈ C2H
    stack_in = (is_first_tick ? C2HNil : _stack_in)
    cond_hit ∈ Bool
    cond_hit = (is_first_tick ? false : _cond_hit)
    capture ∈ Bool
    capture = (is_first_tick ? false : _capture)
    jump_fire ∈ Bool
    jump_fire = (is_first_tick ? false : _jump_fire)
    frame_pop ∈ Bool
    frame_pop = (is_first_tick ? false : _frame_pop)
    parse_ready ∈ Bool
    parse_ready = (is_first_tick ? false : _parse_ready)
    parse_kind ∈ Int
    parse_kind = (is_first_tick ? 0 : _parse_kind)
    parse_bad ∈ Bool
    parse_bad = (is_first_tick ? false : _parse_bad)
    posjump_cap ∈ Bool
    posjump_cap = (is_first_tick ? false : _posjump_cap)
    posjump_fire ∈ Bool
    posjump_fire = (is_first_tick ? false : _posjump_fire)
    bindzip_act ∈ Bool
    bindzip_act = (is_first_tick ? false : _bindzip_act)
    bindzip_count ∈ Int = 0
    bindzip_binds ∈ Seq(Bind)
    #bindzip_binds ≤ 6
    ∀ k ∈ {0..5} : bindzip_binds[k].name = ""
    ∀ k ∈ {0..5} : bindzip_binds[k].handle = 0
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ e ∈ recs : e.name = ""
    ∀ e ∈ recs : e.fnames = ""
    ∀ e ∈ recs : e.ftypes = ""
    ∀ e ∈ recs : e.n_fields = 0
    ∀ e ∈ recs : e.sort = 0
    ∀ e ∈ recs : e.ctor = 0
    ∀ e ∈ recs : e.asort = 0
    ∀ e ∈ recs : e.ssort = 0
    ∀ e ∈ recs : e.accs[0] = 0
    ∀ e ∈ recs : e.accs[1] = 0
    ∀ e ∈ recs : e.accs[2] = 0
    ∀ e ∈ recs : e.accs[3] = 0
    ∀ e ∈ recs : e.accs[4] = 0
    ∀ e ∈ recs : e.accs[5] = 0
    tok_cur ∈ Int
    tok_cur = (is_first_tick ? 0 : _tok_cur)
    positional_line ∈ Bool
    positional_line = (is_first_tick ? false : _positional_line)
    guarding ∈ Bool
    guarding = (is_first_tick ? false : _guarding)
    armed_depth ∈ Int
    armed_depth = (is_first_tick ? 0 : _armed_depth)
    param_count ∈ Int
    param_count = (is_first_tick ? 0 : _param_count)
    param_names ∈ Seq(PbStr)
    #param_names ≤ 6
    ∀ k ∈ {0..5} : param_names[k].s = (is_first_tick ? "" : _param_names[k].s)
    ..DriverCompose
    captured ∈ Bool = (slot_names[0].name = "p")
    effects ∈ Seq(Effect) = (captured
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(slot_names[0].name)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
