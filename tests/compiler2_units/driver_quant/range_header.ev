-- DriverQuant isolation — range-quantifier header classification.
-- Line head pinned to `∀ x ∈ { 0 .. 9 }`; the module must classify
-- q_range = true and decode q_lo = 0, q_hi = 9. Output is "9" only
-- when the range header is recognized and its bound decoded.
--
-- entry: main
-- expect: stdout = "9"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_quant.ev"

fsm main
    line_t0 ∈ Token
    line_t0 = (is_first_tick ? OpForall : _line_t0)
    line_t1 ∈ Token
    line_t1 = (is_first_tick ? Ident("x") : _line_t1)
    line_t2 ∈ Token
    line_t2 = (is_first_tick ? OpIn : _line_t2)
    line_t3 ∈ Token
    line_t3 = (is_first_tick ? LBrace : _line_t3)
    line_t4 ∈ Token
    line_t4 = (is_first_tick ? IntLit(0) : _line_t4)
    tok5 ∈ Token
    tok5 = (is_first_tick ? Dot : _tok5)
    tok6 ∈ Token
    tok6 = (is_first_tick ? Dot : _tok6)
    tok7 ∈ Token
    tok7 = (is_first_tick ? IntLit(9) : _tok7)
    classify_now ∈ Bool
    classify_now = (is_first_tick ? false : _classify_now)
    enter_qset ∈ Bool
    enter_qset = (is_first_tick ? false : _enter_qset)
    in_claim ∈ Bool
    in_claim = (is_first_tick ? false : _in_claim)
    line_end ∈ Bool
    line_end = (is_first_tick ? false : _line_end)
    work_nil ∈ Bool
    work_nil = (is_first_tick ? false : _work_nil)
    guard_is_binop ∈ Bool
    guard_is_binop = (is_first_tick ? false : _guard_is_binop)
    guard_lhs ∈ Expr
    guard_lhs = (is_first_tick ? EInt(0) : _guard_lhs)
    guard_op ∈ Op
    guard_op = (is_first_tick ? OpPlus : _guard_op)
    guard_rhs ∈ Expr
    guard_rhs = (is_first_tick ? EInt(0) : _guard_rhs)
    scope_prefix ∈ String
    scope_prefix = (is_first_tick ? "" : _scope_prefix)
    param_skip ∈ Int
    param_skip = (is_first_tick ? 0 : _param_skip)
    in_parse ∈ Bool
    in_parse = (is_first_tick ? false : _in_parse)
    pratt_done ∈ Bool
    pratt_done = (is_first_tick ? false : _pratt_done)
    pratt_kind ∈ Int
    pratt_kind = (is_first_tick ? 0 : _pratt_kind)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    pratt_bad ∈ Bool
    pratt_bad = (is_first_tick ? false : _pratt_bad)
    pratt_result ∈ Expr
    pratt_result = (is_first_tick ? EInt(0) : _pratt_result)
    seqvar_name ∈ String
    seqvar_name = (is_first_tick ? "" : _seqvar_name)
    seqvar_set ∈ Bool
    seqvar_set = (is_first_tick ? false : _seqvar_set)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? false : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? EofTok : _tok1)
    ..DriverQuant
    ok ∈ Bool = q_range
    msg ∈ String = str_from_int(q_hi)
    effects ∈ Seq(Effect) = (ok
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
