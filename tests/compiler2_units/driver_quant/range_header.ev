-- DriverQuant isolation — range-quantifier header classification.
-- Line head pinned to `∀ x ∈ { 0 .. 9 }`; the module must classify
-- quant_range_line = true and decode range_lower = 0, range_upper = 9. Output is "9" only
-- when the range header is recognized and its bound decoded.
--
-- entry: main
-- expect: stdout = "9"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/lexer.ev"
import "compiler2/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_quant.ev"

fsm main
    tok2 ∈ Token
    tok2 = (is_first_tick ? OpIn : _tok2)
    tok3 ∈ Token
    tok3 = (is_first_tick ? LBrace : _tok3)
    tok4 ∈ Token
    tok4 = (is_first_tick ? IntLit(0) : _tok4)
    tok5 ∈ Token
    tok5 = (is_first_tick ? Dot : _tok5)
    tok6 ∈ Token
    tok6 = (is_first_tick ? Dot : _tok6)
    tok7 ∈ Token
    tok7 = (is_first_tick ? IntLit(9) : _tok7)
    line ∈ ClassifiedLine
    line.at_eof = false
    line.name = ""
    line.ty_name = ""
    line.is_nat = false
    line.enum_key = ""
    line.enum_pos = 0
    line.sort = 0
    line.end = false
    line.dname = ""
    line.items = C2INil
    classify_now ∈ Bool
    classify_now = (is_first_tick ? false : _classify_now)
    is_setquery ∈ Bool
    is_setquery = (is_first_tick ? false : _is_setquery)
    in_claim ∈ Bool
    in_claim = (is_first_tick ? false : _in_claim)
    nil ∈ Bool
    nil = (is_first_tick ? false : _nil)
    binop ∈ Bool
    binop = (is_first_tick ? false : _binop)
    cond_lhs ∈ Expr
    cond_lhs = (is_first_tick ? EInt(0) : _cond_lhs)
    cond_op ∈ Op
    cond_op = (is_first_tick ? OpPlus : _cond_op)
    cond_rhs ∈ Expr
    cond_rhs = (is_first_tick ? EInt(0) : _cond_rhs)
    scope_prefix ∈ String
    scope_prefix = (is_first_tick ? "" : _scope_prefix)
    param_skip ∈ Int
    param_skip = (is_first_tick ? 0 : _param_skip)
    parse ∈ Bool
    parse = (is_first_tick ? false : _parse)
    parser ∈ ParseState
    parser.kind = (is_first_tick ? 0 : _parser.kind)
    parser.ready = (is_first_tick ? false : _parser.ready)
    parser.bad = (is_first_tick ? false : _parser.bad)
    parser.consume = (is_first_tick ? 0 : _parser.consume)
    parser.pd = (is_first_tick ? 0 : _parser.pd)
    parser.qd = (is_first_tick ? 0 : _parser.qd)
    parser.cd = (is_first_tick ? 0 : _parser.cd)
    parser.expop = (is_first_tick ? false : _parser.expop)
    parser.sort = (is_first_tick ? 0 : _parser.sort)
    parser.rec_slot = (is_first_tick ? 0 : _parser.rec_slot)
    parser.decl_name = (is_first_tick ? "" : _parser.decl_name)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    result ∈ Expr
    result = (is_first_tick ? EInt(0) : _result)
    registered_seq_name ∈ String
    registered_seq_name = (is_first_tick ? "" : _registered_seq_name)
    is_seq_registered ∈ Bool
    is_seq_registered = (is_first_tick ? false : _is_seq_registered)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? false : _can_consume)
    tok0 ∈ Token
    tok0 = (is_first_tick ? OpForall : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? Ident("x") : _tok1)
    ..DriverQuant
    ok ∈ Bool = quant_range_line
    msg ∈ String = str_from_int(range_upper)
    effects ∈ Seq(Effect) = (ok
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
