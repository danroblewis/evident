-- DriverQuant isolation — range-quantifier header classification.
-- Line head pinned to `∀ x ∈ { 0 .. 9 }`; the module must classify
-- c_q_rng = true and decode c_q_lo = 0, c_q_hi = 9. Output is "9" only
-- when the range header is recognized and its bound decoded.
--
-- entry: main
-- expect: stdout = "9"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_quant.ev"

fsm main
    c_t0 ∈ Token
    c_t0 = (is_first_tick ? OpForall : _c_t0)
    c_t1 ∈ Token
    c_t1 = (is_first_tick ? Ident("x") : _c_t1)
    c_t2 ∈ Token
    c_t2 = (is_first_tick ? OpIn : _c_t2)
    c_t3 ∈ Token
    c_t3 = (is_first_tick ? LBrace : _c_t3)
    c_t4 ∈ Token
    c_t4 = (is_first_tick ? IntLit(0) : _c_t4)
    tok5 ∈ Token
    tok5 = (is_first_tick ? Dot : _tok5)
    tok6 ∈ Token
    tok6 = (is_first_tick ? Dot : _tok6)
    tok7 ∈ Token
    tok7 = (is_first_tick ? IntLit(9) : _tok7)
    classify_now ∈ Bool
    classify_now = (is_first_tick ? false : _classify_now)
    d_enter_qset ∈ Bool
    d_enter_qset = (is_first_tick ? false : _d_enter_qset)
    d_in_claim ∈ Bool
    d_in_claim = (is_first_tick ? false : _d_in_claim)
    d_line_end ∈ Bool
    d_line_end = (is_first_tick ? false : _d_line_end)
    work_nil ∈ Bool
    work_nil = (is_first_tick ? false : _work_nil)
    gc_bin ∈ Bool
    gc_bin = (is_first_tick ? false : _gc_bin)
    gc_l ∈ Expr
    gc_l = (is_first_tick ? EInt(0) : _gc_l)
    gc_op ∈ Op
    gc_op = (is_first_tick ? OpPlus : _gc_op)
    gc_r ∈ Expr
    gc_r = (is_first_tick ? EInt(0) : _gc_r)
    il_pfx ∈ String
    il_pfx = (is_first_tick ? "" : _il_pfx)
    il_ps ∈ Int
    il_ps = (is_first_tick ? 0 : _il_ps)
    in_parse ∈ Bool
    in_parse = (is_first_tick ? false : _in_parse)
    p_done ∈ Bool
    p_done = (is_first_tick ? false : _p_done)
    pk_kind ∈ Int
    pk_kind = (is_first_tick ? 0 : _pk_kind)
    pmode ∈ Int
    pmode = (is_first_tick ? 0 : _pmode)
    pr_bad ∈ Bool
    pr_bad = (is_first_tick ? false : _pr_bad)
    pr_sres ∈ Expr
    pr_sres = (is_first_tick ? EInt(0) : _pr_sres)
    sq_name ∈ String
    sq_name = (is_first_tick ? "" : _sq_name)
    sq_set ∈ Bool
    sq_set = (is_first_tick ? false : _sq_set)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? false : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? EofTok : _tok1)
    ..DriverQuant
    ok ∈ Bool = c_q_rng
    msg ∈ String = str_from_int(c_q_hi)
    effects ∈ Seq(Effect) = (ok
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
