-- DriverEmit isolation — the EMIT program counter walks once done.
-- emit_step parks at −1 until parse_done, then steps 0→1→…→5 (capped), one
-- per tick: solver-to-string, cstr-copy, render-capture, then the
-- free+puts+Exit row. parse_done held true; exit at emit_step ≥ 5.
-- entry: main
-- expect: stdout = "5"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_core.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_emit.ev"

fsm main
    parse_done ∈ Bool
    parse_done = (is_first_tick ? true : _parse_done)
    cap_int ∈ Int
    cap_int = (is_first_tick ? 0 : _cap_int)
    cap_str ∈ String
    cap_str = (is_first_tick ? "" : _cap_str)
    z3ctx ∈ Z3SolverCtx
    z3ctx.cfg = (is_first_tick ? 0 : _z3ctx.cfg)
    z3ctx.ctx = (is_first_tick ? 0 : _z3ctx.ctx)
    z3ctx.sol = (is_first_tick ? 0 : _z3ctx.sol)
    manifest_fields ∈ String
    manifest_fields = (is_first_tick ? "" : _manifest_fields)
    saw_lastres ∈ Bool
    saw_lastres = (is_first_tick ? false : _saw_lastres)
    saw_first_tick ∈ Bool
    saw_first_tick = (is_first_tick ? false : _saw_first_tick)
    carry_decls ∈ String
    carry_decls = (is_first_tick ? "" : _carry_decls)
    tok_buf ∈ FtiBuffer
    tok_buf.base = (is_first_tick ? 0 : _tok_buf.base)
    tok_buf.count = (is_first_tick ? 0 : _tok_buf.count)
    sym_buf ∈ FtiBuffer
    sym_buf.base = (is_first_tick ? 0 : _sym_buf.base)
    sym_buf.count = (is_first_tick ? 0 : _sym_buf.count)
    claimidx_buf ∈ FtiBuffer
    claimidx_buf.base = (is_first_tick ? 0 : _claimidx_buf.base)
    claimidx_buf.count = (is_first_tick ? 0 : _claimidx_buf.count)
    -- DriverEmit's prelude_txt string literal contains the text
    -- "last_results", which trips the oracle's saw_lastres heuristic and
    -- suppresses the genuine `last_results` declaration. A real read
    -- forces it back into the build context so the kernel's per-tick
    -- result carry resolves (otherwise: "unknown constant last_results").
    lr_probe ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    emit_step ∈ Int
    unit_ptr ∈ Int
    rendered ∈ String
    eff_solver_str ∈ Effect
    eff_copy_unit ∈ Effect
    eff_print_unit ∈ Effect
    eff_free_tokbuf ∈ Effect
    eff_free_symbuf ∈ Effect
    eff_free_claimbuf ∈ Effect
    DriverEmit
    e_msg ∈ String = str_from_int(emit_step + (lr_probe - lr_probe))
    effects ∈ Seq(Effect) = (emit_step ≥ 5
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(e_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
