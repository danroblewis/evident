-- DriverEmit isolation — the EMIT program counter walks once done.
-- estep parks at −1 until d_all_done, then steps 0→1→…→5 (capped), one
-- per tick: solver-to-string, cstr-copy, render-capture, then the
-- free+puts+Exit row. d_all_done held true; exit at estep ≥ 5.
-- entry: main
-- expect: stdout = "5"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_core.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_emit.ev"

fsm main
    d_all_done ∈ Bool
    d_all_done = (is_first_tick ? true : _d_all_done)
    d_cap_int ∈ Int
    d_cap_int = (is_first_tick ? 0 : _d_cap_int)
    d_cap_str ∈ String
    d_cap_str = (is_first_tick ? "" : _d_cap_str)
    z3ctx ∈ Z3SolverCtx
    z3ctx.cfg = (is_first_tick ? 0 : _z3ctx.cfg)
    z3ctx.ctx = (is_first_tick ? 0 : _z3ctx.ctx)
    z3ctx.sol = (is_first_tick ? 0 : _z3ctx.sol)
    fstr ∈ String
    fstr = (is_first_tick ? "" : _fstr)
    saw_lr ∈ Bool
    saw_lr = (is_first_tick ? false : _saw_lr)
    saw_ift ∈ Bool
    saw_ift = (is_first_tick ? false : _saw_ift)
    cdstr ∈ String
    cdstr = (is_first_tick ? "" : _cdstr)
    tok_buf ∈ FtiBuffer
    tok_buf.base = (is_first_tick ? 0 : _tok_buf.base)
    tok_buf.count = (is_first_tick ? 0 : _tok_buf.count)
    sym_buf ∈ FtiBuffer
    sym_buf.base = (is_first_tick ? 0 : _sym_buf.base)
    sym_buf.count = (is_first_tick ? 0 : _sym_buf.count)
    claimidx_buf ∈ FtiBuffer
    claimidx_buf.base = (is_first_tick ? 0 : _claimidx_buf.base)
    claimidx_buf.count = (is_first_tick ? 0 : _claimidx_buf.count)
    -- DriverEmit's d_prelude string literal contains the text
    -- "last_results", which trips the oracle's saw_lr heuristic and
    -- suppresses the genuine `last_results` declaration. A real read
    -- forces it back into the build context so the kernel's per-tick
    -- result carry resolves (otherwise: "unknown constant last_results").
    lr_probe ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    ..DriverEmit
    e_msg ∈ String = str_from_int(estep + (lr_probe - lr_probe))
    effects ∈ Seq(Effect) = (estep ≥ 5
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(e_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
