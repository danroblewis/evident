-- DriverEmit isolation — the EMIT program counter walks once done.
-- render_step parks at −1 until parse_done, then steps 0→1→…→5 (capped), one
-- per tick: solver-to-string, cstr-copy, render-capture, then the
-- free+puts+Exit elem_record. parse_done held true; exit at render_step ≥ 5.
-- entry: main
-- expect: stdout = "5"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_core.ev"
import "compiler2/lexer.ev"
import "compiler2/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_emit.ev"

fsm main
    parse_done ∈ Bool
    parse_done = (is_first_tick ? true : _parse_done)
    parser ∈ ParseState
    parser.kind = (is_first_tick ? 0 : _parser.kind)
    parser.ready = (is_first_tick ? false : _parser.ready)
    parser.bad = (is_first_tick ? false : _parser.bad)
    parser.consume = (is_first_tick ? 0 : _parser.consume)
    parser.pd = (is_first_tick ? 0 : _parser.pd)
    parser.qd = (is_first_tick ? 0 : _parser.qd)
    parser.cd = (is_first_tick ? 0 : _parser.cd)
    parser.expop = (is_first_tick ? false : _parser.expop)
    parser.sort = (is_first_tick ? 0 : _parser.sort)
    parser.rec_slot = (is_first_tick ? 0 : _parser.rec_slot)
    parser.decl_name = (is_first_tick ? "" : _parser.decl_name)
    is_intresult_capture ∈ Int
    is_intresult_capture = (is_first_tick ? 0 : _is_intresult_capture)
    is_strresult_capture ∈ String
    is_strresult_capture = (is_first_tick ? "" : _is_strresult_capture)
    z3ctx ∈ Z3SolverCtx
    z3ctx.cfg = (is_first_tick ? 0 : _z3ctx.cfg)
    z3ctx.ctx = (is_first_tick ? 0 : _z3ctx.ctx)
    z3ctx.sol = (is_first_tick ? 0 : _z3ctx.sol)
    manifest_fields ∈ String
    manifest_fields = (is_first_tick ? "" : _manifest_fields)
    saw_lastres ∈ Bool
    saw_lastres = (is_first_tick ? false : _saw_lastres)
    saw_first_tick ∈ Bool
    saw_first_tick = (is_first_tick ? false : _saw_first_tick)
    carry_decls ∈ String
    carry_decls = (is_first_tick ? "" : _carry_decls)
    tok_buf ∈ FtiBuffer
    tok_buf.base = (is_first_tick ? 0 : _tok_buf.base)
    tok_buf.count = (is_first_tick ? 0 : _tok_buf.count)
    symtab_buffer ∈ FtiBuffer
    symtab_buffer.base = (is_first_tick ? 0 : _symtab_buffer.base)
    symtab_buffer.count = (is_first_tick ? 0 : _symtab_buffer.count)
    claimindex_buf ∈ FtiBuffer
    claimindex_buf.base = (is_first_tick ? 0 : _claimindex_buf.base)
    claimindex_buf.count = (is_first_tick ? 0 : _claimindex_buf.count)
    -- DriverEmit's prelude_txt string literal contains the text
    -- "last_results", which trips the oracle's saw_lastres heuristic and
    -- suppresses the genuine `last_results` declaration. A real read
    -- forces it back into the build context so the kernel's per-tick
    -- result carry resolves (otherwise: "unknown constant last_results").
    lr_probe ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    ..DriverEmit
    e_msg ∈ String = str_from_int(render_step + (lr_probe - lr_probe))
    effects ∈ Seq(Effect) = (render_step ≥ 5
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(e_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
