-- DriverBuildEff isolation — the ED effect-elem_record selector.
-- Act 1 (member finalize) step 13 is the name+constructor-list double write:
-- wbatch2 must select it (w2=1, wf/w3u=0). Boundary case vs the wf elem_record.
-- entry: main
-- expect: stdout = "0/1/0"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_core.ev"
import "stdlib/z3_seq.ev"
import "stdlib/z3_datatypes.ev"
import "compiler2/lexer.ev"
import "compiler2/parser.ev"
import "compiler2/translate2_bool.ev"
import "compiler2/translate2_ctor.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_buildeff.ev"

fsm main
    action_now ∈ Int
    action_now = (is_first_tick ? 1 : _action_now)
    step_now ∈ Int
    step_now = (is_first_tick ? 13 : _step_now)
    is_intresult_capture ∈ Int
    is_intresult_capture = (is_first_tick ? 0 : _is_intresult_capture)
    field_ref2 ∈ Int
    field_ref2 = (is_first_tick ? 0 : _field_ref2)
    header_fields ∈ Seq(Int)
    #header_fields ≤ 6
    ∀ k ∈ {0..5} : header_fields[k] = (is_first_tick ? 0 : _header_fields[k])
    header_name ∈ Int
    header_name = (is_first_tick ? 0 : _header_name)
    header_recognized ∈ Int
    header_recognized = (is_first_tick ? 0 : _header_recognized)
    variant_count ∈ Int
    variant_count = (is_first_tick ? 0 : _variant_count)
    refs_packed01 ∈ Int
    refs_packed01 = (is_first_tick ? 0 : _refs_packed01)
    decl_step ∈ Int
    decl_step = (is_first_tick ? 0 : _decl_step)
    index ∈ Int
    index = (is_first_tick ? 0 : _index)
    symtab_buffer ∈ FtiBuffer
    symtab_buffer.base = (is_first_tick ? 0 : _symtab_buffer.base)
    symtab_buffer.count = (is_first_tick ? 0 : _symtab_buffer.count)
    z3_arena ∈ Int
    z3_arena = (is_first_tick ? 0 : _z3_arena)
    effect_arraysort ∈ Int
    effect_arraysort = (is_first_tick ? 0 : _effect_arraysort)
    z3sorts ∈ Z3Sorts
    z3sorts.isort = (is_first_tick ? 0 : _z3sorts.isort)
    z3sorts.bsort = (is_first_tick ? 0 : _z3sorts.bsort)
    z3sorts.ssort = (is_first_tick ? 0 : _z3sorts.ssort)
    z3sorts.rsort = (is_first_tick ? 0 : _z3sorts.rsort)
    z3ctx ∈ Z3SolverCtx
    z3ctx.cfg = (is_first_tick ? 0 : _z3ctx.cfg)
    z3ctx.ctx = (is_first_tick ? 0 : _z3ctx.ctx)
    z3ctx.sol = (is_first_tick ? 0 : _z3ctx.sol)
    effect_sort ∈ Int
    effect_sort = (is_first_tick ? 0 : _effect_sort)
    effects_length_geq ∈ Int
    effects_length_geq = (is_first_tick ? 0 : _effects_length_geq)
    effects_length ∈ Int
    effects_length = (is_first_tick ? 0 : _effects_length)
    z3_first_tick ∈ Int
    z3_first_tick = (is_first_tick ? 0 : _z3_first_tick)
    z3_last_results ∈ Int
    z3_last_results = (is_first_tick ? 0 : _z3_last_results)
    last_results_geq ∈ Int
    last_results_geq = (is_first_tick ? 0 : _last_results_geq)
    last_results_length ∈ Int
    last_results_length = (is_first_tick ? 0 : _last_results_length)
    last_results_sort ∈ Int
    last_results_sort = (is_first_tick ? 0 : _last_results_sort)
    result_sort ∈ Int
    result_sort = (is_first_tick ? 0 : _result_sort)
    effects_symbol ∈ Int
    effects_symbol = (is_first_tick ? 0 : _effects_symbol)
    effects_length_symbol ∈ Int
    effects_length_symbol = (is_first_tick ? 0 : _effects_length_symbol)
    first_tick_symbol ∈ Int
    first_tick_symbol = (is_first_tick ? 0 : _first_tick_symbol)
    last_results_symbol ∈ Int
    last_results_symbol = (is_first_tick ? 0 : _last_results_symbol)
    last_results_length_symbol ∈ Int
    last_results_length_symbol = (is_first_tick ? 0 : _last_results_length_symbol)
    z3nums ∈ Z3Numerals
    z3nums.zero = (is_first_tick ? 0 : _z3nums.zero)
    z3nums.one = (is_first_tick ? 0 : _z3nums.one)
    z3nums.two = (is_first_tick ? 0 : _z3nums.two)
    z3nums.three = (is_first_tick ? 0 : _z3nums.three)
    z3nums.four = (is_first_tick ? 0 : _z3nums.four)
    nullary_variant ∈ Bool
    nullary_variant = (is_first_tick ? false : _nullary_variant)
    result_harvest ∈ Bool
    result_harvest = (is_first_tick ? false : _result_harvest)
    is_user_enum ∈ Bool
    is_user_enum = (is_first_tick ? false : _is_user_enum)
    declared_name ∈ String
    declared_name = (is_first_tick ? "" : _declared_name)
    geq ∈ Op = OpGeq
    current_variant ∈ EnumVariantDecl = EVNoVariant
    refs_packed23 ∈ Int
    refs_packed23 = (is_first_tick ? 0 : _refs_packed23)
    refs_packed45 ∈ Int
    refs_packed45 = (is_first_tick ? 0 : _refs_packed45)
    member_base ∈ Int
    member_base = (is_first_tick ? 0 : _member_base)
    size ∈ Int
    size = (is_first_tick ? 1 : _size)
    read_cur ∈ Int
    read_cur = (is_first_tick ? 0 : _read_cur)
    member_index ∈ Int = 0
    enumtab_count ∈ Int
    enumtab_count = (is_first_tick ? 0 : _enumtab_count)
    alloc ∈ Int
    alloc = (is_first_tick ? 1 : _alloc)
    int0 ∈ Int
    int0 = (is_first_tick ? 0 : _int0)
    int1 ∈ Int
    int1 = (is_first_tick ? 0 : _int1)
    int2 ∈ Int
    int2 = (is_first_tick ? 0 : _int2)
    int3 ∈ Int
    int3 = (is_first_tick ? 0 : _int3)
    int4 ∈ Int
    int4 = (is_first_tick ? 0 : _int4)
    int5 ∈ Int
    int5 = (is_first_tick ? 0 : _int5)
    slots ∈ Seq(EnumFieldSlot)
    #slots ≤ 6
    ∀ k ∈ {0..5} : slots[k].typename = (is_first_tick ? "" : _slots[k].typename)
    ∀ k ∈ {0..5} : slots[k].key = (is_first_tick ? "" : _slots[k].key)
    ∀ k ∈ {0..5} : slots[k].refpos = (is_first_tick ? 0 : _slots[k].refpos)
    ∀ k ∈ {0..5} : slots[k].isref = (is_first_tick ? false : _slots[k].isref)
    ∀ k ∈ {0..5} : slots[k].ref = (is_first_tick ? 0 : _slots[k].ref)
    ∀ k ∈ {0..5} : slots[k].tabpos = (is_first_tick ? 0 - 1 : _slots[k].tabpos)
    ∀ k ∈ {0..5} : slots[k].istab = (is_first_tick ? false : _slots[k].istab)
    ∀ k ∈ {0..5} : slots[k].xsort = (is_first_tick ? 0 : _slots[k].xsort)
    ∀ k ∈ {0..5} : slots[k].sort = (is_first_tick ? 0 : _slots[k].sort)
    ∀ k ∈ {0..5} : slots[k].unres = (is_first_tick ? false : _slots[k].unres)
    ..DriverBuildEff
    sel ∈ String = (wbatchf ? "1" : "0") ++ "/" ++ (wbatch2 ? "1" : "0") ++ "/" ++ (wbatch3u ? "1" : "0")
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(sel)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
