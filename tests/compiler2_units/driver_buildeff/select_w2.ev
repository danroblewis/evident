-- DriverBuildEff isolation — the ED effect-row selector.
-- Act 1 (member finalize) step 13 is the name+constructor-list double write:
-- enum_wbatch2 must select it (w2=1, wf/w3u=0). Boundary case vs the wf row.
-- entry: main
-- expect: stdout = "0/1/0"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_core.ev"
import "stdlib/z3_seq.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/translate2_bool.ev"
import "compiler2/translate2_ctor.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_buildeff.ev"

fsm main
    enum_act_now ∈ Int
    enum_act_now = (is_first_tick ? 1 : _enum_act_now)
    enum_step_now ∈ Int
    enum_step_now = (is_first_tick ? 13 : _enum_step_now)
    cap_int ∈ Int
    cap_int = (is_first_tick ? 0 : _cap_int)
    field_ref2 ∈ Int
    field_ref2 = (is_first_tick ? 0 : _field_ref2)
    enum_h_fields ∈ Seq(Int)
    #enum_h_fields ≤ 6
    ∀ k ∈ {0..5} : enum_h_fields[k] = (is_first_tick ? 0 : _enum_h_fields[k])
    enum_h_name ∈ Int
    enum_h_name = (is_first_tick ? 0 : _enum_h_name)
    enum_h_recog ∈ Int
    enum_h_recog = (is_first_tick ? 0 : _enum_h_recog)
    enum_n_variants ∈ Int
    enum_n_variants = (is_first_tick ? 0 : _enum_n_variants)
    refs_packed01 ∈ Int
    refs_packed01 = (is_first_tick ? 0 : _refs_packed01)
    enum_step ∈ Int
    enum_step = (is_first_tick ? 0 : _enum_step)
    enum_vidx ∈ Int
    enum_vidx = (is_first_tick ? 0 : _enum_vidx)
    sym_buf ∈ FtiBuffer
    sym_buf.base = (is_first_tick ? 0 : _sym_buf.base)
    sym_buf.count = (is_first_tick ? 0 : _sym_buf.count)
    z3_arena ∈ Int
    z3_arena = (is_first_tick ? 0 : _z3_arena)
    z3_effect_arraysort ∈ Int
    z3_effect_arraysort = (is_first_tick ? 0 : _z3_effect_arraysort)
    z3sorts ∈ Z3Sorts
    z3sorts.isort = (is_first_tick ? 0 : _z3sorts.isort)
    z3sorts.bsort = (is_first_tick ? 0 : _z3sorts.bsort)
    z3sorts.ssort = (is_first_tick ? 0 : _z3sorts.ssort)
    z3sorts.rsort = (is_first_tick ? 0 : _z3sorts.rsort)
    z3ctx ∈ Z3SolverCtx
    z3ctx.cfg = (is_first_tick ? 0 : _z3ctx.cfg)
    z3ctx.ctx = (is_first_tick ? 0 : _z3ctx.ctx)
    z3ctx.sol = (is_first_tick ? 0 : _z3ctx.sol)
    z3_effect_sort ∈ Int
    z3_effect_sort = (is_first_tick ? 0 : _z3_effect_sort)
    z3_effects_length_geq ∈ Int
    z3_effects_length_geq = (is_first_tick ? 0 : _z3_effects_length_geq)
    z3_effects_length ∈ Int
    z3_effects_length = (is_first_tick ? 0 : _z3_effects_length)
    z3_first_tick ∈ Int
    z3_first_tick = (is_first_tick ? 0 : _z3_first_tick)
    z3_last_results ∈ Int
    z3_last_results = (is_first_tick ? 0 : _z3_last_results)
    z3_last_results_geq ∈ Int
    z3_last_results_geq = (is_first_tick ? 0 : _z3_last_results_geq)
    z3_last_results_length ∈ Int
    z3_last_results_length = (is_first_tick ? 0 : _z3_last_results_length)
    z3_last_results_sort ∈ Int
    z3_last_results_sort = (is_first_tick ? 0 : _z3_last_results_sort)
    z3_result_sort ∈ Int
    z3_result_sort = (is_first_tick ? 0 : _z3_result_sort)
    z3_effects_symbol ∈ Int
    z3_effects_symbol = (is_first_tick ? 0 : _z3_effects_symbol)
    z3_effects_length_symbol ∈ Int
    z3_effects_length_symbol = (is_first_tick ? 0 : _z3_effects_length_symbol)
    z3_first_tick_symbol ∈ Int
    z3_first_tick_symbol = (is_first_tick ? 0 : _z3_first_tick_symbol)
    z3_last_results_symbol ∈ Int
    z3_last_results_symbol = (is_first_tick ? 0 : _z3_last_results_symbol)
    z3_last_results_length_symbol ∈ Int
    z3_last_results_length_symbol = (is_first_tick ? 0 : _z3_last_results_length_symbol)
    z3nums ∈ Z3Numerals
    z3nums.zero = (is_first_tick ? 0 : _z3nums.zero)
    z3nums.one = (is_first_tick ? 0 : _z3nums.one)
    z3nums.two = (is_first_tick ? 0 : _z3nums.two)
    z3nums.three = (is_first_tick ? 0 : _z3nums.three)
    z3nums.four = (is_first_tick ? 0 : _z3nums.four)
    enum_nullary ∈ Bool
    enum_nullary = (is_first_tick ? false : _enum_nullary)
    result_harvest ∈ Bool
    result_harvest = (is_first_tick ? false : _result_harvest)
    enum_is_user ∈ Bool
    enum_is_user = (is_first_tick ? false : _enum_is_user)
    enum_decl_name ∈ String
    enum_decl_name = (is_first_tick ? "" : _enum_decl_name)
    op_geq ∈ Op = OpGeq
    enum_variant ∈ EnumVariantDecl = EVNoVariant
    refs_packed23 ∈ Int
    refs_packed23 = (is_first_tick ? 0 : _refs_packed23)
    refs_packed45 ∈ Int
    refs_packed45 = (is_first_tick ? 0 : _refs_packed45)
    member_base ∈ Int
    member_base = (is_first_tick ? 0 : _member_base)
    group_size ∈ Int
    group_size = (is_first_tick ? 1 : _group_size)
    group_read_cur ∈ Int
    group_read_cur = (is_first_tick ? 0 : _group_read_cur)
    enum_member_idx ∈ Int = 0
    enumtab_count ∈ Int
    enumtab_count = (is_first_tick ? 0 : _enumtab_count)
    variant_alloc ∈ Int
    variant_alloc = (is_first_tick ? 1 : _variant_alloc)
    res_int0 ∈ Int
    res_int0 = (is_first_tick ? 0 : _res_int0)
    res_int1 ∈ Int
    res_int1 = (is_first_tick ? 0 : _res_int1)
    res_int2 ∈ Int
    res_int2 = (is_first_tick ? 0 : _res_int2)
    res_int3 ∈ Int
    res_int3 = (is_first_tick ? 0 : _res_int3)
    res_int4 ∈ Int
    res_int4 = (is_first_tick ? 0 : _res_int4)
    res_int5 ∈ Int
    res_int5 = (is_first_tick ? 0 : _res_int5)
    field_slots ∈ Seq(EnumFieldSlot)
    #field_slots ≤ 6
    ∀ k ∈ {0..5} : field_slots[k].ty = (is_first_tick ? "" : _field_slots[k].ty)
    ∀ k ∈ {0..5} : field_slots[k].key = (is_first_tick ? "" : _field_slots[k].key)
    ∀ k ∈ {0..5} : field_slots[k].refpos = (is_first_tick ? 0 : _field_slots[k].refpos)
    ∀ k ∈ {0..5} : field_slots[k].isref = (is_first_tick ? false : _field_slots[k].isref)
    ∀ k ∈ {0..5} : field_slots[k].ref = (is_first_tick ? 0 : _field_slots[k].ref)
    ∀ k ∈ {0..5} : field_slots[k].tabpos = (is_first_tick ? 0 - 1 : _field_slots[k].tabpos)
    ∀ k ∈ {0..5} : field_slots[k].istab = (is_first_tick ? false : _field_slots[k].istab)
    ∀ k ∈ {0..5} : field_slots[k].xsort = (is_first_tick ? 0 : _field_slots[k].xsort)
    ∀ k ∈ {0..5} : field_slots[k].sort = (is_first_tick ? 0 : _field_slots[k].sort)
    ∀ k ∈ {0..5} : field_slots[k].unres = (is_first_tick ? false : _field_slots[k].unres)
    ..DriverBuildEff
    sel ∈ String = (enum_wbatchf ? "1" : "0") ++ "/" ++ (enum_wbatch2 ? "1" : "0") ++ "/" ++ (enum_wbatch3u ? "1" : "0")
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(sel)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
