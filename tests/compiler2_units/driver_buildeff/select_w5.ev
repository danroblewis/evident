-- DriverBuildEff isolation — the ED effect-row selector.
-- Act 1 (ctor-field run) step 5 is the 6-slot field-name/sort write
-- batch: enum_wbatch5 must select the wide row (w5=1, w2/w3u=0). A regression
-- in the batch selector emits the wrong number of effect writes.
-- entry: main
-- expect: stdout = "1/0/0"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_core.ev"
import "stdlib/z3_seq.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/translate2_bool.ev"
import "compiler2/translate2_ctor.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_buildeff.ev"

fsm main
    ed_cur_act ∈ Int
    ed_cur_act = (is_first_tick ? 1 : _ed_cur_act)
    ed_cur_step ∈ Int
    ed_cur_step = (is_first_tick ? 5 : _ed_cur_step)
    d_cap_int ∈ Int
    d_cap_int = (is_first_tick ? 0 : _d_cap_int)
    ed_fr2 ∈ Int
    ed_fr2 = (is_first_tick ? 0 : _ed_fr2)
    ed_h_f0 ∈ Int
    ed_h_f0 = (is_first_tick ? 0 : _ed_h_f0)
    ed_h_f1 ∈ Int
    ed_h_f1 = (is_first_tick ? 0 : _ed_h_f1)
    ed_h_f2 ∈ Int
    ed_h_f2 = (is_first_tick ? 0 : _ed_h_f2)
    ed_h_name ∈ Int
    ed_h_name = (is_first_tick ? 0 : _ed_h_name)
    ed_h_rec ∈ Int
    ed_h_rec = (is_first_tick ? 0 : _ed_h_rec)
    ed_nv ∈ Int
    ed_nv = (is_first_tick ? 0 : _ed_nv)
    ed_pack01 ∈ Int
    ed_pack01 = (is_first_tick ? 0 : _ed_pack01)
    ed_slot0 ∈ Int
    ed_slot0 = (is_first_tick ? 0 : _ed_slot0)
    ed_slot1 ∈ Int
    ed_slot1 = (is_first_tick ? 0 : _ed_slot1)
    ed_slot2 ∈ Int
    ed_slot2 = (is_first_tick ? 0 : _ed_slot2)
    ed_step ∈ Int
    ed_step = (is_first_tick ? 0 : _ed_step)
    ed_vidx ∈ Int
    ed_vidx = (is_first_tick ? 0 : _ed_vidx)
    sym_buf ∈ FtiBuffer
    sym_buf.base = (is_first_tick ? 0 : _sym_buf.base)
    sym_buf.count = (is_first_tick ? 0 : _sym_buf.count)
    z_arena ∈ Int
    z_arena = (is_first_tick ? 0 : _z_arena)
    z_eff_arrsort ∈ Int
    z_eff_arrsort = (is_first_tick ? 0 : _z_eff_arrsort)
    z3sorts ∈ Z3Sorts
    z3sorts.isort = (is_first_tick ? 0 : _z3sorts.isort)
    z3sorts.bsort = (is_first_tick ? 0 : _z3sorts.bsort)
    z3sorts.ssort = (is_first_tick ? 0 : _z3sorts.ssort)
    z3sorts.rsort = (is_first_tick ? 0 : _z3sorts.rsort)
    z3ctx ∈ Z3SolverCtx
    z3ctx.cfg = (is_first_tick ? 0 : _z3ctx.cfg)
    z3ctx.ctx = (is_first_tick ? 0 : _z3ctx.ctx)
    z3ctx.sol = (is_first_tick ? 0 : _z3ctx.sol)
    z_effsort ∈ Int
    z_effsort = (is_first_tick ? 0 : _z_effsort)
    z_efflen_ge ∈ Int
    z_efflen_ge = (is_first_tick ? 0 : _z_efflen_ge)
    z_efflen ∈ Int
    z_efflen = (is_first_tick ? 0 : _z_efflen)
    z_first_tick ∈ Int
    z_first_tick = (is_first_tick ? 0 : _z_first_tick)
    z_lastres ∈ Int
    z_lastres = (is_first_tick ? 0 : _z_lastres)
    z_lastres_ge ∈ Int
    z_lastres_ge = (is_first_tick ? 0 : _z_lastres_ge)
    z_lastres_len ∈ Int
    z_lastres_len = (is_first_tick ? 0 : _z_lastres_len)
    z_lastres_sort ∈ Int
    z_lastres_sort = (is_first_tick ? 0 : _z_lastres_sort)
    z_ressort ∈ Int
    z_ressort = (is_first_tick ? 0 : _z_ressort)
    z_effects_sym ∈ Int
    z_effects_sym = (is_first_tick ? 0 : _z_effects_sym)
    z_efflen_sym ∈ Int
    z_efflen_sym = (is_first_tick ? 0 : _z_efflen_sym)
    z_first_tick_sym ∈ Int
    z_first_tick_sym = (is_first_tick ? 0 : _z_first_tick_sym)
    z_lastres_sym ∈ Int
    z_lastres_sym = (is_first_tick ? 0 : _z_lastres_sym)
    z_lastres_len_sym ∈ Int
    z_lastres_len_sym = (is_first_tick ? 0 : _z_lastres_len_sym)
    z3nums ∈ Z3Numerals
    z3nums.zero = (is_first_tick ? 0 : _z3nums.zero)
    z3nums.one = (is_first_tick ? 0 : _z3nums.one)
    z3nums.two = (is_first_tick ? 0 : _z3nums.two)
    z3nums.three = (is_first_tick ? 0 : _z3nums.three)
    z3nums.four = (is_first_tick ? 0 : _z3nums.four)
    ed_nullary ∈ Bool
    ed_nullary = (is_first_tick ? false : _ed_nullary)
    ed_res_harvest ∈ Bool
    ed_res_harvest = (is_first_tick ? false : _ed_res_harvest)
    ed_user ∈ Bool
    ed_user = (is_first_tick ? false : _ed_user)
    ed_name ∈ String
    ed_name = (is_first_tick ? "" : _ed_name)
    d_op_geq ∈ Op = OpGeq
    ed_v ∈ EnumVariantDecl = EVNoVariant
    ..DriverBuildEff
    sel ∈ String = (enum_wbatch5 ? "1" : "0") ++ "/" ++ (enum_wbatch2 ? "1" : "0") ++ "/" ++ (enum_wbatch3u ? "1" : "0")
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(sel)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
