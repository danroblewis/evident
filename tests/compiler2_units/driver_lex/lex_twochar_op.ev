-- DriverLex isolation — boundary: the 2-char `++` operator (the §4
-- contract clause the per-char scanner can't see in one step).
--
-- input "x ++ y" must lex as Ident, PlusPlus, Ident — three tokens — and
-- the `++` peek must advance the scan cursor by 2 (lx_pp ⇒ next_pos =
-- pos + 2). If the 2-char detection regressed (counted `+` `+` as two
-- ops, or failed to advance 2) the token count would not be 3.
--
-- entry: main
-- expect: stdout = "3"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler2/lex_fti.ev"
import "compiler2/driver_lex.ev"

fsm main
    zstep   ∈ Int
    zstep   = (is_first_tick ? 38 : _zstep)
    got_path ∈ Bool
    got_path = (is_first_tick ? true : _got_path)
    input   ∈ String
    input   = (is_first_tick ? "x ++ y" : _input)
    tbase     ∈ Int
    tbase     = (is_first_tick ? 0 : _tbase)
    d_cap_int ∈ Int
    d_cap_int = (is_first_tick ? 0 : _d_cap_int)
    ..DriverLex
    cnt_msg ∈ String = str_from_int(lx_count)
    effects ∈ Seq(Effect) = (lex_done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(cnt_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
