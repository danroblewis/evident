-- DriverLex isolation — happy path: lex two idents from "ab cd"; the
-- scan must produce exactly two Ident tokens (tbuf.count = 2 at
-- lex_done). The token-buffer writes (w_*) are NOT scheduled into
-- effects, so no __mem/Z3 arena is needed — we read the cursor directly.
-- entry: main
-- expect: stdout = "2"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler2/lex_fti.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_lex.ev"

fsm main
    -- _zstep/_got_path are DriverLex's start gate — carries it does not
    -- own, so main owns them and holds them past the gate all run.
    zstep   ∈ Int
    zstep   = (is_first_tick ? 38 : _zstep)
    got_path ∈ Bool
    got_path = (is_first_tick ? true : _got_path)
    -- input/tbase/d_cap_int are read by DriverLex as plain values; hold
    -- them as live carries so they stay present in every tick's model
    -- (a pinned `= const` gets simplified out and the kernel's state
    -- carry then can't find the field).
    input   ∈ String
    input   = (is_first_tick ? "ab cd" : _input)
    tbuf      ∈ FtiBuffer
    tbuf.base = (is_first_tick ? 0 : _tbuf.base)
    d_cap_int ∈ Int
    d_cap_int = (is_first_tick ? 0 : _d_cap_int)
    ..DriverLex
    cnt_msg ∈ String = str_from_int(tbuf.count)
    effects ∈ Seq(Effect) = (lex_done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(cnt_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
