-- FtiBuffer memory-safety invariant `count ≤ cap`: a cursor past capacity
-- (3000 into a 2048-slot buffer) is an overrun — UNSAT (exit 2), the
-- kernel halts instead of writing out of region.
--
-- entry: main
-- expect: exit = 2
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    buf ∈ FtiBuffer
    buf.base = 100
    buf.count = 3000
    buf.cap = 2048
    effects ∈ Seq(Effect) = ⟨Exit(7)⟩
