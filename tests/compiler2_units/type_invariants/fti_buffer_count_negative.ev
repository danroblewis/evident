-- FtiBuffer invariant: `count ≥ 0`. A negative write cursor is a
-- contract violation, so the tick is UNSAT (exit 2) — the kernel halts
-- instead of computing an out-of-region address. If the invariant were
-- missing, the pinned Exit(7) would run and the test would see exit 7.
--
-- entry: main
-- expect: exit = 2
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    buf ∈ FtiBuffer
    buf.base = 100
    buf.count = -1
    buf.cap = 2048
    effects ∈ Seq(Effect) = ⟨Exit(7)⟩
