-- Z3Sorts invariant: `rsort > 0 ⇒ (isort > 0 ∧ bsort > 0 ∧ ssort > 0)`.
-- rsort latches last, so a live rsort with a null isort is impossible →
-- UNSAT (exit 2).
--
-- entry: main
-- expect: exit = 2
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    s ∈ Z3Sorts
    s.isort = 0
    s.bsort = 6
    s.ssort = 7
    s.rsort = 8
    effects ∈ Seq(Effect) = ⟨Exit(7)⟩
