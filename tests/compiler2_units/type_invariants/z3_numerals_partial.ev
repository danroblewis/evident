-- Z3Numerals invariant: `four > 0 ⇒ (zero > 0 ∧ one > 0 ∧ two > 0 ∧ three > 0)`.
-- `four` is minted last, so a live `four` with a null `zero` is
-- impossible → UNSAT (exit 2).
--
-- entry: main
-- expect: exit = 2
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    n ∈ Z3Numerals
    n.zero = 0
    n.one = 11
    n.two = 12
    n.three = 13
    n.four = 14
    effects ∈ Seq(Effect) = ⟨Exit(7)⟩
