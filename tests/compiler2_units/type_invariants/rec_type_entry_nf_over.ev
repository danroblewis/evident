-- The registry's structural bound `0 ≤ n_fields ≤ 6`, restated as an
-- element-∀ over recs exactly as DriverRecord states it (the bounded-Seq
-- lowering never instantiates RecTypeEntry's body over the flattened
-- entries — gap noted in driver_ir.ev, 2026-06-10). An entry claiming 7
-- fields is unrepresentable, so the tick is UNSAT (exit 2). Every field
-- gets a covering assignment (the carried-record guardrail).
--
-- entry: main
-- expect: exit = 2
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ e ∈ recs : 0 ≤ e.n_fields ≤ 6
    ∀ e ∈ recs : e.name = ""
    ∀ e ∈ recs : e.fnames = ""
    ∀ e ∈ recs : e.ftypes = ""
    ∀ k ∈ {0..2} : recs[k].n_fields = (k = 0 ? 7 : 0)
    ∀ e ∈ recs : e.sort = 0
    ∀ e ∈ recs : e.ctor = 0
    ∀ e ∈ recs : e.asort = 0
    ∀ e ∈ recs : e.ssort = 0
    ∀ e ∈ recs : e.accs[0] = 0
    ∀ e ∈ recs : e.accs[1] = 0
    ∀ e ∈ recs : e.accs[2] = 0
    ∀ e ∈ recs : e.accs[3] = 0
    ∀ e ∈ recs : e.accs[4] = 0
    ∀ e ∈ recs : e.accs[5] = 0
    effects ∈ Seq(Effect) = ⟨Exit(7)⟩
