-- RecTypeEntry invariant: `0 ≤ n_fields ≤ 6` — the registry's hard structural
-- bound (acc0..acc5 are the ≤6 field-accessor decls). A slot claiming 7
-- fields cannot be represented, so the tick is UNSAT (exit 2). Every
-- field gets a covering assignment (the carried-record guardrail).
--
-- entry: main
-- expect: exit = 2
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"

fsm main
    e ∈ RecTypeEntry
    e.name = ""
    e.fnames = ""
    e.ftypes = ""
    e.n_fields = 7
    e.sort = 0
    e.ctor = 0
    e.asort = 0
    e.ssort = 0
    e.acc0 = 0
    e.acc1 = 0
    e.acc2 = 0
    e.acc3 = 0
    e.acc4 = 0
    e.acc5 = 0
    effects ∈ Seq(Effect) = ⟨Exit(7)⟩
