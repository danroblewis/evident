-- DriverSetVar isolation — Set(T) registry append + name capture.
-- setmem_decl_line held under classify_now (not at line end) so enter_setdecl
-- fires and the ≤2-entry Set registry appends: setvar_count climbs 0→1→2
-- (capped), set_vars[0].name captures line_dname = "myset". Exit at setvar_count = 2.
--
-- entry: main
-- expect: stdout = "myset"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_setvar.ev"

fsm main
    classify_now ∈ Bool
    classify_now = (is_first_tick ? true : _classify_now)
    setmem_decl_line ∈ Bool
    setmem_decl_line = (is_first_tick ? true : _setmem_decl_line)
    line_end ∈ Bool
    line_end = (is_first_tick ? false : _line_end)
    line_dname ∈ String
    line_dname = (is_first_tick ? "myset" : _line_dname)
    effects_line ∈ Bool
    effects_line = (is_first_tick ? false : _effects_line)
    line_is_mem ∈ Bool
    line_is_mem = (is_first_tick ? false : _line_is_mem)
    line_is_notmem ∈ Bool
    line_is_notmem = (is_first_tick ? false : _line_is_notmem)
    line_name ∈ String
    line_name = (is_first_tick ? "" : _line_name)
    q_is_exists ∈ Bool
    q_is_exists = (is_first_tick ? false : _q_is_exists)
    q_seq_plain ∈ Bool
    q_seq_plain = (is_first_tick ? false : _q_seq_plain)
    q_t3_name ∈ String
    q_t3_name = (is_first_tick ? "" : _q_t3_name)
    q_var ∈ String
    q_var = (is_first_tick ? "" : _q_var)
    intset_line ∈ Bool
    intset_line = (is_first_tick ? false : _intset_line)
    seq_elt_slot ∈ Int
    seq_elt_slot = (is_first_tick ? 0 : _seq_elt_slot)
    line_t0_ident ∈ Bool
    line_t0_ident = (is_first_tick ? false : _line_t0_ident)
    line_t1 ∈ Token
    line_t1 = (is_first_tick ? EofTok : _line_t1)
    line_t2 ∈ Token
    line_t2 = (is_first_tick ? EofTok : _line_t2)
    line_ty_name ∈ String
    line_ty_name = (is_first_tick ? "" : _line_ty_name)
    enter_seqlit ∈ Bool
    enter_seqlit = (is_first_tick ? false : _enter_seqlit)
    in_skip ∈ Bool
    in_skip = (is_first_tick ? false : _in_skip)
    work_nil ∈ Bool
    work_nil = (is_first_tick ? false : _work_nil)
    scope_prefix ∈ String
    scope_prefix = (is_first_tick ? "" : _scope_prefix)
    in_parse ∈ Bool
    in_parse = (is_first_tick ? false : _in_parse)
    name ∈ String
    name = (is_first_tick ? "" : _name)
    pratt_done ∈ Bool
    pratt_done = (is_first_tick ? false : _pratt_done)
    pratt_kind ∈ Int
    pratt_kind = (is_first_tick ? 0 : _pratt_kind)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    pratt_bad ∈ Bool
    pratt_bad = (is_first_tick ? false : _pratt_bad)
    pratt_result ∈ Expr
    pratt_result = (is_first_tick ? EInt(0) : _pratt_result)
    rec_pad31 ∈ String
    rec_pad31 = (is_first_tick ? "" : _rec_pad31)
    seqvar_name ∈ String
    seqvar_name = (is_first_tick ? "" : _seqvar_name)
    seqvar_slot ∈ Int
    seqvar_slot = (is_first_tick ? 0 : _seqvar_slot)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? false : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    tok5 ∈ Token
    tok5 = (is_first_tick ? EofTok : _tok5)
    tok6 ∈ Token
    tok6 = (is_first_tick ? EofTok : _tok6)
    tok7 ∈ Token
    tok7 = (is_first_tick ? EofTok : _tok7)
    ..DriverSetVar
    done ∈ Bool = (setvar_count = 2)
    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(set_vars[0].name)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
