-- DriverSetVar isolation — Set(T) registry append + name capture.
-- decl_line held under classify_now (not at line end) so is_setdecl
-- fires and the ≤2-entry Set registry appends: set_registry_count climbs 0→1→2
-- (capped), vars[0].name captures line_dname = "myset". Exit at set_registry_count = 2.
--
-- entry: main
-- expect: stdout = "myset"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_setvar.ev"

fsm main
    classify_now ∈ Bool
    classify_now = (is_first_tick ? true : _classify_now)
    decl_line ∈ Bool
    decl_line = (is_first_tick ? true : _decl_line)
    line ∈ ClassifiedLine
    line.at_eof = false
    line.name = ""
    line.ty_name = ""
    line.is_nat = false
    line.enum_key = ""
    line.enum_pos = 0
    line.sort = 0
    line.end = false
    line.dname = "myset"
    line.items = C2INil
    effects_line ∈ Bool
    effects_line = (is_first_tick ? false : _effects_line)
    is_mem ∈ Bool
    is_mem = (is_first_tick ? false : _is_mem)
    is_notmem ∈ Bool
    is_notmem = (is_first_tick ? false : _is_notmem)
    is_exists ∈ Bool
    is_exists = (is_first_tick ? false : _is_exists)
    is_plain_ident ∈ Bool
    is_plain_ident = (is_first_tick ? false : _is_plain_ident)
    t3_name ∈ String
    t3_name = (is_first_tick ? "" : _t3_name)
    loop_variable ∈ String
    loop_variable = (is_first_tick ? "" : _loop_variable)
    intset_line ∈ Bool
    intset_line = (is_first_tick ? false : _intset_line)
    kind_slot ∈ Int
    kind_slot = (is_first_tick ? 0 : _kind_slot)
    is_ident_head ∈ Bool
    is_ident_head = (is_first_tick ? false : _is_ident_head)
    tok1 ∈ Token
    tok1 = (is_first_tick ? EofTok : _tok1)
    tok2 ∈ Token
    tok2 = (is_first_tick ? EofTok : _tok2)
    enter_seqlit ∈ Bool
    enter_seqlit = (is_first_tick ? false : _enter_seqlit)
    in_skip ∈ Bool
    in_skip = (is_first_tick ? false : _in_skip)
    nil ∈ Bool
    nil = (is_first_tick ? false : _nil)
    scope_prefix ∈ String
    scope_prefix = (is_first_tick ? "" : _scope_prefix)
    parse ∈ Bool
    parse = (is_first_tick ? false : _parse)
    name ∈ String
    name = (is_first_tick ? "" : _name)
    parser ∈ ParseState
    parser.kind = (is_first_tick ? 0 : _parser.kind)
    parser.ready = (is_first_tick ? false : _parser.ready)
    parser.bad = (is_first_tick ? false : _parser.bad)
    parser.consume = (is_first_tick ? 0 : _parser.consume)
    parser.pd = (is_first_tick ? 0 : _parser.pd)
    parser.qd = (is_first_tick ? 0 : _parser.qd)
    parser.cd = (is_first_tick ? 0 : _parser.cd)
    parser.expop = (is_first_tick ? false : _parser.expop)
    parser.sort = (is_first_tick ? 0 : _parser.sort)
    parser.rec_slot = (is_first_tick ? 0 : _parser.rec_slot)
    parser.decl_name = (is_first_tick ? "" : _parser.decl_name)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    result ∈ Expr
    result = (is_first_tick ? EInt(0) : _result)
    rec_pad31 ∈ String
    rec_pad31 = (is_first_tick ? "" : _rec_pad31)
    registered_seq_name ∈ String
    registered_seq_name = (is_first_tick ? "" : _registered_seq_name)
    registered_seq_kind ∈ Int
    registered_seq_kind = (is_first_tick ? 0 : _registered_seq_kind)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? false : _can_consume)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    tok5 ∈ Token
    tok5 = (is_first_tick ? EofTok : _tok5)
    tok6 ∈ Token
    tok6 = (is_first_tick ? EofTok : _tok6)
    tok7 ∈ Token
    tok7 = (is_first_tick ? EofTok : _tok7)
    ..DriverSetVar
    done ∈ Bool = (set_registry_count = 2)
    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(vars[0].name)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
