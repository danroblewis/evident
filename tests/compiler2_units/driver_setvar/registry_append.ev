-- DriverSetVar isolation — Set(T) registry append + name capture.
-- decl_line held under classify_now (not at line end) so setdecl
-- fires and the ≤2-entry Set registry appends: collection_count climbs 0→1→2
-- (capped), vars[0].name captures line_dname = "myset". Exit at collection_count = 2.
--
-- entry: main
-- expect: stdout = "myset"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_setvar.ev"

fsm main
    classify_now ∈ Bool
    classify_now = (is_first_tick ? true : _classify_now)
    decl_line ∈ Bool
    decl_line = (is_first_tick ? true : _decl_line)
    line_end ∈ Bool
    line_end = (is_first_tick ? false : _line_end)
    line_dname ∈ String
    line_dname = (is_first_tick ? "myset" : _line_dname)
    effects_line ∈ Bool
    effects_line = (is_first_tick ? false : _effects_line)
    is_mem ∈ Bool
    is_mem = (is_first_tick ? false : _is_mem)
    is_notmem ∈ Bool
    is_notmem = (is_first_tick ? false : _is_notmem)
    line_name ∈ String
    line_name = (is_first_tick ? "" : _line_name)
    is_exists ∈ Bool
    is_exists = (is_first_tick ? false : _is_exists)
    seq_plain ∈ Bool
    seq_plain = (is_first_tick ? false : _seq_plain)
    t3_name ∈ String
    t3_name = (is_first_tick ? "" : _t3_name)
    q_var ∈ String
    q_var = (is_first_tick ? "" : _q_var)
    intset_line ∈ Bool
    intset_line = (is_first_tick ? false : _intset_line)
    kind_slot ∈ Int
    kind_slot = (is_first_tick ? 0 : _kind_slot)
    t0_ident ∈ Bool
    t0_ident = (is_first_tick ? false : _t0_ident)
    line_t1 ∈ Token
    line_t1 = (is_first_tick ? EofTok : _line_t1)
    line_t2 ∈ Token
    line_t2 = (is_first_tick ? EofTok : _line_t2)
    line_ty_name ∈ String
    line_ty_name = (is_first_tick ? "" : _line_ty_name)
    enter_seqlit ∈ Bool
    enter_seqlit = (is_first_tick ? false : _enter_seqlit)
    in_skip ∈ Bool
    in_skip = (is_first_tick ? false : _in_skip)
    nil ∈ Bool
    nil = (is_first_tick ? false : _nil)
    scope_prefix ∈ String
    scope_prefix = (is_first_tick ? "" : _scope_prefix)
    parse ∈ Bool
    parse = (is_first_tick ? false : _parse)
    name ∈ String
    name = (is_first_tick ? "" : _name)
    parse_ready ∈ Bool
    parse_ready = (is_first_tick ? false : _parse_ready)
    parse_kind ∈ Int
    parse_kind = (is_first_tick ? 0 : _parse_kind)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    parse_bad ∈ Bool
    parse_bad = (is_first_tick ? false : _parse_bad)
    result ∈ Expr
    result = (is_first_tick ? EInt(0) : _result)
    rec_pad31 ∈ String
    rec_pad31 = (is_first_tick ? "" : _rec_pad31)
    seqvar_name ∈ String
    seqvar_name = (is_first_tick ? "" : _seqvar_name)
    seqvar_slot ∈ Int
    seqvar_slot = (is_first_tick ? 0 : _seqvar_slot)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? false : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? EofTok : _tok0)
    tok5 ∈ Token
    tok5 = (is_first_tick ? EofTok : _tok5)
    tok6 ∈ Token
    tok6 = (is_first_tick ? EofTok : _tok6)
    tok7 ∈ Token
    tok7 = (is_first_tick ? EofTok : _tok7)
    ..DriverSetVar
    done ∈ Bool = (collection_count = 2)
    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(vars[0].name)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
