-- DriverZInit isolation — zstep climbs −2,−1,0,1,… one per tick with the
-- ED hold released (decl_action 0, source 4 ⇒ enum_hold false). z3sorts.isort
-- must latch is_intresult_capture (42) at EXACTLY zstep = 5 and hold; zstep ≥ 6
-- drives the exit. A skipped step or wrong-step latch ⇒ isort stays 0.
--
-- entry: main
-- expect: stdout = "42"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_zinit.ev"

fsm main
    decl_action ∈ Int
    decl_action = (is_first_tick ? 0 : _decl_action)
    source ∈ Int
    source = (is_first_tick ? 4 : _source)
    is_intresult_capture ∈ Int
    is_intresult_capture = (is_first_tick ? 42 : _is_intresult_capture)
    ..DriverZInit
    -- Cursors normally driven by DriverLex/DriverClaimIdx (absent here);
    -- stub them so the carried record fields have a covering assignment.
    tok_buf.count = (is_first_tick ? 0 : _tok_buf.count)
    symtab_buffer.count = (is_first_tick ? 0 : _symtab_buffer.count)
    claimindex_buf.count = (is_first_tick ? 0 : _claimindex_buf.count)
    isort_msg ∈ String = str_from_int(z3sorts.isort)
    effects ∈ Seq(Effect) = (zstep ≥ 6
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(isort_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
