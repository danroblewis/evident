-- DriverMatchPin isolation — scrutinee recognition + capture: a pmode-6
-- match line whose scrutinee is the plain ident `e` (tok0 = Ident,
-- el_head_name "e"). From state 0 the walk must recognize mp_s_id,
-- advance mp_st 0→1, and capture mp_scrut = "e"; reported once mp_st = 1.
-- entry: main
-- expect: stdout = "e"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_matchpin.ev"

fsm main
    in_parse ∈ Bool
    in_parse = (is_first_tick ? true : _in_parse)
    pmode ∈ Int
    pmode = (is_first_tick ? 6 : _pmode)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? true : _tok_ready)
    tok0 ∈ Token
    tok0 = (is_first_tick ? Ident("e") : _tok0)
    el_head_name ∈ String
    el_head_name = (is_first_tick ? "e" : _el_head_name)
    c_dname ∈ String
    c_dname = (is_first_tick ? "" : _c_dname)
    c_sc ∈ Int
    c_sc = (is_first_tick ? 0 : _c_sc)
    d_enter_match ∈ Bool
    d_enter_match = (is_first_tick ? false : _d_enter_match)
    p_done ∈ Bool
    p_done = (is_first_tick ? false : _p_done)
    pk_kind ∈ Int
    pk_kind = (is_first_tick ? 0 : _pk_kind)
    pr_bad ∈ Bool
    pr_bad = (is_first_tick ? false : _pr_bad)
    pr_sres ∈ Expr
    pr_sres = (is_first_tick ? EInt(0) : _pr_sres)
    uev ∈ Seq(UserEnumVariant)
    #uev ≤ 6
    uev = (is_first_tick ? ⟨⟩ : _uev)
    tok1 ∈ Token
    tok1 = (is_first_tick ? EofTok : _tok1)
    tok2 ∈ Token
    tok2 = (is_first_tick ? EofTok : _tok2)
    tok3 ∈ Token
    tok3 = (is_first_tick ? EofTok : _tok3)
    tok4 ∈ Token
    tok4 = (is_first_tick ? EofTok : _tok4)
    z_iracc ∈ Int
    z_iracc = (is_first_tick ? 0 : _z_iracc)
    z_irtest ∈ Int
    z_irtest = (is_first_tick ? 0 : _z_irtest)
    z_sracc ∈ Int
    z_sracc = (is_first_tick ? 0 : _z_sracc)
    z_srtest ∈ Int
    z_srtest = (is_first_tick ? 0 : _z_srtest)
    ..DriverMatchPin
    ready ∈ Bool = (mp_st = 1)
    effects ∈ Seq(Effect) = (ready
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(mp_scrut)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
