-- DriverMatchPin isolation — scrutinee recognition + capture.
--
-- Drives a pmode-6 match line whose scrutinee is the plain ident `e`
-- (in_parse, pmode 6, tok_ready held; ww_t0 = Ident, el_head_name "e").
-- From state 0 the walk must recognize mp_s_id, advance mp_st 0→1, and
-- capture mp_scrut = "e". We exit reporting mp_scrut once mp_st = 1. If
-- the scrutinee recognizer, the state advance, or the capture regresses,
-- the walk never reaches state 1 with scrut "e".
--
-- entry: main
-- expect: stdout = "e"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_matchpin.ev"

fsm main
    in_parse ∈ Bool
    in_parse = (is_first_tick ? true : _in_parse)
    pmode ∈ Int
    pmode = (is_first_tick ? 6 : _pmode)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? true : _tok_ready)
    ww_t0 ∈ Token
    ww_t0 = (is_first_tick ? Ident("e") : _ww_t0)
    el_head_name ∈ String
    el_head_name = (is_first_tick ? "e" : _el_head_name)
    c_dname ∈ String
    c_dname = (is_first_tick ? "" : _c_dname)
    c_sc ∈ Int
    c_sc = (is_first_tick ? 0 : _c_sc)
    d_enter_match ∈ Bool
    d_enter_match = (is_first_tick ? false : _d_enter_match)
    p_done ∈ Bool
    p_done = (is_first_tick ? false : _p_done)
    pk_kind ∈ Int
    pk_kind = (is_first_tick ? 0 : _pk_kind)
    pr_bad ∈ Bool
    pr_bad = (is_first_tick ? false : _pr_bad)
    pr_sres ∈ Expr
    pr_sres = (is_first_tick ? EInt(0) : _pr_sres)
    uev_a0 ∈ Int
    uev_a0 = (is_first_tick ? 0 : _uev_a0)
    uev_a1 ∈ Int
    uev_a1 = (is_first_tick ? 0 : _uev_a1)
    uev_a2 ∈ Int
    uev_a2 = (is_first_tick ? 0 : _uev_a2)
    uev_a3 ∈ Int
    uev_a3 = (is_first_tick ? 0 : _uev_a3)
    uev_a4 ∈ Int
    uev_a4 = (is_first_tick ? 0 : _uev_a4)
    uev_a5 ∈ Int
    uev_a5 = (is_first_tick ? 0 : _uev_a5)
    uev_n0 ∈ String
    uev_n0 = (is_first_tick ? "" : _uev_n0)
    uev_n1 ∈ String
    uev_n1 = (is_first_tick ? "" : _uev_n1)
    uev_n2 ∈ String
    uev_n2 = (is_first_tick ? "" : _uev_n2)
    uev_n3 ∈ String
    uev_n3 = (is_first_tick ? "" : _uev_n3)
    uev_n4 ∈ String
    uev_n4 = (is_first_tick ? "" : _uev_n4)
    uev_n5 ∈ String
    uev_n5 = (is_first_tick ? "" : _uev_n5)
    uev_t0 ∈ Int
    uev_t0 = (is_first_tick ? 0 : _uev_t0)
    uev_t1 ∈ Int
    uev_t1 = (is_first_tick ? 0 : _uev_t1)
    uev_t2 ∈ Int
    uev_t2 = (is_first_tick ? 0 : _uev_t2)
    uev_t3 ∈ Int
    uev_t3 = (is_first_tick ? 0 : _uev_t3)
    uev_t4 ∈ Int
    uev_t4 = (is_first_tick ? 0 : _uev_t4)
    uev_t5 ∈ Int
    uev_t5 = (is_first_tick ? 0 : _uev_t5)
    ww_t1 ∈ Token
    ww_t1 = (is_first_tick ? EofTok : _ww_t1)
    ww_t2 ∈ Token
    ww_t2 = (is_first_tick ? EofTok : _ww_t2)
    ww_t3 ∈ Token
    ww_t3 = (is_first_tick ? EofTok : _ww_t3)
    ww_t4 ∈ Token
    ww_t4 = (is_first_tick ? EofTok : _ww_t4)
    z_iracc ∈ Int
    z_iracc = (is_first_tick ? 0 : _z_iracc)
    z_irtest ∈ Int
    z_irtest = (is_first_tick ? 0 : _z_irtest)
    z_sracc ∈ Int
    z_sracc = (is_first_tick ? 0 : _z_sracc)
    z_srtest ∈ Int
    z_srtest = (is_first_tick ? 0 : _z_srtest)
    ..DriverMatchPin
    ready ∈ Bool = (mp_st = 1)
    effects ∈ Seq(Effect) = (ready
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(mp_scrut)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
