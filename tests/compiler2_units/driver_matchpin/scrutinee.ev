-- DriverMatchPin isolation — scrutinee recognition + capture: a parse_mode-6
-- match line whose scrutinee is the plain ident `e` (tok0 = Ident,
-- head_ident "e"). From state 0 the walk must recognize scrut_ident,
-- advance case_state 0→1, and capture scrutinee = "e"; reported once case_state = 1.
-- entry: main
-- expect: stdout = "e"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_matchpin.ev"

fsm main
    parse ∈ Bool
    parse = (is_first_tick ? true : _parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 6 : _parse_mode)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? true : _can_consume)
    tok0 ∈ Token
    tok0 = (is_first_tick ? Ident("e") : _tok0)
    head_ident ∈ String
    head_ident = (is_first_tick ? "e" : _head_ident)
    line_dname ∈ String
    line_dname = (is_first_tick ? "" : _line_dname)
    line_sort ∈ Int
    line_sort = (is_first_tick ? 0 : _line_sort)
    enter_match ∈ Bool
    enter_match = (is_first_tick ? false : _enter_match)
    parse_ready ∈ Bool
    parse_ready = (is_first_tick ? false : _parse_ready)
    parse_kind ∈ Int
    parse_kind = (is_first_tick ? 0 : _parse_kind)
    parse_bad ∈ Bool
    parse_bad = (is_first_tick ? false : _parse_bad)
    result ∈ Expr
    result = (is_first_tick ? EInt(0) : _result)
    user_variants ∈ Seq(UserEnumVariant)
    #user_variants ≤ 6
    user_variants = (is_first_tick ? ⟨⟩ : _user_variants)
    tok1 ∈ Token
    tok1 = (is_first_tick ? EofTok : _tok1)
    tok2 ∈ Token
    tok2 = (is_first_tick ? EofTok : _tok2)
    tok3 ∈ Token
    tok3 = (is_first_tick ? EofTok : _tok3)
    tok4 ∈ Token
    tok4 = (is_first_tick ? EofTok : _tok4)
    intresult_accessor ∈ Int
    intresult_accessor = (is_first_tick ? 0 : _intresult_accessor)
    intresult_tester ∈ Int
    intresult_tester = (is_first_tick ? 0 : _intresult_tester)
    strresult_accessor ∈ Int
    strresult_accessor = (is_first_tick ? 0 : _strresult_accessor)
    strresult_tester ∈ Int
    strresult_tester = (is_first_tick ? 0 : _strresult_tester)
    variant_names ∈ String
    variant_names = (is_first_tick ? "" : _variant_names)
    acctab_p ∈ Int = 0
    is_intresult_capture ∈ Int
    is_intresult_capture = (is_first_tick ? 0 : _is_intresult_capture)
    ..DriverMatchPin
    ready ∈ Bool = (case_state = 1)
    effects ∈ Seq(Effect) = (ready
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(scrutinee)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
