-- DriverClassify isolation — classify a pinned-membership line.
-- Window pinned to `x ∈ Int = 5` (Ident OpIn Ident Eq IntLit), empty
-- registries, depth-0 frame; tok0..tok7 pinned directly (no
-- DriverWindow). verdict = c_is_mem + 2*c_pinned + 4*d_enter_pratt0 = 7.
-- entry: main
-- expect: stdout = "7"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_expr.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_classify.ev"

fsm main
    tok0 ∈ Token
    tok0 = (is_first_tick ? Ident("x") : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? OpIn : _tok1)
    tok2 ∈ Token
    tok2 = (is_first_tick ? Ident("Int") : _tok2)
    tok3 ∈ Token
    tok3 = (is_first_tick ? Eq : _tok3)
    tok4 ∈ Token
    tok4 = (is_first_tick ? IntLit(5) : _tok4)
    tok5 ∈ Token
    tok5 = (is_first_tick ? EofTok : _tok5)
    tok6 ∈ Token
    tok6 = (is_first_tick ? EofTok : _tok6)
    tok7 ∈ Token
    tok7 = (is_first_tick ? EofTok : _tok7)
    classify_now ∈ Bool
    classify_now = (is_first_tick ? true : _classify_now)
    claimidx_names ∈ String
    claimidx_names = (is_first_tick ? "" : _claimidx_names)
    sym_names ∈ String
    sym_names = (is_first_tick ? "" : _sym_names)
    frame_depth ∈ Int
    frame_depth = (is_first_tick ? 0 : _frame_depth)
    scope_prefix ∈ String
    scope_prefix = (is_first_tick ? "" : _scope_prefix)
    bind_n0 ∈ String
    bind_n0 = (is_first_tick ? "" : _bind_n0)
    bind_n1 ∈ String
    bind_n1 = (is_first_tick ? "" : _bind_n1)
    bind_n2 ∈ String
    bind_n2 = (is_first_tick ? "" : _bind_n2)
    bind_n3 ∈ String
    bind_n3 = (is_first_tick ? "" : _bind_n3)
    bind_n4 ∈ String
    bind_n4 = (is_first_tick ? "" : _bind_n4)
    bind_n5 ∈ String
    bind_n5 = (is_first_tick ? "" : _bind_n5)
    rec0 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    rec1 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    rec2 ∈ RecTypeEntry(name ↦ "", fnames ↦ "", ftypes ↦ "", n_fields ↦ 0,
        sort ↦ 0, ctor ↦ 0, asort ↦ 0, ssort ↦ 0,
        acc0 ↦ 0, acc1 ↦ 0, acc2 ↦ 0, acc3 ↦ 0, acc4 ↦ 0, acc5 ↦ 0)
    -- user-enum + seq-var carries (no user enum, no registered seq).
    ue_done ∈ Bool
    ue_done = (is_first_tick ? false : _ue_done)
    ue_name ∈ String
    ue_name = (is_first_tick ? "" : _ue_name)
    sq_set ∈ Bool
    sq_set = (is_first_tick ? false : _sq_set)
    sq_name ∈ String
    sq_name = (is_first_tick ? "" : _sq_name)
    -- sibling sub-walk enter signals (none active in this isolation).
    efflit_exit_enter ∈ Bool
    efflit_exit_enter = (is_first_tick ? false : _efflit_exit_enter)
    efflit_guard_enter ∈ Bool
    efflit_guard_enter = (is_first_tick ? false : _efflit_guard_enter)
    mp_benter ∈ Bool
    mp_benter = (is_first_tick ? false : _mp_benter)
    sl_e_enter ∈ Bool
    sl_e_enter = (is_first_tick ? false : _sl_e_enter)
    callw_slot ∈ Bool
    callw_slot = (is_first_tick ? false : _callw_slot)
    q_close ∈ Bool
    q_close = (is_first_tick ? false : _q_close)
    d_enter_qs ∈ Bool
    d_enter_qs = (is_first_tick ? false : _d_enter_qs)
    pt_elem ∈ Bool
    pt_elem = (is_first_tick ? false : _pt_elem)
    -- other line-shape flags this block reads but does not define.
    c_q_line ∈ Bool
    c_q_line = (is_first_tick ? false : _c_q_line)
    c_q_rng ∈ Bool
    c_q_rng = (is_first_tick ? false : _c_q_rng)
    c_q_seq ∈ Bool
    c_q_seq = (is_first_tick ? false : _c_q_seq)
    c_setlit_line ∈ Bool
    c_setlit_line = (is_first_tick ? false : _c_setlit_line)
    pcl_line ∈ Bool
    pcl_line = (is_first_tick ? false : _pcl_line)
    d_enter_qset ∈ Bool
    d_enter_qset = (is_first_tick ? false : _d_enter_qset)
    c_q_s2 ∈ Bool
    c_q_s2 = (is_first_tick ? false : _c_q_s2)
    mp_take ∈ Bool
    mp_take = (is_first_tick ? false : _mp_take)
    mp_arm_pl_h ∈ Bool
    mp_arm_pl_h = (is_first_tick ? false : _mp_arm_pl_h)
    ..DriverClassify
    verdict ∈ Int = ((c_is_mem ? 1 : 0) + (c_pinned ? 2 : 0)
        + (d_enter_pratt0 ? 4 : 0))
    v_msg ∈ String = str_from_int(verdict)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(v_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
