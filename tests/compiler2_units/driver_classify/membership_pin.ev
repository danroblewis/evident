-- DriverClassify isolation — classify a pinned-membership line.
-- Window pinned to `x ∈ Int = 5` (Ident OpIn Ident Eq IntLit), empty
-- registries, depth-0 frame; tok0..tok7 pinned directly (no
-- DriverWindow). verdict = is_mem + 2*pinned + 4*pratt_line = 7.
-- entry: main
-- expect: stdout = "7"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_expr.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_classify.ev"

fsm main
    tok0 ∈ Token
    tok0 = (is_first_tick ? Ident("x") : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? OpIn : _tok1)
    tok2 ∈ Token
    tok2 = (is_first_tick ? Ident("Int") : _tok2)
    tok3 ∈ Token
    tok3 = (is_first_tick ? Eq : _tok3)
    tok4 ∈ Token
    tok4 = (is_first_tick ? IntLit(5) : _tok4)
    tok5 ∈ Token
    tok5 = (is_first_tick ? EofTok : _tok5)
    tok6 ∈ Token
    tok6 = (is_first_tick ? EofTok : _tok6)
    tok7 ∈ Token
    tok7 = (is_first_tick ? EofTok : _tok7)
    classify_now ∈ Bool
    classify_now = (is_first_tick ? true : _classify_now)
    claimindex_names ∈ String
    claimindex_names = (is_first_tick ? "" : _claimindex_names)
    symbol_index ∈ String
    symbol_index = (is_first_tick ? "" : _symbol_index)
    frame_depth ∈ Int
    frame_depth = (is_first_tick ? 0 : _frame_depth)
    scope_prefix ∈ String
    scope_prefix = (is_first_tick ? "" : _scope_prefix)
    binds ∈ Seq(Bind)
    #binds ≤ 12
    ∀ k ∈ {0..11} : binds[k].name = (is_first_tick ? "" : _binds[k].name)
    ∀ k ∈ {0..11} : binds[k].handle = (is_first_tick ? 0 : _binds[k].handle)
    bind_base ∈ Int
    bind_base = (is_first_tick ? 0 : _bind_base)
    bind_top ∈ Int
    bind_top = (is_first_tick ? 0 : _bind_top)
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ e ∈ recs : e.name = ""
    ∀ e ∈ recs : e.fnames = ""
    ∀ e ∈ recs : e.ftypes = ""
    ∀ e ∈ recs : e.n_fields = 0
    ∀ e ∈ recs : e.sort = 0
    ∀ e ∈ recs : e.ctor = 0
    ∀ e ∈ recs : e.asort = 0
    ∀ e ∈ recs : e.ssort = 0
    ∀ e ∈ recs : e.accs[0] = 0
    ∀ e ∈ recs : e.accs[1] = 0
    ∀ e ∈ recs : e.accs[2] = 0
    ∀ e ∈ recs : e.accs[3] = 0
    ∀ e ∈ recs : e.accs[4] = 0
    ∀ e ∈ recs : e.accs[5] = 0
    -- user-enum + seq-var carries (no user enum, no registered seq).
    decl_names ∈ String
    decl_names = (is_first_tick ? "" : _decl_names)
    is_seq_registered ∈ Bool
    is_seq_registered = (is_first_tick ? false : _is_seq_registered)
    registered_seq_name ∈ String
    registered_seq_name = (is_first_tick ? "" : _registered_seq_name)
    -- sibling sub-walk enter signals (none active in this isolation).
    exit_enter ∈ Bool
    exit_enter = (is_first_tick ? false : _exit_enter)
    is_guard_enter ∈ Bool
    is_guard_enter = (is_first_tick ? false : _is_guard_enter)
    body_enter ∈ Bool
    body_enter = (is_first_tick ? false : _body_enter)
    enter_seq_elem ∈ Bool
    enter_seq_elem = (is_first_tick ? false : _enter_seq_elem)
    call_arg_slot ∈ Bool
    call_arg_slot = (is_first_tick ? false : _call_arg_slot)
    pun ∈ Bool
    pun = (is_first_tick ? false : _pun)
    join_hdr ∈ String
    join_hdr = (is_first_tick ? "*" : _join_hdr)
    qrange_close ∈ Bool
    qrange_close = (is_first_tick ? false : _qrange_close)
    qseq ∈ Bool
    qseq = (is_first_tick ? false : _qseq)
    element ∈ Bool
    element = (is_first_tick ? false : _element)
    -- other line-shape flags this block reads but does not define.
    is_quant_line ∈ Bool
    is_quant_line = (is_first_tick ? false : _is_quant_line)
    quant_range_line ∈ Bool
    quant_range_line = (is_first_tick ? false : _quant_range_line)
    over_seq ∈ Bool
    over_seq = (is_first_tick ? false : _over_seq)
    is_setlit_line ∈ Bool
    is_setlit_line = (is_first_tick ? false : _is_setlit_line)
    positional_line ∈ Bool
    positional_line = (is_first_tick ? false : _positional_line)
    is_setquery ∈ Bool
    is_setquery = (is_first_tick ? false : _is_setquery)
    is_dotted_ident ∈ Bool
    is_dotted_ident = (is_first_tick ? false : _is_dotted_ident)
    arm_take ∈ Bool
    arm_take = (is_first_tick ? false : _arm_take)
    arm_payload_head ∈ Bool
    arm_payload_head = (is_first_tick ? false : _arm_payload_head)
    close_take ∈ Bool
    close_take = (is_first_tick ? false : _close_take)
    ..DriverClassify
    verdict ∈ Int = ((is_mem ? 1 : 0) + (pinned ? 2 : 0)
        + (pratt_line ? 4 : 0))
    v_msg ∈ String = str_from_int(verdict)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(v_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
