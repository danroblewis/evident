-- DriverPosBind isolation — tuple-element recognizer + atom parse.
-- parse_mode-12 positional walk, window = `( 5 , 7 )`. Must parse both atoms
-- (tuparg_ok0) and recognize the 5-token tuple bite (tuple_bite).
-- verdict = 1*tuple_bite + 2*tuparg_ok0 = 3.
--
-- entry: main
-- expect: stdout = "3"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_expr.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_posbind.ev"

fsm main
    in_parse ∈ Bool
    in_parse = (is_first_tick ? true : _in_parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 12 : _parse_mode)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? true : _tok_ready)
    work_nil ∈ Bool
    work_nil = (is_first_tick ? true : _work_nil)
    tok0 ∈ Token
    tok0 = (is_first_tick ? LParen : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? IntLit(5) : _tok1)
    tok2 ∈ Token
    tok2 = (is_first_tick ? Comma : _tok2)
    tok3 ∈ Token
    tok3 = (is_first_tick ? IntLit(7) : _tok3)
    tok4 ∈ Token
    tok4 = (is_first_tick ? RParen : _tok4)
    comp_found ∈ Bool
    comp_found = (is_first_tick ? false : _comp_found)
    dotdot_shape ∈ Bool
    dotdot_shape = (is_first_tick ? false : _dotdot_shape)
    line_name ∈ String
    line_name = (is_first_tick ? "" : _line_name)
    line_t0 ∈ Token
    line_t0 = (is_first_tick ? EofTok : _line_t0)
    line_t0_ident ∈ Bool
    line_t0_ident = (is_first_tick ? false : _line_t0_ident)
    line_t1 ∈ Token
    line_t1 = (is_first_tick ? EofTok : _line_t1)
    line_t2 ∈ Token
    line_t2 = (is_first_tick ? EofTok : _line_t2)
    line_t3 ∈ Token
    line_t3 = (is_first_tick ? EofTok : _line_t3)
    line_t4 ∈ Token
    line_t4 = (is_first_tick ? EofTok : _line_t4)
    claimidx_buf ∈ FtiBuffer
    claimidx_buf.base = (is_first_tick ? 0 : _claimidx_buf.base)
    claimidx_buf.count = (is_first_tick ? 0 : _claimidx_buf.count)
    claimidx_names ∈ String
    claimidx_names = (is_first_tick ? "" : _claimidx_names)
    callw_reset ∈ Bool
    callw_reset = (is_first_tick ? false : _callw_reset)
    classify_now ∈ Bool
    classify_now = (is_first_tick ? false : _classify_now)
    h_2nd ∈ Int
    h_2nd = (is_first_tick ? 0 : _h_2nd)
    h_3rd ∈ Int
    h_3rd = (is_first_tick ? 0 : _h_3rd)
    h_4th ∈ Int
    h_4th = (is_first_tick ? 0 : _h_4th)
    h_tail1 ∈ C2H
    h_tail1 = (is_first_tick ? C2HNil : _h_tail1)
    h_tail2 ∈ C2H
    h_tail2 = (is_first_tick ? C2HNil : _h_tail2)
    h_tail3 ∈ C2H
    h_tail3 = (is_first_tick ? C2HNil : _h_tail3)
    h_tail4 ∈ C2H
    h_tail4 = (is_first_tick ? C2HNil : _h_tail4)
    h_tail5 ∈ C2H
    h_tail5 = (is_first_tick ? C2HNil : _h_tail5)
    h_top ∈ Int
    h_top = (is_first_tick ? 0 : _h_top)
    stack_in ∈ C2H
    stack_in = (is_first_tick ? C2HNil : _stack_in)
    line_end ∈ Bool
    line_end = (is_first_tick ? false : _line_end)
    enum_values ∈ Seq(EnumVariantVal)
    #enum_values ≤ 6
    enum_values = (is_first_tick ? ⟨⟩ : _enum_values)
    guard_hit ∈ Bool
    guard_hit = (is_first_tick ? false : _guard_hit)
    guard_lhs ∈ Expr
    guard_lhs = (is_first_tick ? EInt(0) : _guard_lhs)
    guard_on ∈ Bool
    guard_on = (is_first_tick ? false : _guard_on)
    guard_depth ∈ Int
    guard_depth = (is_first_tick ? 0 : _guard_depth)
    callw_hide ∈ Bool
    callw_hide = (is_first_tick ? false : _callw_hide)
    callw_bare ∈ Bool
    callw_bare = (is_first_tick ? false : _callw_bare)
    callw_is_type ∈ Bool
    callw_is_type = (is_first_tick ? false : _callw_is_type)
    enum_names ∈ String
    enum_names = (is_first_tick ? "" : _enum_names)
    idx ∈ String
    idx = (is_first_tick ? "" : _idx)
    frame_depth ∈ Int
    frame_depth = (is_first_tick ? 0 : _frame_depth)
    frame_jump ∈ Bool
    frame_jump = (is_first_tick ? false : _frame_jump)
    param_depth ∈ Int
    param_depth = (is_first_tick ? 0 : _param_depth)
    scope_prefix ∈ String
    scope_prefix = (is_first_tick ? "" : _scope_prefix)
    binds ∈ Seq(Bind)
    #binds ≤ 12
    ∀ k ∈ {0..11} : binds[k].name = (is_first_tick ? "" : _binds[k].name)
    ∀ k ∈ {0..11} : binds[k].handle = (is_first_tick ? 0 : _binds[k].handle)
    bind_base ∈ Int
    bind_base = (is_first_tick ? 0 : _bind_base)
    bind_top ∈ Int
    bind_top = (is_first_tick ? 0 : _bind_top)
    pskip_done ∈ Bool
    pskip_done = (is_first_tick ? false : _pskip_done)
    pskip_off ∈ Bool
    pskip_off = (is_first_tick ? false : _pskip_off)
    pskip_open ∈ Bool
    pskip_open = (is_first_tick ? false : _pskip_open)
    pskip_run ∈ Bool
    pskip_run = (is_first_tick ? false : _pskip_run)
    match_items ∈ C2Items
    match_items = (is_first_tick ? C2INil : _match_items)
    wc_body_done ∈ Bool
    wc_body_done = (is_first_tick ? false : _wc_body_done)
    name ∈ String
    name = (is_first_tick ? "" : _name)
    pratt_done ∈ Bool
    pratt_done = (is_first_tick ? false : _pratt_done)
    pratt_kind ∈ Int
    pratt_kind = (is_first_tick ? 0 : _pratt_kind)
    pratt_decl_name ∈ String
    pratt_decl_name = (is_first_tick ? "" : _pratt_decl_name)
    pratt_nat ∈ Bool
    pratt_nat = (is_first_tick ? false : _pratt_nat)
    pratt_nodecl ∈ Bool
    pratt_nodecl = (is_first_tick ? false : _pratt_nodecl)
    pratt_pin_name ∈ String
    pratt_pin_name = (is_first_tick ? "" : _pratt_pin_name)
    pratt_rec_slot ∈ Int
    pratt_rec_slot = (is_first_tick ? 0 : _pratt_rec_slot)
    pratt_sort ∈ Int
    pratt_sort = (is_first_tick ? 0 : _pratt_sort)
    pratt_bad ∈ Bool
    pratt_bad = (is_first_tick ? false : _pratt_bad)
    pratt_result ∈ Expr
    pratt_result = (is_first_tick ? EInt(0) : _pratt_result)
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ e ∈ recs : e.name = ""
    ∀ e ∈ recs : e.fnames = ""
    ∀ e ∈ recs : e.ftypes = ""
    ∀ e ∈ recs : e.n_fields = 0
    ∀ e ∈ recs : e.sort = 0
    ∀ e ∈ recs : e.ctor = 0
    ∀ e ∈ recs : e.asort = 0
    ∀ e ∈ recs : e.ssort = 0
    ∀ e ∈ recs : e.accs[0] = 0
    ∀ e ∈ recs : e.accs[1] = 0
    ∀ e ∈ recs : e.accs[2] = 0
    ∀ e ∈ recs : e.accs[3] = 0
    ∀ e ∈ recs : e.accs[4] = 0
    ∀ e ∈ recs : e.accs[5] = 0
    seqlit_elem_items ∈ C2Items
    seqlit_elem_items = (is_first_tick ? C2INil : _seqlit_elem_items)
    sym_names ∈ String
    sym_names = (is_first_tick ? "" : _sym_names)
    tok5 ∈ Token
    tok5 = (is_first_tick ? EofTok : _tok5)
    z_exit_decl ∈ Int
    z_exit_decl = (is_first_tick ? 0 : _z_exit_decl)
    efflit_sel_eq ∈ C2Item
    efflit_sel_eq = (is_first_tick ? C2Drop : _efflit_sel_eq)
    ..DriverPosBind
    verdict ∈ Int = ((tuple_bite ? 1 : 0) + (tuparg_ok0 ? 2 : 0))
    v_msg ∈ String = str_from_int(verdict)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(v_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
