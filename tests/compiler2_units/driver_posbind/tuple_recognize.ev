-- DriverPosBind isolation — tuple-element recognizer + atom parse.
-- parse_mode-12 positional walk, window = `( 5 , 7 )`. Must parse both atoms
-- (ok0) and recognize the 5-token tuple bite (bite).
-- verdict = 1*bite + 2*ok0 = 3.
--
-- entry: main
-- expect: stdout = "3"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_expr.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_posbind.ev"

fsm main
    parse ∈ Bool
    parse = (is_first_tick ? true : _parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 12 : _parse_mode)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? true : _can_consume)
    nil ∈ Bool
    nil = (is_first_tick ? true : _nil)
    tok0 ∈ Token
    tok0 = (is_first_tick ? LParen : _tok0)
    tok1 ∈ Token
    tok1 = (is_first_tick ? IntLit(5) : _tok1)
    tok2 ∈ Token
    tok2 = (is_first_tick ? Comma : _tok2)
    tok3 ∈ Token
    tok3 = (is_first_tick ? IntLit(7) : _tok3)
    tok4 ∈ Token
    tok4 = (is_first_tick ? RParen : _tok4)
    is_comp_found ∈ Bool
    is_comp_found = (is_first_tick ? false : _is_comp_found)
    is_lift_shape ∈ Bool
    is_lift_shape = (is_first_tick ? false : _is_lift_shape)
    line ∈ ClassifiedLine
    line.at_eof = false
    line.name = ""
    line.ty_name = ""
    line.is_nat = false
    line.enum_key = ""
    line.enum_pos = 0
    line.sort = 0
    line.end = false
    line.dname = ""
    line.items = C2INil
    is_ident_head ∈ Bool
    is_ident_head = (is_first_tick ? false : _is_ident_head)
    claimindex_buf ∈ FtiBuffer
    claimindex_buf.base = (is_first_tick ? 0 : _claimindex_buf.base)
    claimindex_buf.count = (is_first_tick ? 0 : _claimindex_buf.count)
    claimindex_names ∈ String
    claimindex_names = (is_first_tick ? "" : _claimindex_names)
    reset ∈ Bool
    reset = (is_first_tick ? false : _reset)
    classify_now ∈ Bool
    classify_now = (is_first_tick ? false : _classify_now)
    second_handle ∈ Int
    second_handle = (is_first_tick ? 0 : _second_handle)
    third_handle ∈ Int
    third_handle = (is_first_tick ? 0 : _third_handle)
    fourth_handle ∈ Int
    fourth_handle = (is_first_tick ? 0 : _fourth_handle)
    tail1 ∈ C2H
    tail1 = (is_first_tick ? C2HNil : _tail1)
    tail2 ∈ C2H
    tail2 = (is_first_tick ? C2HNil : _tail2)
    tail3 ∈ C2H
    tail3 = (is_first_tick ? C2HNil : _tail3)
    tail4 ∈ C2H
    tail4 = (is_first_tick ? C2HNil : _tail4)
    tail5 ∈ C2H
    tail5 = (is_first_tick ? C2HNil : _tail5)
    topmost_handle ∈ Int
    topmost_handle = (is_first_tick ? 0 : _topmost_handle)
    stack_in ∈ C2H
    stack_in = (is_first_tick ? C2HNil : _stack_in)
    values ∈ Seq(EnumVariantVal)
    #values ≤ 6
    values = (is_first_tick ? ⟨⟩ : _values)
    cond_hit ∈ Bool
    cond_hit = (is_first_tick ? false : _cond_hit)
    cond_lhs ∈ Expr
    cond_lhs = (is_first_tick ? EInt(0) : _cond_lhs)
    guarding ∈ Bool
    guarding = (is_first_tick ? false : _guarding)
    armed_depth ∈ Int
    armed_depth = (is_first_tick ? 0 : _armed_depth)
    hide ∈ Bool
    hide = (is_first_tick ? false : _hide)
    is_bare_call ∈ Bool
    is_bare_call = (is_first_tick ? false : _is_bare_call)
    is_type ∈ Bool
    is_type = (is_first_tick ? false : _is_type)
    decl_names ∈ String
    decl_names = (is_first_tick ? "" : _decl_names)
    idx ∈ String
    idx = (is_first_tick ? "" : _idx)
    frame_depth ∈ Int
    frame_depth = (is_first_tick ? 0 : _frame_depth)
    jump ∈ Bool
    jump = (is_first_tick ? false : _jump)
    param_depth ∈ Int
    param_depth = (is_first_tick ? 0 : _param_depth)
    scope_prefix ∈ String
    scope_prefix = (is_first_tick ? "" : _scope_prefix)
    binds ∈ Seq(Bind)
    #binds ≤ 12
    ∀ k ∈ {0..11} : binds[k].name = (is_first_tick ? "" : _binds[k].name)
    ∀ k ∈ {0..11} : binds[k].handle = (is_first_tick ? 0 : _binds[k].handle)
    bind_base ∈ Int
    bind_base = (is_first_tick ? 0 : _bind_base)
    bind_top ∈ Int
    bind_top = (is_first_tick ? 0 : _bind_top)
    pskip_done ∈ Bool
    pskip_done = (is_first_tick ? false : _pskip_done)
    off ∈ Bool
    off = (is_first_tick ? false : _off)
    pskip_open ∈ Bool
    pskip_open = (is_first_tick ? false : _pskip_open)
    run ∈ Bool
    run = (is_first_tick ? false : _run)
    case_items ∈ C2Items
    case_items = (is_first_tick ? C2INil : _case_items)
    wildcard_body_done ∈ Bool
    wildcard_body_done = (is_first_tick ? false : _wildcard_body_done)
    name ∈ String
    name = (is_first_tick ? "" : _name)
    parse_ready ∈ Bool
    parse_ready = (is_first_tick ? false : _parse_ready)
    parse_kind ∈ Int
    parse_kind = (is_first_tick ? 0 : _parse_kind)
    parse_decl_name ∈ String
    parse_decl_name = (is_first_tick ? "" : _parse_decl_name)
    is_nat_type ∈ Bool
    is_nat_type = (is_first_tick ? false : _is_nat_type)
    nodecl ∈ Bool
    nodecl = (is_first_tick ? false : _nodecl)
    membership_record_name ∈ String
    membership_record_name = (is_first_tick ? "" : _membership_record_name)
    parse_rec_slot ∈ Int
    parse_rec_slot = (is_first_tick ? 0 : _parse_rec_slot)
    parse_sort ∈ Int
    parse_sort = (is_first_tick ? 0 : _parse_sort)
    parse_bad ∈ Bool
    parse_bad = (is_first_tick ? false : _parse_bad)
    result ∈ Expr
    result = (is_first_tick ? EInt(0) : _result)
    recs ∈ Seq(RecTypeEntry)
    #recs ≤ 3
    ∀ e ∈ recs : e.name = ""
    ∀ e ∈ recs : e.fnames = ""
    ∀ e ∈ recs : e.ftypes = ""
    ∀ e ∈ recs : e.n_fields = 0
    ∀ e ∈ recs : e.sort = 0
    ∀ e ∈ recs : e.ctor = 0
    ∀ e ∈ recs : e.asort = 0
    ∀ e ∈ recs : e.ssort = 0
    ∀ e ∈ recs : e.accs[0] = 0
    ∀ e ∈ recs : e.accs[1] = 0
    ∀ e ∈ recs : e.accs[2] = 0
    ∀ e ∈ recs : e.accs[3] = 0
    ∀ e ∈ recs : e.accs[4] = 0
    ∀ e ∈ recs : e.accs[5] = 0
    append_elem_items ∈ C2Items
    append_elem_items = (is_first_tick ? C2INil : _append_elem_items)
    symbol_index ∈ String
    symbol_index = (is_first_tick ? "" : _symbol_index)
    tok5 ∈ Token
    tok5 = (is_first_tick ? EofTok : _tok5)
    exit_decl ∈ Int
    exit_decl = (is_first_tick ? 0 : _exit_decl)
    equality_test ∈ C2Item
    equality_test = (is_first_tick ? C2Drop : _equality_test)
    ..DriverPosBind
    verdict ∈ Int = ((bite ? 1 : 0) + (ok0 ? 2 : 0))
    v_msg ∈ String = str_from_int(verdict)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(v_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
