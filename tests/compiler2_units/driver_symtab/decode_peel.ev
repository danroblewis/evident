-- DriverSymtab isolation — handle-stack peel + work-item discriminator.
-- Handle stack pinned to ⟨99, 7⟩, work items to one C2DeclConst("x", 0).
-- Must peel topmost_handle = 99, second_handle = 7 and decode is_decl_item = true.
-- verdict = 1*(top=99) + 2*(2nd=7) + 4*is_decl_item = 7.
--
-- entry: main
-- expect: stdout = "7"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_symtab.ev"

fsm main
    stack_in ∈ C2H
    stack_in = (is_first_tick ? C2HCons(99, C2HCons(7, C2HNil)) : _stack_in)
    work_items ∈ C2Items
    work_items = (is_first_tick ? C2ICons(C2DeclConst("x", 0), C2INil) : _work_items)
    in_claim ∈ Bool
    in_claim = (is_first_tick ? false : _in_claim)
    lookup_read ∈ Bool
    lookup_read = (is_first_tick ? false : _lookup_read)
    lookup_name ∈ String
    lookup_name = (is_first_tick ? "" : _lookup_name)
    qloop_on ∈ Bool
    qloop_on = (is_first_tick ? false : _qloop_on)
    param_skip ∈ Int
    param_skip = (is_first_tick ? 0 : _param_skip)
    parse ∈ Bool
    parse = (is_first_tick ? false : _parse)
    item_step ∈ Int
    item_step = (is_first_tick ? 0 : _item_step)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 0 : _parse_mode)
    pinning ∈ Bool
    pinning = (is_first_tick ? false : _pinning)
    can_consume ∈ Bool
    can_consume = (is_first_tick ? false : _can_consume)
    symtab_buffer ∈ FtiBuffer
    symtab_buffer.base = (is_first_tick ? 0 : _symtab_buffer.base)
    ..DriverSymtab
    verdict ∈ Int = ((topmost_handle = 99 ? 1 : 0) + (second_handle = 7 ? 2 : 0)
        + (is_decl_item ? 4 : 0))
    v_msg ∈ String = str_from_int(verdict)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(v_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
