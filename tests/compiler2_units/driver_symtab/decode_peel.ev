-- DriverSymtab isolation — handle-stack peel + work-item discriminator.
-- Handle stack pinned to ⟨99, 7⟩, work items to one C2DeclConst("x", 0).
-- Must peel h_top = 99, h_2nd = 7 and decode it_decl = true.
-- verdict = 1*(top=99) + 2*(2nd=7) + 4*it_decl = 7.
--
-- entry: main
-- expect: stdout = "7"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_symtab.ev"

fsm main
    d_hstk_in ∈ C2H
    d_hstk_in = (is_first_tick ? C2HCons(99, C2HCons(7, C2HNil)) : _d_hstk_in)
    witems ∈ C2Items
    witems = (is_first_tick ? C2ICons(C2DeclConst("x", 0), C2INil) : _witems)
    d_in_claim ∈ Bool
    d_in_claim = (is_first_tick ? false : _d_in_claim)
    d_lk_read ∈ Bool
    d_lk_read = (is_first_tick ? false : _d_lk_read)
    lookup_name ∈ String
    lookup_name = (is_first_tick ? "" : _lookup_name)
    fl_on ∈ Bool
    fl_on = (is_first_tick ? false : _fl_on)
    param_skip ∈ Int
    param_skip = (is_first_tick ? 0 : _param_skip)
    in_parse ∈ Bool
    in_parse = (is_first_tick ? false : _in_parse)
    istep ∈ Int
    istep = (is_first_tick ? 0 : _istep)
    pmode ∈ Int
    pmode = (is_first_tick ? 0 : _pmode)
    rb_on ∈ Bool
    rb_on = (is_first_tick ? false : _rb_on)
    tok_ready ∈ Bool
    tok_ready = (is_first_tick ? false : _tok_ready)
    sym_buf ∈ FtiBuffer
    sym_buf.base = (is_first_tick ? 0 : _sym_buf.base)
    ..DriverSymtab
    verdict ∈ Int = ((h_top = 99 ? 1 : 0) + (h_2nd = 7 ? 2 : 0)
        + (it_decl ? 4 : 0))
    v_msg ∈ String = str_from_int(verdict)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(v_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
