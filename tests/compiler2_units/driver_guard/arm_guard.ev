-- DriverGuard isolation — guard arms when the jump fires: drive the
-- composition jump-fire condition (parse, parse_mode 10, callwalk_state 4, work_items
-- nil) with inline-frame-top guard handle h_top = 99 and no
-- reset/unguard; the splice phase must latch active_handle ← 99 on the fire tick.
-- entry: main
-- expect: stdout = "99"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/parser.ev"
import "compiler2/translate2_bool.ev"
import "stdlib/z3_datatypes.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_guard.ev"

fsm main
    parse ∈ Bool
    parse = (is_first_tick ? true : _parse)
    parse_mode ∈ Int
    parse_mode = (is_first_tick ? 10 : _parse_mode)
    callwalk_state ∈ Int
    callwalk_state = (is_first_tick ? 4 : _callwalk_state)
    nil ∈ Bool
    nil = (is_first_tick ? true : _nil)
    h_top ∈ Int
    h_top = (is_first_tick ? 99 : _h_top)
    reset ∈ Bool
    reset = (is_first_tick ? false : _reset)
    frame_pop ∈ Bool
    frame_pop = (is_first_tick ? false : _frame_pop)
    frame_depth ∈ Int
    frame_depth = (is_first_tick ? 0 : _frame_depth)
    -- Recognizer inputs the phase also reads (inert here — no guard line).
    result ∈ Expr
    result = (is_first_tick ? ENoExpr : _result)
    parse_ready ∈ Bool
    parse_ready = (is_first_tick ? false : _parse_ready)
    parse_kind ∈ Int
    parse_kind = (is_first_tick ? 0 : _parse_kind)
    parse_bad ∈ Bool
    parse_bad = (is_first_tick ? false : _parse_bad)
    claimindex_names ∈ String
    claimindex_names = (is_first_tick ? "" : _claimindex_names)
    claimindex_buf ∈ FtiBuffer
    claimindex_buf.base = (is_first_tick ? 0 : _claimindex_buf.base)
    claimindex_buf.count = (is_first_tick ? 0 : _claimindex_buf.count)
    ..DriverGuard
    g_msg ∈ String = str_from_int(active_handle)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(g_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
