-- DriverGuard isolation — guard arms when the jump fires: drive the
-- composition jump-fire condition (in_parse, pmode 10, callw_st 4, witems
-- nil) with inline-frame-top guard handle h_top = 99 and no
-- reset/unguard; the splice phase must latch guard_handle ← 99 on the fire tick.
-- entry: main
-- expect: stdout = "99"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/parser.ev"
import "compiler2/translate2_bool.ev"
import "stdlib/z3_datatypes.ev"
import "compiler2/driver_ir.ev"
import "compiler2/driver_guard.ev"

fsm main
    in_parse ∈ Bool
    in_parse = (is_first_tick ? true : _in_parse)
    pmode ∈ Int
    pmode = (is_first_tick ? 10 : _pmode)
    callw_st ∈ Int
    callw_st = (is_first_tick ? 4 : _callw_st)
    work_nil ∈ Bool
    work_nil = (is_first_tick ? true : _work_nil)
    h_top ∈ Int
    h_top = (is_first_tick ? 99 : _h_top)
    callw_reset ∈ Bool
    callw_reset = (is_first_tick ? false : _callw_reset)
    frame_pop ∈ Bool
    frame_pop = (is_first_tick ? false : _frame_pop)
    frame_depth ∈ Int
    frame_depth = (is_first_tick ? 0 : _frame_depth)
    -- Recognizer inputs the phase also reads (inert here — no guard line).
    pratt_result ∈ Expr
    pratt_result = (is_first_tick ? ENoExpr : _pratt_result)
    pratt_done ∈ Bool
    pratt_done = (is_first_tick ? false : _pratt_done)
    pratt_kind ∈ Int
    pratt_kind = (is_first_tick ? 0 : _pratt_kind)
    pratt_bad ∈ Bool
    pratt_bad = (is_first_tick ? false : _pratt_bad)
    claimidx_names ∈ String
    claimidx_names = (is_first_tick ? "" : _claimidx_names)
    claimidx_buf ∈ FtiBuffer
    claimidx_buf.base = (is_first_tick ? 0 : _claimidx_buf.base)
    claimidx_buf.count = (is_first_tick ? 0 : _claimidx_buf.count)
    ..DriverGuard
    g_msg ∈ String = str_from_int(guard_handle)
    effects ∈ Seq(Effect) = ((¬is_first_tick)
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(g_msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
