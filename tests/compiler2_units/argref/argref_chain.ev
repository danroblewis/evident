-- ArgRef intra-tick handle chain (wave-5a B1). One tick chains three
-- calls: malloc(8) → write_long(ArgRef(0), 42) → read_long(ArgRef(0)) —
-- the second and third resolve ArgRef(0) to the malloc'd pointer DURING
-- the same tick. The next tick reads the chain's final result from
-- last_results[2] and exits with it. Before B1 this took three ticks
-- and two carried handles.
--
-- entry: main
-- expect: exit = 42
import "stdlib/kernel.ev"

fsm main
    tick ∈ Int
    tick = (is_first_tick ? 0 : _tick + 1)
    got ∈ Int = match last_results[2]
        IntResult(n) ⇒ n
        _ ⇒ 0 - 1
    effects ∈ Seq(Effect) = (tick = 0
        ? ⟨LibCall("libc", "malloc", ⟨ArgInt(8)⟩),
           LibCall("__mem", "write_long", ⟨ArgRef(0), ArgInt(42)⟩),
           LibCall("__mem", "read_long", ⟨ArgRef(0)⟩)⟩
        : ⟨Exit(got)⟩)
