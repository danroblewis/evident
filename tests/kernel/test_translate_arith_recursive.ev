-- Recursive arithmetic translation: walk an arbitrary Expr tree to
-- nested SMT-LIB via a WorkItem work-stack (the test_ast_walker.ev
-- depth-first pattern), driving compiler/translate_arith.ev's
-- ArithTranslateStep claim once per tick.
--
-- Input AST (3 deep):
--   EBinOp(OpPlus, EBinOp(OpMul, EInt(1), EInt(2)), EInt(3))
--
-- The host carries a `WorkList` stack and a `String` output accumulator
-- across ticks. Each non-initial tick pops the head WorkItem, asks the
-- step claim for the text it emits and the reshaped stack, and appends
-- the text to the accumulator. When the stack empties, the accumulated
-- SMT-LIB is printed and the FSM exits.
--
-- Pop sequence for the tree:
--   P(+) → "(" "+" " " P(*) " " P(3) ")"
--   P(*) → "(" "*" " " P(1) " " P(2) ")"
--   leaves emit "1" / "2" / "3"
-- yielding "(+ (* 1 2) 3)".
--
-- expect: stdout = "(+ (* 1 2) 3)"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/translate_arith.ev"

claim main
    initial_expr ∈ Expr = EBinOp(OpPlus, EBinOp(OpMul, EInt(1), EInt(2)), EInt(3))
    initial_stack ∈ WorkList = WLCons(WIProcess(initial_expr), WLNil)

    stack  ∈ WorkList
    _stack ∈ WorkList
    out  ∈ String
    _out ∈ String

    hd ∈ WorkItem = match _stack
        WLCons(h, _) ⇒ h
        WLNil ⇒ WIEmit("")
    rst ∈ WorkList = match _stack
        WLCons(_, t) ⇒ t
        WLNil ⇒ WLNil
    is_empty ∈ Bool = match _stack
        WLNil ⇒ true
        _ ⇒ false

    nstack ∈ WorkList
    em ∈ String
    ArithTranslateStep(head ↦ hd, rest ↦ rst, new_stack ↦ nstack, emit ↦ em)

    stack = (is_first_tick ? initial_stack : nstack)
    out = (is_first_tick ? "" : _out ++ em)

    done ∈ Bool = (¬is_first_tick ∧ is_empty)

    -- The output line is printed once, when the work-stack drains. Every
    -- other tick advances with a side-effect-free getpid (the
    -- tick-advance-without-stdout idiom from test_multi_tick.ev); a fully
    -- empty effects Seq leaves the `effects` array unconstrained and the
    -- kernel can't find it in the model.
    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(out)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
