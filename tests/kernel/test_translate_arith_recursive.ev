-- Recursive arithmetic translation: walk an Expr tree to nested
-- SMT-LIB via a WorkItem work-stack, driving ArithTranslateStep once
-- per tick; the host carries the stack + a String accumulator and
-- prints "(+ (* 1 2) 3)" when the stack drains.
--
-- expect: stdout = "(+ (* 1 2) 3)"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/translate_arith.ev"

claim main
    initial_expr ∈ Expr = EBinOp(OpPlus, EBinOp(OpMul, EInt(1), EInt(2)), EInt(3))
    initial_stack ∈ WorkList = WLCons(WIProcess(initial_expr), WLNil)

    stack  ∈ WorkList
    _stack ∈ WorkList
    out  ∈ String
    _out ∈ String

    hd ∈ WorkItem = match _stack
        WLCons(h, _) ⇒ h
        WLNil ⇒ WIEmit("")
    rst ∈ WorkList = match _stack
        WLCons(_, t) ⇒ t
        WLNil ⇒ WLNil
    is_empty ∈ Bool = match _stack
        WLNil ⇒ true
        _ ⇒ false

    nstack ∈ WorkList
    em ∈ String
    ArithTranslateStep(head ↦ hd, rest ↦ rst, new_stack ↦ nstack, emit ↦ em)

    stack = (is_first_tick ? initial_stack : nstack)
    out = (is_first_tick ? "" : _out ++ em)

    done ∈ Bool = (¬is_first_tick ∧ is_empty)

    -- Non-final ticks advance with a side-effect-free getpid: a fully
    -- empty effects Seq leaves the `effects` array unconstrained and the
    -- kernel can't find it in the model.
    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(out)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
