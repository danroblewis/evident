-- Multi-character integer literals (iter 3.5).
--
-- Walks "12+345\n" and emits ⟨IntLit(345), Plus, IntLit(12)⟩ in the
-- TokenList. Uses an Int accumulator (`partial_int`) instead of a String
-- partial, avoiding the missing `str_to_int` runtime function.
--
-- Accumulator semantics:
--   _partial_int = -1 → not in a digit run
--   continuing  → partial_int = _partial_int * 10 + DigitToInt(cur_char)
--   starting    → partial_int = DigitToInt(cur_char)
--   else        → partial_int = -1
--
-- The boundary tick (digits → operator) emits TWO tokens (IntLit + op)
-- via nested TLCons.
--
-- expect: stdout = "  start: 1"
-- expect: stdout = "  cont: 2"
-- expect: stdout = "int: 12 + char: +"
-- expect: stdout = "  start: 3"
-- expect: stdout = "  cont: 4"
-- expect: stdout = "  cont: 5"
-- expect: stdout = "int: 345"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"

claim main
    input  ∈ String
    _input ∈ String
    read_result ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ "<no-read>"
    input = (is_first_tick ? "" : (_input = "" ? read_result : _input))

    pos  ∈ Int
    _pos ∈ Int
    partial_int  ∈ Int
    _partial_int ∈ Int

    pos = (is_first_tick ? 0 - 1 : (_input = "" ? 0 : _pos + 1))

    cur_char ∈ String = substr(input, pos, 1)
    is_dig ∈ Bool
    IsDigitChar(c ↦ cur_char, out ↦ is_dig)
    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)
    op_tok ∈ Token
    is_op ∈ Bool
    SingleCharTok(c ↦ cur_char, t ↦ op_tok, recognized ↦ is_op)
    dig_val ∈ Int
    DigitToInt(c ↦ cur_char, n ↦ dig_val)

    was_collecting ∈ Bool = (_partial_int ≥ 0)
    done ∈ Bool = ((pos ≥ #input) ∧ (#input > 0))
    in_range ∈ Bool = ((pos ≥ 0) ∧ ¬done)

    continuing ∈ Bool = (was_collecting ∧ is_dig ∧ in_range)
    finishing  ∈ Bool = (was_collecting ∧ ((¬is_dig ∧ in_range) ∨ done))
    starting   ∈ Bool = ((¬was_collecting) ∧ is_dig ∧ in_range)

    partial_int = (is_first_tick ? 0 - 1 : (continuing ? (_partial_int * 10) + dig_val : (starting ? dig_val : 0 - 1)))

    finish_with_char ∈ Bool = (finishing ∧ is_op ∧ in_range)
    finish_only      ∈ Bool = (finishing ∧ ((is_ws ∨ done)))
    char_only        ∈ Bool = ((¬was_collecting) ∧ is_op ∧ in_range)

    int_tok    ∈ Token = IntLit(_partial_int)
    single_tok ∈ Token = op_tok

    tokens  ∈ TokenList
    _tokens ∈ TokenList
    tokens = (is_first_tick ? TLNil
            : (finish_with_char ? TLCons(single_tok, TLCons(int_tok, _tokens))
            : (finish_only ? TLCons(int_tok, _tokens)
            : (char_only ? TLCons(single_tok, _tokens)
            : _tokens))))

    halting ∈ Bool = (done ∧ ¬was_collecting)

    label ∈ String = (halting ? "[eof]" : (pos < 0 ? "got input" : (finish_with_char ? ("int: " ++ str_from_int(_partial_int) ++ " + char: " ++ cur_char) : (finish_only ? ("int: " ++ str_from_int(_partial_int)) : (char_only ? ("char: " ++ cur_char) : (is_ws ? "  skip" : (continuing ? ("  cont: " ++ cur_char) : (starting ? ("  start: " ++ cur_char) : "  ?"))))))))

    effects ∈ Seq(Effect) = (is_first_tick ? ⟨ReadFile("/tmp/evident_digits_input.txt")⟩ : (halting ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩ : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩))
