-- AST tree walker (iter 3.12).
--
-- Walks `EBinOp(OpPlus, EBinOp(OpPlus, EInt(1), EInt(2)), EInt(3))`
-- depth-first via a work-stack, prints each visited node, counts
-- the EInt leaves.
--
-- Architecture: an ExprList "work stack" carried as Datatype state
-- across ticks. Each tick pops the head, classifies via `match` +
-- `matches`, pushes children for compound nodes. Halt when stack
-- is empty.
--
-- This is the foundation for any AST → text translator:
--   - AST → SMT-LIB (iter 3.13)
--   - AST → pretty-printed source
--   - AST → traversal-based analyses (count nodes, find names, …)
--
-- For "(1+2)+3" the depth-first walk visits:
--   EBinOp (root) → EBinOp (left subtree) → EInt(1) → EInt(2) → EInt(3)
--
-- expect: stdout = "[start]"
-- expect: stdout = "binop"
-- expect: stdout = "binop"
-- expect: stdout = "int(1)"
-- expect: stdout = "int(2)"
-- expect: stdout = "int(3)"
-- expect: stdout = "done; ints=3"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/parser.ev"

claim main
    initial_expr ∈ Expr = EBinOp(OpPlus, EBinOp(OpPlus, EInt(1), EInt(2)), EInt(3))
    initial_stack ∈ ExprList = ELCons(initial_expr, ELNil)

    stack  ∈ ExprList
    _stack ∈ ExprList
    count  ∈ Int
    _count ∈ Int

    head_expr ∈ Expr = match _stack
        ELCons(e, _) ⇒ e
        ELNil ⇒ ENoExpr

    tail_stack ∈ ExprList = match _stack
        ELCons(_, rest) ⇒ rest
        ELNil ⇒ ELNil

    is_empty ∈ Bool = match _stack
        ELNil ⇒ true
        _ ⇒ false

    bin_left ∈ Expr = match head_expr
        EBinOp(_, l, _) ⇒ l
        _ ⇒ ENoExpr
    bin_right ∈ Expr = match head_expr
        EBinOp(_, _, r) ⇒ r
        _ ⇒ ENoExpr

    is_int   ∈ Bool = (head_expr matches EInt(_))
    is_binop ∈ Bool = (head_expr matches EBinOp(_, _, _))

    int_val ∈ Int = match head_expr
        EInt(n) ⇒ n
        _ ⇒ 0 - 1

    -- Push right then left → left gets popped first (preorder DFS).
    new_stack ∈ ExprList = (is_binop
        ? ELCons(bin_left, ELCons(bin_right, tail_stack))
        : tail_stack)

    stack = (is_first_tick ? initial_stack : new_stack)
    count = (is_first_tick ? 0 : (is_int ? _count + 1 : _count))

    label ∈ String = (is_first_tick ? "[start]" : (is_empty ? ("done; ints=" ++ str_from_int(_count)) : (is_int ? ("int(" ++ str_from_int(int_val) ++ ")") : (is_binop ? "binop" : "?"))))

    effects ∈ Seq(Effect) = (is_first_tick
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩
        : (is_empty
            ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩
            : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩))
