-- C3: Boolean expression translation to SMT-LIB.
--
-- Two-tick FSM: each tick runs one hardcoded AST through
-- BoolExprSmtlib (compiler/translate_bool.ev) and prints the result.
--
-- expect: stdout = "(= x 5)"
-- expect: stdout = "(=> p q)"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/translate_bool.ev"

claim main
    step  ∈ Int
    _step ∈ Int
    step = (is_first_tick ? 0 : _step + 1)

    e_eq   ∈ Expr = EBinOp(OpEq,   EIdent("x"), EInt(5))
    e_impl ∈ Expr = EBinOp(OpImpl, EIdent("p"), EIdent("q"))
    e ∈ Expr = (step = 0 ? e_eq : e_impl)

    out ∈ String
    ok  ∈ Bool
    BoolExprSmtlib(e ↦ e, out ↦ out, ok ↦ ok)

    done ∈ Bool = (step ≥ 1)

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(out)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(out)⟩)⟩)
