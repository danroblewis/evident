-- Full keyword set (A5): walks every keyword the Rust lexer recognises
-- through MaybeKeyword and confirms each classifies to its Kw* variant;
-- the 7 newly-added (subclaim/external/matches/in/true/false/mapsto)
-- are the A5 acceptance signal.
--
-- Word lengths (in input order, sum=73):
--   claim 5, type 4, schema 6, fsm 3, enum 4, import 6, match 5,
--   subclaim 8, external 8, matches 7, in 2, true 4, false 5, mapsto 6
-- Per-tick: word_len letter ticks + 1 boundary tick; plus one [eof] tick.
--
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: claim"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: type"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: schema"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: fsm"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: enum"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: import"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: match"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: subclaim"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: external"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: matches"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: in"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: true"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: false"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: mapsto"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"

claim main
    input  ∈ String
    _input ∈ String
    read_result ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ "<no-read>"
    input = (is_first_tick ? "" : (_input = "" ? read_result : _input))

    pos  ∈ Int
    _pos ∈ Int
    partial  ∈ String
    _partial ∈ String

    pos = (is_first_tick ? 0 - 1 : (_input = "" ? 0 : _pos + 1))

    cur_char ∈ String = substr(input, pos, 1)
    is_alpha ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)
    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)

    was_collecting ∈ Bool = (#_partial > 0)
    done ∈ Bool = ((pos ≥ #input) ∧ (#input > 0))
    in_range ∈ Bool = ((pos ≥ 0) ∧ ¬done)

    continuing ∈ Bool = (was_collecting ∧ is_alpha ∧ in_range)
    finishing  ∈ Bool = (was_collecting ∧ ((¬is_alpha ∧ in_range) ∨ done))
    starting   ∈ Bool = ((¬was_collecting) ∧ is_alpha ∧ in_range)

    partial = (is_first_tick ? "" : (continuing ? _partial ++ cur_char : (starting ? cur_char : "")))

    finish_only ∈ Bool = (finishing ∧ ((is_ws ∨ done)))

    classified_tok ∈ Token
    MaybeKeyword(s ↦ _partial, t ↦ classified_tok)

    tokens  ∈ TokenList
    _tokens ∈ TokenList
    tokens = (is_first_tick ? TLNil
            : (finish_only ? TLCons(classified_tok, _tokens)
            : _tokens))

    halting ∈ Bool = (done ∧ ¬was_collecting)

    -- Every input word is a keyword; the "ident:" fallback stays so a
    -- keyword misclassifying as Ident fails loudly as a label mismatch.
    is_kw ∈ Bool = ((_partial = "claim")    ∨ (_partial = "type")
                  ∨ (_partial = "schema")  ∨ (_partial = "fsm")
                  ∨ (_partial = "enum")    ∨ (_partial = "import")
                  ∨ (_partial = "match")   ∨ (_partial = "subclaim")
                  ∨ (_partial = "external") ∨ (_partial = "matches")
                  ∨ (_partial = "in")      ∨ (_partial = "true")
                  ∨ (_partial = "false")   ∨ (_partial = "mapsto"))

    label ∈ String = (halting ? "[eof]" : (pos < 0 ? "got input" : (finish_only ? (is_kw ? ("kw: " ++ _partial) : ("ident: " ++ _partial)) : (is_ws ? "  skip" : (continuing ? "  cont" : (starting ? "  start" : "  ?"))))))

    effects ∈ Seq(Effect) = (is_first_tick ? ⟨ReadFile("/tmp/evident_full_kw_input.txt")⟩ : (halting ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩ : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩))
