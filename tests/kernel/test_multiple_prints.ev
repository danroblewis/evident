-- expect: stdout = "a"
-- expect: stdout = "b"
-- expect: stdout = "c"
-- expect: exit = 0
import "stdlib/kernel.ev"

claim main
    effects ∈ Seq(Effect) = ⟨
        LibCall("libc", "puts", ⟨ArgStr("a")⟩),
        LibCall("libc", "puts", ⟨ArgStr("b")⟩),
        LibCall("libc", "puts", ⟨ArgStr("c")⟩),
        Exit(0)
    ⟩
