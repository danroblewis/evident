-- B1: multi-binop precedence. Input TokenList encodes `1 + 2 * 3`;
-- the parser must build EBinOp(OpPlus, EInt(1), EBinOp(OpMul, EInt(2),
-- EInt(3))) — `*` binds tighter than `+`. Precedence-climbing FSM slots:
--   left / current — low-prec accumulator / high-prec subtree
--   low_pending / high_pending — ops awaiting their right operand
--   has_low/has_high/has_current — slot occupancy flags
--
-- For `1 + 2 * 3` the trace is:
--   tick 1 IntLit(1) → current=EInt(1)
--   tick 2 Plus      → left=EInt(1), low_pending=OpPlus, clear current
--   tick 3 IntLit(2) → current=EInt(2)
--   tick 4 Star      → high_pending=OpMul
--   tick 5 IntLit(3) → current=EBinOp(OpMul, EInt(2), EInt(3))
--   tick 6 TLNil     → final = EBinOp(OpPlus, EInt(1), EBinOp(OpMul, EInt(2), EInt(3)))
--
-- expect: stdout = "[start]"
-- expect: stdout = "saw int"
-- expect: stdout = "saw op +"
-- expect: stdout = "saw int"
-- expect: stdout = "saw op *"
-- expect: stdout = "saw int"
-- expect: stdout = "tree: ok"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/parser.ev"

claim main
    initial ∈ TokenList = TLCons(IntLit(1), TLCons(Plus, TLCons(IntLit(2), TLCons(Star, TLCons(IntLit(3), TLNil)))))

    list  ∈ TokenList
    _list ∈ TokenList

    left  ∈ Expr
    _left ∈ Expr

    current  ∈ Expr
    _current ∈ Expr

    low_pending  ∈ Op
    _low_pending ∈ Op

    high_pending  ∈ Op
    _high_pending ∈ Op

    has_low  ∈ Bool
    _has_low ∈ Bool

    has_high  ∈ Bool
    _has_high ∈ Bool

    has_current  ∈ Bool
    _has_current ∈ Bool

    -- ── List advance ─────────────────────────────────────────────
    next_list ∈ TokenList = match _list
        TLCons(_, tail) ⇒ tail
        TLNil ⇒ TLNil

    head_tok ∈ Token = match _list
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok

    is_nil ∈ Bool = match _list
        TLNil ⇒ true
        _ ⇒ false

    -- ── Head classification ──────────────────────────────────────
    head_int ∈ Int = match head_tok
        IntLit(n) ⇒ n
        _ ⇒ 0 - 1
    is_int ∈ Bool = (head_int ≥ 0)

    head_op ∈ Op
    is_op ∈ Bool
    TokenToOp(t ↦ head_tok, o ↦ head_op, is_binop ↦ is_op)

    head_prec ∈ Int
    Precedence(op ↦ head_op, n ↦ head_prec)
    is_high_op ∈ Bool = (is_op ∧ (head_prec ≥ 2))
    is_low_op  ∈ Bool = (is_op ∧ (head_prec ≤ 1))

    -- ── List ─────────────────────────────────────────────────────
    list = (is_first_tick ? initial : next_list)

    -- ── current slot update ──────────────────────────────────────
    folded_int ∈ Expr = EBinOp(_high_pending, _current, EInt(head_int))
    new_current_int ∈ Expr = (_has_high ? folded_int : EInt(head_int))

    new_current ∈ Expr = (is_int ? new_current_int : (is_low_op ? ENoExpr : _current))

    current = (is_first_tick ? ENoExpr : new_current)

    -- ── has_current slot update ──────────────────────────────────
    new_has_current ∈ Bool = (is_int ? true : (is_low_op ? false : _has_current))
    has_current = (is_first_tick ? false : new_has_current)

    -- ── high_pending / has_high slot update ──────────────────────
    new_high_pending ∈ Op = (is_high_op ? head_op : _high_pending)
    new_has_high ∈ Bool = (is_int ? false : (is_high_op ? true : (is_low_op ? false : _has_high)))
    high_pending = (is_first_tick ? OpPlus : new_high_pending)
    has_high     = (is_first_tick ? false   : new_has_high)

    -- ── left / low_pending / has_low slot update ─────────────────
    flushed_left ∈ Expr = EBinOp(_low_pending, _left, _current)
    new_left_low ∈ Expr = (_has_low ? flushed_left : _current)
    new_left ∈ Expr = (is_low_op ? new_left_low : _left)
    new_low_pending ∈ Op = (is_low_op ? head_op : _low_pending)
    new_has_low ∈ Bool   = (is_low_op ? true    : _has_low)
    left        = (is_first_tick ? ENoExpr : new_left)
    low_pending = (is_first_tick ? OpPlus  : new_low_pending)
    has_low     = (is_first_tick ? false   : new_has_low)

    -- ── Final assembly (read at the nil tick) ────────────────────
    final_assembled ∈ Expr = EBinOp(_low_pending, _left, _current)
    final ∈ Expr = (_has_low ? final_assembled : _current)

    -- ── Structural check on the final ────────────────────────────
    final_top_op ∈ Op = match final
        EBinOp(o, _, _) ⇒ o
        _ ⇒ OpPlus
    final_left ∈ Expr = match final
        EBinOp(_, l, _) ⇒ l
        _ ⇒ ENoExpr
    final_right ∈ Expr = match final
        EBinOp(_, _, r) ⇒ r
        _ ⇒ ENoExpr

    top_is_plus ∈ Bool = (final_top_op matches OpPlus)
    final_left_int ∈ Int = match final_left
        EInt(n) ⇒ n
        _ ⇒ 0 - 1
    left_is_one ∈ Bool = (final_left_int = 1)

    right_op ∈ Op = match final_right
        EBinOp(o, _, _) ⇒ o
        _ ⇒ OpPlus
    right_left ∈ Expr = match final_right
        EBinOp(_, l, _) ⇒ l
        _ ⇒ ENoExpr
    right_right ∈ Expr = match final_right
        EBinOp(_, _, r) ⇒ r
        _ ⇒ ENoExpr
    right_is_mul ∈ Bool = (right_op matches OpMul)
    right_left_int ∈ Int = match right_left
        EInt(n) ⇒ n
        _ ⇒ 0 - 1
    right_right_int ∈ Int = match right_right
        EInt(n) ⇒ n
        _ ⇒ 0 - 1
    right_shape_ok ∈ Bool = (right_is_mul ∧ (right_left_int = 2) ∧ (right_right_int = 3))

    tree_ok ∈ Bool = (top_is_plus ∧ left_is_one ∧ right_shape_ok)

    -- ── Labels ───────────────────────────────────────────────────
    head_is_plus  ∈ Bool = (head_op matches OpPlus)
    head_is_mul   ∈ Bool = (head_op matches OpMul)
    head_is_sub   ∈ Bool = (head_op matches OpSub)
    head_is_div   ∈ Bool = (head_op matches OpDiv)
    op_label ∈ String = (head_is_plus ? "saw op +" : (head_is_mul ? "saw op *" : (head_is_sub ? "saw op -" : (head_is_div ? "saw op /" : "saw op ="))))
    done_label ∈ String = (tree_ok ? "tree: ok" : "tree: bad")

    label ∈ String = (is_first_tick ? "[start]" : (is_nil ? done_label : (is_int ? "saw int" : (is_op ? op_label : "skip"))))

    effects ∈ Seq(Effect) = (is_first_tick ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩ : (is_nil ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩ : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩))
