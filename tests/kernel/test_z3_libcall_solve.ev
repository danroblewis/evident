-- Wave 5a — Z3-as-library FTI proof: drive Z3 from an Evident FSM
-- via the new BuildZ3* sugar (stdlib/kernel.ev). Source-level
-- equivalent of tests/kernel/wave-5a/z3_solve_x42.smt2 (the
-- hand-written .smt2 proof). When this compiles and runs to exit
-- 0, wave 5a's Evident-source loop is closed.
--
-- The FSM is multi-tick because every Z3 call's return handle
-- arrives in `last_results` on the NEXT tick (the libcall.rs
-- return-as-i64 contract). The chain:
--
--   0  MkConfig                                       cfg ← [0]
--   1  MkContext(cfg)                                 ctx ← [0]
--   2  MkSolver(ctx)
--   3  SolverIncRef(ctx, sol)         (captures sol from [0])
--   4  Parse(ctx, src)
--   5  AstVectorIncRef(ctx, vec)      (captures vec from [0])
--   6  AstVectorGet(ctx, vec, 0)
--   7  IncRef(ctx, ast)               (captures ast from [0])
--   8  SolverAssert(ctx, sol, ast)
--   9  SolverCheck(ctx, sol)
--   10 Exit(0 iff sat==1)             (captures sat from [0])
--
-- The Z3 source asserts `(= x 42)`. Without the inc_refs, Z3 GCs
-- the AST/solver between ticks and SolverCheck crashes.
--
-- expect: stdout = ""
-- expect: exit = 0

import "stdlib/kernel.ev"

claim main
    z3_src ∈ String = "(declare-const x Int)\n(assert (= x 42))"

    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    cfg_h ∈ Int
    _cfg_h ∈ Int
    cfg_capture ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    cfg_h = (is_first_tick ? 0
        : phase = 1 ? cfg_capture
        : _cfg_h)

    ctx_h ∈ Int
    _ctx_h ∈ Int
    ctx_capture ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    ctx_h = (is_first_tick ? 0
        : phase = 2 ? ctx_capture
        : _ctx_h)

    sol_h ∈ Int
    _sol_h ∈ Int
    sol_capture ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    sol_h = (is_first_tick ? 0
        : phase = 3 ? sol_capture
        : _sol_h)

    vec_h ∈ Int
    _vec_h ∈ Int
    vec_capture ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    vec_h = (is_first_tick ? 0
        : phase = 5 ? vec_capture
        : _vec_h)

    ast_h ∈ Int
    _ast_h ∈ Int
    ast_capture ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    ast_h = (is_first_tick ? 0
        : phase = 7 ? ast_capture
        : _ast_h)

    sat ∈ Int
    _sat ∈ Int
    sat_capture ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0 - 99
    sat = (is_first_tick ? 0 - 99
        : phase = 10 ? sat_capture
        : _sat)

    exit_code ∈ Int = (sat = 1 ? 0 : (sat = 0 ? 3 : (sat = 0 - 1 ? 4 : 5)))

    effects ∈ Seq(Effect) = (phase = 0 ? ⟨LibCall("libz3", "Z3_mk_config", ⟨⟩)⟩
        : phase = 1 ? ⟨LibCall("libz3", "Z3_mk_context", ⟨ArgInt(cfg_h)⟩)⟩
        : phase = 2 ? ⟨LibCall("libz3", "Z3_mk_solver", ⟨ArgInt(ctx_h)⟩)⟩
        : phase = 3 ? ⟨LibCall("libz3", "Z3_solver_inc_ref",
                           ⟨ArgInt(ctx_h), ArgInt(sol_h)⟩)⟩
        : phase = 4 ? ⟨LibCall("libz3", "Z3_parse_smtlib2_string",
                           ⟨ArgInt(ctx_h), ArgStr(z3_src),
                            ArgInt(0), ArgInt(0), ArgInt(0),
                            ArgInt(0), ArgInt(0), ArgInt(0)⟩)⟩
        : phase = 5 ? ⟨LibCall("libz3", "Z3_ast_vector_inc_ref",
                           ⟨ArgInt(ctx_h), ArgInt(vec_h)⟩)⟩
        : phase = 6 ? ⟨LibCall("libz3", "Z3_ast_vector_get",
                           ⟨ArgInt(ctx_h), ArgInt(vec_h), ArgInt(0)⟩)⟩
        : phase = 7 ? ⟨LibCall("libz3", "Z3_inc_ref",
                           ⟨ArgInt(ctx_h), ArgInt(ast_h)⟩)⟩
        : phase = 8 ? ⟨LibCall("libz3", "Z3_solver_assert",
                           ⟨ArgInt(ctx_h), ArgInt(sol_h), ArgInt(ast_h)⟩)⟩
        : phase = 9 ? ⟨LibCall("libz3", "Z3_solver_check",
                           ⟨ArgInt(ctx_h), ArgInt(sol_h)⟩)⟩
        : ⟨Exit(exit_code)⟩)
