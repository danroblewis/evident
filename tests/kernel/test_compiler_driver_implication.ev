-- Grammar wave 4k, Item 2: implication body line `LHS ⇒ RHS`.
--
-- A line `name op atom ⇒ name2 op2 atom2` lowers to a single
-- `(assert (=> <lhs> <rhs>))` (compiler/parse_body.ev MembershipStep,
-- ms_is_impl) — detected by OpImplies at t3, taking priority over the
-- bare-`=` path (which alone would consume `today = Sat` and drop the
-- consequent — the wave-4j Wall-2 bug). `true`/`false` lex as KwTrue/
-- KwFalse and render as the SMT-LIB Bool literals.
--   `today = Sat ⇒ is_weekend = true`
--     → (assert (=> (= today Sat) (= is_weekend true)))
-- See docs/plans/wave-4k-membership-walk-shapes.md.
--
-- expect: stdout = ";; manifest: state-fields = today:Day is_weekend:Bool"
-- expect: stdout = ";; manifest: effects-name = effects"
-- expect: stdout = ";; manifest: effect-enum-name = Effect"
-- expect: stdout = ";; manifest: result-enum-name = Result"
-- expect: stdout = ";; manifest: max-effects = 0"
-- expect: stdout = "(declare-fun today () Day)"
-- expect: stdout = "(declare-fun is_weekend () Bool)"
-- expect: stdout = "(assert (=> (= today Sat) (= is_weekend true)))"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler/translate_declare.ev"
import "compiler/translate_arith.ev"
import "compiler/parse_body.ev"

claim main
    input ∈ String = "claim foo\n    today ∈ Day\n    is_weekend ∈ Bool\n    today = Sat ⇒ is_weekend = true\n"
    -- ── LEX state (consolidated-lexer FSM, reverse-order tokens) ──
    pos  ∈ Int
    _pos ∈ Int
    pos = (is_first_tick ? 0 - 1 : _pos + 1)

    partial_str  ∈ String
    _partial_str ∈ String
    partial_int  ∈ Int
    _partial_int ∈ Int

    cur_char ∈ String = substr(input, pos, 1)

    is_alpha ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)
    is_dig ∈ Bool
    IsDigitChar(c ↦ cur_char, out ↦ is_dig)
    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)
    op_tok ∈ Token
    is_op ∈ Bool
    SingleCharTok(c ↦ cur_char, t ↦ op_tok, recognized ↦ is_op)
    dig_val ∈ Int
    DigitToInt(c ↦ cur_char, n ↦ dig_val)

    done ∈ Bool = ((pos ≥ #input) ∧ (#input > 0))
    in_range ∈ Bool = ((pos ≥ 0) ∧ ¬done)

    was_collecting_str ∈ Bool = (#_partial_str > 0)
    was_collecting_int ∈ Bool = (_partial_int ≥ 0)

    str_continuing ∈ Bool = (was_collecting_str ∧ is_alpha ∧ in_range)
    str_finishing  ∈ Bool = (was_collecting_str ∧ ((¬is_alpha ∧ in_range) ∨ done))
    str_starting   ∈ Bool = ((¬was_collecting_str) ∧ is_alpha ∧ in_range)

    int_continuing ∈ Bool = (was_collecting_int ∧ is_dig ∧ in_range)
    int_finishing  ∈ Bool = (was_collecting_int ∧ ((¬is_dig ∧ in_range) ∨ done))
    int_starting   ∈ Bool = ((¬was_collecting_int) ∧ is_dig ∧ in_range)

    partial_str = (is_first_tick ? "" : (str_continuing ? _partial_str ++ cur_char : (str_starting ? cur_char : "")))
    partial_int = (is_first_tick ? 0 - 1 : (int_continuing ? (_partial_int * 10) + dig_val : (int_starting ? dig_val : 0 - 1)))

    classified_str ∈ Token
    MaybeKeyword(s ↦ _partial_str, t ↦ classified_str)
    int_tok ∈ Token = IntLit(_partial_int)

    finish_str_only    ∈ Bool = (str_finishing ∧ (is_ws ∨ done))
    finish_int_only    ∈ Bool = (int_finishing ∧ (is_ws ∨ done))
    finish_str_with_op ∈ Bool = (str_finishing ∧ is_op ∧ in_range)
    finish_int_with_op ∈ Bool = (int_finishing ∧ is_op ∧ in_range)
    char_only          ∈ Bool = ((¬was_collecting_str) ∧ (¬was_collecting_int) ∧ is_op ∧ in_range)

    tokens  ∈ TokenList
    _tokens ∈ TokenList
    tokens = (is_first_tick ? TLNil
            : (finish_str_with_op ? TLCons(op_tok, TLCons(classified_str, _tokens))
            : (finish_int_with_op ? TLCons(op_tok, TLCons(int_tok, _tokens))
            : (finish_str_only ? TLCons(classified_str, _tokens)
            : (finish_int_only ? TLCons(int_tok, _tokens)
            : (char_only ? TLCons(op_tok, _tokens)
            : _tokens))))))

    lex_done ∈ Bool = (done ∧ ¬was_collecting_str ∧ ¬was_collecting_int ∧ ¬is_first_tick)

    -- ── PHASE control (0 lex · 1 reverse · 2 parse · 3 emit) ──────
    phase  ∈ Int
    _phase ∈ Int

    work_is_nil ∈ Bool = match _work
        TLNil ⇒ true
        _ ⇒ false
    work_hd ∈ Token
    TLHd(l ↦ _work, out ↦ work_hd)
    work_tl ∈ TokenList
    TLTl(l ↦ _work, out ↦ work_tl)

    entering_reverse ∈ Bool = ((¬is_first_tick) ∧ (_phase = 0) ∧ lex_done)
    in_reverse       ∈ Bool = (_phase = 1)
    entering_parse   ∈ Bool = ((¬is_first_tick) ∧ (_phase = 1) ∧ work_is_nil)
    in_parse         ∈ Bool = (_phase = 2)

    -- ── REVERSE: pop reverse-list head, push onto forward list ────
    work ∈ TokenList
    _work ∈ TokenList
    fwd  ∈ TokenList
    _fwd ∈ TokenList
    work = (is_first_tick ? TLNil
        : (entering_reverse ? tokens
        : (in_reverse ∧ (¬work_is_nil) ? work_tl
        : _work)))
    fwd = (is_first_tick ? TLNil
        : (entering_reverse ? TLNil
        : (in_reverse ∧ (¬work_is_nil) ? TLCons(work_hd, _fwd)
        : _fwd)))

    -- ── PARSE: drop the 2-token `<kw> Ident` head, walk memberships ─
    fwd_d1 ∈ TokenList
    TLTl(l ↦ _fwd, out ↦ fwd_d1)
    fwd_d2 ∈ TokenList
    TLTl(l ↦ fwd_d1, out ↦ fwd_d2)

    rem  ∈ TokenList
    _rem ∈ TokenList

    step_decl ∈ String
    step_assert ∈ String
    step_field ∈ String
    step_pinned ∈ Bool
    step_rest ∈ TokenList
    step_ok ∈ Bool
    step_saw_ift ∈ Bool
    MembershipStep(rem ↦ _rem, decl ↦ step_decl, assertln ↦ step_assert,
        field ↦ step_field, pinned ↦ step_pinned, rest ↦ step_rest, ok ↦ step_ok,
        saw_ift ↦ step_saw_ift)

    chunk ∈ String = (step_pinned ? step_decl ++ "\n" ++ step_assert : step_decl)

    rem = (is_first_tick ? TLNil
        : (entering_parse ? fwd_d2
        : (in_parse ∧ step_ok ? step_rest
        : _rem)))

    out  ∈ String
    _out ∈ String
    out = (is_first_tick ? ""
        : (entering_parse ? ""
        : (in_parse ∧ step_ok ? (_out = "" ? chunk : _out ++ "\n" ++ chunk)
        : _out)))

    fstr  ∈ String
    _fstr ∈ String
    fstr = (is_first_tick ? ""
        : (entering_parse ? ""
        : (in_parse ∧ step_ok ? (step_field = "" ? _fstr : (_fstr = "" ? step_field : _fstr ++ " " ++ step_field))
        : _fstr)))

    phase = (is_first_tick ? 0
        : (_phase = 0 ? (lex_done ? 1 : 0)
        : (_phase = 1 ? (work_is_nil ? 2 : 1)
        : (_phase = 2 ? (step_ok ? 2 : 3)
        : 3))))

    -- ── EMIT: the tick the parse walk drains (phase 2 → 3) ────────
    emit_now ∈ Bool = ((¬is_first_tick) ∧ (_phase = 2) ∧ (¬step_ok))
    manifest ∈ String = (";; manifest: state-fields = " ++ _fstr ++ "\n"
        ++ ";; manifest: effects-name = effects\n"
        ++ ";; manifest: effect-enum-name = Effect\n"
        ++ ";; manifest: result-enum-name = Result\n"
        ++ ";; manifest: max-effects = 0")
    smtlib ∈ String = manifest ++ "\n" ++ _out

    effects ∈ Seq(Effect) = (emit_now
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(smtlib)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
