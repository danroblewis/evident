-- AST → text translator: operator + identifier fidelity (iter 3.14).
--
-- Extends the iter 3.13 translator demonstration. The original
-- (test_ast_to_text.ev) always emitted "(+ " for any binop and had no
-- EIdent arm — so a parsed `x = 1` would mis-translate to `(+ ...)`.
--
-- This fixture walks `EBinOp(OpEq, EIdent("x"), EInt(1))` and emits the
-- SMT-LIB prefix form `(= x 1)`, proving the translator now respects:
--   • the actual Op stored in the EBinOp (OpEq → "(= "), and
--   • EIdent leaves (emit the identifier string directly).
--
-- Same work-stack architecture as iter 3.13: a WorkList of WorkItem
-- (WIProcess(Expr) | WIEmit(String)). For a binop, push
-- [Process(left), Emit(" "), Process(right), Emit(")")].
--
-- expect: stdout = "[translating]"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "(= x 1)"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/parser.ev"

claim main
    initial_expr ∈ Expr = EBinOp(OpEq, EIdent("x"), EInt(1))
    initial_stack ∈ WorkList = WLCons(WIProcess(initial_expr), WLNil)

    stack  ∈ WorkList
    _stack ∈ WorkList
    output_str  ∈ String
    _output_str ∈ String

    head_item ∈ WorkItem = match _stack
        WLCons(w, _) ⇒ w
        WLNil ⇒ WIEmit("")

    tail_stack ∈ WorkList = match _stack
        WLCons(_, rest) ⇒ rest
        WLNil ⇒ WLNil

    is_empty ∈ Bool = match _stack
        WLNil ⇒ true
        _ ⇒ false

    is_process ∈ Bool = (head_item matches WIProcess(_))

    proc_expr ∈ Expr = match head_item
        WIProcess(e) ⇒ e
        _ ⇒ ENoExpr

    emit_text ∈ String = match head_item
        WIEmit(s) ⇒ s
        _ ⇒ ""

    proc_is_int   ∈ Bool = (proc_expr matches EInt(_))
    proc_is_ident ∈ Bool = (proc_expr matches EIdent(_))
    proc_is_binop ∈ Bool = (proc_expr matches EBinOp(_, _, _))

    proc_int_val ∈ Int = match proc_expr
        EInt(n) ⇒ n
        _ ⇒ 0

    proc_ident_val ∈ String = match proc_expr
        EIdent(s) ⇒ s
        _ ⇒ ""

    proc_op ∈ Op = match proc_expr
        EBinOp(o, _, _) ⇒ o
        _ ⇒ OpPlus
    op_is_eq ∈ Bool = (proc_op matches OpEq)
    binop_open ∈ String = (op_is_eq ? "(= " : "(+ ")

    proc_left ∈ Expr = match proc_expr
        EBinOp(_, l, _) ⇒ l
        _ ⇒ ENoExpr
    proc_right ∈ Expr = match proc_expr
        EBinOp(_, _, r) ⇒ r
        _ ⇒ ENoExpr

    this_emit ∈ String = (¬is_process ? emit_text : (proc_is_int ? str_from_int(proc_int_val) : (proc_is_ident ? proc_ident_val : (proc_is_binop ? binop_open : ""))))

    binop_push ∈ WorkList = WLCons(WIProcess(proc_left), WLCons(WIEmit(" "), WLCons(WIProcess(proc_right), WLCons(WIEmit(")"), tail_stack))))
    new_stack ∈ WorkList = (is_process ∧ proc_is_binop ? binop_push : tail_stack)

    stack = (is_first_tick ? initial_stack : new_stack)
    output_str = (is_first_tick ? "" : _output_str ++ this_emit)

    effects ∈ Seq(Effect) = (is_first_tick
        ? ⟨LibCall("libc", "puts", ⟨ArgStr("[translating]")⟩)⟩
        : (is_empty
            ? ⟨LibCall("libc", "puts", ⟨ArgStr(_output_str)⟩), Exit(0)⟩
            : ⟨LibCall("libc", "puts", ⟨ArgStr("  step")⟩)⟩))
