-- Seq carried as evolving FSM state across ticks — the cons→Seq carry
-- capability (task #21). A `Seq(Int)` is used as a LIFO stack with the
-- top at the END of the Seq: push 5/6/7 (ticks 1-3, append `++ ⟨v⟩`),
-- then pop them back off (ticks 4-6, drop-last via `seq_init`), printing
-- the popped top each time, then exit when empty.
--
-- This exercises every translator path the capability added:
--   * `Seq(Int)` carried as state (bootstrap discover_state_fields +
--     kernel read_state_var / pin of the array + `__len`),
--   * the carry-assignment `stack = (is_first_tick ? ⟨⟩ : …)` (Seq-typed
--     ternary + whole-array equality),
--   * append `_stack ++ ⟨v⟩`, drop-last `seq_init(_stack)`,
--   * index-from-end `_stack[#_stack - 1]` and cardinality `#_stack`.
--
-- Append/single-pop Seqs stay cheap on Z3; the push-heavy translator
-- work-stacks do NOT (symbolic-index store-chains + whole-array
-- extensional equality) — see docs/plans/blocked-cons-to-seq-perf.md,
-- which is why the work-stacks keep their cons-lists for now.
--
-- expect: stdout = "7"
-- expect: stdout = "6"
-- expect: stdout = "5"
-- expect: exit = 0
import "stdlib/kernel.ev"

claim main
    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    stack  ∈ Seq(Int)
    _stack ∈ Seq(Int)

    is_empty ∈ Bool = (#_stack = 0)
    top ∈ Int = (is_empty ? 0 - 1 : _stack[#_stack - 1])
    popped ∈ Seq(Int) = (is_empty ? ⟨⟩ : seq_init(_stack))

    stack = (is_first_tick ? ⟨⟩
        : (phase = 1 ? _stack ++ ⟨5⟩
        : (phase = 2 ? _stack ++ ⟨6⟩
        : (phase = 3 ? _stack ++ ⟨7⟩
        : popped))))

    popping ∈ Bool = (¬is_first_tick ∧ phase ≥ 4)
    done ∈ Bool = (popping ∧ is_empty)

    effects ∈ Seq(Effect) = (done
        ? ⟨Exit(0)⟩
        : (popping
            ? ⟨LibCall("libc", "puts", ⟨ArgStr(str_from_int(top))⟩)⟩
            : ⟨LibCall("libc", "getpid", ⟨⟩)⟩))
