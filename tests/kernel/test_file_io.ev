-- Multi-tick I/O: read a file, write contents back, puts confirmation.
-- Setup (test driver): writes "Hello from the file!\n" to
-- /tmp/evident_kernel_io_input.txt before running.
-- Tick 0: ReadFile → StringResult(contents) into last_results
-- Tick 1: extract contents via match, WriteFile out
-- Tick 2: puts "wrote it", Exit(0)
-- expect: stdout = "wrote it"
-- expect: exit = 0
import "stdlib/kernel.ev"

claim main
    tick_count  ∈ Int
    _tick_count ∈ Int
    tick_count = (is_first_tick ? 0 : _tick_count + 1)

    file_contents ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ "<read failed>"

    effects ∈ Seq(Effect) = (tick_count = 0
        ? ⟨ReadFile("/tmp/evident_kernel_io_input.txt")⟩
        : (tick_count = 1
            ? ⟨WriteFile("/tmp/evident_kernel_io_output.txt", file_contents)⟩
            : ⟨LibCall("libc", "puts", ⟨ArgStr("wrote it")⟩), Exit(0)⟩))
