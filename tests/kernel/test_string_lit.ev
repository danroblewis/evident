-- Phase A3: String-literal recognition with `\n` / `\t` / `\"` / `\\`
-- escapes. Mode-state FSM dispatched off the previous tick's mode:
--   mode 0 — normal · mode 1 — in string · mode 2 — escape pending
--   (0,`"`) → open; (1,`"`) → close, emit StringLit(_partial);
--   (1,`\`) → esc; (1,other) → append; (2,any) → append EscapeChar, mode 1
--
-- Input (after Evident's source escapes) is the 7-char  "hi\nx"  —
-- quote, h, i, backslash, n, x, quote; the lexed literal is the 4-char
-- hi<NL>x. On close we print the LENGTH, not the value — the real
-- newline in puts would split the line in the captured stdout.
--
-- expect: stdout = "open"
-- expect: stdout = "char"
-- expect: stdout = "char"
-- expect: stdout = "esc-start"
-- expect: stdout = "esc-n"
-- expect: stdout = "char"
-- expect: stdout = "close:4"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"

claim main
    input ∈ String = "\"hi\\nx\""

    pos  ∈ Int
    _pos ∈ Int
    pos = (is_first_tick ? 0 : _pos + 1)

    mode  ∈ Int
    _mode ∈ Int

    partial  ∈ String
    _partial ∈ String

    cur_char ∈ String = substr(input, pos, 1)

    is_quote ∈ Bool
    IsQuote(c ↦ cur_char, out ↦ is_quote)
    is_bs ∈ Bool
    IsBackslash(c ↦ cur_char, out ↦ is_bs)
    esc_char ∈ String
    EscapeChar(c ↦ cur_char, out ↦ esc_char)

    done ∈ Bool = (pos ≥ #input)

    in_normal  ∈ Bool = (_mode = 0)
    in_string  ∈ Bool = (_mode = 1)
    in_escape  ∈ Bool = (_mode = 2)

    do_open      ∈ Bool = (in_normal ∧ is_quote ∧ ¬done)
    do_close     ∈ Bool = (in_string ∧ is_quote ∧ ¬done)
    do_esc_start ∈ Bool = (in_string ∧ is_bs ∧ ¬done)
    do_esc_end   ∈ Bool = (in_escape ∧ ¬done)
    do_append    ∈ Bool = (in_string ∧ ¬is_quote ∧ ¬is_bs ∧ ¬done)

    -- _mode defaults to 0 on tick 0, so the "normal" branch handles the
    -- opening quote at pos 0 with no is_first_tick special-case.
    mode = (do_open      ? 1
        : (do_close     ? 0
        : (do_esc_start ? 2
        : (do_esc_end   ? 1
        : _mode))))

    partial = (do_open    ? ""
        : (do_close   ? ""
        : (do_append  ? _partial ++ cur_char
        : (do_esc_end ? _partial ++ esc_char
        : _partial))))

    -- Token list is Cons-prepended, so reverse-time-order.
    tokens  ∈ TokenList
    _tokens ∈ TokenList
    emitted_tok ∈ Token = StringLit(_partial)
    tokens = (do_close ? TLCons(emitted_tok, _tokens)
        : _tokens)

    closed_len_str ∈ String = str_from_int(#_partial)

    label ∈ String = (done ? "[eof]"
        : (do_open      ? "open"
        : (do_close     ? ("close:" ++ closed_len_str)
        : (do_esc_start ? "esc-start"
        : (do_esc_end   ? "esc-n"
        : (do_append    ? "char"
        : "?"))))))

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩)
