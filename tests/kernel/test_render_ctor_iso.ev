-- ISOLATION test for compiler/translate_ctor.ev's RenderExprToks.
-- Drives the renderer on hand-built TokenLists (no lexer/driver) to
-- check constructor-application + nested-Seq rendering in isolation.
--
-- expect: stdout = "(Exit 0)"
-- expect: stdout = "(seq.++ (seq.unit (Exit 0)) (seq.unit (Exit 1)))"
-- expect: stdout = "(LibCall "libc" "puts")"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler/translate_ctor.ev"

claim main
    -- Exit(0)
    toks_a ∈ TokenList = TLCons(Ident("Exit"), TLCons(LParen,
        TLCons(IntLit(0), TLCons(RParen, TLNil))))
    out_a ∈ String
    rest_a ∈ TokenList
    ok_a ∈ Bool
    RenderExprToks(toks ↦ toks_a, out ↦ out_a, rest ↦ rest_a, ok ↦ ok_a)

    -- ⟨Exit(0), Exit(1)⟩
    toks_b ∈ TokenList = TLCons(OpSeqOpen,
        TLCons(Ident("Exit"), TLCons(LParen, TLCons(IntLit(0), TLCons(RParen,
        TLCons(Comma,
        TLCons(Ident("Exit"), TLCons(LParen, TLCons(IntLit(1), TLCons(RParen,
        TLCons(OpSeqClose, TLNil)))))))))))
    out_b ∈ String
    rest_b ∈ TokenList
    ok_b ∈ Bool
    RenderExprToks(toks ↦ toks_b, out ↦ out_b, rest ↦ rest_b, ok ↦ ok_b)

    -- LibCall("libc", "puts")  — ctor with two string-atom args.
    toks_c ∈ TokenList = TLCons(Ident("LibCall"), TLCons(LParen,
        TLCons(StringLit("libc"), TLCons(Comma,
        TLCons(StringLit("puts"), TLCons(RParen, TLNil))))))
    out_c ∈ String
    rest_c ∈ TokenList
    ok_c ∈ Bool
    RenderExprToks(toks ↦ toks_c, out ↦ out_c, rest ↦ rest_c, ok ↦ ok_c)

    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    line ∈ String = (phase = 0 ? out_a : phase = 1 ? out_b : out_c)

    effects ∈ Seq(Effect) = (phase ≥ 2
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(line)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(line)⟩)⟩)
