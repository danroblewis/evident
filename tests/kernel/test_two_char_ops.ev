-- Phase A2: Two-char ASCII operator recognition
-- (++, =>, <=, >=, !=, ..) with peek-ahead and single-char fallback.
--
-- Input segments as "++ => <= >= != .. < > ." — the two-char ops,
-- then single-char fall-throughs (`<` with lookahead `>`, `>` with
-- lookahead `.`, `.` with lookahead EOF) so both paths fire.
--
-- expect: stdout = "PLUSPLUS"
-- expect: stdout = "IMPLIES"
-- expect: stdout = "LE"
-- expect: stdout = "GE"
-- expect: stdout = "NE"
-- expect: stdout = "DOTDOT"
-- expect: stdout = "LT"
-- expect: stdout = "GT"
-- expect: stdout = "DOT"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"

claim main
    input ∈ String = "++=><=>=!=..<>."

    pos  ∈ Int
    _pos ∈ Int
    -- _step is the PREVIOUS tick's recognition: 2 if it emitted a
    -- two-char op, 1 otherwise.
    _step ∈ Int
    pos = (is_first_tick ? 0 : _pos + _step)

    cur_char  ∈ String = substr(input, pos, 1)
    next_char ∈ String = substr(input, pos + 1, 1)

    two_tok ∈ Token
    two_recognized ∈ Bool
    MaybeTwoCharOp(c1 ↦ cur_char, c2 ↦ next_char, t ↦ two_tok, recognized ↦ two_recognized)

    single_tok ∈ Token
    single_recognized ∈ Bool
    SingleCharTok(c ↦ cur_char, t ↦ single_tok, recognized ↦ single_recognized)

    emit_tok ∈ Token = (two_recognized ? two_tok : single_tok)
    step ∈ Int = (two_recognized ? 2 : 1)

    done ∈ Bool = (pos ≥ #input)

    -- Drive the label off the Token variant, not the substr — that's
    -- what verifies the lexer mapping.
    is_plusplus ∈ Bool = (emit_tok matches PlusPlus)
    is_implies  ∈ Bool = (emit_tok matches OpImplies)
    is_le       ∈ Bool = (emit_tok matches OpLe)
    is_ge       ∈ Bool = (emit_tok matches OpGe)
    is_ne       ∈ Bool = (emit_tok matches OpNe)
    is_dotdot   ∈ Bool = (emit_tok matches DotDot)
    is_lt       ∈ Bool = (emit_tok matches Lt)
    is_gt       ∈ Bool = (emit_tok matches Gt)
    is_dot      ∈ Bool = (emit_tok matches Dot)

    label ∈ String = (done ? "[eof]"
        : (is_plusplus ? "PLUSPLUS"
        : (is_implies  ? "IMPLIES"
        : (is_le       ? "LE"
        : (is_ge       ? "GE"
        : (is_ne       ? "NE"
        : (is_dotdot   ? "DOTDOT"
        : (is_lt       ? "LT"
        : (is_gt       ? "GT"
        : (is_dot      ? "DOT"
        : "?"))))))))))

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩)
