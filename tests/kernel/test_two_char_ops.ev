-- Phase A2: Two-char ASCII operator recognition
-- (++, =>, <=, >=, !=, ..) with peek-ahead and single-char fallback.
--
-- Walks a hardcoded ASCII string. At each position the FSM:
--   1. reads cur_char  = input[pos]
--   2. reads next_char = input[pos+1]
--   3. asks MaybeTwoCharOp(cur, next) — if recognized, emits the
--      two-char token's label AND advances pos by 2 next tick.
--   4. else asks SingleCharTok(cur) and emits its label, advancing
--      pos by 1.
--
-- The input mixes recognized two-char ops with their single-char
-- fall-through neighbours so both code paths fire:
--   "++=><=>=!=..<>."
--    ^^|^|^^|^^|^^|^^^
--    | | |  |  |  ||||
--    | | |  |  |  ||| `.` Dot      (single, lookahead is EOF)
--    | | |  |  |  || `>` Gt        (single, lookahead is `.`)
--    | | |  |  |  | `<` Lt         (single, lookahead is `>`)
--    | | |  |  |  `..` DotDot      (two-char)
--    | | |  |  `!=` OpNe           (two-char)
--    | | |  `>=` OpGe              (two-char)
--    | | `<=` OpLe                 (two-char)
--    | `=>` OpImplies              (two-char)
--    `++` PlusPlus                 (two-char)
--
-- Tokens emitted, in order:
--   PlusPlus, Implies, Le, Ge, Ne, DotDot, Lt, Gt, Dot, [eof]
--
-- This is the acceptance test for Phase A2 of the completion
-- roadmap (see docs/plans/completion-roadmap.md).
--
-- expect: stdout = "PLUSPLUS"
-- expect: stdout = "IMPLIES"
-- expect: stdout = "LE"
-- expect: stdout = "GE"
-- expect: stdout = "NE"
-- expect: stdout = "DOTDOT"
-- expect: stdout = "LT"
-- expect: stdout = "GT"
-- expect: stdout = "DOT"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"

claim main
    input ∈ String = "++=><=>=!=..<>."

    pos  ∈ Int
    _pos ∈ Int
    -- step is set by the previous tick's recognition: 2 if a
    -- two-char op was emitted, 1 otherwise. On tick 0, pos = 0.
    _step ∈ Int
    pos = (is_first_tick ? 0 : _pos + _step)

    cur_char  ∈ String = substr(input, pos, 1)
    next_char ∈ String = substr(input, pos + 1, 1)

    two_tok ∈ Token
    two_recognized ∈ Bool
    MaybeTwoCharOp(c1 ↦ cur_char, c2 ↦ next_char, t ↦ two_tok, recognized ↦ two_recognized)

    single_tok ∈ Token
    single_recognized ∈ Bool
    SingleCharTok(c ↦ cur_char, t ↦ single_tok, recognized ↦ single_recognized)

    -- Pick the right token + step.
    emit_tok ∈ Token = (two_recognized ? two_tok : single_tok)
    step ∈ Int = (two_recognized ? 2 : 1)

    done ∈ Bool = (pos ≥ #input)

    -- Recognizers for every variant we emit. Drive the label off
    -- the token to verify the lexer mapping, not the substr.
    is_plusplus ∈ Bool = (emit_tok matches PlusPlus)
    is_implies  ∈ Bool = (emit_tok matches OpImplies)
    is_le       ∈ Bool = (emit_tok matches OpLe)
    is_ge       ∈ Bool = (emit_tok matches OpGe)
    is_ne       ∈ Bool = (emit_tok matches OpNe)
    is_dotdot   ∈ Bool = (emit_tok matches DotDot)
    is_lt       ∈ Bool = (emit_tok matches Lt)
    is_gt       ∈ Bool = (emit_tok matches Gt)
    is_dot      ∈ Bool = (emit_tok matches Dot)

    label ∈ String = (done ? "[eof]"
        : (is_plusplus ? "PLUSPLUS"
        : (is_implies  ? "IMPLIES"
        : (is_le       ? "LE"
        : (is_ge       ? "GE"
        : (is_ne       ? "NE"
        : (is_dotdot   ? "DOTDOT"
        : (is_lt       ? "LT"
        : (is_gt       ? "GT"
        : (is_dot      ? "DOT"
        : "?"))))))))))

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩)
