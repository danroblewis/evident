-- Recursive match translation: walk a MatchArmList to a nested `ite`
-- chain via a match-specialised work-stack, driving
-- compiler/translate_match.ev's MatchTranslateStep once per tick.
--
-- Pop sequence:
--   MWArms[Some⇒1, _⇒0] → "(ite ((_ is Some) e) " MWBody(1) " " MWArms[_⇒0] ")"
--   MWBody(1)           → "1"
--   MWArms[_⇒0]         → MWBody(0)  (wildcard = innermost else)
--   MWBody(0)           → "0"
--
-- expect: stdout = "(ite ((_ is Some) e) 1 0)"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/translate_match.ev"

claim main
    initial_arms ∈ MatchArmList = MACons(MArm(MPCtor("Some", MBNil), EInt(1)),
        MACons(MArm(MPWildcard, EInt(0)), MANil))
    initial_stack ∈ MatchWorkList = MWLCons(MWArms(initial_arms), MWLNil)

    stack  ∈ MatchWorkList
    _stack ∈ MatchWorkList
    out  ∈ String
    _out ∈ String

    hd ∈ MatchWork = match _stack
        MWLCons(h, _) ⇒ h
        MWLNil ⇒ MWEmit("")
    rst ∈ MatchWorkList = match _stack
        MWLCons(_, t) ⇒ t
        MWLNil ⇒ MWLNil
    is_empty ∈ Bool = match _stack
        MWLNil ⇒ true
        _ ⇒ false

    nstack ∈ MatchWorkList
    em ∈ String
    MatchTranslateStep(scrutinee ↦ "e", head ↦ hd, rest ↦ rst, new_stack ↦ nstack, emit ↦ em)

    stack = (is_first_tick ? initial_stack : nstack)
    out = (is_first_tick ? "" : _out ++ em)

    done ∈ Bool = (¬is_first_tick ∧ is_empty)

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(out)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
