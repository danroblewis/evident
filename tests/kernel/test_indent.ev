-- Phase A6: Indentation tracking.
--
-- The Rust lexer (runtime/src/lexer.rs lines 102-135) emits an
-- `Indent(n)` token at the start of each non-blank, non-comment
-- line, where `n` is the leading-space column count (tab = 4).
-- Blank lines and comment-only lines emit nothing. Inside a paren
-- group both Indent and Newline are suppressed. The PARSER then
-- compares Indent(n) values to determine body-block membership
-- (runtime/src/parser/schema.rs::parse_indented_body) — there is no
-- Dedent token; "leaving a block" is just an Indent whose n is
-- smaller than the block's chosen indent level.
--
-- This fixture exercises the per-line indent counter. Input is a
-- four-line program with varying indent levels:
--   "a\n  b\n    c\nd\n"
-- Line-by-line:
--   line 1: "a"        — indent 0 → emit IND(0), content "a"
--   line 2: "  b"      — indent 2 → emit IND(2), content "b"
--   line 3: "    c"    — indent 4 → emit IND(4), content "c"
--   line 4: "d"        — indent 0 → emit IND(0), content "d"
-- The fixture's FSM scans char-by-char and, on transitioning from
-- "in leading whitespace" to "in content," emits the accumulated
-- indent count via the new Indent(n) token. The label format
-- mirrors test_consolidated_lexer.ev:
--   "IND(0)" / "IND(2)" / "IND(4)" — Indent tokens
--   "ID(c)"  — Ident tokens for each line's content char
--   "NL"     — Newline tokens at \n
--   "[eof]"  — halting signal
--
-- The FSM has TWO state carries beyond pos:
--   at_line_start ∈ Bool — true at tick 0 and after every Newline
--     emit. While true, indent-counting chars (' '/'\t') bump
--     `indent`; the first content char flips it to false and
--     triggers the Indent emit.
--   indent ∈ Int — accumulating leading-space count for the
--     current line; reset on Newline.
--
-- expect: stdout = "IND(0)"
-- expect: stdout = "ID(a)"
-- expect: stdout = "NL"
-- expect: stdout = "  -"
-- expect: stdout = "  -"
-- expect: stdout = "IND(2)"
-- expect: stdout = "ID(b)"
-- expect: stdout = "NL"
-- expect: stdout = "  -"
-- expect: stdout = "  -"
-- expect: stdout = "  -"
-- expect: stdout = "  -"
-- expect: stdout = "IND(4)"
-- expect: stdout = "ID(c)"
-- expect: stdout = "NL"
-- expect: stdout = "IND(0)"
-- expect: stdout = "ID(d)"
-- expect: stdout = "NL"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/lexer.ev"

claim main
    input ∈ String = "a\n  b\n    c\nd\n"

    pos  ∈ Int
    _pos ∈ Int
    pos = (is_first_tick ? 0 : _pos + 1)

    cur_char  ∈ String = substr(input, pos, 1)

    width   ∈ Int
    IndentWidth(c ↦ cur_char, w ↦ width)
    is_indent_char ∈ Bool
    IsIndentChar(c ↦ cur_char, out ↦ is_indent_char)

    is_newline ∈ Bool = (cur_char = "\n")
    is_alpha   ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)

    done ∈ Bool = (pos ≥ #input)

    -- Two state carries. Tick 0 is at line start with indent 0.
    -- On all subsequent ticks:
    --   - if cur_char is '\n', this tick emits Newline and resets
    --     for the next line (both carries fire from the "after
    --     newline" branch on the NEXT tick because is_newline
    --     forces at_line_start = true).
    --   - if cur_char is space/tab AND we were already at line
    --     start, accumulate.
    --   - if cur_char is content AND we were at line start, this
    --     is the transition tick: emit Indent(indent) + content,
    --     and from next tick onward we are no longer at line start.
    at_line_start  ∈ Bool
    _at_line_start ∈ Bool
    indent  ∈ Int
    _indent ∈ Int

    -- IMPORTANT: gate _-references behind is_first_tick so tick 0
    -- doesn't read the unconstrained carry. The `effective_*`
    -- locals materialize "what the carry would be on tick 1+, or
    -- the initial value on tick 0" so downstream Bool/Int
    -- expressions read one source of truth.
    effective_prev_at_line_start ∈ Bool = (is_first_tick ? true : _at_line_start)
    effective_prev_indent        ∈ Int  = (is_first_tick ? 0    : _indent)

    -- at_line_start carries forward iff we're still seeing indent
    -- chars in the prefix, OR resets to true after a newline.
    -- After the transition tick (content), flips to false until
    -- the next newline.
    at_line_start = (is_newline
                   ? true
                   : (effective_prev_at_line_start ∧ is_indent_char))

    -- indent accumulates while at_line_start; resets to 0 on
    -- newline; otherwise carries previous value (so the transition
    -- tick can read it for the Indent emit, and remains stable
    -- through any post-content chars on the same line — though
    -- this fixture's inputs have only one content char per line).
    indent = (is_newline
            ? 0
            : (effective_prev_at_line_start ∧ is_indent_char
                ? effective_prev_indent + width
                : effective_prev_indent))

    -- Emit decisions. The "transition" tick is the one where we
    -- were at line start last tick AND the current char is content
    -- (not indent, not newline, not eof).
    indent_emit ∈ Bool = (effective_prev_at_line_start ∧ ¬is_indent_char ∧ ¬is_newline ∧ ¬done)
    newline_emit ∈ Bool = (is_newline ∧ ¬done)
    ident_emit ∈ Bool = (is_alpha ∧ ¬done)

    -- The Indent token carries the current line's accumulated
    -- indent count. By the recurrence above, on the transition
    -- tick `indent` equals the accumulated leading-space count.
    indent_tok ∈ Token = Indent(indent)
    ident_tok  ∈ Token = Ident(cur_char)

    indent_line ∈ String = "IND(" ++ str_from_int(indent) ++ ")"
    ident_line  ∈ String = "ID(" ++ cur_char ++ ")"

    -- A transition tick emits TWO tokens (Indent then Ident); the
    -- effects list lengths differ per tick. "Skip" ticks (inside
    -- a leading-whitespace prefix) emit a single "  -" marker so
    -- the effects Seq always has at least one element (works around
    -- the kernel's "effects var not in model" failure for empty
    -- Seqs).
    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr("[eof]")⟩), Exit(0)⟩
        : (indent_emit ∧ ident_emit
            ? ⟨LibCall("libc", "puts", ⟨ArgStr(indent_line)⟩),
                LibCall("libc", "puts", ⟨ArgStr(ident_line)⟩)⟩
            : (indent_emit
                ? ⟨LibCall("libc", "puts", ⟨ArgStr(indent_line)⟩)⟩
                : (newline_emit
                    ? ⟨LibCall("libc", "puts", ⟨ArgStr("NL")⟩)⟩
                    : (ident_emit
                        ? ⟨LibCall("libc", "puts", ⟨ArgStr(ident_line)⟩)⟩
                        : ⟨LibCall("libc", "puts", ⟨ArgStr("  -")⟩)⟩)))))
