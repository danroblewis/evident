-- Real self-hosted lexer: walks "(4+2)" one char per tick, building a
-- TokenList of tokens via Datatype state carry (iter 3.2).
--
-- Validates that text processing + structured-data-carry both work on
-- the kernel, the two foundations of self-hosting.
--
-- Output line per character:
--   "  emit: <char>" for digits / operators / alpha
--   "  skip" for whitespace
--   "[eof]" when past the end
--
-- expect: stdout = "  emit: ("
-- expect: stdout = "  emit: 4"
-- expect: stdout = "  emit: +"
-- expect: stdout = "  emit: 2"
-- expect: stdout = "  emit: )"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"

claim main
    input ∈ String = "(4+2)"

    pos  ∈ Int
    _pos ∈ Int
    pos = (is_first_tick ? 0 : _pos + 1)

    tokens  ∈ TokenList
    _tokens ∈ TokenList

    cur_char ∈ String = substr(input, pos, 1)

    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)
    is_dig ∈ Bool
    IsDigitChar(c ↦ cur_char, out ↦ is_dig)
    is_alpha ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)
    op_tok ∈ Token
    is_op ∈ Bool
    SingleCharTok(c ↦ cur_char, t ↦ op_tok, recognized ↦ is_op)

    dig_val ∈ Int
    DigitToInt(c ↦ cur_char, n ↦ dig_val)

    done ∈ Bool = (pos ≥ #input)

    this_tok ∈ Token = (is_dig ? IntLit(dig_val) : (is_op ? op_tok : (is_alpha ? Ident(cur_char) : ErrTok(cur_char))))

    tokens = (is_first_tick ? TLNil : (done ? _tokens : (is_ws ? _tokens : TLCons(this_tok, _tokens))))

    label ∈ String = (done ? "[eof]" : (is_ws ? "  skip" : ("  emit: " ++ cur_char)))

    effects ∈ Seq(Effect) = (done ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩ : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩)
