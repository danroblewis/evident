-- Keyword-recognizing lexer (iter 3.6).
--
-- Walks "claim hello type fsm\n" and emits keyword tokens (KwClaim,
-- KwType, KwFsm) where the alpha run matches a known keyword,
-- otherwise Ident.
--
-- The trick: at the boundary tick, run the collected `_partial`
-- through MaybeKeyword (stdlib/lexer.ev) which returns either the
-- matching Kw* variant or Ident(s).
--
-- Resulting TokenList (reversed because Cons-prepends):
--   TLCons(KwFsm, TLCons(KwType, TLCons(Ident("hello"), TLCons(KwClaim, TLNil))))
--
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: claim"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "ident: hello"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: type"
-- expect: stdout = "  start"
-- expect: stdout = "  cont"
-- expect: stdout = "  cont"
-- expect: stdout = "kw: fsm"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/lexer.ev"

claim main
    input  ∈ String
    _input ∈ String
    read_result ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ "<no-read>"
    input = (is_first_tick ? "" : (_input = "" ? read_result : _input))

    pos  ∈ Int
    _pos ∈ Int
    partial  ∈ String
    _partial ∈ String

    pos = (is_first_tick ? 0 - 1 : (_input = "" ? 0 : _pos + 1))

    cur_char ∈ String = substr(input, pos, 1)
    is_alpha ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)
    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)

    was_collecting ∈ Bool = (#_partial > 0)
    done ∈ Bool = ((pos ≥ #input) ∧ (#input > 0))
    in_range ∈ Bool = ((pos ≥ 0) ∧ ¬done)

    continuing ∈ Bool = (was_collecting ∧ is_alpha ∧ in_range)
    finishing  ∈ Bool = (was_collecting ∧ ((¬is_alpha ∧ in_range) ∨ done))
    starting   ∈ Bool = ((¬was_collecting) ∧ is_alpha ∧ in_range)

    partial = (is_first_tick ? "" : (continuing ? _partial ++ cur_char : (starting ? cur_char : "")))

    finish_only ∈ Bool = (finishing ∧ ((is_ws ∨ done)))

    classified_tok ∈ Token
    MaybeKeyword(s ↦ _partial, t ↦ classified_tok)

    tokens  ∈ TokenList
    _tokens ∈ TokenList
    tokens = (is_first_tick ? TLNil
            : (finish_only ? TLCons(classified_tok, _tokens)
            : _tokens))

    halting ∈ Bool = (done ∧ ¬was_collecting)

    is_kw ∈ Bool = ((_partial = "claim") ∨ (_partial = "type") ∨ (_partial = "schema") ∨ (_partial = "fsm") ∨ (_partial = "enum") ∨ (_partial = "import") ∨ (_partial = "match"))

    label ∈ String = (halting ? "[eof]" : (pos < 0 ? "got input" : (finish_only ? (is_kw ? ("kw: " ++ _partial) : ("ident: " ++ _partial)) : (is_ws ? "  skip" : (continuing ? "  cont" : (starting ? "  start" : "  ?"))))))

    effects ∈ Seq(Effect) = (is_first_tick ? ⟨ReadFile("/tmp/evident_kw_input.txt")⟩ : (halting ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩ : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩))
