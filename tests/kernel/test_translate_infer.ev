-- C12: type-inference from Expr RHS.
--
-- Exercises InferType over four canonical RHS shapes: eq-binop → Bool,
-- arith-binop → Int, bare int literal → Int, bare EIdent → ok=false
-- (an identifier's type is opaque without a whole-program lookup, so
-- the per-Expr probe defers). One puts per tick.
--
-- expect: stdout = "[start]"
-- expect: stdout = "A_ok=true"
-- expect: stdout = "A_type=Bool"
-- expect: stdout = "B_ok=true"
-- expect: stdout = "B_type=Int"
-- expect: stdout = "C_ok=true"
-- expect: stdout = "C_type=Int"
-- expect: stdout = "D_ok=false"
-- expect: stdout = "D_type="
-- expect: stdout = "[done]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/translate_infer.ev"

claim main
    a_rhs ∈ Expr = EBinOp(OpEq, EIdent("x"), EInt(5))
    a_inferred ∈ String
    a_ok ∈ Bool
    InferType(rhs ↦ a_rhs, inferred ↦ a_inferred, ok ↦ a_ok)

    b_rhs ∈ Expr = EBinOp(OpPlus, EInt(1), EInt(2))
    b_inferred ∈ String
    b_ok ∈ Bool
    InferType(rhs ↦ b_rhs, inferred ↦ b_inferred, ok ↦ b_ok)

    c_rhs ∈ Expr = EInt(42)
    c_inferred ∈ String
    c_ok ∈ Bool
    InferType(rhs ↦ c_rhs, inferred ↦ c_inferred, ok ↦ c_ok)

    d_rhs ∈ Expr = EIdent("foo")
    d_inferred ∈ String
    d_ok ∈ Bool
    InferType(rhs ↦ d_rhs, inferred ↦ d_inferred, ok ↦ d_ok)

    step ∈ Int
    _step ∈ Int
    step = (is_first_tick ? 0 : _step + 1)

    a_ok_str   ∈ String = (a_ok ? "A_ok=true" : "A_ok=false")
    a_type_str ∈ String = "A_type=" ++ a_inferred
    b_ok_str   ∈ String = (b_ok ? "B_ok=true" : "B_ok=false")
    b_type_str ∈ String = "B_type=" ++ b_inferred
    c_ok_str   ∈ String = (c_ok ? "C_ok=true" : "C_ok=false")
    c_type_str ∈ String = "C_type=" ++ c_inferred
    d_ok_str   ∈ String = (d_ok ? "D_ok=true" : "D_ok=false")
    d_type_str ∈ String = "D_type=" ++ d_inferred

    label ∈ String = (step = 0 ? "[start]"
        : (step = 1 ? a_ok_str
        : (step = 2 ? a_type_str
        : (step = 3 ? b_ok_str
        : (step = 4 ? b_type_str
        : (step = 5 ? c_ok_str
        : (step = 6 ? c_type_str
        : (step = 7 ? d_ok_str
        : (step = 8 ? d_type_str
        : "[done]")))))))))

    done ∈ Bool = (step ≥ 9)

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩)
