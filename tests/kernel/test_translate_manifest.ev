-- Phase C14: SMT-LIB manifest header emission.
--
-- Builds a hardcoded StateFieldList with two fields:
--
--     SFLCons(SField("count", "Int"),
--             SFLCons(SField("buf", "String"),
--                     SFLNil))
--
-- and invokes ManifestHeader with max_effects = 4. The resulting
-- single String embeds four `\n` separators; one puts produces all
-- five output lines (the kernel test driver compares against the
-- `-- expect:` lines joined with `\n`).
--
-- This is the Evident-side counterpart of runtime/src/emit.rs's
-- manifest-prefix emitter — the missing piece called out by Phase C
-- of docs/plans/completion-roadmap.md.
--
-- expect: stdout = ";; manifest: state-fields = count:Int buf:String"
-- expect: stdout = ";; manifest: effects-name = effects"
-- expect: stdout = ";; manifest: effect-enum-name = Effect"
-- expect: stdout = ";; manifest: result-enum-name = Result"
-- expect: stdout = ";; manifest: max-effects = 4"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/translate_manifest.ev"

claim main
    fields ∈ StateFieldList = SFLCons(SField("count", "Int"),
                                       SFLCons(SField("buf", "String"),
                                               SFLNil))

    header ∈ String
    ManifestHeader(fields ↦ fields, max_effects ↦ 4, out ↦ header)

    effects ∈ Seq(Effect) = ⟨
        LibCall("libc", "puts", ⟨ArgStr(header)⟩),
        Exit(0)
    ⟩
