-- Consolidated self-hosted lexer: multi-char idents, int-literal
-- accumulator, keyword recognition, comment skipping (mode state),
-- single-char operators. Input "claim x = 1\n" → KwClaim, Ident("x"),
-- Eq, IntLit(1) after Cons-list reversal. Diagnostic labels: KW/ID/INT/OP
-- per emitted token, "?" in-progress collection, "-" whitespace skip.
--
-- expect: stdout = "  ?"
-- expect: stdout = "  ?"
-- expect: stdout = "  ?"
-- expect: stdout = "  ?"
-- expect: stdout = "  ?"
-- expect: stdout = "KW(claim)"
-- expect: stdout = "  ?"
-- expect: stdout = "ID(x)"
-- expect: stdout = "OP(=)"
-- expect: stdout = "  -"
-- expect: stdout = "  ?"
-- expect: stdout = "INT(1)"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"

claim main
    input  ∈ String
    _input ∈ String
    read_result ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ "<no-read>"
    input = (is_first_tick ? "" : (_input = "" ? read_result : _input))

    pos  ∈ Int
    _pos ∈ Int
    pos = (is_first_tick ? 0 - 1 : (_input = "" ? 0 : _pos + 1))

    mode  ∈ Int
    _mode ∈ Int
    partial_str  ∈ String
    _partial_str ∈ String
    partial_int  ∈ Int
    _partial_int ∈ Int

    cur_char ∈ String = substr(input, pos, 1)
    next_char ∈ String = substr(input, pos + 1, 1)

    is_dash ∈ Bool = (cur_char = "-")
    is_next_dash ∈ Bool = (next_char = "-")
    is_newline ∈ Bool = (cur_char = "\n")
    is_alpha ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)
    is_dig ∈ Bool
    IsDigitChar(c ↦ cur_char, out ↦ is_dig)
    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)
    op_tok ∈ Token
    is_op ∈ Bool
    SingleCharTok(c ↦ cur_char, t ↦ op_tok, recognized ↦ is_op)
    dig_val ∈ Int
    DigitToInt(c ↦ cur_char, n ↦ dig_val)

    done ∈ Bool = ((pos ≥ #input) ∧ (#input > 0))
    in_range ∈ Bool = ((pos ≥ 0) ∧ ¬done)

    start_comment ∈ Bool = ((_mode = 0) ∧ is_dash ∧ is_next_dash ∧ in_range)
    end_comment ∈ Bool = ((_mode = 1) ∧ is_newline)
    mode = (is_first_tick ? 0 : (start_comment ? 1 : (end_comment ? 0 : _mode)))
    in_comment ∈ Bool = (mode = 1)

    was_collecting_str ∈ Bool = (#_partial_str > 0)
    was_collecting_int ∈ Bool = (_partial_int ≥ 0)

    str_continuing ∈ Bool = (was_collecting_str ∧ is_alpha ∧ in_range ∧ ¬in_comment)
    str_finishing ∈ Bool = (was_collecting_str ∧ ((¬is_alpha ∧ in_range) ∨ done ∨ in_comment))
    str_starting ∈ Bool = ((¬was_collecting_str) ∧ is_alpha ∧ in_range ∧ ¬in_comment)

    int_continuing ∈ Bool = (was_collecting_int ∧ is_dig ∧ in_range ∧ ¬in_comment)
    int_finishing ∈ Bool = (was_collecting_int ∧ ((¬is_dig ∧ in_range) ∨ done ∨ in_comment))
    int_starting ∈ Bool = ((¬was_collecting_int) ∧ is_dig ∧ in_range ∧ ¬in_comment)

    partial_str = (is_first_tick ? "" : (str_continuing ? _partial_str ++ cur_char : (str_starting ? cur_char : "")))
    partial_int = (is_first_tick ? 0 - 1 : (int_continuing ? (_partial_int * 10) + dig_val : (int_starting ? dig_val : 0 - 1)))

    classified_str ∈ Token
    MaybeKeyword(s ↦ _partial_str, t ↦ classified_str)
    int_tok ∈ Token = IntLit(_partial_int)

    finish_str_only ∈ Bool = (str_finishing ∧ ((is_ws ∨ done ∨ in_comment) ∨ start_comment))
    finish_int_only ∈ Bool = (int_finishing ∧ ((is_ws ∨ done ∨ in_comment) ∨ start_comment))
    finish_str_with_op ∈ Bool = (str_finishing ∧ is_op ∧ in_range)
    finish_int_with_op ∈ Bool = (int_finishing ∧ is_op ∧ in_range)
    char_only ∈ Bool = ((¬was_collecting_str) ∧ (¬was_collecting_int) ∧ is_op ∧ in_range ∧ ¬in_comment ∧ ¬start_comment)

    tokens  ∈ TokenList
    _tokens ∈ TokenList
    tokens = (is_first_tick ? TLNil
            : (finish_str_with_op ? TLCons(op_tok, TLCons(classified_str, _tokens))
            : (finish_int_with_op ? TLCons(op_tok, TLCons(int_tok, _tokens))
            : (finish_str_only ? TLCons(classified_str, _tokens)
            : (finish_int_only ? TLCons(int_tok, _tokens)
            : (char_only ? TLCons(op_tok, _tokens)
            : _tokens))))))

    halting ∈ Bool = (done ∧ ¬was_collecting_str ∧ ¬was_collecting_int)
    is_kw ∈ Bool = ((_partial_str = "claim") ∨ (_partial_str = "type") ∨ (_partial_str = "schema") ∨ (_partial_str = "fsm") ∨ (_partial_str = "enum") ∨ (_partial_str = "import") ∨ (_partial_str = "match"))

    label ∈ String = (halting ? "[eof]" : (pos < 0 ? "got input" : (start_comment ? "  # comment" : (in_comment ? "  ." : (finish_str_with_op ? ((is_kw ? ("KW(" ++ _partial_str ++ ")") : ("ID(" ++ _partial_str ++ ")")) ++ " + OP(" ++ cur_char ++ ")") : (finish_int_with_op ? ("INT(" ++ str_from_int(_partial_int) ++ ") + OP(" ++ cur_char ++ ")") : (finish_str_only ? (is_kw ? ("KW(" ++ _partial_str ++ ")") : ("ID(" ++ _partial_str ++ ")")) : (finish_int_only ? ("INT(" ++ str_from_int(_partial_int) ++ ")") : (char_only ? ("OP(" ++ cur_char ++ ")") : (is_ws ? "  -" : "  ?"))))))))))

    effects ∈ Seq(Effect) = (is_first_tick ? ⟨ReadFile("/tmp/evident_consolidated_input.txt")⟩ : (halting ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩ : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩))
