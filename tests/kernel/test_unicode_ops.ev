-- Phase A1: Unicode operator recognition (вИИ, вЗТ, вЯ®, вЯ©, вЖ¶, вЙ§, вЙ•, вЙ†,
-- вИІ, вИ®, ¬ђ, вИА, вИГ).
--
-- Walks a hardcoded string of 13 single-char Unicode operators.
-- For each char, calls SingleCharTok and emits the operator's
-- semantic label. Halts on end-of-input.
--
-- The input is a String constant baked into the program вАФ no file
-- read needed, so the first tick walks position 0 directly. The
-- multi-byte UTF-8 codepoint extraction works because the
-- runtime's `substr` lowers to Z3's `seq.extract` on a string
-- treated as a codepoint sequence; each Unicode op is one
-- codepoint, so `substr(s, i, 1)` yields exactly one logical char.
--
-- This is the acceptance test for Phase A1 of the completion
-- roadmap (see docs/plans/completion-roadmap.md).
--
-- expect: stdout = "IN"
-- expect: stdout = "IMPLIES"
-- expect: stdout = "SEQOPEN"
-- expect: stdout = "SEQCLOSE"
-- expect: stdout = "MAPSTO"
-- expect: stdout = "LE"
-- expect: stdout = "GE"
-- expect: stdout = "NE"
-- expect: stdout = "AND"
-- expect: stdout = "OR"
-- expect: stdout = "NOT"
-- expect: stdout = "FORALL"
-- expect: stdout = "EXISTS"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/lexer.ev"

claim main
    input вИИ String = "вИИвЗТвЯ®вЯ©вЖ¶вЙ§вЙ•вЙ†вИІвИ®¬ђвИАвИГ"

    pos  вИИ Int
    _pos вИИ Int
    pos = (is_first_tick ? 0 : _pos + 1)

    cur_char вИИ String = substr(input, pos, 1)

    op_tok вИИ Token
    is_op вИИ Bool
    SingleCharTok(c вЖ¶ cur_char, t вЖ¶ op_tok, recognized вЖ¶ is_op)

    done вИИ Bool = (pos вЙ• #input)

    -- Drive the label off the Token variant emitted by SingleCharTok
    -- (not off cur_char directly) вАФ that's what verifies the lexer
    -- mapping rather than the substr extraction. `matches` works as
    -- a recognizer; one per variant.
    is_in       вИИ Bool = (op_tok matches OpIn)
    is_implies  вИИ Bool = (op_tok matches OpImplies)
    is_sopen    вИИ Bool = (op_tok matches OpSeqOpen)
    is_sclose   вИИ Bool = (op_tok matches OpSeqClose)
    is_mapsto   вИИ Bool = (op_tok matches OpMapsto)
    is_le       вИИ Bool = (op_tok matches OpLe)
    is_ge       вИИ Bool = (op_tok matches OpGe)
    is_ne       вИИ Bool = (op_tok matches OpNe)
    is_and      вИИ Bool = (op_tok matches OpAnd)
    is_or       вИИ Bool = (op_tok matches OpOr)
    is_not      вИИ Bool = (op_tok matches OpNot)
    is_forall   вИИ Bool = (op_tok matches OpForall)
    is_exists   вИИ Bool = (op_tok matches OpExists)

    label вИИ String = (done ? "[eof]"
        : (is_in      ? "IN"
        : (is_implies ? "IMPLIES"
        : (is_sopen   ? "SEQOPEN"
        : (is_sclose  ? "SEQCLOSE"
        : (is_mapsto  ? "MAPSTO"
        : (is_le      ? "LE"
        : (is_ge      ? "GE"
        : (is_ne      ? "NE"
        : (is_and     ? "AND"
        : (is_or      ? "OR"
        : (is_not     ? "NOT"
        : (is_forall  ? "FORALL"
        : (is_exists  ? "EXISTS"
        : "?"))))))))))))))

    effects вИИ Seq(Effect) = (done
        ? вЯ®LibCall("libc", "puts", вЯ®ArgStr(label)вЯ©), Exit(0)вЯ©
        : вЯ®LibCall("libc", "puts", вЯ®ArgStr(label)вЯ©)вЯ©)
