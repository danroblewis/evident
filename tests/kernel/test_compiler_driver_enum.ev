-- Grammar wave 3, item 1: a top-level `enum` declaration (incl. payload
-- variants) → SMT-LIB `(declare-datatypes …)`.
--
-- Nothing is hardcoded as tokens/AST: the source string is lexed
-- character-by-character (the consolidated-lexer FSM shared with
-- compiler.ev / the wave-2 fixtures), reversed to forward order, then
-- walked ONE TOKEN PER TICK by an enum-parse state machine that builds
-- each variant and renders it via compiler/translate.ev's VariantText
-- (the C1 pass), accumulating the variant-group string. The final
-- (declare-datatypes …) block is assembled by EnumDeclSmtlib.
-- See docs/plans/grammar-wave3.md and docs/plans/grammar-coverage-survey.md §3.
--
-- Source: "enum Box = Pair(Int, Int) | Empty\n" exercises a 2-field
-- payload variant AND a nullary variant in one enum.
--
-- expect: stdout = "(declare-datatypes ((Box 0)) (((Pair (Pair__f0 Int) (Pair__f1 Int)) (Empty))))"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler/translate.ev"

claim main
    input ∈ String = "enum Box = Pair(Int, Int) | Empty\n"

    -- ── LEX state (consolidated-lexer FSM, reverse-order tokens) ──
    pos  ∈ Int
    _pos ∈ Int
    pos = (is_first_tick ? 0 - 1 : _pos + 1)

    partial_str  ∈ String
    _partial_str ∈ String
    partial_int  ∈ Int
    _partial_int ∈ Int

    cur_char ∈ String = substr(input, pos, 1)

    is_alpha ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)
    is_dig ∈ Bool
    IsDigitChar(c ↦ cur_char, out ↦ is_dig)
    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)
    op_tok ∈ Token
    is_op ∈ Bool
    SingleCharTok(c ↦ cur_char, t ↦ op_tok, recognized ↦ is_op)
    dig_val ∈ Int
    DigitToInt(c ↦ cur_char, n ↦ dig_val)

    done ∈ Bool = ((pos ≥ #input) ∧ (#input > 0))
    in_range ∈ Bool = ((pos ≥ 0) ∧ ¬done)

    was_collecting_str ∈ Bool = (#_partial_str > 0)
    was_collecting_int ∈ Bool = (_partial_int ≥ 0)

    str_continuing ∈ Bool = (was_collecting_str ∧ is_alpha ∧ in_range)
    str_finishing  ∈ Bool = (was_collecting_str ∧ ((¬is_alpha ∧ in_range) ∨ done))
    str_starting   ∈ Bool = ((¬was_collecting_str) ∧ is_alpha ∧ in_range)

    int_continuing ∈ Bool = (was_collecting_int ∧ is_dig ∧ in_range)
    int_finishing  ∈ Bool = (was_collecting_int ∧ ((¬is_dig ∧ in_range) ∨ done))
    int_starting   ∈ Bool = ((¬was_collecting_int) ∧ is_dig ∧ in_range)

    partial_str = (is_first_tick ? "" : (str_continuing ? _partial_str ++ cur_char : (str_starting ? cur_char : "")))
    partial_int = (is_first_tick ? 0 - 1 : (int_continuing ? (_partial_int * 10) + dig_val : (int_starting ? dig_val : 0 - 1)))

    classified_str ∈ Token
    MaybeKeyword(s ↦ _partial_str, t ↦ classified_str)
    int_tok ∈ Token = IntLit(_partial_int)

    finish_str_only    ∈ Bool = (str_finishing ∧ (is_ws ∨ done))
    finish_int_only    ∈ Bool = (int_finishing ∧ (is_ws ∨ done))
    finish_str_with_op ∈ Bool = (str_finishing ∧ is_op ∧ in_range)
    finish_int_with_op ∈ Bool = (int_finishing ∧ is_op ∧ in_range)
    char_only          ∈ Bool = ((¬was_collecting_str) ∧ (¬was_collecting_int) ∧ is_op ∧ in_range)

    tokens  ∈ TokenList
    _tokens ∈ TokenList
    tokens = (is_first_tick ? TLNil
            : (finish_str_with_op ? TLCons(op_tok, TLCons(classified_str, _tokens))
            : (finish_int_with_op ? TLCons(op_tok, TLCons(int_tok, _tokens))
            : (finish_str_only ? TLCons(classified_str, _tokens)
            : (finish_int_only ? TLCons(int_tok, _tokens)
            : (char_only ? TLCons(op_tok, _tokens)
            : _tokens))))))

    lex_done ∈ Bool = (done ∧ ¬was_collecting_str ∧ ¬was_collecting_int ∧ ¬is_first_tick)

    -- ── PHASE control (0 lex · 1 reverse · 2 parse+render · 3 emit) ──
    phase  ∈ Int
    _phase ∈ Int

    work_is_nil ∈ Bool = match _work
        TLNil ⇒ true
        _ ⇒ false
    work_hd ∈ Token = match _work
        TLCons(h, _) ⇒ h
        TLNil ⇒ EofTok
    work_tl ∈ TokenList = match _work
        TLCons(_, t) ⇒ t
        TLNil ⇒ TLNil

    entering_reverse ∈ Bool = ((¬is_first_tick) ∧ (_phase = 0) ∧ lex_done)
    in_reverse       ∈ Bool = (_phase = 1)
    entering_parse   ∈ Bool = ((¬is_first_tick) ∧ (_phase = 1) ∧ work_is_nil)
    in_parse         ∈ Bool = (_phase = 2)

    -- ── REVERSE: pop reverse-list head, push onto forward list ────
    work ∈ TokenList
    _work ∈ TokenList
    fwd  ∈ TokenList
    _fwd ∈ TokenList
    work = (is_first_tick ? TLNil
        : (entering_reverse ? tokens
        : (in_reverse ∧ (¬work_is_nil) ? work_tl
        : _work)))
    fwd = (is_first_tick ? TLNil
        : (entering_reverse ? TLNil
        : (in_reverse ∧ (¬work_is_nil) ? TLCons(work_hd, _fwd)
        : _fwd)))

    -- ── PARSE+RENDER: one token per tick over the forward list ────
    -- ephase: 1 KwEnum · 2 name · 3 Eq · 4 variant-name · 5 after-name
    --         (LParen→6, Pipe/end→finalize) · 6 field-type · 7 after-field
    --         (Comma→6, RParen→8) · 8 after-fields (Pipe/end→finalize)
    plist  ∈ TokenList
    _plist ∈ TokenList
    ephase  ∈ Int
    _ephase ∈ Int
    ename   ∈ String
    _ename  ∈ String
    body    ∈ String
    _body   ∈ String
    first_v  ∈ Bool
    _first_v ∈ Bool
    cur_name  ∈ String
    _cur_name ∈ String
    fcount  ∈ Int
    _fcount ∈ Int
    fA  ∈ String
    _fA ∈ String
    fB  ∈ String
    _fB ∈ String
    fC  ∈ String
    _fC ∈ String

    ptok ∈ Token = match _plist
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    ptail ∈ TokenList = match _plist
        TLCons(_, t) ⇒ t
        TLNil ⇒ TLNil
    plist_nil ∈ Bool = match _plist
        TLNil ⇒ true
        _ ⇒ false

    p_is_enum   ∈ Bool = (ptok matches KwEnum)
    p_is_ident  ∈ Bool = (ptok matches Ident(_))
    p_is_eq     ∈ Bool = (ptok matches Eq)
    p_is_lp     ∈ Bool = (ptok matches LParen)
    p_is_rp     ∈ Bool = (ptok matches RParen)
    p_is_comma  ∈ Bool = (ptok matches Comma)
    p_is_pipe   ∈ Bool = (ptok matches Pipe)
    p_id ∈ String = match ptok
        Ident(s) ⇒ s
        _ ⇒ ""

    e1 ∈ Bool = (_ephase = 1)
    e2 ∈ Bool = (_ephase = 2)
    e3 ∈ Bool = (_ephase = 3)
    e4 ∈ Bool = (_ephase = 4)
    e5 ∈ Bool = (_ephase = 5)
    e6 ∈ Bool = (_ephase = 6)
    e7 ∈ Bool = (_ephase = 7)
    e8 ∈ Bool = (_ephase = 8)

    -- A variant is pending (name read, awaiting boundary) in e5 or e8.
    have_pending ∈ Bool = (e5 ∨ e8)
    at_boundary  ∈ Bool = (p_is_pipe ∨ plist_nil)
    finalize     ∈ Bool = (in_parse ∧ have_pending ∧ at_boundary)

    -- Reconstruct the EnumVariantDecl from the carried slots and render.
    cur_fields ∈ EVFieldList = (_fcount = 0 ? EVFNil
        : _fcount = 1 ? EVFCons(EVFType(_fA), EVFNil)
        : _fcount = 2 ? EVFCons(EVFType(_fA), EVFCons(EVFType(_fB), EVFNil))
        : EVFCons(EVFType(_fA), EVFCons(EVFType(_fB), EVFCons(EVFType(_fC), EVFNil))))
    cur_decl ∈ EnumVariantDecl = (_fcount = 0 ? EVDecl(_cur_name) : EVDeclP(_cur_name, cur_fields))
    rendered ∈ String
    VariantText(v ↦ cur_decl, out ↦ rendered)

    new_body ∈ String = (finalize ? (_first_v ? rendered : _body ++ " " ++ rendered) : _body)

    -- ephase transition.
    next_ephase ∈ Int = (e1 ∧ p_is_enum ? 2
        : e2 ∧ p_is_ident ? 3
        : e3 ∧ p_is_eq ? 4
        : e4 ∧ p_is_ident ? 5
        : e5 ∧ p_is_lp ? 6
        : e5 ∧ p_is_pipe ? 4
        : e6 ∧ p_is_ident ? 7
        : e7 ∧ p_is_comma ? 6
        : e7 ∧ p_is_rp ? 8
        : e8 ∧ p_is_pipe ? 4
        : _ephase)

    starting_variant ∈ Bool = (e4 ∧ p_is_ident)
    adding_field     ∈ Bool = (e6 ∧ p_is_ident)

    -- State carry for the parse machine.
    plist   = (is_first_tick ? TLNil : (entering_parse ? _fwd : (in_parse ∧ (¬plist_nil) ? ptail : _plist)))
    ephase  = (is_first_tick ? 1 : (entering_parse ? 1 : (in_parse ? next_ephase : _ephase)))
    ename   = (is_first_tick ? "" : (in_parse ∧ e2 ∧ p_is_ident ? p_id : _ename))
    body    = (is_first_tick ? "" : (entering_parse ? "" : (in_parse ? new_body : _body)))
    first_v = (is_first_tick ? true : (entering_parse ? true : (finalize ? false : _first_v)))
    cur_name = (is_first_tick ? "" : (in_parse ∧ starting_variant ? p_id : _cur_name))
    fcount  = (is_first_tick ? 0
        : (in_parse ∧ starting_variant ? 0
        : (in_parse ∧ adding_field ? _fcount + 1
        : _fcount)))
    fA = (is_first_tick ? "" : (in_parse ∧ adding_field ∧ (_fcount = 0) ? p_id : _fA))
    fB = (is_first_tick ? "" : (in_parse ∧ adding_field ∧ (_fcount = 1) ? p_id : _fB))
    fC = (is_first_tick ? "" : (in_parse ∧ adding_field ∧ (_fcount = 2) ? p_id : _fC))

    parse_done ∈ Bool = (in_parse ∧ plist_nil)

    phase = (is_first_tick ? 0
        : (_phase = 0 ? (lex_done ? 1 : 0)
        : (_phase = 1 ? (work_is_nil ? 2 : 1)
        : (_phase = 2 ? (plist_nil ? 3 : 2)
        : 3))))

    -- ── EMIT ──────────────────────────────────────────────────────
    emit_now ∈ Bool = ((¬is_first_tick) ∧ (_phase = 2) ∧ plist_nil)
    grouped_body ∈ String = "(" ++ new_body ++ ")"
    final_decl ∈ EnumDeclAst = EnumD(_ename, EVNil)
    full_smtlib ∈ String
    EnumDeclSmtlib(decl ↦ final_decl, body_str ↦ grouped_body, out ↦ full_smtlib)

    effects ∈ Seq(Effect) = (emit_now
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(full_smtlib)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
