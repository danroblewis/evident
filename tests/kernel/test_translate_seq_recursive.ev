-- Recursive seq-concat translation: walk a nested `++` tree to fully
-- nested Z3 sequence form via a WorkItem work-stack, driving
-- compiler/translate_seq.ev's SeqConcatStep once per tick.
-- The input is `⟨1⟩ ++ ⟨2, 3⟩` desugared (`++` flattens; `⟨2,3⟩ = ⟨2⟩ ++ ⟨3⟩`).
--
-- Pop sequence:
--   P(++(1, ++(2,3))) → "(seq.++ " P(1) " " P(++(2,3)) ")"
--   P(1)              → "(seq.unit 1)"
--   P(++(2,3))        → "(seq.++ " P(2) " " P(3) ")"
--   leaves emit "(seq.unit 2)" / "(seq.unit 3)"
--
-- expect: stdout = "(seq.++ (seq.unit 1) (seq.++ (seq.unit 2) (seq.unit 3)))"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/translate_seq.ev"

claim main
    initial_expr ∈ Expr = EBinOp(OpConcat, EInt(1), EBinOp(OpConcat, EInt(2), EInt(3)))
    initial_stack ∈ WorkList = WLCons(WIProcess(initial_expr), WLNil)

    stack  ∈ WorkList
    _stack ∈ WorkList
    out  ∈ String
    _out ∈ String

    hd ∈ WorkItem = match _stack
        WLCons(h, _) ⇒ h
        WLNil ⇒ WIEmit("")
    rst ∈ WorkList = match _stack
        WLCons(_, t) ⇒ t
        WLNil ⇒ WLNil
    is_empty ∈ Bool = match _stack
        WLNil ⇒ true
        _ ⇒ false

    nstack ∈ WorkList
    em ∈ String
    SeqConcatStep(head ↦ hd, rest ↦ rst, new_stack ↦ nstack, emit ↦ em)

    stack = (is_first_tick ? initial_stack : nstack)
    out = (is_first_tick ? "" : _out ++ em)

    done ∈ Bool = (¬is_first_tick ∧ is_empty)

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(out)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
