-- Phase B3: type-name parsing. Types are carried as opaque strings;
-- a multi-tick FSM walks a TokenList head-by-head, accumulating the
-- type-name into a String and flushing/resetting on a Newline boundary.
-- Inputs cover all four type shapes: "Int", "Seq(Int)", "Edge<Rect>",
-- "Seq(Edge<Rect>)".
--
-- Token-to-fragment mapping is owned by TypeTokenText: Ident → its
-- payload, LParen → "(", RParen → ")", Lt → "<", Gt → ">", Comma → ", ".
--
-- expect: stdout = "[start]"
-- expect: stdout = "  step"
-- expect: stdout = "Int"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "Seq(Int)"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "Edge<Rect>"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "  step"
-- expect: stdout = "Seq(Edge<Rect>)"
-- expect: stdout = "[done]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/parser.ev"

claim main
    -- Four Newline-terminated type-token streams, built in chunks to
    -- keep individual expressions under the parser's call-depth limit.
    case_d ∈ TokenList = TLCons(Ident("Seq"), TLCons(LParen, TLCons(Ident("Edge"), TLCons(Lt, TLCons(Ident("Rect"), TLCons(Gt, TLCons(RParen, TLCons(Newline, TLNil))))))))
    case_c ∈ TokenList = TLCons(Ident("Edge"), TLCons(Lt, TLCons(Ident("Rect"), TLCons(Gt, TLCons(Newline, case_d)))))
    case_b ∈ TokenList = TLCons(Ident("Seq"), TLCons(LParen, TLCons(Ident("Int"), TLCons(RParen, TLCons(Newline, case_c)))))
    case_a ∈ TokenList = TLCons(Ident("Int"), TLCons(Newline, case_b))
    initial ∈ TokenList = case_a

    list  ∈ TokenList
    _list ∈ TokenList

    accum  ∈ String
    _accum ∈ String

    head_tok ∈ Token = match _list
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok

    tail_list ∈ TokenList = match _list
        TLCons(_, rest) ⇒ rest
        TLNil ⇒ TLNil

    is_nil ∈ Bool = match _list
        TLNil ⇒ true
        _ ⇒ false

    tok_str ∈ String
    is_type_tok ∈ Bool
    TypeTokenText(t ↦ head_tok, s ↦ tok_str, is_type_tok ↦ is_type_tok)

    is_newline ∈ Bool = (head_tok matches Newline)

    accum = (is_first_tick ? "" : (is_newline ? "" : (is_type_tok ? _accum ++ tok_str : _accum)))

    list = (is_first_tick ? initial : tail_list)

    -- On Newline emit the PREVIOUS tick's _accum — this tick already
    -- consumed the newline.
    label ∈ String = (is_first_tick ? "[start]" : (is_nil ? "[done]" : (is_newline ? _accum : "  step")))

    effects ∈ Seq(Effect) = (is_nil ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩ : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩)
