-- Functionizer exerciser: determined-scalar FSM — `count` is a pure
-- function of the previous count (Scalar step, JIT to native arithmetic)
-- and `effects` a fixed-arity guarded ternary (Guarded-Seq step,
-- interpreted); runs entirely off the fast path, no per-tick Z3 solve.
-- getpid is a silent libcall; the only stdout is the final "done".
-- expect: stdout = "done"
-- expect: exit = 0
import "stdlib/kernel.ev"

claim main
    count  ∈ Int
    _count ∈ Int
    count = (is_first_tick ? 0 : _count + 1)

    effects ∈ Seq(Effect) = (count < 5
        ? ⟨LibCall("libc", "getpid", ⟨⟩)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr("done")⟩), Exit(0)⟩)
