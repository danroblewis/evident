-- expect: stdout = "log"
-- expect: stdout = "data"
-- expect: exit = 0
import "stdlib/kernel.ev"

claim main
    eff_log  ∈ Seq(Effect) = ⟨LibCall("libc", "puts", ⟨ArgStr("log")⟩)⟩
    eff_data ∈ Seq(Effect) = ⟨LibCall("libc", "puts", ⟨ArgStr("data")⟩)⟩
    eff_exit ∈ Seq(Effect) = ⟨Exit(0)⟩
    effects  ∈ Seq(Effect) = eff_log ++ eff_data ++ eff_exit
