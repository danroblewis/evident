-- Validation fixture for stdlib/z3_ops.ev (z3-sugar-inventory §3+§4).
--
-- Builds `(ite (and (< 3 4) (not false)) (+ 1 2) 9)` as a Z3 AST via
-- libz3 calls, reads back Z3's canonical printing with
-- Z3_ast_to_string + __cstr.copy, compares, and exits 0 iff equal.
-- Exercises one binary comparison (Z3_mk_lt), one unary boolean
-- (Z3_mk_not), one array-form boolean (Z3_mk_and), one array-form
-- arithmetic (Z3_mk_add), and the ternary (Z3_mk_ite) — covering
-- each call-shape class in stdlib/z3_ops.ev (binary, unary,
-- array-form, 4-arg ite).
--
-- FALLBACK NOTE (read before "fixing" this to call the sugar
-- claims): sugar claims are only invocable via claim composition,
-- and the committed (fossil) compiler.smt2 SILENTLY DROPS both the
-- positional-call form `BuildZ3MkNot(1, 2, eff)` and the
-- positional-membership form `(1, 2, eff) ∈ BuildZ3MkNot` — probed
-- 2026-06-07: the compiled output contains no Z3_mk_not constraint
-- and `eff` ends up unbound. Until compiler.smt2 is rebuilt with
-- composition support, this fixture inlines the RAW LibCall effects
-- with exactly the payload shapes the z3_ops.ev claims wrap
-- (lib="libz3", same fn name, same ArgInt order).
--
-- SECOND BLOCKER: the fossil compiler.smt2 also cannot emit the
-- multi-tick state-carry + match-on-last_results + per-phase ITE
-- chain shape this FSM needs (same gap tests/kernel/wave-5a/
-- README.md documents — output silently truncates at the phase
-- carry; re-verified 2026-06-07, including on the long-green
-- test_counter.ev). So, following the wave-5a precedent, the
-- RUNNABLE proof of this file is the hand-written sibling
-- tests/kernel/z3_ops/sugar_ops.smt2 — same phases, same LibCall
-- payloads — which runs exit 0 under the kernel. This .ev file is
-- the source-of-record the seam should compile once both gaps
-- close.
--
-- Array marshaling (same pattern as test_translate_arith_via_z3.ev):
-- malloc 16 bytes, two __mem.write_long stores of the operand
-- handles, pass the buffer pointer + num_args = 2.
--
-- Multi-tick FSM: every libcall's return lands in last_results on
-- the NEXT tick, so the effect emitted at phase N is captured at
-- phase N+1. Composite AST handles get a Z3_inc_ref pin on the tick
-- after capture (never capture from an inc_ref tick — libz3 void
-- returns come back as register garbage in IntResult).
--
-- expect: stdout = ""
-- expect: exit = 0

import "stdlib/z3_ops.ev"

claim main
    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    -- Shared capture views of last_results[0].
    res_int ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    res_str ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""

    -- ── Captured handles (each set on its capture tick, else carried).

    cfg_h ∈ Int
    _cfg_h ∈ Int
    cfg_h = (is_first_tick ? 0 : phase = 1 ? res_int : _cfg_h)

    ctx_h ∈ Int
    _ctx_h ∈ Int
    ctx_h = (is_first_tick ? 0 : phase = 2 ? res_int : _ctx_h)

    int_sort_h ∈ Int
    _int_sort_h ∈ Int
    int_sort_h = (is_first_tick ? 0 : phase = 3 ? res_int : _int_sort_h)

    n1_h ∈ Int
    _n1_h ∈ Int
    n1_h = (is_first_tick ? 0 : phase = 4 ? res_int : _n1_h)

    n2_h ∈ Int
    _n2_h ∈ Int
    n2_h = (is_first_tick ? 0 : phase = 5 ? res_int : _n2_h)

    n3_h ∈ Int
    _n3_h ∈ Int
    n3_h = (is_first_tick ? 0 : phase = 6 ? res_int : _n3_h)

    n4_h ∈ Int
    _n4_h ∈ Int
    n4_h = (is_first_tick ? 0 : phase = 7 ? res_int : _n4_h)

    n9_h ∈ Int
    _n9_h ∈ Int
    n9_h = (is_first_tick ? 0 : phase = 8 ? res_int : _n9_h)

    false_h ∈ Int
    _false_h ∈ Int
    false_h = (is_first_tick ? 0 : phase = 9 ? res_int : _false_h)

    lt_h ∈ Int
    _lt_h ∈ Int
    lt_h = (is_first_tick ? 0 : phase = 10 ? res_int : _lt_h)

    not_h ∈ Int
    _not_h ∈ Int
    not_h = (is_first_tick ? 0 : phase = 12 ? res_int : _not_h)

    and_buf ∈ Int
    _and_buf ∈ Int
    and_buf = (is_first_tick ? 0 : phase = 14 ? res_int : _and_buf)

    and_h ∈ Int
    _and_h ∈ Int
    and_h = (is_first_tick ? 0 : phase = 17 ? res_int : _and_h)

    add_buf ∈ Int
    _add_buf ∈ Int
    add_buf = (is_first_tick ? 0 : phase = 19 ? res_int : _add_buf)

    add_h ∈ Int
    _add_h ∈ Int
    add_h = (is_first_tick ? 0 : phase = 22 ? res_int : _add_h)

    ite_h ∈ Int
    _ite_h ∈ Int
    ite_h = (is_first_tick ? 0 : phase = 24 ? res_int : _ite_h)

    str_ptr ∈ Int
    _str_ptr ∈ Int
    str_ptr = (is_first_tick ? 0 : phase = 26 ? res_int : _str_ptr)

    rendered ∈ String
    _rendered ∈ String
    rendered = (is_first_tick ? "" : phase = 27 ? res_str : _rendered)

    -- ── Effects per phase. Effect at phase N → result readable at
    --    phase N+1 (the capture phases above).
    --   0  Z3_mk_config                      → cfg_h
    --   1  Z3_mk_context(cfg)                → ctx_h
    --   2  Z3_mk_int_sort(ctx)               → int_sort_h
    --   3  Z3_mk_int(ctx, 1, sort)           → n1_h
    --   4  Z3_mk_int(ctx, 2, sort)           → n2_h
    --   5  Z3_mk_int(ctx, 3, sort)           → n3_h
    --   6  Z3_mk_int(ctx, 4, sort)           → n4_h
    --   7  Z3_mk_int(ctx, 9, sort)           → n9_h
    --   8  Z3_mk_false(ctx)                  → false_h
    --   9  Z3_mk_lt(ctx, n3, n4)             → lt_h     [BuildZ3MkLt shape]
    --  10  Z3_inc_ref(ctx, lt_h)
    --  11  Z3_mk_not(ctx, false_h)           → not_h    [BuildZ3MkNot shape]
    --  12  Z3_inc_ref(ctx, not_h)
    --  13  malloc 16                         → and_buf
    --  14  __mem.write_long(and_buf, lt_h)
    --  15  __mem.write_long(and_buf+8, not_h)
    --  16  Z3_mk_and(ctx, 2, and_buf)        → and_h    [BuildZ3MkAnd shape]
    --  17  Z3_inc_ref(ctx, and_h)
    --  18  malloc 16                         → add_buf
    --  19  __mem.write_long(add_buf, n1_h)
    --  20  __mem.write_long(add_buf+8, n2_h)
    --  21  Z3_mk_add(ctx, 2, add_buf)        → add_h    [BuildZ3MkAdd shape]
    --  22  Z3_inc_ref(ctx, add_h)
    --  23  Z3_mk_ite(ctx, and_h, add_h, n9)  → ite_h    [BuildZ3MkIte shape]
    --  24  Z3_inc_ref(ctx, ite_h)
    --  25  Z3_ast_to_string(ctx, ite_h)      → str_ptr
    --  26  __cstr.copy(str_ptr)              → rendered
    --  27  verdict: Exit(0) iff rendered = expected; on mismatch
    --      print the actual rendering, then Exit(4).

    expected ∈ String = "(ite (and (< 3 4) (not false)) (+ 1 2) 9)"
    match_ok ∈ Bool = (rendered = expected)

    effects ∈ Seq(Effect) = (phase = 0
            ? ⟨LibCall("libz3", "Z3_mk_config", ⟨⟩)⟩
        : phase = 1
            ? ⟨LibCall("libz3", "Z3_mk_context", ⟨ArgInt(cfg_h)⟩)⟩
        : phase = 2
            ? ⟨LibCall("libz3", "Z3_mk_int_sort", ⟨ArgInt(ctx_h)⟩)⟩
        : phase = 3
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(1), ArgInt(int_sort_h)⟩)⟩
        : phase = 4
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(2), ArgInt(int_sort_h)⟩)⟩
        : phase = 5
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(3), ArgInt(int_sort_h)⟩)⟩
        : phase = 6
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(4), ArgInt(int_sort_h)⟩)⟩
        : phase = 7
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(9), ArgInt(int_sort_h)⟩)⟩
        : phase = 8
            ? ⟨LibCall("libz3", "Z3_mk_false", ⟨ArgInt(ctx_h)⟩)⟩
        : phase = 9
            ? ⟨LibCall("libz3", "Z3_mk_lt",
                ⟨ArgInt(ctx_h), ArgInt(n3_h), ArgInt(n4_h)⟩)⟩
        : phase = 10
            ? ⟨LibCall("libz3", "Z3_inc_ref", ⟨ArgInt(ctx_h), ArgInt(lt_h)⟩)⟩
        : phase = 11
            ? ⟨LibCall("libz3", "Z3_mk_not",
                ⟨ArgInt(ctx_h), ArgInt(false_h)⟩)⟩
        : phase = 12
            ? ⟨LibCall("libz3", "Z3_inc_ref", ⟨ArgInt(ctx_h), ArgInt(not_h)⟩)⟩
        : phase = 13
            ? ⟨LibCall("libc", "malloc", ⟨ArgInt(16)⟩)⟩
        : phase = 14
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(and_buf), ArgInt(lt_h)⟩)⟩
        : phase = 15
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(and_buf + 8), ArgInt(not_h)⟩)⟩
        : phase = 16
            ? ⟨LibCall("libz3", "Z3_mk_and",
                ⟨ArgInt(ctx_h), ArgInt(2), ArgInt(and_buf)⟩)⟩
        : phase = 17
            ? ⟨LibCall("libz3", "Z3_inc_ref", ⟨ArgInt(ctx_h), ArgInt(and_h)⟩)⟩
        : phase = 18
            ? ⟨LibCall("libc", "malloc", ⟨ArgInt(16)⟩)⟩
        : phase = 19
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(add_buf), ArgInt(n1_h)⟩)⟩
        : phase = 20
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(add_buf + 8), ArgInt(n2_h)⟩)⟩
        : phase = 21
            ? ⟨LibCall("libz3", "Z3_mk_add",
                ⟨ArgInt(ctx_h), ArgInt(2), ArgInt(add_buf)⟩)⟩
        : phase = 22
            ? ⟨LibCall("libz3", "Z3_inc_ref", ⟨ArgInt(ctx_h), ArgInt(add_h)⟩)⟩
        : phase = 23
            ? ⟨LibCall("libz3", "Z3_mk_ite",
                ⟨ArgInt(ctx_h), ArgInt(and_h), ArgInt(add_h), ArgInt(n9_h)⟩)⟩
        : phase = 24
            ? ⟨LibCall("libz3", "Z3_inc_ref", ⟨ArgInt(ctx_h), ArgInt(ite_h)⟩)⟩
        : phase = 25
            ? ⟨LibCall("libz3", "Z3_ast_to_string",
                ⟨ArgInt(ctx_h), ArgInt(ite_h)⟩)⟩
        : phase = 26
            ? ⟨LibCall("__cstr", "copy", ⟨ArgInt(str_ptr)⟩)⟩
        : match_ok
            ? ⟨Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(rendered)⟩), Exit(4)⟩)
