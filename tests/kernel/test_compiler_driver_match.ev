-- Grammar wave 3, item 2: a `match` expression as a membership pin RHS,
-- lowered to nested ITE over constructor testers.
--
-- The source is lexed character-by-character (nothing hardcoded), reversed
-- to forward order, the `claim Ident` head dropped, then the membership's
-- match arms are parsed (bounded: one ctor arm + one wildcard arm — the
-- dominant `match last_results[0]` shape in compiler.ev) into a
-- MatchArmList. The nested ITE is produced by walking that arm list with
-- compiler/translate_match.ev's MatchTranslateStep work-stack, ONE pop per
-- tick. See docs/plans/grammar-wave3.md and grammar-coverage-survey.md §3.
--
-- This mirrors translate_match.ev's contract exactly: the wildcard arm is
-- the innermost else, and binds render as their NAME (translate_match does
-- not substitute the payload accessor — that is a bootstrap-only refinement
-- noted in grammar-wave3.md, out of this wave's "compose the pass" scope).
--
-- Source:
--   n ∈ Int = match e
--       Ok(v) ⇒ v
--       _ ⇒ 0
--
-- expect: stdout = ";; manifest: state-fields = n:Int"
-- expect: stdout = ";; manifest: effects-name = effects"
-- expect: stdout = ";; manifest: effect-enum-name = Effect"
-- expect: stdout = ";; manifest: result-enum-name = Result"
-- expect: stdout = ";; manifest: max-effects = 0"
-- expect: stdout = "(declare-fun is_first_tick () Bool)"
-- expect: stdout = "(declare-fun n () Int)"
-- expect: stdout = "(assert (= n (ite ((_ is Ok) e) v 0)))"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler/translate_declare.ev"
import "compiler/translate_match.ev"
import "compiler/parse_body_seq.ev"

claim main
    input ∈ String = "claim foo\n    n ∈ Int = match e\n        Ok(v) ⇒ v\n        _ ⇒ 0\n"

    -- ── LEX state (consolidated-lexer FSM, reverse-order tokens) ──
    pos  ∈ Int
    _pos ∈ Int
    pos = (is_first_tick ? 0 - 1 : _pos + 1)

    partial_str  ∈ String
    _partial_str ∈ String
    partial_int  ∈ Int
    _partial_int ∈ Int

    cur_char ∈ String = substr(input, pos, 1)

    is_alpha ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)
    is_dig ∈ Bool
    IsDigitChar(c ↦ cur_char, out ↦ is_dig)
    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)
    op_tok ∈ Token
    is_op ∈ Bool
    SingleCharTok(c ↦ cur_char, t ↦ op_tok, recognized ↦ is_op)
    dig_val ∈ Int
    DigitToInt(c ↦ cur_char, n ↦ dig_val)

    done ∈ Bool = ((pos ≥ #input) ∧ (#input > 0))
    in_range ∈ Bool = ((pos ≥ 0) ∧ ¬done)

    was_collecting_str ∈ Bool = (#_partial_str > 0)
    was_collecting_int ∈ Bool = (_partial_int ≥ 0)

    str_continuing ∈ Bool = (was_collecting_str ∧ is_alpha ∧ in_range)
    str_finishing  ∈ Bool = (was_collecting_str ∧ ((¬is_alpha ∧ in_range) ∨ done))
    str_starting   ∈ Bool = ((¬was_collecting_str) ∧ is_alpha ∧ in_range)

    int_continuing ∈ Bool = (was_collecting_int ∧ is_dig ∧ in_range)
    int_finishing  ∈ Bool = (was_collecting_int ∧ ((¬is_dig ∧ in_range) ∨ done))
    int_starting   ∈ Bool = ((¬was_collecting_int) ∧ is_dig ∧ in_range)

    partial_str = (is_first_tick ? "" : (str_continuing ? _partial_str ++ cur_char : (str_starting ? cur_char : "")))
    partial_int = (is_first_tick ? 0 - 1 : (int_continuing ? (_partial_int * 10) + dig_val : (int_starting ? dig_val : 0 - 1)))

    classified_str ∈ Token
    MaybeKeyword(s ↦ _partial_str, t ↦ classified_str)
    int_tok ∈ Token = IntLit(_partial_int)

    finish_str_only    ∈ Bool = (str_finishing ∧ (is_ws ∨ done))
    finish_int_only    ∈ Bool = (int_finishing ∧ (is_ws ∨ done))
    finish_str_with_op ∈ Bool = (str_finishing ∧ is_op ∧ in_range)
    finish_int_with_op ∈ Bool = (int_finishing ∧ is_op ∧ in_range)
    char_only          ∈ Bool = ((¬was_collecting_str) ∧ (¬was_collecting_int) ∧ is_op ∧ in_range)

    tokens  ∈ TokenList
    _tokens ∈ TokenList
    tokens = (is_first_tick ? TLNil
            : (finish_str_with_op ? TLCons(op_tok, TLCons(classified_str, _tokens))
            : (finish_int_with_op ? TLCons(op_tok, TLCons(int_tok, _tokens))
            : (finish_str_only ? TLCons(classified_str, _tokens)
            : (finish_int_only ? TLCons(int_tok, _tokens)
            : (char_only ? TLCons(op_tok, _tokens)
            : _tokens))))))

    lex_done ∈ Bool = (done ∧ ¬was_collecting_str ∧ ¬was_collecting_int ∧ ¬is_first_tick)

    -- ── PHASE control (0 lex · 1 reverse · 2 match-walk · 3 emit) ──
    phase  ∈ Int
    _phase ∈ Int

    work_is_nil ∈ Bool = match _work
        TLNil ⇒ true
        _ ⇒ false
    work_hd ∈ Token = match _work
        TLCons(h, _) ⇒ h
        TLNil ⇒ EofTok
    work_tl ∈ TokenList = match _work
        TLCons(_, t) ⇒ t
        TLNil ⇒ TLNil

    entering_reverse ∈ Bool = ((¬is_first_tick) ∧ (_phase = 0) ∧ lex_done)
    in_reverse       ∈ Bool = (_phase = 1)
    entering_walk     ∈ Bool = ((¬is_first_tick) ∧ (_phase = 1) ∧ work_is_nil)
    in_walk          ∈ Bool = (_phase = 2)

    work ∈ TokenList
    _work ∈ TokenList
    fwd  ∈ TokenList
    _fwd ∈ TokenList
    work = (is_first_tick ? TLNil
        : (entering_reverse ? tokens
        : (in_reverse ∧ (¬work_is_nil) ? work_tl
        : _work)))
    fwd = (is_first_tick ? TLNil
        : (entering_reverse ? TLNil
        : (in_reverse ∧ (¬work_is_nil) ? TLCons(work_hd, _fwd)
        : _fwd)))

    -- ── Bounded membership-with-match peel (from _fwd, drop 2 head) ──
    d1 ∈ TokenList
    TLTlS(l ↦ _fwd, out ↦ d1)
    d2 ∈ TokenList
    TLTlS(l ↦ d1, out ↦ d2)
    m_t0 ∈ Token
    TLHdS(l ↦ d2, out ↦ m_t0)
    a1 ∈ TokenList
    TLTlS(l ↦ d2, out ↦ a1)
    m_t1 ∈ Token
    TLHdS(l ↦ a1, out ↦ m_t1)
    a2 ∈ TokenList
    TLTlS(l ↦ a1, out ↦ a2)
    m_t2 ∈ Token
    TLHdS(l ↦ a2, out ↦ m_t2)
    a3 ∈ TokenList
    TLTlS(l ↦ a2, out ↦ a3)
    a4 ∈ TokenList
    TLTlS(l ↦ a3, out ↦ a4)
    m_t4 ∈ Token
    TLHdS(l ↦ a4, out ↦ m_t4)
    a5 ∈ TokenList
    TLTlS(l ↦ a4, out ↦ a5)
    m_t5 ∈ Token
    TLHdS(l ↦ a5, out ↦ m_t5)
    a6 ∈ TokenList
    TLTlS(l ↦ a5, out ↦ a6)
    m_t6 ∈ Token
    TLHdS(l ↦ a6, out ↦ m_t6)
    a7 ∈ TokenList
    TLTlS(l ↦ a6, out ↦ a7)
    a8 ∈ TokenList
    TLTlS(l ↦ a7, out ↦ a8)
    m_t8 ∈ Token
    TLHdS(l ↦ a8, out ↦ m_t8)
    a9 ∈ TokenList
    TLTlS(l ↦ a8, out ↦ a9)
    a10 ∈ TokenList
    TLTlS(l ↦ a9, out ↦ a10)
    a11 ∈ TokenList
    TLTlS(l ↦ a10, out ↦ a11)
    m_t11 ∈ Token
    TLHdS(l ↦ a11, out ↦ m_t11)
    a12 ∈ TokenList
    TLTlS(l ↦ a11, out ↦ a12)
    a13 ∈ TokenList
    TLTlS(l ↦ a12, out ↦ a13)
    a14 ∈ TokenList
    TLTlS(l ↦ a13, out ↦ a14)
    m_t14 ∈ Token
    TLHdS(l ↦ a14, out ↦ m_t14)

    m_name ∈ String = match m_t0
        Ident(s) ⇒ s
        _ ⇒ ""
    m_type ∈ String = match m_t2
        Ident(s) ⇒ s
        _ ⇒ ""
    m_scrut ∈ String = match m_t5
        Ident(s) ⇒ s
        _ ⇒ ""
    m_ctor ∈ String = match m_t6
        Ident(s) ⇒ s
        _ ⇒ ""
    m_bind ∈ String = match m_t8
        Ident(s) ⇒ s
        _ ⇒ ""
    m_body1 ∈ Expr = (m_t11 matches IntLit(_) ? EInt(m_b1i) : EIdent(m_b1s))
    m_b1i ∈ Int = match m_t11
        IntLit(n) ⇒ n
        _ ⇒ 0
    m_b1s ∈ String = match m_t11
        Ident(s) ⇒ s
        _ ⇒ ""
    m_body2 ∈ Expr = (m_t14 matches IntLit(_) ? EInt(m_b2i) : EIdent(m_b2s))
    m_b2i ∈ Int = match m_t14
        IntLit(n) ⇒ n
        _ ⇒ 0
    m_b2s ∈ String = match m_t14
        Ident(s) ⇒ s
        _ ⇒ ""

    arm_list ∈ MatchArmList = MACons(
        MArm(MPCtor(m_ctor, MBCons(MBName(m_bind), MBNil)), m_body1),
        MACons(MArm(MPWildcard, m_body2), MANil))

    -- ── MATCH WALK: MatchTranslateStep work-stack, one pop per tick ──
    mstack  ∈ MatchWorkList
    _mstack ∈ MatchWorkList
    mout  ∈ String
    _mout ∈ String
    scrut  ∈ String
    _scrut ∈ String

    mhead ∈ MatchWork = match _mstack
        MWLCons(h, _) ⇒ h
        MWLNil ⇒ MWEmit("")
    mrest ∈ MatchWorkList = match _mstack
        MWLCons(_, t) ⇒ t
        MWLNil ⇒ MWLNil
    mstack_nil ∈ Bool = match _mstack
        MWLNil ⇒ true
        _ ⇒ false

    mns ∈ MatchWorkList
    mem ∈ String
    MatchTranslateStep(scrutinee ↦ _scrut, head ↦ mhead, rest ↦ mrest,
        new_stack ↦ mns, emit ↦ mem)

    scrut  = (is_first_tick ? "" : (entering_walk ? m_scrut : _scrut))
    mstack = (is_first_tick ? MWLNil
        : (entering_walk ? MWLCons(MWArms(arm_list), MWLNil)
        : (in_walk ∧ (¬mstack_nil) ? mns
        : _mstack)))
    mout = (is_first_tick ? ""
        : (entering_walk ? ""
        : (in_walk ∧ (¬mstack_nil) ? _mout ++ mem
        : _mout)))

    phase = (is_first_tick ? 0
        : (_phase = 0 ? (lex_done ? 1 : 0)
        : (_phase = 1 ? (work_is_nil ? 2 : 1)
        : (_phase = 2 ? (mstack_nil ? 3 : 2)
        : 3))))

    -- ── EMIT ──────────────────────────────────────────────────────
    emit_now ∈ Bool = ((¬is_first_tick) ∧ (_phase = 2) ∧ mstack_nil)
    decl_line ∈ String
    DeclareFun(name ↦ m_name, type_str ↦ m_type, out ↦ decl_line)
    assert_line ∈ String = "(assert (= " ++ m_name ++ " " ++ _mout ++ "))"
    manifest ∈ String = (";; manifest: state-fields = " ++ m_name ++ ":" ++ m_type ++ "\n"
        ++ ";; manifest: effects-name = effects\n"
        ++ ";; manifest: effect-enum-name = Effect\n"
        ++ ";; manifest: result-enum-name = Result\n"
        ++ ";; manifest: max-effects = 0")
    smtlib ∈ String = (manifest ++ "\n(declare-fun is_first_tick () Bool)\n"
        ++ decl_line ++ "\n" ++ assert_line)

    effects ∈ Seq(Effect) = (emit_now
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(smtlib)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
