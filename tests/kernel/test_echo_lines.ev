-- Stdin echo loop: reads lines until EOF, prints each, then exits.
-- Test driver feeds "alpha\nbeta\ngamma\n" on stdin.
--
-- The FSM always emits exactly 2 effects per tick so last_results[1]
-- is always the ReadLine result (predictable index).
--
-- expect: stdout = "(begin)"
-- expect: stdout = "alpha"
-- expect: stdout = "beta"
-- expect: stdout = "gamma"
-- expect: stdout = "(end)"
-- expect: exit = 0
import "stdlib/kernel.ev"

claim main
    line ∈ String = match last_results[1]
        StringResult(s) ⇒ s
        _ ⇒ ""

    is_eof ∈ Bool = match last_results[1]
        EofResult ⇒ true
        _ ⇒ false

    effects ∈ Seq(Effect) = (is_first_tick
        ? ⟨LibCall("libc", "puts", ⟨ArgStr("(begin)")⟩), ReadLine⟩
        : (is_eof
            ? ⟨LibCall("libc", "puts", ⟨ArgStr("(end)")⟩), Exit(0)⟩
            : ⟨LibCall("libc", "puts", ⟨ArgStr(line)⟩), ReadLine⟩))
