-- Parenthesized subexpressions (Phase B2). Consumes a hardcoded
-- TokenList for `(1 + 2) * 3` and builds
-- EBinOp(OpMul, EBinOp(OpPlus, EInt(1), EInt(2)), EInt(3)) via a
-- FrameList stack: suspend the outer (current, pending) context on
-- LParen, restore + combine on RParen.
--
-- expect: stdout = "[start]"
-- expect: stdout = "saw lparen"
-- expect: stdout = "saw int"
-- expect: stdout = "saw op"
-- expect: stdout = "saw int"
-- expect: stdout = "saw rparen"
-- expect: stdout = "saw op"
-- expect: stdout = "saw int"
-- expect: stdout = "done"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/parser.ev"

claim main
    initial ∈ TokenList = TLCons(LParen, TLCons(IntLit(1), TLCons(Plus, TLCons(IntLit(2), TLCons(RParen, TLCons(Star, TLCons(IntLit(3), TLNil)))))))

    list  ∈ TokenList
    _list ∈ TokenList

    current  ∈ Expr
    _current ∈ Expr

    pending  ∈ Op
    _pending ∈ Op

    frames  ∈ FrameList
    _frames ∈ FrameList

    next_list ∈ TokenList = match _list
        TLCons(_, tail) ⇒ tail
        TLNil ⇒ TLNil

    head_tok ∈ Token = match _list
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok

    is_nil ∈ Bool = match _list
        TLNil ⇒ true
        _ ⇒ false

    is_lparen ∈ Bool = (head_tok matches LParen)
    is_rparen ∈ Bool = (head_tok matches RParen)

    head_int ∈ Int = match head_tok
        IntLit(n) ⇒ n
        _ ⇒ 0 - 1
    is_int ∈ Bool = (head_int ≥ 0)

    head_op ∈ Op
    is_op ∈ Bool
    TokenToOp(t ↦ head_tok, o ↦ head_op, is_binop ↦ is_op)

    list = (is_first_tick ? initial : next_list)

    -- ── LParen: push the outer (current, pending) context onto frames ──
    pushed_frames ∈ FrameList = FLCons(_current, _pending, _frames)

    -- ── RParen: pop the top frame, recover outer_current + outer_pending ──
    outer_current ∈ Expr = match _frames
        FLCons(oc, _, _) ⇒ oc
        FLNil ⇒ ENoExpr
    outer_pending ∈ Op = match _frames
        FLCons(_, op, _) ⇒ op
        FLNil ⇒ OpPlus
    popped_frames ∈ FrameList = match _frames
        FLCons(_, _, rest) ⇒ rest
        FLNil ⇒ FLNil

    outer_was_empty ∈ Bool = (outer_current matches ENoExpr)
    combined_after_rparen ∈ Expr = (outer_was_empty ? _current : EBinOp(outer_pending, outer_current, _current))

    -- ── IntLit: extend current with the new int ──
    has_current ∈ Bool = ¬(_current matches ENoExpr)
    new_current_int ∈ Expr = (has_current ? EBinOp(_pending, _current, EInt(head_int)) : EInt(head_int))

    current = (is_first_tick ? ENoExpr
             : (is_lparen ? ENoExpr
             : (is_rparen ? combined_after_rparen
             : (is_int ? new_current_int
             : _current))))

    pending = (is_first_tick ? OpPlus
             : (is_lparen ? OpPlus
             : (is_rparen ? OpPlus
             : (is_op ? head_op
             : _pending))))

    frames = (is_first_tick ? FLNil
             : (is_lparen ? pushed_frames
             : (is_rparen ? popped_frames
             : _frames)))

    -- ── AST verification at end-of-input ──
    expected_ast ∈ Expr = EBinOp(OpMul, EBinOp(OpPlus, EInt(1), EInt(2)), EInt(3))
    ast_ok ∈ Bool = (_current = expected_ast)
    end_label ∈ String = (ast_ok ? "done" : "FAIL-bad-ast")

    label ∈ String = (is_first_tick ? "[start]" : (is_nil ? end_label : (is_lparen ? "saw lparen" : (is_rparen ? "saw rparen" : (is_int ? "saw int" : (is_op ? "saw op" : "skip"))))))

    effects ∈ Seq(Effect) = (is_first_tick ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩ : (is_nil ? ⟨LibCall("libc", "puts", ⟨ArgStr(end_label)⟩), Exit(0)⟩ : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩))
