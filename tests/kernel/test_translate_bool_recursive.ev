-- Recursive Boolean translation: walk a nested Boolean binop tree to
-- fully nested SMT-LIB via a WorkItem work-stack (the
-- test_ast_walker.ev depth-first pattern), driving
-- compiler/translate_bool.ev's BoolTranslateStep once per tick.
--
-- The task's target shape is `(and (or x y) z)`, but ∧ / ∨ are not
-- representable: the parser's `Op` enum (compiler/parser.ev, frozen)
-- has no OpAnd / OpOr variant — see docs/plans/blocked-translate-bool.md.
-- This fixture proves the identical recursive machinery on the Boolean
-- operators the `Op` enum DOES carry (OpImpl → "=>", OpEq → "="):
--
--   EBinOp(OpImpl, EBinOp(OpEq, EIdent("x"), EIdent("y")), EIdent("z"))
--
-- Pop sequence:
--   P(=> (= x y) z) → "(" "=>" " " P(= x y) " " P(z) ")"
--   P(= x y)        → "(" "=" " " P(x) " " P(y) ")"
--   leaves emit "x" / "y" / "z"
-- yielding "(=> (= x y) z)".
--
-- expect: stdout = "(=> (= x y) z)"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/translate_bool.ev"

claim main
    initial_expr ∈ Expr = EBinOp(OpImpl, EBinOp(OpEq, EIdent("x"), EIdent("y")), EIdent("z"))
    initial_stack ∈ WorkList = WLCons(WIProcess(initial_expr), WLNil)

    stack  ∈ WorkList
    _stack ∈ WorkList
    out  ∈ String
    _out ∈ String

    hd ∈ WorkItem = match _stack
        WLCons(h, _) ⇒ h
        WLNil ⇒ WIEmit("")
    rst ∈ WorkList = match _stack
        WLCons(_, t) ⇒ t
        WLNil ⇒ WLNil
    is_empty ∈ Bool = match _stack
        WLNil ⇒ true
        _ ⇒ false

    nstack ∈ WorkList
    em ∈ String
    BoolTranslateStep(head ↦ hd, rest ↦ rst, new_stack ↦ nstack, emit ↦ em)

    stack = (is_first_tick ? initial_stack : nstack)
    out = (is_first_tick ? "" : _out ++ em)

    done ∈ Bool = (¬is_first_tick ∧ is_empty)

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(out)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
