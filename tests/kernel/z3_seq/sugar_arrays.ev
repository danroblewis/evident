-- stdlib/z3_seq.ev validation, array + conversion leg (§5 of
-- docs/plans/z3-sugar-inventory.md, plus Z3_mk_int_to_str from §6).
-- Companion fixture sugar_seq.ev covers the §6 string/sequence leg.
-- The FSM:
--   1. Builds Z3 lifecycle (config, context, int_sort).
--   2. Z3_mk_const_array(int_sort, 7) → constant (Array Int Int).
--   3. Z3_mk_store(arr, 1, 9), then Z3_mk_select(stored, 1).
--   4. Z3_mk_int_to_str(42) for the int→string conversion shape.
--   5. Z3_ast_to_string + __cstr.copy for both built ASTs and
--      compares against Z3 4.15.4's canonical prints (discovered
--      empirically via the z3 CLI):
--        (select (store ((as const (Array Int Int)) 7) 1 9) 1)
--        (str.from_int 42)
--   6. Exit 0 iff both match; exit 4 (select mismatch) / 5
--      (from_int mismatch) / 6 (premature) localize a failure.
--
-- Same raw-LibCall single-schema shape as sugar_seq.ev (and
-- test_translate_arith_via_z3.ev) — see sugar_seq.ev's header for
-- why (size envelope, not a composition limitation); the LibCall
-- constraints are byte-for-byte the bodies of BuildZ3MkConstArray /
-- BuildZ3MkStore / BuildZ3MkSelect / BuildZ3MkIntToStr in
-- stdlib/z3_seq.ev.
--
-- expect: stdout = ""
-- expect: exit = 0

import "stdlib/kernel.ev"
import "stdlib/z3_seq.ev"

claim main
    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    cfg_h ∈ Int
    _cfg_h ∈ Int
    cfg_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    cfg_h = (is_first_tick ? 0 : phase = 1 ? cfg_cap : _cfg_h)

    ctx_h ∈ Int
    _ctx_h ∈ Int
    ctx_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    ctx_h = (is_first_tick ? 0 : phase = 2 ? ctx_cap : _ctx_h)

    isort_h ∈ Int
    _isort_h ∈ Int
    isort_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    isort_h = (is_first_tick ? 0 : phase = 3 ? isort_cap : _isort_h)

    n7_h ∈ Int
    _n7_h ∈ Int
    n7_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    n7_h = (is_first_tick ? 0 : phase = 4 ? n7_cap : _n7_h)

    ca_h ∈ Int
    _ca_h ∈ Int
    ca_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    ca_h = (is_first_tick ? 0 : phase = 5 ? ca_cap : _ca_h)

    n1_h ∈ Int
    _n1_h ∈ Int
    n1_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    n1_h = (is_first_tick ? 0 : phase = 6 ? n1_cap : _n1_h)

    n9_h ∈ Int
    _n9_h ∈ Int
    n9_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    n9_h = (is_first_tick ? 0 : phase = 7 ? n9_cap : _n9_h)

    st_h ∈ Int
    _st_h ∈ Int
    st_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    st_h = (is_first_tick ? 0 : phase = 8 ? st_cap : _st_h)

    sel_h ∈ Int
    _sel_h ∈ Int
    sel_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    sel_h = (is_first_tick ? 0 : phase = 10 ? sel_cap : _sel_h)

    sel_ptr ∈ Int
    _sel_ptr ∈ Int
    sel_ptr_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    sel_ptr = (is_first_tick ? 0 : phase = 12 ? sel_ptr_cap : _sel_ptr)

    sel_str ∈ String
    _sel_str ∈ String
    sel_str_cap ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""
    sel_str = (is_first_tick ? ""
        : phase = 13 ? sel_str_cap
        : _sel_str)

    n42_h ∈ Int
    _n42_h ∈ Int
    n42_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    n42_h = (is_first_tick ? 0 : phase = 14 ? n42_cap : _n42_h)

    fi_h ∈ Int
    _fi_h ∈ Int
    fi_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    fi_h = (is_first_tick ? 0 : phase = 15 ? fi_cap : _fi_h)

    fi_ptr ∈ Int
    _fi_ptr ∈ Int
    fi_ptr_cap ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    fi_ptr = (is_first_tick ? 0 : phase = 17 ? fi_ptr_cap : _fi_ptr)

    fi_str ∈ String
    _fi_str ∈ String
    fi_str_cap ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""
    fi_str = (is_first_tick ? ""
        : phase = 18 ? fi_str_cap
        : _fi_str)

    -- ── Verdict (both expected strings are quote-free) ───────────

    expected_sel ∈ String = "(select (store ((as const (Array Int Int)) 7) 1 9) 1)"
    expected_fi ∈ String = "(str.from_int 42)"
    sel_ok ∈ Bool = (sel_str = expected_sel)
    fi_ok ∈ Bool = (fi_str = expected_fi)
    exit_code ∈ Int = (phase = 19
        ? (sel_ok ? (fi_ok ? 0 : 5) : 4)
        : 6)

    -- ── Effects per phase ────────────────────────────────────────
    --   0  Z3_mk_config                        → cfg_h
    --   1  Z3_mk_context(cfg)                  → ctx_h
    --   2  Z3_mk_int_sort(ctx)                 → isort_h
    --   3  Z3_mk_int(ctx, 7, isort)            → n7_h
    --   4  Z3_mk_const_array(ctx, isort, n7)   → ca_h
    --   5  Z3_mk_int(ctx, 1, isort)            → n1_h
    --   6  Z3_mk_int(ctx, 9, isort)            → n9_h
    --   7  Z3_mk_store(ctx, ca, n1, n9)        → st_h
    --   8  Z3_inc_ref(ctx, st_h)
    --   9  Z3_mk_select(ctx, st, n1)           → sel_h
    --  10  Z3_inc_ref(ctx, sel_h)
    --  11  Z3_ast_to_string(ctx, sel_h)        → sel_ptr
    --  12  __cstr.copy(sel_ptr)                → sel_str
    --  13  Z3_mk_int(ctx, 42, isort)           → n42_h
    --  14  Z3_mk_int_to_str(ctx, n42)          → fi_h
    --  15  Z3_inc_ref(ctx, fi_h)
    --  16  Z3_ast_to_string(ctx, fi_h)         → fi_ptr
    --  17  __cstr.copy(fi_ptr)                 → fi_str
    --  18  (compare on 19)
    --  19  Exit(exit_code)

    effects ∈ Seq(Effect) = (phase = 0
            ? ⟨LibCall("libz3", "Z3_mk_config", ⟨⟩)⟩
        : phase = 1
            ? ⟨LibCall("libz3", "Z3_mk_context", ⟨ArgInt(cfg_h)⟩)⟩
        : phase = 2
            ? ⟨LibCall("libz3", "Z3_mk_int_sort", ⟨ArgInt(ctx_h)⟩)⟩
        : phase = 3
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(7), ArgInt(isort_h)⟩)⟩
        : phase = 4
            ? ⟨LibCall("libz3", "Z3_mk_const_array",
                ⟨ArgInt(ctx_h), ArgInt(isort_h), ArgInt(n7_h)⟩)⟩
        : phase = 5
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(1), ArgInt(isort_h)⟩)⟩
        : phase = 6
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(9), ArgInt(isort_h)⟩)⟩
        : phase = 7
            ? ⟨LibCall("libz3", "Z3_mk_store",
                ⟨ArgInt(ctx_h), ArgInt(ca_h), ArgInt(n1_h), ArgInt(n9_h)⟩)⟩
        : phase = 8
            ? ⟨LibCall("libz3", "Z3_inc_ref",
                ⟨ArgInt(ctx_h), ArgInt(st_h)⟩)⟩
        : phase = 9
            ? ⟨LibCall("libz3", "Z3_mk_select",
                ⟨ArgInt(ctx_h), ArgInt(st_h), ArgInt(n1_h)⟩)⟩
        : phase = 10
            ? ⟨LibCall("libz3", "Z3_inc_ref",
                ⟨ArgInt(ctx_h), ArgInt(sel_h)⟩)⟩
        : phase = 11
            ? ⟨LibCall("libz3", "Z3_ast_to_string",
                ⟨ArgInt(ctx_h), ArgInt(sel_h)⟩)⟩
        : phase = 12
            ? ⟨LibCall("__cstr", "copy", ⟨ArgInt(sel_ptr)⟩)⟩
        : phase = 13
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(42), ArgInt(isort_h)⟩)⟩
        : phase = 14
            ? ⟨LibCall("libz3", "Z3_mk_int_to_str",
                ⟨ArgInt(ctx_h), ArgInt(n42_h)⟩)⟩
        : phase = 15
            ? ⟨LibCall("libz3", "Z3_inc_ref",
                ⟨ArgInt(ctx_h), ArgInt(fi_h)⟩)⟩
        : phase = 16
            ? ⟨LibCall("libz3", "Z3_ast_to_string",
                ⟨ArgInt(ctx_h), ArgInt(fi_h)⟩)⟩
        : phase = 17
            ? ⟨LibCall("__cstr", "copy", ⟨ArgInt(fi_ptr)⟩)⟩
        : phase = 18
            ? ⟨LibCall("libc", "time", ⟨ArgInt(0)⟩)⟩
        : ⟨Exit(exit_code)⟩)
