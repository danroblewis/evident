-- tests/kernel/compiler2/cond_effects_fixture.ev — D2 fixture:
-- conditional effects writer with Seq literals (gap census D2).
--
-- NOT a kernel test_*.ev fixture: this file is an INPUT for the
-- compiler2 driver. The effects RHS is the corpus's conditional
-- shape — a guard over branch literals of DIFFERENT lengths, with
-- a 2-element then-branch (LibCall + Exit). The driver lowers it
-- to the oracle's guarded select/len shape:
--   (and (=> c (and … (= (select effects 0) (LibCall …))
--                   (= (select effects 1) (Exit 0))
--                   (= effects__len 2)))
--        (=> (not c) (and (= (select effects 0) (Exit 1))
--                         (= effects__len 1))))
-- (conjunct order/2-ary nesting may differ — the accepted cosmetic
-- divergence class; the guard-implies structure is the oracle's.)
--
-- Build + run under the driver (mktemp for all temp files):
--   TD=$(mktemp -d)
--   evident-oracle emit compiler2/driver.ev driver_main -o "$TD/driver.smt2"
--   scripts/flatten-evident.sh tests/kernel/compiler2/cond_effects_fixture.ev > "$TD/flat.ev"
--   printf '%s\nmain\n' "$TD/flat.ev" | kernel/target/release/kernel "$TD/driver.smt2" > "$TD/out.smt2"
--   grep -F '(=> c' "$TD/out.smt2"               # guard-implies branch
--   grep -F '(select effects 1)' "$TD/out.smt2"  # 2nd then-element
--   kernel/target/release/kernel "$TD/out.smt2"  # expect stdout `yes`, exit 0
--
-- c = true pins the THEN path: the kernel must read effects__len =
-- 2 and dispatch both elements — stdout `yes` then Exit(0). A wrong
-- guard fold or len pin takes the else path (exit 1) or UNSATs.
--
-- expected stdout: yes
-- expected exit: 0

import "stdlib/kernel.ev"

claim main
    c ∈ Bool
    c = true
    effects ∈ Seq(Effect) = (c ? ⟨LibCall("libc", "puts", ⟨ArgStr("yes")⟩), Exit(0)⟩ : ⟨Exit(1)⟩)
