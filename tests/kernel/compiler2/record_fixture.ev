-- compiler2 P2 record-pass fixture: declare a 2-field record
-- datatype `IVec2(x, y ∈ Int)` through the libz3 C API (the proven
-- sequence from tests/kernel/z3_datatypes/sugar_datatypes.ev,
-- generalized from 1 field to 2), then drive the
-- compiler2/translate2_record.ev claims to build:
--
--   1. `(= (x p) 3)` for a const p of the record sort — field access
--      via RecordFieldAccessBuildZ3 over the accessor decl harvested
--      at the RecordEqPlan-computed slot, receiver via
--      RecordRecvBuildZ3, eq node via RecordFieldEqBuildZ3.
--   2. `(IVec2 1 2)` — record literal via RecordLiteralBuildZ3 over
--      the harvested ctor decl.
--
-- Both are Z3_ast_to_string'd + __cstr.copy'd and compared against
-- the canonical forms discovered via the z3 CLI (simplify of the
-- same terms prints exactly these spellings). Exit(0) iff both
-- match and the harvested sort handle is non-null.
--
-- Unlike sugar_datatypes.ev this fixture is NOT fossil-subset
-- constrained: it is compiled by /usr/local/bin/evident-oracle
-- (full Evident), so the BuildZ3* choices come from slot-bound
-- compositions of the translate2_record claims, not inlined
-- LibCall literals.
--
-- Build + run:
--   evident-oracle emit tests/kernel/compiler2/record_fixture.ev main -o $(mktemp).smt2
--   kernel/target/release/kernel <that .smt2>   # expect exit 0
--
-- expect: stdout = ""
-- expect: exit = 0

import "stdlib/kernel.ev"
import "compiler2/translate2_record.ev"

claim main
    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    cap_int ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    cap_str ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""

    -- ── Captured handles (phase N emits, phase N+1 captures) ────

    cfg_h ∈ Int
    _cfg_h ∈ Int
    cfg_h = (is_first_tick ? 0 : phase = 1 ? cap_int : _cfg_h)

    ctx_h ∈ Int
    _ctx_h ∈ Int
    ctx_h = (is_first_tick ? 0 : phase = 2 ? cap_int : _ctx_h)

    int_sort_h ∈ Int
    _int_sort_h ∈ Int
    int_sort_h = (is_first_tick ? 0 : phase = 3 ? cap_int : _int_sort_h)

    -- One 128-byte arena for every handle array. Layout (8-byte slots):
    --   +0  field_names[2]            +64 mk_datatypes ctor_lists[1]
    --   +16 field_sorts[2]            +72 query ctor_decl OUT
    --   +32 sort_refs[2] (4-byte ×2)  +80 query tester_decl OUT
    --   +40 ctor list array[1]        +88 query accessors OUT[2]
    --   +48 mk_datatypes names[1]     +104 mk_app args scratch[2]
    --   +56 mk_datatypes sorts OUT[1]
    buf ∈ Int
    _buf ∈ Int
    buf = (is_first_tick ? 0 : phase = 4 ? cap_int : _buf)

    sym_ivec2 ∈ Int
    _sym_ivec2 ∈ Int
    sym_ivec2 = (is_first_tick ? 0 : phase = 5 ? cap_int : _sym_ivec2)

    sym_is ∈ Int
    _sym_is ∈ Int
    sym_is = (is_first_tick ? 0 : phase = 6 ? cap_int : _sym_is)

    sym_x ∈ Int
    _sym_x ∈ Int
    sym_x = (is_first_tick ? 0 : phase = 7 ? cap_int : _sym_x)

    sym_y ∈ Int
    _sym_y ∈ Int
    sym_y = (is_first_tick ? 0 : phase = 8 ? cap_int : _sym_y)

    sym_p ∈ Int
    _sym_p ∈ Int
    sym_p = (is_first_tick ? 0 : phase = 9 ? cap_int : _sym_p)

    ivec2_ctor ∈ Int
    _ivec2_ctor ∈ Int
    ivec2_ctor = (is_first_tick ? 0 : phase = 15 ? cap_int : _ivec2_ctor)

    clist_h ∈ Int
    _clist_h ∈ Int
    clist_h = (is_first_tick ? 0 : phase = 17 ? cap_int : _clist_h)

    ivec2_sort ∈ Int
    _ivec2_sort ∈ Int
    ivec2_sort = (is_first_tick ? 0 : phase = 21 ? cap_int : _ivec2_sort)

    acc_x_decl ∈ Int
    _acc_x_decl ∈ Int
    acc_x_decl = (is_first_tick ? 0 : phase = 23 ? cap_int : _acc_x_decl)

    p_h ∈ Int
    _p_h ∈ Int
    p_h = (is_first_tick ? 0 : phase = 24 ? cap_int : _p_h)

    accapp_h ∈ Int
    _accapp_h ∈ Int
    accapp_h = (is_first_tick ? 0 : phase = 26 ? cap_int : _accapp_h)

    n3_h ∈ Int
    _n3_h ∈ Int
    n3_h = (is_first_tick ? 0 : phase = 27 ? cap_int : _n3_h)

    eq_h ∈ Int
    _eq_h ∈ Int
    eq_h = (is_first_tick ? 0 : phase = 28 ? cap_int : _eq_h)

    eq_str_ptr ∈ Int
    _eq_str_ptr ∈ Int
    eq_str_ptr = (is_first_tick ? 0 : phase = 29 ? cap_int : _eq_str_ptr)

    rendered_eq ∈ String
    _rendered_eq ∈ String
    rendered_eq = (is_first_tick ? "" : phase = 30 ? cap_str : _rendered_eq)

    ctor_decl ∈ Int
    _ctor_decl ∈ Int
    ctor_decl = (is_first_tick ? 0 : phase = 31 ? cap_int : _ctor_decl)

    n1_h ∈ Int
    _n1_h ∈ Int
    n1_h = (is_first_tick ? 0 : phase = 32 ? cap_int : _n1_h)

    n2_h ∈ Int
    _n2_h ∈ Int
    n2_h = (is_first_tick ? 0 : phase = 33 ? cap_int : _n2_h)

    lit_h ∈ Int
    _lit_h ∈ Int
    lit_h = (is_first_tick ? 0 : phase = 36 ? cap_int : _lit_h)

    lit_str_ptr ∈ Int
    _lit_str_ptr ∈ Int
    lit_str_ptr = (is_first_tick ? 0 : phase = 37 ? cap_int : _lit_str_ptr)

    rendered_lit ∈ String
    _rendered_lit ∈ String
    rendered_lit = (is_first_tick ? "" : phase = 38 ? cap_str : _rendered_lit)

    -- ── translate2_record claim compositions ───────────────────

    -- Field-0 accessor slot address for the live read_long at
    -- phase 22 (also sanity-checks the plan's flags in the verdict).
    plan_addr0 ∈ Int
    plan_in0, plan_last0, plan_and0 ∈ Bool
    RecordEqPlan(n_fields ↦ 2, accessors_arr_p ↦ buf + 88, idx ↦ 0,
        acc_slot_addr ↦ plan_addr0, in_range ↦ plan_in0,
        is_last ↦ plan_last0, needs_and ↦ plan_and0)

    recv_e ∈ Expr = EIdent("p")
    eff_recv ∈ Effect
    recv_ok ∈ Bool
    RecordRecvBuildZ3(ctx_h ↦ ctx_h, record_sort_h ↦ ivec2_sort,
        sym_h ↦ sym_p, e ↦ recv_e, eff ↦ eff_recv, ok ↦ recv_ok)

    eff_acc ∈ Effect
    RecordFieldAccessBuildZ3(ctx_h ↦ ctx_h, accessor_decl_h ↦ acc_x_decl,
        recv_arg_p ↦ buf + 104, eff ↦ eff_acc)

    eff_eq ∈ Effect
    RecordFieldEqBuildZ3(ctx_h ↦ ctx_h, l_field_h ↦ accapp_h,
        r_field_h ↦ n3_h, eff ↦ eff_eq)

    eff_lit ∈ Effect
    RecordLiteralBuildZ3(ctx_h ↦ ctx_h, ctor_decl_h ↦ ctor_decl,
        n_fields ↦ 2, args_arr_p ↦ buf + 104, eff ↦ eff_lit)

    -- ── Verdict ────────────────────────────────────────────────
    eq_ok ∈ Bool = (rendered_eq = "(= (x p) 3)")
    lit_ok ∈ Bool = (rendered_lit = "(IVec2 1 2)")
    sort_ok ∈ Bool = (ivec2_sort > 0)
    plan_ok ∈ Bool = (recv_ok ∧ plan_in0 ∧ ¬plan_last0 ∧ plan_and0)
    exit_code ∈ Int = (phase = 40
        ? (eq_ok ? (lit_ok ? (sort_ok ? (plan_ok ? 0 : 8) : 6) : 7) : 4)
        : 5)

    -- ── Effects, one per phase ─────────────────────────────────
    effects ∈ Seq(Effect) = (phase = 0
            ? ⟨LibCall("libz3", "Z3_mk_config", ⟨⟩)⟩
        : phase = 1
            ? ⟨LibCall("libz3", "Z3_mk_context", ⟨ArgInt(cfg_h)⟩)⟩
        : phase = 2
            ? ⟨LibCall("libz3", "Z3_mk_int_sort", ⟨ArgInt(ctx_h)⟩)⟩
        : phase = 3
            ? ⟨LibCall("libc", "malloc", ⟨ArgInt(128)⟩)⟩
        : phase = 4
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("IVec2")⟩)⟩
        : phase = 5
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("is_IVec2")⟩)⟩
        : phase = 6
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("x")⟩)⟩
        : phase = 7
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("y")⟩)⟩
        : phase = 8
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("p")⟩)⟩
        -- field_names[2] / field_sorts[2] / sort_refs[2] IN-arrays.
        -- sort_refs is 4-byte unsigneds: one write_long of 0 covers
        -- both slots (width caveat, stdlib/z3_datatypes.ev header).
        : phase = 9
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf), ArgInt(sym_x)⟩)⟩
        : phase = 10
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 8), ArgInt(sym_y)⟩)⟩
        : phase = 11
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 16), ArgInt(int_sort_h)⟩)⟩
        : phase = 12
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 24), ArgInt(int_sort_h)⟩)⟩
        : phase = 13
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 32), ArgInt(0)⟩)⟩
        : phase = 14
            ? ⟨LibCall("libz3", "Z3_mk_constructor",
                ⟨ArgInt(ctx_h), ArgInt(sym_ivec2), ArgInt(sym_is),
                 ArgInt(2), ArgInt(buf), ArgInt(buf + 16),
                 ArgInt(buf + 32)⟩)⟩
        : phase = 15
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 40), ArgInt(ivec2_ctor)⟩)⟩
        : phase = 16
            ? ⟨LibCall("libz3", "Z3_mk_constructor_list",
                ⟨ArgInt(ctx_h), ArgInt(1), ArgInt(buf + 40)⟩)⟩
        : phase = 17
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 48), ArgInt(sym_ivec2)⟩)⟩
        : phase = 18
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 64), ArgInt(clist_h)⟩)⟩
        : phase = 19
            ? ⟨LibCall("libz3", "Z3_mk_datatypes",
                ⟨ArgInt(ctx_h), ArgInt(1), ArgInt(buf + 48),
                 ArgInt(buf + 56), ArgInt(buf + 64)⟩)⟩
        : phase = 20
            ? ⟨LibCall("__mem", "read_long", ⟨ArgInt(buf + 56)⟩)⟩
        : phase = 21
            ? ⟨LibCall("libz3", "Z3_query_constructor",
                ⟨ArgInt(ctx_h), ArgInt(ivec2_ctor), ArgInt(2),
                 ArgInt(buf + 72), ArgInt(buf + 80), ArgInt(buf + 88)⟩)⟩
        -- harvest field-0's accessor decl at the plan-computed slot
        : phase = 22
            ? ⟨LibCall("__mem", "read_long", ⟨ArgInt(plan_addr0)⟩)⟩
        -- p : IVec2 — RecordRecvBuildZ3
        : phase = 23
            ? ⟨eff_recv⟩
        : phase = 24
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 104), ArgInt(p_h)⟩)⟩
        -- (x p) — RecordFieldAccessBuildZ3
        : phase = 25
            ? ⟨eff_acc⟩
        : phase = 26
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(3), ArgInt(int_sort_h)⟩)⟩
        -- (= (x p) 3) — RecordFieldEqBuildZ3
        : phase = 27
            ? ⟨eff_eq⟩
        : phase = 28
            ? ⟨LibCall("libz3", "Z3_ast_to_string",
                ⟨ArgInt(ctx_h), ArgInt(eq_h)⟩)⟩
        : phase = 29
            ? ⟨LibCall("__cstr", "copy", ⟨ArgInt(eq_str_ptr)⟩)⟩
        -- record literal: harvest ctor decl, build args, apply
        : phase = 30
            ? ⟨LibCall("__mem", "read_long", ⟨ArgInt(buf + 72)⟩)⟩
        : phase = 31
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(1), ArgInt(int_sort_h)⟩)⟩
        : phase = 32
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(2), ArgInt(int_sort_h)⟩)⟩
        : phase = 33
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 104), ArgInt(n1_h)⟩)⟩
        : phase = 34
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 112), ArgInt(n2_h)⟩)⟩
        -- (IVec2 1 2) — RecordLiteralBuildZ3
        : phase = 35
            ? ⟨eff_lit⟩
        : phase = 36
            ? ⟨LibCall("libz3", "Z3_ast_to_string",
                ⟨ArgInt(ctx_h), ArgInt(lit_h)⟩)⟩
        : phase = 37
            ? ⟨LibCall("__cstr", "copy", ⟨ArgInt(lit_str_ptr)⟩)⟩
        : phase = 38
            ? ⟨LibCall("libz3", "Z3_del_constructor",
                ⟨ArgInt(ctx_h), ArgInt(ivec2_ctor)⟩)⟩
        : phase = 39
            ? ⟨LibCall("libz3", "Z3_del_constructor_list",
                ⟨ArgInt(ctx_h), ArgInt(clist_h)⟩)⟩
        : ⟨Exit(exit_code)⟩)
