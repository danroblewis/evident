-- tests/kernel/compiler2/carry_fixture.ev — E1 fixture: `_name`
-- state carries + is_first_tick + the manifest floor (gap census E1).
--
-- NOT a kernel test_*.ev fixture: this file is an INPUT for the
-- compiler2 driver. It is a 2-tick FSM in the corpus's carry idiom:
-- an explicit `_count ∈ Int` carry membership (the oracle REQUIRES
-- the explicit declaration — an unbound `_count` mention is a
-- dropped constraint, probed) read back through
-- `count = (is_first_tick ? 5 : _count + 1)`. The driver must
--   · resolve `_count` / `is_first_tick` to build-context consts,
--   · EXCLUDE `_count` from manifest state-fields (base pairing:
--     the kernel pins `_count = <prev count>` itself),
--   · emit exactly ONE `(declare-fun _count () Int)` — the
--     serialization carries it (the assert mentions it), so the
--     textual carry line from `count`'s membership must be spliced,
--   · keep the UNREFERENCED `_done` carry declare textual (nothing
--     mentions it, so the serialization drops it — but the kernel
--     asserts into it from tick 1 on),
--   · emit the `(assert (>= effects__len 0))` floor (oracle parity).
--
-- Build + run under the driver (mktemp for all temp files):
--   TD=$(mktemp -d)
--   evident-oracle emit compiler2/driver.ev driver_main -o "$TD/driver.smt2"
--   scripts/flatten-evident.sh tests/kernel/compiler2/carry_fixture.ev > "$TD/flat.ev"
--   printf '%s\nmain\n' "$TD/flat.ev" | kernel/target/release/kernel "$TD/driver.smt2" > "$TD/out.smt2"
--   grep -c 'declare-fun _count' "$TD/out.smt2"        # exactly 1
--   grep -F 'state-fields = count:Int done:Bool' "$TD/out.smt2"
--   grep -F '(>= effects__len 0)' "$TD/out.smt2"
--   kernel/target/release/kernel "$TD/out.smt2"        # expect exit 0
--
-- The unit must run TWO ticks: tick 0 (is_first_tick) pins
-- count = 5, done = false → the getpid filler branch; tick 1 reads
-- the kernel's `_count = 5` carry, pins count = 6, done = true →
-- Exit(count - 6) = Exit(0). A dropped/mis-paired carry leaves
-- count unconstrained on tick 1 (exit ≠ 0), a duplicate `_count`
-- declare is a Z3 parse error (exit 3), and a missing `_done`
-- declare breaks the kernel's tick-1 carry assert.
--
-- expected exit: 0

import "stdlib/kernel.ev"

claim main
    count ∈ Int
    _count ∈ Int
    count = (is_first_tick ? 5 : _count + 1)
    done ∈ Bool
    _done ∈ Bool
    done = (is_first_tick ? false : true)
    effects ∈ Seq(Effect) = (done ? ⟨Exit(count - 6)⟩ : ⟨LibCall("libc", "getpid", ⟨⟩)⟩)
