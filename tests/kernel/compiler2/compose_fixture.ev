-- tests/kernel/compiler2/compose_fixture.ev — F2 unit fixture: a
-- DRIVER INPUT (not a test_*.ev kernel fixture). Exercises slot-call
-- composition with EXPRESSION slot values, nested TWO frames deep,
-- with α-renamed callee body locals:
--
--   main          Wrap(v ↦ 2 + 3, res ↦ r)        — expr value, depth 1
--   Wrap          Add2(x ↦ v + 10, out ↦ mid)      — expr value over a
--                                                    BIND, depth 2
--   Add2          tmp ∈ Int (α-renames to __c2_tmp), tmp = x + 1,
--                 out = tmp + 1
--
-- Solved chain: v = 5 → x = 15 → tmp = 16 → out = mid = 17 → r = 17
-- → ok → Exit(0). The emitted unit must kernel-run exit 0; it exits 1
-- if any bind/α-rename resolved the wrong handle.
--
-- Drive it:
--   TD=$(mktemp -d)
--   scripts/flatten-evident.sh tests/kernel/compiler2/compose_fixture.ev > $TD/flat.ev
--   printf '%s\nmain\n' "$TD/flat.ev" | kernel/target/release/kernel driver.smt2 > $TD/unit.smt2
--   kernel/target/release/kernel $TD/unit.smt2   # expect exit 0

import "stdlib/kernel.ev"

claim Add2(x ∈ Int, out ∈ Int)
    tmp ∈ Int
    tmp = x + 1
    out = tmp + 1

claim Wrap(v ∈ Int, res ∈ Int)
    mid ∈ Int
    Add2(x ↦ v + 10, out ↦ mid)
    res = mid

claim main
    r ∈ Int
    Wrap(v ↦ 2 + 3, res ↦ r)
    ok ∈ Bool = (r = 17)
    effects ∈ Seq(Effect) = ⟨Exit(ok ? 0 : 1)⟩
