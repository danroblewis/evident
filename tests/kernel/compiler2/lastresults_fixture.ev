-- tests/kernel/compiler2/lastresults_fixture.ev — D3 fixture: the
-- last_results channel in compiled user code (gap census D3).
--
-- NOT a kernel test_*.ev fixture: this file is an INPUT for the
-- compiler2 driver, proving the D3 surface compiles:
-- `r ∈ Result = last_results[0]` (Pratt PrIdx → C2SelH →
-- `(= r (select last_results 0))`) and an IntResult payload read
-- via the restricted match-pin shape (`v = match r` with an
-- `IntResult(n) ⇒ n` arm → the tester/accessor ite
-- `(ite ((_ is IntResult) r) (IntResult__f0 r) 7)`).
-- (The frozen bootstrap oracle compiles this source to the same
-- shapes; the FOSSIL compiler.smt2 does not — it drops the select
-- and the match — so this cannot be a fossil-driven test_*.ev.)
--
-- Build + run under the driver (mktemp for all temp files):
--   TD=$(mktemp -d)
--   evident-oracle emit compiler2/driver.ev driver_main -o "$TD/driver.smt2"
--   scripts/flatten-evident.sh tests/kernel/compiler2/lastresults_fixture.ev > "$TD/flat.ev"
--   printf '%s\nmain\n' "$TD/flat.ev" | kernel/target/release/kernel "$TD/driver.smt2" > "$TD/out.smt2"
--   grep -F '(select last_results 0)' "$TD/out.smt2"
--   grep -F 'IntResult__f0' "$TD/out.smt2"
--   kernel/target/release/kernel "$TD/out.smt2"   # expect exit 0
--
-- Determinism: the kernel pins is_first_tick = true and
-- last_results__len = 0 on tick 0; `(select last_results 0)` itself
-- is model-free, so the exit code routes through the is_first_tick
-- ternary (w = 7 on tick 0) — the payload-read ite is exercised in
-- the solve without making the exit depend on an unpinned select.
--
-- expected exit: 0

import "stdlib/kernel.ev"

claim main
    r ∈ Result = last_results[0]
    v ∈ Int = match r
        IntResult(n) ⇒ n
        _ ⇒ 7
    w ∈ Int = (is_first_tick ? 7 : v)
    ok ∈ Bool = (w = 7)
    effects ∈ Seq(Effect) = ⟨Exit(ok ? 0 : 1)⟩
