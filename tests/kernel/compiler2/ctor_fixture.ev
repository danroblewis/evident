-- tests/kernel/compiler2/ctor_fixture.ev — P2 validation for
-- compiler2/translate2_ctor.ev.
--
-- Declares TWO datatypes in a child Z3 context purely through the
-- pass's per-step claims, driven from PARSED enum data (parser.ev's
-- EnumDeclAst literals):
--
--   enum E  = A | B(Int)            — the plain payload case
--   enum LL = Nil | Cons(Int, LL)   — single recursion (sort_refs path,
--                                     incl. the 2-field SortRefsPack2
--                                     width-caveat packing)
--
-- Then applies the harvested constructor decls:
--
--   1. B with a COMPOUND argument: mk_int(3), mk_int(4), mk_add → one
--      handle, CtorArgWriteStep + CtorAppStep → (B (+ 3 4)),
--      Z3_simplify → ast_to_string → expect "(B 7)". This is the exact
--      shape the legacy text renderer dropped (the Exit(3+4) bug
--      class); here the compound arg is just a handle.
--   2. Cons(1, Nil): nullary CtorAppStep for Nil, then a 2-arg
--      CtorAppStep where arg 1 is ITSELF a ctor-app handle —
--      ast_to_string → expect "(Cons 1 Nil)".
--
-- Exit(0) iff both renders match and the harvested E sort handle is
-- non-null. Multi-tick FSM convention: phase-N's libcall result is
-- captured at phase N+1 (same as sugar_datatypes.ev).
--
-- Build + run (oracle path; mktemp for all temp files):
--   TD=$(mktemp -d)
--   evident-oracle emit tests/kernel/compiler2/ctor_fixture.ev ctor_fixture_main -o "$TD/f.smt2"
--   kernel/target/release/kernel "$TD/f.smt2"   # expect exit 0
--
-- expect: stdout = ""
-- expect: exit = 0

import "compiler2/translate2_ctor.ev"

claim ctor_fixture_main
    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    cap_int ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    cap_str ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""

    -- ── Parsed enum data (what a P3 driver gets from the parser) ──
    v_a ∈ EnumVariantDecl = EVDecl("A")
    v_b ∈ EnumVariantDecl = EVDeclP("B", EVFCons(EVFType("Int"), EVFNil))
    decl_e ∈ EnumDeclAst = EnumD("E", EVCons(v_a, EVCons(v_b, EVNil)))

    v_nil ∈ EnumVariantDecl = EVDecl("Nil")
    v_cons ∈ EnumVariantDecl = EVDeclP("Cons",
        EVFCons(EVFType("Int"), EVFCons(EVFType("LL"), EVFNil)))
    decl_ll ∈ EnumDeclAst = EnumD("LL", EVCons(v_nil, EVCons(v_cons, EVNil)))

    -- ── Captured handles (phase N emits, phase N+1 captures) ──────
    cfg ∈ Int
    _cfg ∈ Int
    cfg = (is_first_tick ? 0 : phase = 1 ? cap_int : _cfg)

    ctx ∈ Int
    _ctx ∈ Int
    ctx = (is_first_tick ? 0 : phase = 2 ? cap_int : _ctx)

    isort ∈ Int
    _isort ∈ Int
    isort = (is_first_tick ? 0 : phase = 3 ? cap_int : _isort)

    -- One 264-byte arena. Layout (8-byte slots, offsets from buf):
    --   E:  +0 B fnames[1]   +8 B fsorts[1]   +16 B srefs
    --       +24 ctors[2]     +40 names[1]     +48 sorts OUT[1]
    --       +56 clists[1]    +64 query-B decl +72 tester +80 acc[1]
    --       +88 add args[2]  +104 B-app args[1]
    --   LL: +112 Cons fnames[2]  +128 Cons fsorts[2]  +144 srefs packed
    --       +152 ctors[2]    +168 names[1]    +176 sorts OUT[1]
    --       +184 clists[1]   +192 query-Nil decl/tester/acc
    --       +216 query-Cons decl +224 tester +232 acc[2]
    --       +248 Cons-app args[2]
    buf ∈ Int
    _buf ∈ Int
    buf = (is_first_tick ? 0 : phase = 4 ? cap_int : _buf)

    sym_a ∈ Int
    _sym_a ∈ Int
    sym_a = (is_first_tick ? 0 : phase = 5 ? cap_int : _sym_a)

    sym_is_a ∈ Int
    _sym_is_a ∈ Int
    sym_is_a = (is_first_tick ? 0 : phase = 6 ? cap_int : _sym_is_a)

    sym_b ∈ Int
    _sym_b ∈ Int
    sym_b = (is_first_tick ? 0 : phase = 7 ? cap_int : _sym_b)

    sym_is_b ∈ Int
    _sym_is_b ∈ Int
    sym_is_b = (is_first_tick ? 0 : phase = 8 ? cap_int : _sym_is_b)

    sym_b_f0 ∈ Int
    _sym_b_f0 ∈ Int
    sym_b_f0 = (is_first_tick ? 0 : phase = 9 ? cap_int : _sym_b_f0)

    sym_e ∈ Int
    _sym_e ∈ Int
    sym_e = (is_first_tick ? 0 : phase = 10 ? cap_int : _sym_e)

    a_ctor ∈ Int
    _a_ctor ∈ Int
    a_ctor = (is_first_tick ? 0 : phase = 11 ? cap_int : _a_ctor)

    b_ctor ∈ Int
    _b_ctor ∈ Int
    b_ctor = (is_first_tick ? 0 : phase = 15 ? cap_int : _b_ctor)

    clist ∈ Int
    _clist ∈ Int
    clist = (is_first_tick ? 0 : phase = 18 ? cap_int : _clist)

    e_sort ∈ Int
    _e_sort ∈ Int
    e_sort = (is_first_tick ? 0 : phase = 22 ? cap_int : _e_sort)

    b_decl ∈ Int
    _b_decl ∈ Int
    b_decl = (is_first_tick ? 0 : phase = 24 ? cap_int : _b_decl)

    n3 ∈ Int
    _n3 ∈ Int
    n3 = (is_first_tick ? 0 : phase = 25 ? cap_int : _n3)

    n4 ∈ Int
    _n4 ∈ Int
    n4 = (is_first_tick ? 0 : phase = 26 ? cap_int : _n4)

    sum_h ∈ Int
    _sum_h ∈ Int
    sum_h = (is_first_tick ? 0 : phase = 29 ? cap_int : _sum_h)

    b_app ∈ Int
    _b_app ∈ Int
    b_app = (is_first_tick ? 0 : phase = 31 ? cap_int : _b_app)

    simp_h ∈ Int
    _simp_h ∈ Int
    simp_h = (is_first_tick ? 0 : phase = 32 ? cap_int : _simp_h)

    sptr1 ∈ Int
    _sptr1 ∈ Int
    sptr1 = (is_first_tick ? 0 : phase = 33 ? cap_int : _sptr1)

    r1 ∈ String
    _r1 ∈ String
    r1 = (is_first_tick ? "" : phase = 34 ? cap_str : _r1)

    sym_nil ∈ Int
    _sym_nil ∈ Int
    sym_nil = (is_first_tick ? 0 : phase = 35 ? cap_int : _sym_nil)

    sym_is_nil ∈ Int
    _sym_is_nil ∈ Int
    sym_is_nil = (is_first_tick ? 0 : phase = 36 ? cap_int : _sym_is_nil)

    sym_cons ∈ Int
    _sym_cons ∈ Int
    sym_cons = (is_first_tick ? 0 : phase = 37 ? cap_int : _sym_cons)

    sym_is_cons ∈ Int
    _sym_is_cons ∈ Int
    sym_is_cons = (is_first_tick ? 0 : phase = 38 ? cap_int : _sym_is_cons)

    sym_c_f0 ∈ Int
    _sym_c_f0 ∈ Int
    sym_c_f0 = (is_first_tick ? 0 : phase = 39 ? cap_int : _sym_c_f0)

    sym_c_f1 ∈ Int
    _sym_c_f1 ∈ Int
    sym_c_f1 = (is_first_tick ? 0 : phase = 40 ? cap_int : _sym_c_f1)

    sym_ll ∈ Int
    _sym_ll ∈ Int
    sym_ll = (is_first_tick ? 0 : phase = 41 ? cap_int : _sym_ll)

    nil_ctor ∈ Int
    _nil_ctor ∈ Int
    nil_ctor = (is_first_tick ? 0 : phase = 42 ? cap_int : _nil_ctor)

    cons_ctor ∈ Int
    _cons_ctor ∈ Int
    cons_ctor = (is_first_tick ? 0 : phase = 48 ? cap_int : _cons_ctor)

    clist2 ∈ Int
    _clist2 ∈ Int
    clist2 = (is_first_tick ? 0 : phase = 51 ? cap_int : _clist2)

    nil_decl ∈ Int
    _nil_decl ∈ Int
    nil_decl = (is_first_tick ? 0 : phase = 56 ? cap_int : _nil_decl)

    cons_decl ∈ Int
    _cons_decl ∈ Int
    cons_decl = (is_first_tick ? 0 : phase = 58 ? cap_int : _cons_decl)

    n1 ∈ Int
    _n1 ∈ Int
    n1 = (is_first_tick ? 0 : phase = 59 ? cap_int : _n1)

    nil_app ∈ Int
    _nil_app ∈ Int
    nil_app = (is_first_tick ? 0 : phase = 60 ? cap_int : _nil_app)

    cons_app ∈ Int
    _cons_app ∈ Int
    cons_app = (is_first_tick ? 0 : phase = 63 ? cap_int : _cons_app)

    sptr2 ∈ Int
    _sptr2 ∈ Int
    sptr2 = (is_first_tick ? 0 : phase = 64 ? cap_int : _sptr2)

    r2 ∈ String
    _r2 ∈ String
    r2 = (is_first_tick ? "" : phase = 65 ? cap_str : _r2)

    -- ── Field-slot resolution through the pass claims ─────────────
    ty_b0 ∈ String
    VariantFieldType(v ↦ v_b, idx ↦ 0, ty ↦ ty_b0)
    slot_b0 ∈ Int
    ref_b0 ∈ Int
    self_b0 ∈ Bool
    FieldSortSlot(enum_name ↦ "E", ty ↦ ty_b0,
        int_sort_h ↦ isort, bool_sort_h ↦ 0, string_sort_h ↦ 0,
        self_sort_idx ↦ 0,
        sort_slot ↦ slot_b0, ref_slot ↦ ref_b0, is_self ↦ self_b0)

    ty_c0 ∈ String
    VariantFieldType(v ↦ v_cons, idx ↦ 0, ty ↦ ty_c0)
    slot_c0 ∈ Int
    ref_c0 ∈ Int
    self_c0 ∈ Bool
    FieldSortSlot(enum_name ↦ "LL", ty ↦ ty_c0,
        int_sort_h ↦ isort, bool_sort_h ↦ 0, string_sort_h ↦ 0,
        self_sort_idx ↦ 0,
        sort_slot ↦ slot_c0, ref_slot ↦ ref_c0, is_self ↦ self_c0)

    ty_c1 ∈ String
    VariantFieldType(v ↦ v_cons, idx ↦ 1, ty ↦ ty_c1)
    slot_c1 ∈ Int
    ref_c1 ∈ Int
    self_c1 ∈ Bool
    FieldSortSlot(enum_name ↦ "LL", ty ↦ ty_c1,
        int_sort_h ↦ isort, bool_sort_h ↦ 0, string_sort_h ↦ 0,
        self_sort_idx ↦ 0,
        sort_slot ↦ slot_c1, ref_slot ↦ ref_c1, is_self ↦ self_c1)

    packed_c ∈ Int
    SortRefsPack2(ref_lo ↦ ref_c0, ref_hi ↦ ref_c1, packed ↦ packed_c)

    -- ── Per-phase Effects via the step claims ─────────────────────
    eff_cfg ∈ Effect
    BuildZ3MkConfig(eff ↦ eff_cfg)
    eff_ctx ∈ Effect
    BuildZ3MkContext(cfg_h ↦ cfg, eff ↦ eff_ctx)
    eff_isort ∈ Effect
    BuildZ3MkIntSort(ctx_h ↦ ctx, eff ↦ eff_isort)
    eff_arena ∈ Effect
    BuildMalloc(n_bytes ↦ 264, eff ↦ eff_arena)

    eff_sym_a ∈ Effect
    VariantNameSymStep(ctx_h ↦ ctx, v ↦ v_a, eff ↦ eff_sym_a)
    eff_sym_is_a ∈ Effect
    VariantRecognizerSymStep(ctx_h ↦ ctx, v ↦ v_a, eff ↦ eff_sym_is_a)
    eff_sym_b ∈ Effect
    VariantNameSymStep(ctx_h ↦ ctx, v ↦ v_b, eff ↦ eff_sym_b)
    eff_sym_is_b ∈ Effect
    VariantRecognizerSymStep(ctx_h ↦ ctx, v ↦ v_b, eff ↦ eff_sym_is_b)
    eff_sym_b_f0 ∈ Effect
    VariantFieldSymStep(ctx_h ↦ ctx, v ↦ v_b, idx ↦ 0, eff ↦ eff_sym_b_f0)
    eff_sym_e ∈ Effect
    EnumSortSymStep(ctx_h ↦ ctx, decl ↦ decl_e, eff ↦ eff_sym_e)

    eff_mk_a ∈ Effect
    VariantMkConstructorStep(ctx_h ↦ ctx, v ↦ v_a,
        name_sym_h ↦ sym_a, recog_sym_h ↦ sym_is_a,
        fnames_p ↦ buf, fsorts_p ↦ buf + 8, srefs_p ↦ buf + 16,
        eff ↦ eff_mk_a)
    eff_w_bfn ∈ Effect
    BuildMemWriteLong(addr ↦ buf, value ↦ sym_b_f0, eff ↦ eff_w_bfn)
    eff_w_bfs ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 8, value ↦ slot_b0, eff ↦ eff_w_bfs)
    eff_w_bfr ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 16, value ↦ ref_b0, eff ↦ eff_w_bfr)
    eff_mk_b ∈ Effect
    VariantMkConstructorStep(ctx_h ↦ ctx, v ↦ v_b,
        name_sym_h ↦ sym_b, recog_sym_h ↦ sym_is_b,
        fnames_p ↦ buf, fsorts_p ↦ buf + 8, srefs_p ↦ buf + 16,
        eff ↦ eff_mk_b)
    eff_w_ca ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 24, value ↦ a_ctor, eff ↦ eff_w_ca)
    eff_w_cb ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 32, value ↦ b_ctor, eff ↦ eff_w_cb)
    eff_clist ∈ Effect
    BuildZ3MkConstructorList(ctx_h ↦ ctx, n_ctors ↦ 2, ctors_arr_p ↦ buf + 24,
        eff ↦ eff_clist)
    eff_w_nm ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 40, value ↦ sym_e, eff ↦ eff_w_nm)
    eff_w_cl ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 56, value ↦ clist, eff ↦ eff_w_cl)
    eff_mkdt ∈ Effect
    BuildZ3MkDatatypes(ctx_h ↦ ctx, n_sorts ↦ 1,
        sort_names_arr_p ↦ buf + 40, sorts_out_arr_p ↦ buf + 48,
        ctor_lists_arr_p ↦ buf + 56, eff ↦ eff_mkdt)
    eff_rd_sort ∈ Effect
    BuildMemReadLong(addr ↦ buf + 48, eff ↦ eff_rd_sort)
    eff_query_b ∈ Effect
    VariantQueryStep(ctx_h ↦ ctx, ctor_h ↦ b_ctor, v ↦ v_b,
        out_base_p ↦ buf + 64, eff ↦ eff_query_b)
    eff_rd_bdecl ∈ Effect
    BuildMemReadLong(addr ↦ buf + 64, eff ↦ eff_rd_bdecl)

    eff_n3 ∈ Effect
    BuildZ3MkInt(ctx_h ↦ ctx, val ↦ 3, sort_h ↦ isort, eff ↦ eff_n3)
    eff_n4 ∈ Effect
    BuildZ3MkInt(ctx_h ↦ ctx, val ↦ 4, sort_h ↦ isort, eff ↦ eff_n4)
    eff_w_a0 ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 88, value ↦ n3, eff ↦ eff_w_a0)
    eff_w_a1 ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 96, value ↦ n4, eff ↦ eff_w_a1)
    eff_add ∈ Effect
    BuildZ3MkAdd(ctx_h ↦ ctx, num_args ↦ 2, args_arr_ptr ↦ buf + 88,
        eff ↦ eff_add)
    eff_w_barg ∈ Effect
    CtorArgWriteStep(args_p ↦ buf + 104, idx ↦ 0, arg_h ↦ sum_h,
        eff ↦ eff_w_barg)
    eff_app_b ∈ Effect
    CtorAppStep(ctx_h ↦ ctx, ctor_decl_h ↦ b_decl, n_args ↦ 1,
        args_p ↦ buf + 104, eff ↦ eff_app_b)
    eff_simp ∈ Effect
    BuildZ3Simplify(ctx_h ↦ ctx, ast_h ↦ b_app, eff ↦ eff_simp)
    eff_str1 ∈ Effect
    BuildZ3AstToString(ctx_h ↦ ctx, ast_h ↦ simp_h, eff ↦ eff_str1)
    eff_cp1 ∈ Effect
    BuildCstrCopy(addr ↦ sptr1, eff ↦ eff_cp1)

    eff_sym_nil ∈ Effect
    VariantNameSymStep(ctx_h ↦ ctx, v ↦ v_nil, eff ↦ eff_sym_nil)
    eff_sym_is_nil ∈ Effect
    VariantRecognizerSymStep(ctx_h ↦ ctx, v ↦ v_nil, eff ↦ eff_sym_is_nil)
    eff_sym_cons ∈ Effect
    VariantNameSymStep(ctx_h ↦ ctx, v ↦ v_cons, eff ↦ eff_sym_cons)
    eff_sym_is_cons ∈ Effect
    VariantRecognizerSymStep(ctx_h ↦ ctx, v ↦ v_cons, eff ↦ eff_sym_is_cons)
    eff_sym_c_f0 ∈ Effect
    VariantFieldSymStep(ctx_h ↦ ctx, v ↦ v_cons, idx ↦ 0, eff ↦ eff_sym_c_f0)
    eff_sym_c_f1 ∈ Effect
    VariantFieldSymStep(ctx_h ↦ ctx, v ↦ v_cons, idx ↦ 1, eff ↦ eff_sym_c_f1)
    eff_sym_ll ∈ Effect
    EnumSortSymStep(ctx_h ↦ ctx, decl ↦ decl_ll, eff ↦ eff_sym_ll)

    eff_mk_nil ∈ Effect
    VariantMkConstructorStep(ctx_h ↦ ctx, v ↦ v_nil,
        name_sym_h ↦ sym_nil, recog_sym_h ↦ sym_is_nil,
        fnames_p ↦ buf + 112, fsorts_p ↦ buf + 128, srefs_p ↦ buf + 144,
        eff ↦ eff_mk_nil)
    eff_w_cfn0 ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 112, value ↦ sym_c_f0, eff ↦ eff_w_cfn0)
    eff_w_cfn1 ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 120, value ↦ sym_c_f1, eff ↦ eff_w_cfn1)
    eff_w_cfs0 ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 128, value ↦ slot_c0, eff ↦ eff_w_cfs0)
    eff_w_cfs1 ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 136, value ↦ slot_c1, eff ↦ eff_w_cfs1)
    eff_w_cfr ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 144, value ↦ packed_c, eff ↦ eff_w_cfr)
    eff_mk_cons ∈ Effect
    VariantMkConstructorStep(ctx_h ↦ ctx, v ↦ v_cons,
        name_sym_h ↦ sym_cons, recog_sym_h ↦ sym_is_cons,
        fnames_p ↦ buf + 112, fsorts_p ↦ buf + 128, srefs_p ↦ buf + 144,
        eff ↦ eff_mk_cons)
    eff_w_cnil ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 152, value ↦ nil_ctor, eff ↦ eff_w_cnil)
    eff_w_ccons ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 160, value ↦ cons_ctor, eff ↦ eff_w_ccons)
    eff_clist2 ∈ Effect
    BuildZ3MkConstructorList(ctx_h ↦ ctx, n_ctors ↦ 2,
        ctors_arr_p ↦ buf + 152, eff ↦ eff_clist2)
    eff_w_nm2 ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 168, value ↦ sym_ll, eff ↦ eff_w_nm2)
    eff_w_cl2 ∈ Effect
    BuildMemWriteLong(addr ↦ buf + 184, value ↦ clist2, eff ↦ eff_w_cl2)
    eff_mkdt2 ∈ Effect
    BuildZ3MkDatatypes(ctx_h ↦ ctx, n_sorts ↦ 1,
        sort_names_arr_p ↦ buf + 168, sorts_out_arr_p ↦ buf + 176,
        ctor_lists_arr_p ↦ buf + 184, eff ↦ eff_mkdt2)
    eff_query_nil ∈ Effect
    VariantQueryStep(ctx_h ↦ ctx, ctor_h ↦ nil_ctor, v ↦ v_nil,
        out_base_p ↦ buf + 192, eff ↦ eff_query_nil)
    eff_rd_nildecl ∈ Effect
    BuildMemReadLong(addr ↦ buf + 192, eff ↦ eff_rd_nildecl)
    eff_query_cons ∈ Effect
    VariantQueryStep(ctx_h ↦ ctx, ctor_h ↦ cons_ctor, v ↦ v_cons,
        out_base_p ↦ buf + 216, eff ↦ eff_query_cons)
    eff_rd_consdecl ∈ Effect
    BuildMemReadLong(addr ↦ buf + 216, eff ↦ eff_rd_consdecl)

    eff_n1 ∈ Effect
    BuildZ3MkInt(ctx_h ↦ ctx, val ↦ 1, sort_h ↦ isort, eff ↦ eff_n1)
    eff_app_nil ∈ Effect
    CtorAppStep(ctx_h ↦ ctx, ctor_decl_h ↦ nil_decl, n_args ↦ 0,
        args_p ↦ 0, eff ↦ eff_app_nil)
    eff_w_carg0 ∈ Effect
    CtorArgWriteStep(args_p ↦ buf + 248, idx ↦ 0, arg_h ↦ n1,
        eff ↦ eff_w_carg0)
    eff_w_carg1 ∈ Effect
    CtorArgWriteStep(args_p ↦ buf + 248, idx ↦ 1, arg_h ↦ nil_app,
        eff ↦ eff_w_carg1)
    eff_app_cons ∈ Effect
    CtorAppStep(ctx_h ↦ ctx, ctor_decl_h ↦ cons_decl, n_args ↦ 2,
        args_p ↦ buf + 248, eff ↦ eff_app_cons)
    eff_str2 ∈ Effect
    BuildZ3AstToString(ctx_h ↦ ctx, ast_h ↦ cons_app, eff ↦ eff_str2)
    eff_cp2 ∈ Effect
    BuildCstrCopy(addr ↦ sptr2, eff ↦ eff_cp2)

    -- ── Verdict ───────────────────────────────────────────────────
    exit_code ∈ Int = (r1 = "(B 7)"
        ? (r2 = "(Cons 1 Nil)" ? (e_sort > 0 ? 0 : 6) : 7)
        : 4)

    -- ── Schedule: one step per tick ───────────────────────────────
    effects ∈ Seq(Effect) = (phase = 0 ? ⟨eff_cfg⟩
        : phase = 1 ? ⟨eff_ctx⟩
        : phase = 2 ? ⟨eff_isort⟩
        : phase = 3 ? ⟨eff_arena⟩
        : phase = 4 ? ⟨eff_sym_a⟩
        : phase = 5 ? ⟨eff_sym_is_a⟩
        : phase = 6 ? ⟨eff_sym_b⟩
        : phase = 7 ? ⟨eff_sym_is_b⟩
        : phase = 8 ? ⟨eff_sym_b_f0⟩
        : phase = 9 ? ⟨eff_sym_e⟩
        : phase = 10 ? ⟨eff_mk_a⟩
        : phase = 11 ? ⟨eff_w_bfn⟩
        : phase = 12 ? ⟨eff_w_bfs⟩
        : phase = 13 ? ⟨eff_w_bfr⟩
        : phase = 14 ? ⟨eff_mk_b⟩
        : phase = 15 ? ⟨eff_w_ca⟩
        : phase = 16 ? ⟨eff_w_cb⟩
        : phase = 17 ? ⟨eff_clist⟩
        : phase = 18 ? ⟨eff_w_nm⟩
        : phase = 19 ? ⟨eff_w_cl⟩
        : phase = 20 ? ⟨eff_mkdt⟩
        : phase = 21 ? ⟨eff_rd_sort⟩
        : phase = 22 ? ⟨eff_query_b⟩
        : phase = 23 ? ⟨eff_rd_bdecl⟩
        : phase = 24 ? ⟨eff_n3⟩
        : phase = 25 ? ⟨eff_n4⟩
        : phase = 26 ? ⟨eff_w_a0⟩
        : phase = 27 ? ⟨eff_w_a1⟩
        : phase = 28 ? ⟨eff_add⟩
        : phase = 29 ? ⟨eff_w_barg⟩
        : phase = 30 ? ⟨eff_app_b⟩
        : phase = 31 ? ⟨eff_simp⟩
        : phase = 32 ? ⟨eff_str1⟩
        : phase = 33 ? ⟨eff_cp1⟩
        : phase = 34 ? ⟨eff_sym_nil⟩
        : phase = 35 ? ⟨eff_sym_is_nil⟩
        : phase = 36 ? ⟨eff_sym_cons⟩
        : phase = 37 ? ⟨eff_sym_is_cons⟩
        : phase = 38 ? ⟨eff_sym_c_f0⟩
        : phase = 39 ? ⟨eff_sym_c_f1⟩
        : phase = 40 ? ⟨eff_sym_ll⟩
        : phase = 41 ? ⟨eff_mk_nil⟩
        : phase = 42 ? ⟨eff_w_cfn0⟩
        : phase = 43 ? ⟨eff_w_cfn1⟩
        : phase = 44 ? ⟨eff_w_cfs0⟩
        : phase = 45 ? ⟨eff_w_cfs1⟩
        : phase = 46 ? ⟨eff_w_cfr⟩
        : phase = 47 ? ⟨eff_mk_cons⟩
        : phase = 48 ? ⟨eff_w_cnil⟩
        : phase = 49 ? ⟨eff_w_ccons⟩
        : phase = 50 ? ⟨eff_clist2⟩
        : phase = 51 ? ⟨eff_w_nm2⟩
        : phase = 52 ? ⟨eff_w_cl2⟩
        : phase = 53 ? ⟨eff_mkdt2⟩
        : phase = 54 ? ⟨eff_query_nil⟩
        : phase = 55 ? ⟨eff_rd_nildecl⟩
        : phase = 56 ? ⟨eff_query_cons⟩
        : phase = 57 ? ⟨eff_rd_consdecl⟩
        : phase = 58 ? ⟨eff_n1⟩
        : phase = 59 ? ⟨eff_app_nil⟩
        : phase = 60 ? ⟨eff_w_carg0⟩
        : phase = 61 ? ⟨eff_w_carg1⟩
        : phase = 62 ? ⟨eff_app_cons⟩
        : phase = 63 ? ⟨eff_str2⟩
        : phase = 64 ? ⟨eff_cp2⟩
        : ⟨Exit(exit_code)⟩)
