-- tests/kernel/compiler2/match_bind_fixture.ev — C5 fixture: match
-- payload binds + full-expression arm bodies (gap census C5).
--
-- NOT a kernel test_*.ev fixture: this file is an INPUT for the
-- compiler2 driver. It declares a payloaded USER enum, pins a var
-- to a ctor application, and reads the payload back through a
-- match-pin whose payload-bind arm has a FULL EXPRESSION body
-- (`B(v) ⇒ v * 2` — the bind substitutes as the harvested accessor
-- app, the oracle's `(B__f0 x)`, scoped to its arm body only). The
-- last arm (`A ⇒ 0`) is the dropped-test default per the legacy
-- right-to-left fold rule.
--
-- Oracle-verified target shape:
--   (= y (ite ((_ is B) x) (* (B__f0 x) 2) 0))
--
-- Build + run under the driver (mktemp for all temp files):
--   TD=$(mktemp -d)
--   evident-oracle emit compiler2/driver.ev driver_main -o "$TD/driver.smt2"
--   scripts/flatten-evident.sh tests/kernel/compiler2/match_bind_fixture.ev > "$TD/flat.ev"
--   printf '%s\nmain\n' "$TD/flat.ev" | kernel/target/release/kernel "$TD/driver.smt2" > "$TD/out.smt2"
--   grep -F '(B__f0 x)' "$TD/out.smt2"          # accessor app in the emit
--   grep -F '((_ is B) x)' "$TD/out.smt2"       # arm tester
--   kernel/target/release/kernel "$TD/out.smt2" # expect exit 0
--
-- x = B(21) pins the scrutinee, so y = (B__f0 x) * 2 = 42 and the
-- unit exits Exit(y - 42) = 0 ONLY if the bind resolved through the
-- right accessor decl; a dropped/mis-resolved bind leaves y
-- unconstrained (exit ≠ 0).
--
-- expected exit: 0

import "stdlib/kernel.ev"

enum E = A | B(Int)

claim main
    x ∈ E = B(21)
    y ∈ Int = match x
        B(v) ⇒ v * 2
        A ⇒ 0
    effects ∈ Seq(Effect) = ⟨Exit(y - 42)⟩
