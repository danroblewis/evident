-- tests/kernel/compiler2/ctor_app_fixture.ev — C3/C4 fixture: ctor
-- applications + matches recognizers (gap census C3 + C4).
--
-- NOT a kernel test_*.ev fixture: this file is an INPUT for the
-- compiler2 driver. It declares a payloaded USER enum in source
-- (`B(Int)` — the P3e nullary-only descope lifted), pins a variable
-- to a ctor application with a COMPOUND argument (`B(3 + 4)` — the
-- exact shape the legacy text-renderer dropped silently; here the
-- argument is a Z3_ast handle, so depth is invisible to mk_app),
-- and recognizes it with both payload-wildcard and nullary
-- `matches` forms.
--
-- Build + run under the driver (mktemp for all temp files):
--   TD=$(mktemp -d)
--   evident-oracle emit compiler2/driver.ev driver_main -o "$TD/driver.smt2"
--   scripts/flatten-evident.sh tests/kernel/compiler2/ctor_app_fixture.ev > "$TD/flat.ev"
--   printf '%s\nmain\n' "$TD/flat.ev" | kernel/target/release/kernel "$TD/driver.smt2" > "$TD/out.smt2"
--   grep -F '(= x (B (+ 3 4)))' "$TD/out.smt2"  # ctor app, compound arg INTACT
--   grep -F '((_ is B) x)' "$TD/out.smt2"       # payload-wildcard tester app
--   grep -F '((_ is A) x)' "$TD/out.smt2"       # nullary tester app
--   kernel/target/release/kernel "$TD/out.smt2" # expect exit 0
--
-- x = B(7) makes `x matches B(_)` true and `x matches A` false, so
-- the unit exits 0 only if the ctor decl AND both testers resolved
-- to the right func_decls.
--
-- expected exit: 0

import "stdlib/kernel.ev"

enum E = A | B(Int)

claim main
    x ∈ E = B(3 + 4)
    ok ∈ Bool = (x matches B(_))
    nok ∈ Bool = (x matches A)
    effects ∈ Seq(Effect) = ⟨Exit((ok ∧ ¬nok) ? 0 : 1)⟩
