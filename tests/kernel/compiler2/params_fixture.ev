-- tests/kernel/compiler2/params_fixture.ev — F1 fixture: first-line
-- parameter lists with a multi-name group (gap census F1).
--
-- NOT a kernel test_*.ev fixture: this file is an INPUT for the
-- compiler2 driver. The TARGET claim carries a first-line param
-- list with a multi-name group (`a, b ∈ Int`) and a second group
-- (`ok ∈ Bool`). The driver's pmode-9 group walk must declare each
-- param as a typed build-context const (symtab entry + manifest
-- state field + textual carry declare), then walk the body like
-- any claim.
--
-- DIVERGENCE from the oracle (deliberate): the oracle substitutes
-- pinned param values away (`(= 3 3)`), never declares `a`/`b`,
-- and its emitted unit DIES under the kernel ("state var `a` not
-- in model", exit 3 — probed). The driver declares params for
-- real, so this unit actually runs.
--
-- Build + run under the driver (mktemp for all temp files):
--   TD=$(mktemp -d)
--   evident-oracle emit compiler2/driver.ev driver_main -o "$TD/driver.smt2"
--   scripts/flatten-evident.sh tests/kernel/compiler2/params_fixture.ev > "$TD/flat.ev"
--   printf '%s\nmain\n' "$TD/flat.ev" | kernel/target/release/kernel "$TD/driver.smt2" > "$TD/out.smt2"
--   grep -F 'a:Int' "$TD/out.smt2"                # params in state-fields
--   grep -F '(declare-fun _ok () Bool)' "$TD/out.smt2"
--   kernel/target/release/kernel "$TD/out.smt2"  # expect exit 0
--
-- ok = (a + b = 7) with a = 3, b = 4 forces ok = true and
-- Exit(ok ? 0 : 1) = Exit(0) ONLY if both groups declared with the
-- right sorts; a dropped param leaves ok unconstrained.
--
-- expected exit: 0

import "stdlib/kernel.ev"

claim main(a, b ∈ Int, ok ∈ Bool)
    a = 3
    b = 4
    ok = (a + b = 7)
    effects ∈ Seq(Effect) = ⟨Exit(ok ? 0 : 1)⟩
