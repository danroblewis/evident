-- compiler2 P2 match-pass proof: declare `enum E = A | B(Int)` through
-- the proven libz3 datatype sequence (tests/kernel/z3_datatypes/
-- sugar_datatypes.ev, phases 0..24 here), then build the lowering of
--
--   match e            and the          e matches B(_)
--       B(v) ⇒ v       standalone       ────────────────
--       A    ⇒ 0       recognizer:      ((_ is B) e)
--   ──────────────────────────
--   (ite ((_ is B) e) (b_val e) 0)
--
-- and a literal-pattern match
--
--   match n
--       5 ⇒ 1          →   (ite (= n 5) 1 2)
--       _ ⇒ 2
--
-- ENTIRELY via compiler2/translate2_match.ev's claims, composed with
-- slot bindings (this fixture is oracle-compiled — full Evident, no
-- fossil-subset raw-LibCall contortion needed for the pass under
-- test; the datatype scaffolding stays raw to mirror the proven
-- sequence byte-for-byte):
--
--   phase 29  MatchesBuildZ3       tester app  ((_ is B) e)   (a)
--   phase 30  MatchPayloadBuildZ3  accessor    (b_val e)      (c)
--   phase 31  MatchArmFoldBuildZ3  the ctor-arm fold step     (b)
--   phase 41  MatchLitTestBuildZ3  literal test (= n 5)       (d)
--   phase 42  MatchArmFoldBuildZ3  the literal-arm fold step  (b)
--
-- Right-to-left fold (see the pass header): each match has one
-- non-default arm, so the fold is one step — else_h is the default
-- arm's RHS handle (0 / 2), built before the fold.
--
-- Expected strings discovered via Z3 4.15.4 CLI (get-assertions
-- round-trip of the same terms):
--   (ite ((_ is B) e) (b_val e) 0)
--   ((_ is B) e)
--   (ite (= n 5) 1 2)
--
-- Exit 0 iff all three Z3_ast_to_string renderings match; 4 = match
-- ite mismatch, 6 = matches mismatch, 8 = literal ite mismatch.
--
-- Build + run (oracle, not the fossil seam):
--   evident-oracle emit tests/kernel/compiler2/match_fixture.ev main -o out.smt2
--   kernel/target/release/kernel out.smt2   # expect exit 0
--
-- expect: stdout = ""
-- expect: exit = 0

import "compiler2/translate2_match.ev"

claim main
    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    cap_int ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    cap_str ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""

    -- ── Captured handles (phase N emits, phase N+1 captures) ────

    cfg_h ∈ Int
    _cfg_h ∈ Int
    cfg_h = (is_first_tick ? 0 : phase = 1 ? cap_int : _cfg_h)

    ctx_h ∈ Int
    _ctx_h ∈ Int
    ctx_h = (is_first_tick ? 0 : phase = 2 ? cap_int : _ctx_h)

    int_sort_h ∈ Int
    _int_sort_h ∈ Int
    int_sort_h = (is_first_tick ? 0 : phase = 3 ? cap_int : _int_sort_h)

    -- One 96-byte arena. Layout (8-byte slots):
    --   +0  B field_names[1]        +48 mk_datatypes sorts OUT[1]
    --   +8  B field_sorts[1]        +56 mk_datatypes ctor_lists[1]
    --   +16 B sort_refs[1]          +64 query ctor_decl OUT
    --   +24 ctor list array[2]      +72 query tester_decl OUT
    --   +40 mk_datatypes names[1]   +80 query accessors OUT[1]
    --                               +88 scrutinee args[1]
    buf ∈ Int
    _buf ∈ Int
    buf = (is_first_tick ? 0 : phase = 4 ? cap_int : _buf)

    sym_a ∈ Int
    _sym_a ∈ Int
    sym_a = (is_first_tick ? 0 : phase = 5 ? cap_int : _sym_a)

    sym_is_a ∈ Int
    _sym_is_a ∈ Int
    sym_is_a = (is_first_tick ? 0 : phase = 6 ? cap_int : _sym_is_a)

    sym_b ∈ Int
    _sym_b ∈ Int
    sym_b = (is_first_tick ? 0 : phase = 7 ? cap_int : _sym_b)

    sym_is_b ∈ Int
    _sym_is_b ∈ Int
    sym_is_b = (is_first_tick ? 0 : phase = 8 ? cap_int : _sym_is_b)

    sym_bval ∈ Int
    _sym_bval ∈ Int
    sym_bval = (is_first_tick ? 0 : phase = 9 ? cap_int : _sym_bval)

    sym_e_sort ∈ Int
    _sym_e_sort ∈ Int
    sym_e_sort = (is_first_tick ? 0 : phase = 10 ? cap_int : _sym_e_sort)

    a_ctor ∈ Int
    _a_ctor ∈ Int
    a_ctor = (is_first_tick ? 0 : phase = 11 ? cap_int : _a_ctor)

    b_ctor ∈ Int
    _b_ctor ∈ Int
    b_ctor = (is_first_tick ? 0 : phase = 15 ? cap_int : _b_ctor)

    clist_h ∈ Int
    _clist_h ∈ Int
    clist_h = (is_first_tick ? 0 : phase = 18 ? cap_int : _clist_h)

    e_sort_h ∈ Int
    _e_sort_h ∈ Int
    e_sort_h = (is_first_tick ? 0 : phase = 22 ? cap_int : _e_sort_h)

    tester_decl ∈ Int
    _tester_decl ∈ Int
    tester_decl = (is_first_tick ? 0 : phase = 24 ? cap_int : _tester_decl)

    acc_decl ∈ Int
    _acc_decl ∈ Int
    acc_decl = (is_first_tick ? 0 : phase = 25 ? cap_int : _acc_decl)

    sym_e ∈ Int
    _sym_e ∈ Int
    sym_e = (is_first_tick ? 0 : phase = 26 ? cap_int : _sym_e)

    e_h ∈ Int
    _e_h ∈ Int
    e_h = (is_first_tick ? 0 : phase = 27 ? cap_int : _e_h)

    zero_h ∈ Int
    _zero_h ∈ Int
    zero_h = (is_first_tick ? 0 : phase = 28 ? cap_int : _zero_h)

    test_h ∈ Int
    _test_h ∈ Int
    test_h = (is_first_tick ? 0 : phase = 30 ? cap_int : _test_h)

    acc_h ∈ Int
    _acc_h ∈ Int
    acc_h = (is_first_tick ? 0 : phase = 31 ? cap_int : _acc_h)

    ite_h ∈ Int
    _ite_h ∈ Int
    ite_h = (is_first_tick ? 0 : phase = 32 ? cap_int : _ite_h)

    str1_p ∈ Int
    _str1_p ∈ Int
    str1_p = (is_first_tick ? 0 : phase = 33 ? cap_int : _str1_p)

    rendered_match ∈ String
    _rendered_match ∈ String
    rendered_match = (is_first_tick ? "" : phase = 34 ? cap_str : _rendered_match)

    str2_p ∈ Int
    _str2_p ∈ Int
    str2_p = (is_first_tick ? 0 : phase = 35 ? cap_int : _str2_p)

    rendered_matches ∈ String
    _rendered_matches ∈ String
    rendered_matches = (is_first_tick ? "" : phase = 36 ? cap_str : _rendered_matches)

    sym_n ∈ Int
    _sym_n ∈ Int
    sym_n = (is_first_tick ? 0 : phase = 37 ? cap_int : _sym_n)

    n_h ∈ Int
    _n_h ∈ Int
    n_h = (is_first_tick ? 0 : phase = 38 ? cap_int : _n_h)

    five_h ∈ Int
    _five_h ∈ Int
    five_h = (is_first_tick ? 0 : phase = 39 ? cap_int : _five_h)

    one_h ∈ Int
    _one_h ∈ Int
    one_h = (is_first_tick ? 0 : phase = 40 ? cap_int : _one_h)

    two_h ∈ Int
    _two_h ∈ Int
    two_h = (is_first_tick ? 0 : phase = 41 ? cap_int : _two_h)

    eq_h ∈ Int
    _eq_h ∈ Int
    eq_h = (is_first_tick ? 0 : phase = 42 ? cap_int : _eq_h)

    ite2_h ∈ Int
    _ite2_h ∈ Int
    ite2_h = (is_first_tick ? 0 : phase = 43 ? cap_int : _ite2_h)

    str3_p ∈ Int
    _str3_p ∈ Int
    str3_p = (is_first_tick ? 0 : phase = 44 ? cap_int : _str3_p)

    rendered_lit ∈ String
    _rendered_lit ∈ String
    rendered_lit = (is_first_tick ? "" : phase = 45 ? cap_str : _rendered_lit)

    -- ── The pass under test, composed via slot bindings ─────────
    scrut_args_p ∈ Int = buf + 88

    eff_test ∈ Effect
    MatchesBuildZ3(ctx_h ↦ ctx_h, tester_decl_h ↦ tester_decl,
        scrut_args_arr_p ↦ scrut_args_p, eff ↦ eff_test)

    eff_payload ∈ Effect
    MatchPayloadBuildZ3(ctx_h ↦ ctx_h, accessor_decl_h ↦ acc_decl,
        scrut_args_arr_p ↦ scrut_args_p, eff ↦ eff_payload)

    eff_fold ∈ Effect
    MatchArmFoldBuildZ3(ctx_h ↦ ctx_h, test_h ↦ test_h, rhs_h ↦ acc_h,
        else_h ↦ zero_h, eff ↦ eff_fold)

    eff_littest ∈ Effect
    MatchLitTestBuildZ3(ctx_h ↦ ctx_h, scrut_h ↦ n_h, lit_h ↦ five_h,
        eff ↦ eff_littest)

    eff_litfold ∈ Effect
    MatchArmFoldBuildZ3(ctx_h ↦ ctx_h, test_h ↦ eq_h, rhs_h ↦ one_h,
        else_h ↦ two_h, eff ↦ eff_litfold)

    -- ── Verdict ─────────────────────────────────────────────────
    match_ok   ∈ Bool = (rendered_match = "(ite ((_ is B) e) (b_val e) 0)")
    matches_ok ∈ Bool = (rendered_matches = "((_ is B) e)")
    lit_ok     ∈ Bool = (rendered_lit = "(ite (= n 5) 1 2)")
    exit_code ∈ Int = (phase = 49
        ? (match_ok ? (matches_ok ? (lit_ok ? 0 : 8) : 6) : 4)
        : 5)

    -- ── Effects, one per phase ──────────────────────────────────
    effects ∈ Seq(Effect) = (phase = 0
            ? ⟨LibCall("libz3", "Z3_mk_config", ⟨⟩)⟩
        : phase = 1
            ? ⟨LibCall("libz3", "Z3_mk_context", ⟨ArgInt(cfg_h)⟩)⟩
        : phase = 2
            ? ⟨LibCall("libz3", "Z3_mk_int_sort", ⟨ArgInt(ctx_h)⟩)⟩
        : phase = 3
            ? ⟨LibCall("libc", "malloc", ⟨ArgInt(96)⟩)⟩
        : phase = 4
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("A")⟩)⟩
        : phase = 5
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("is_A")⟩)⟩
        : phase = 6
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("B")⟩)⟩
        : phase = 7
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("is_B")⟩)⟩
        : phase = 8
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("b_val")⟩)⟩
        : phase = 9
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("E")⟩)⟩
        : phase = 10
            ? ⟨LibCall("libz3", "Z3_mk_constructor",
                ⟨ArgInt(ctx_h), ArgInt(sym_a), ArgInt(sym_is_a),
                 ArgInt(0), ArgInt(0), ArgInt(0), ArgInt(0)⟩)⟩
        : phase = 11
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf), ArgInt(sym_bval)⟩)⟩
        : phase = 12
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 8), ArgInt(int_sort_h)⟩)⟩
        : phase = 13
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 16), ArgInt(0)⟩)⟩
        : phase = 14
            ? ⟨LibCall("libz3", "Z3_mk_constructor",
                ⟨ArgInt(ctx_h), ArgInt(sym_b), ArgInt(sym_is_b),
                 ArgInt(1), ArgInt(buf), ArgInt(buf + 8), ArgInt(buf + 16)⟩)⟩
        : phase = 15
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 24), ArgInt(a_ctor)⟩)⟩
        : phase = 16
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 32), ArgInt(b_ctor)⟩)⟩
        : phase = 17
            ? ⟨LibCall("libz3", "Z3_mk_constructor_list",
                ⟨ArgInt(ctx_h), ArgInt(2), ArgInt(buf + 24)⟩)⟩
        : phase = 18
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 40), ArgInt(sym_e_sort)⟩)⟩
        : phase = 19
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 56), ArgInt(clist_h)⟩)⟩
        : phase = 20
            ? ⟨LibCall("libz3", "Z3_mk_datatypes",
                ⟨ArgInt(ctx_h), ArgInt(1), ArgInt(buf + 40),
                 ArgInt(buf + 48), ArgInt(buf + 56)⟩)⟩
        : phase = 21
            ? ⟨LibCall("__mem", "read_long", ⟨ArgInt(buf + 48)⟩)⟩
        : phase = 22
            ? ⟨LibCall("libz3", "Z3_query_constructor",
                ⟨ArgInt(ctx_h), ArgInt(b_ctor), ArgInt(1),
                 ArgInt(buf + 64), ArgInt(buf + 72), ArgInt(buf + 80)⟩)⟩
        : phase = 23
            ? ⟨LibCall("__mem", "read_long", ⟨ArgInt(buf + 72)⟩)⟩
        : phase = 24
            ? ⟨LibCall("__mem", "read_long", ⟨ArgInt(buf + 80)⟩)⟩
        : phase = 25
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("e")⟩)⟩
        : phase = 26
            ? ⟨LibCall("libz3", "Z3_mk_const",
                ⟨ArgInt(ctx_h), ArgInt(sym_e), ArgInt(e_sort_h)⟩)⟩
        : phase = 27
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(0), ArgInt(int_sort_h)⟩)⟩
        : phase = 28
            ? ⟨LibCall("__mem", "write_long",
                ⟨ArgInt(buf + 88), ArgInt(e_h)⟩)⟩
        : phase = 29
            ? ⟨eff_test⟩
        : phase = 30
            ? ⟨eff_payload⟩
        : phase = 31
            ? ⟨eff_fold⟩
        : phase = 32
            ? ⟨LibCall("libz3", "Z3_ast_to_string",
                ⟨ArgInt(ctx_h), ArgInt(ite_h)⟩)⟩
        : phase = 33
            ? ⟨LibCall("__cstr", "copy", ⟨ArgInt(str1_p)⟩)⟩
        : phase = 34
            ? ⟨LibCall("libz3", "Z3_ast_to_string",
                ⟨ArgInt(ctx_h), ArgInt(test_h)⟩)⟩
        : phase = 35
            ? ⟨LibCall("__cstr", "copy", ⟨ArgInt(str2_p)⟩)⟩
        : phase = 36
            ? ⟨LibCall("libz3", "Z3_mk_string_symbol",
                ⟨ArgInt(ctx_h), ArgStr("n")⟩)⟩
        : phase = 37
            ? ⟨LibCall("libz3", "Z3_mk_const",
                ⟨ArgInt(ctx_h), ArgInt(sym_n), ArgInt(int_sort_h)⟩)⟩
        : phase = 38
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(5), ArgInt(int_sort_h)⟩)⟩
        : phase = 39
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(1), ArgInt(int_sort_h)⟩)⟩
        : phase = 40
            ? ⟨LibCall("libz3", "Z3_mk_int",
                ⟨ArgInt(ctx_h), ArgInt(2), ArgInt(int_sort_h)⟩)⟩
        : phase = 41
            ? ⟨eff_littest⟩
        : phase = 42
            ? ⟨eff_litfold⟩
        : phase = 43
            ? ⟨LibCall("libz3", "Z3_ast_to_string",
                ⟨ArgInt(ctx_h), ArgInt(ite2_h)⟩)⟩
        : phase = 44
            ? ⟨LibCall("__cstr", "copy", ⟨ArgInt(str3_p)⟩)⟩
        : phase = 45
            ? ⟨LibCall("libz3", "Z3_del_constructor",
                ⟨ArgInt(ctx_h), ArgInt(a_ctor)⟩)⟩
        : phase = 46
            ? ⟨LibCall("libz3", "Z3_del_constructor",
                ⟨ArgInt(ctx_h), ArgInt(b_ctor)⟩)⟩
        : phase = 47
            ? ⟨LibCall("libz3", "Z3_del_constructor_list",
                ⟨ArgInt(ctx_h), ArgInt(clist_h)⟩)⟩
        : phase = 48
            ? ⟨LibCall("libc", "free", ⟨ArgInt(buf)⟩)⟩
        : ⟨Exit(exit_code)⟩)
