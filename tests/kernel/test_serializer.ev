-- Token list serializer (iter 3.9): consumes a TokenList one element
-- per tick and prints each token's textual form.
--
-- Inverse of the lexer accumulator pattern. The lexer takes String
-- input → builds TokenList; the serializer takes TokenList input →
-- emits String output. Together they form the round-trip path that
-- a compiler's lex/pretty-print pair occupies.
--
-- State: the remaining TokenList. Each tick:
--   - Pull the head token from _list via `match`
--   - Tail becomes the next tick's list
--   - Print the head's textual representation
--   - Halt when the carried _list is TLNil
--
-- The match-on-Datatype-state pattern shown here (via `match _list`
-- in three places) is the parser's primary building block: consume
-- one node per tick, branch on its variant.
--
-- expect: stdout = "[start]"
-- expect: stdout = "claim"
-- expect: stdout = "x"
-- expect: stdout = "="
-- expect: stdout = "42"
-- expect: stdout = "[done]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/lexer.ev"

claim main
    initial_list ∈ TokenList = TLCons(KwClaim, TLCons(Ident("x"), TLCons(Eq, TLCons(IntLit(42), TLNil))))

    list  ∈ TokenList
    _list ∈ TokenList

    next_list ∈ TokenList = match _list
        TLCons(_, tail) ⇒ tail
        TLNil ⇒ TLNil

    list = (is_first_tick ? initial_list : next_list)

    head_tok ∈ Token = match _list
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok

    head_str ∈ String = match head_tok
        KwClaim ⇒ "claim"
        KwType ⇒ "type"
        KwFsm ⇒ "fsm"
        KwEnum ⇒ "enum"
        KwMatch ⇒ "match"
        KwImport ⇒ "import"
        KwSchema ⇒ "schema"
        Ident(n) ⇒ n
        IntLit(n) ⇒ str_from_int(n)
        Eq ⇒ "="
        LParen ⇒ "("
        RParen ⇒ ")"
        Comma ⇒ ","
        Plus ⇒ "+"
        EofTok ⇒ "[eof]"
        ErrTok(c) ⇒ "ERR"

    is_nil ∈ Bool = match _list
        TLNil ⇒ true
        _ ⇒ false

    effects ∈ Seq(Effect) = (is_first_tick
        ? ⟨LibCall("libc", "puts", ⟨ArgStr("[start]")⟩)⟩
        : (is_nil
            ? ⟨LibCall("libc", "puts", ⟨ArgStr("[done]")⟩), Exit(0)⟩
            : ⟨LibCall("libc", "puts", ⟨ArgStr(head_str)⟩)⟩))
