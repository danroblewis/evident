-- Token list serializer: consumes a TokenList one element per tick
-- and prints each token's textual form — the inverse of the lexer
-- accumulator pattern. Halts when the carried _list is TLNil.
--
-- expect: stdout = "[start]"
-- expect: stdout = "claim"
-- expect: stdout = "x"
-- expect: stdout = "="
-- expect: stdout = "42"
-- expect: stdout = "[done]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"

claim main
    initial_list ∈ TokenList = TLCons(KwClaim, TLCons(Ident("x"), TLCons(Eq, TLCons(IntLit(42), TLNil))))

    list  ∈ TokenList
    _list ∈ TokenList

    next_list ∈ TokenList = match _list
        TLCons(_, tail) ⇒ tail
        TLNil ⇒ TLNil

    list = (is_first_tick ? initial_list : next_list)

    head_tok ∈ Token = match _list
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok

    head_str ∈ String = match head_tok
        KwClaim ⇒ "claim"
        KwType ⇒ "type"
        KwFsm ⇒ "fsm"
        KwEnum ⇒ "enum"
        KwMatch ⇒ "match"
        KwImport ⇒ "import"
        KwSchema ⇒ "schema"
        Ident(n) ⇒ n
        IntLit(n) ⇒ str_from_int(n)
        Eq ⇒ "="
        LParen ⇒ "("
        RParen ⇒ ")"
        Comma ⇒ ","
        Plus ⇒ "+"
        EofTok ⇒ "[eof]"
        ErrTok(c) ⇒ "ERR"

    is_nil ∈ Bool = match _list
        TLNil ⇒ true
        _ ⇒ false

    effects ∈ Seq(Effect) = (is_first_tick
        ? ⟨LibCall("libc", "puts", ⟨ArgStr("[start]")⟩)⟩
        : (is_nil
            ? ⟨LibCall("libc", "puts", ⟨ArgStr("[done]")⟩), Exit(0)⟩
            : ⟨LibCall("libc", "puts", ⟨ArgStr(head_str)⟩)⟩))
