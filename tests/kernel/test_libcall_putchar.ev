-- LibCall with ArgInt: putchar three times to spell "Hi\n".
-- expect: stdout = "Hi"
-- expect: exit = 0
import "stdlib/kernel.ev"

claim main
    mode ∈ String = "Done"
    effects ∈ Seq(Effect) = ⟨
        LibCall("libc", "putchar", ⟨ArgInt(72)⟩),
        LibCall("libc", "putchar", ⟨ArgInt(105)⟩),
        LibCall("libc", "putchar", ⟨ArgInt(10)⟩),
        Exit(0)
    ⟩
