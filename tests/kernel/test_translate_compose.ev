-- C5: claim composition translation — passthrough + claim-call markers.
--
-- Drives `ComposeInline` over hand-built BodyItems, one per tick:
-- passthroughs/claim-calls yield ok=true and print their marker line;
-- BIConstraint yields ok=false (printed explicitly so the negative
-- arm is verified too).
--
-- expect: stdout = ";; inline Distinct"
-- expect: stdout = ";; call Toposort"
-- expect: stdout = ";; inline Logger"
-- expect: stdout = ";; call Counter"
-- expect: stdout = "ok=false"
-- expect: stdout = "[done]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/translate_compose.ev"

claim main
    -- ── Hardcoded inputs: one per step ────────────────────────────
    bi0 ∈ BodyItem = BIPassthrough("Distinct")

    bi1 ∈ BodyItem = BIClaimCall("Toposort", CANil)

    -- Second passthrough with a different name: the per-variant
    -- recogniser must not latch on a literal.
    bi2 ∈ BodyItem = BIPassthrough("Logger")

    one_arg ∈ ClaimArg = CArg("n", EInt(3))
    args ∈ ClaimArgList = CACons(one_arg, CANil)
    bi3 ∈ BodyItem = BIClaimCall("Counter", args)

    bi4 ∈ BodyItem = BIConstraint(EInt(1))

    -- ── Per-step selection ────────────────────────────────────────
    step ∈ Int
    _step ∈ Int
    step = (is_first_tick ? 0 : _step + 1)

    current ∈ BodyItem = (step = 0 ? bi0
        : (step = 1 ? bi1
        : (step = 2 ? bi2
        : (step = 3 ? bi3
        : bi4))))

    -- ── Drive the C5 claim ────────────────────────────────────────
    inlined ∈ String
    ok ∈ Bool
    ComposeInline(item ↦ current, inlined ↦ inlined, ok ↦ ok)

    -- ── Diagnostic line per step ──────────────────────────────────
    diag ∈ String = (step ≥ 5 ? "[done]"
        : (ok ? inlined
        : "ok=false"))

    done ∈ Bool = (step ≥ 5)

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(diag)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(diag)⟩)⟩)
