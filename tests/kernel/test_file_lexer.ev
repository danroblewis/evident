-- File-driven self-hosted lexer.
-- Tick 0: ReadFile("/tmp/evident_lex_input.txt") — captures contents as StringResult.
-- Tick 1: input becomes the file contents; walk begins at pos=0.
-- Tick 2+: walk one char per tick, classify via stdlib/lexer.ev predicates.
-- EOF when pos ≥ #input.
--
-- Test driver writes "(7+3)\n" to the input file before running.
--
-- expect: stdout = "  emit: ("
-- expect: stdout = "  emit: 7"
-- expect: stdout = "  emit: +"
-- expect: stdout = "  emit: 3"
-- expect: stdout = "  emit: )"
-- expect: stdout = "  skip"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"

claim main
    input  ∈ String
    _input ∈ String

    read_result ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ "<no-read>"

    input = (is_first_tick ? "" : (_input = "" ? read_result : _input))

    pos  ∈ Int
    _pos ∈ Int
    pos = (is_first_tick ? 0 - 1 : (_input = "" ? 0 : _pos + 1))

    tokens  ∈ TokenList
    _tokens ∈ TokenList
    cur_char ∈ String = substr(input, pos, 1)

    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)
    is_dig ∈ Bool
    IsDigitChar(c ↦ cur_char, out ↦ is_dig)
    op_tok ∈ Token
    is_op ∈ Bool
    SingleCharTok(c ↦ cur_char, t ↦ op_tok, recognized ↦ is_op)
    dig_val ∈ Int
    DigitToInt(c ↦ cur_char, n ↦ dig_val)

    done ∈ Bool = (pos ≥ #input ∧ #input > 0)

    this_tok ∈ Token = (is_dig ? IntLit(dig_val) : (is_op ? op_tok : ErrTok(cur_char)))

    tokens = (is_first_tick ? TLNil : (done ? _tokens : (pos < 0 ? _tokens : (is_ws ? _tokens : TLCons(this_tok, _tokens)))))

    label ∈ String = (done ? "[eof]" : (pos < 0 ? "got input" : (is_ws ? "  skip" : ("  emit: " ++ cur_char))))

    effects ∈ Seq(Effect) = (is_first_tick
        ? ⟨ReadFile("/tmp/evident_lex_input.txt")⟩
        : (done
            ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩
            : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩))
