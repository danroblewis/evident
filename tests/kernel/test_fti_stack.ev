-- Stack FTI honesty test: push 3, pop 2, then read the contents back out
-- of libc memory in LIFO order — proving the data really lives in C, not
-- in the Z3 model.
--
-- Drives the honest stdlib/fti/stack.ev across 9 ticks:
--   * tick 0:     malloc the backing region (libc). depth 0.
--   * ticks 1-3:  push 10/20/30 — each WRITES the full long into libc
--                 memory via __mem::write_long at slot (depth-1). depth
--                 1→2→3.
--   * ticks 4-5:  pop twice — just decrement depth (no libcall touches
--                 the data; the bytes stay in libc memory). depth 2→1.
--   * ticks 5-7:  emit __mem::read_long of slots 2,1,0 — reading the
--                 three pushed values back out of libc memory. Each read
--                 surfaces in `top` on the NEXT tick (two-tick latency).
--   * ticks 6-8:  print the read-back `top`: 30, 20, 10 — the LIFO drain,
--                 proving all three values persisted in external memory.
--   * tick 8:     free(base) on teardown (is_halting), then Exit(0).
--
-- stdout = the depth metadata trace (0 1 2 3 2 1) followed by the
-- read-back drain (30 20 10). The depth line proves the Z3 side carries
-- only an Int counter; the drain proves the values came back out of libc.
--
-- expect: stdout = "0"
-- expect: stdout = "1"
-- expect: stdout = "2"
-- expect: stdout = "3"
-- expect: stdout = "2"
-- expect: stdout = "1"
-- expect: stdout = "30"
-- expect: stdout = "20"
-- expect: stdout = "10"
-- expect: exit = 0
import "stdlib/fti/stack.ev"

claim main
    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    -- Z3-side state is integer metadata only: depth (+ the carried base
    -- pointer). No cons-list anywhere.
    depth  ∈ Int
    _depth ∈ Int

    -- Backing pointer: malloc's return arrives next tick in last_results[0];
    -- capture it once, then carry it forward (two-tick handle threading).
    -- The very same last_results[0] slot later carries the read-back value
    -- (`read_val`) on the drain ticks — both are decoded the same way.
    read_val ∈ Int = match last_results[0]
        IntResult(p) ⇒ p
        _ ⇒ 0
    base  ∈ Int
    _base ∈ Int
    base = (is_first_tick ? 0 : (_base = 0 ? read_val : _base))

    -- Phase-driven depth: push (1-3), pop (4-5), then hold for the drain.
    depth = (phase = 0 ? 0
          : (phase ≤ 3 ? _depth + 1
          : (phase ≤ 5 ? _depth - 1
          : _depth)))

    -- The FTI: assert the depth transition is legal, surface push/pop.
    pushing ∈ Bool
    popping ∈ Bool
    Stack(depth ↦ depth, prev_depth ↦ _depth, is_init ↦ is_first_tick, pushing ↦ pushing, popping ↦ popping)

    -- Push writes the full long at slot (phase-1); value is 10*phase.
    store_slot  ∈ Int = phase - 1
    store_value ∈ Int = phase * 10
    store_elem ∈ Effect
    BuildStackStore(base ↦ base, slot ↦ store_slot, value ↦ store_value, eff ↦ store_elem)

    -- Drain reads: slot 2 at phase 5, slot 1 at phase 6, slot 0 at phase 7.
    read_slot ∈ Int = (phase = 5 ? 2 : (phase = 6 ? 1 : 0))
    read_elem ∈ Effect
    BuildStackRead(base ↦ base, slot ↦ read_slot, eff ↦ read_elem)

    alloc_elem ∈ Effect
    BuildStackAlloc(eff ↦ alloc_elem)
    free_elem ∈ Effect
    BuildStackFree(base ↦ base, eff ↦ free_elem)

    -- Report: depth on the trace ticks (≤5), the read-back top on the drain.
    report_int ∈ Int = (phase ≤ 5 ? depth : read_val)
    report_elem ∈ Effect = LibCall("libc", "puts", ⟨ArgStr(str_from_int(report_int))⟩)

    -- Single channel, single writer, `++` of literal Seqs (inlined so the
    -- only top-level Seq is `effects` itself — keeping the Int metadata
    -- (depth/top) functionizable rather than dragged onto Z3 by a carried
    -- Seq state field). The read on the drain ticks is FIRST so its result
    -- lands at last_results[0] next tick (where `read_val`/`top` reads it);
    -- base capture uses the same slot on tick 1 (the malloc result).
    effects ∈ Seq(Effect) = (is_first_tick ? ⟨alloc_elem⟩ ++ ⟨report_elem⟩
                          : (phase ≤ 3 ? ⟨store_elem⟩ ++ ⟨report_elem⟩
                          : (phase ≤ 4 ? ⟨report_elem⟩ ++ ⟨⟩
                          : (phase ≤ 7 ? ⟨read_elem⟩ ++ ⟨report_elem⟩
                          : ⟨report_elem⟩ ++ ⟨free_elem⟩ ++ ⟨Exit(0)⟩))))
