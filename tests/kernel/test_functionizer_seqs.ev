-- Functionizer record-Seq exerciser: a Seq(Rect) varying per tick plus
-- scalar outputs over it — the extractor recomposes `rs` into a Seq step;
-- `(select rs i)` + the record accessors resolve to leaf fields, so
-- wsum/npos JIT to native arithmetic (interpret under EVIDENT_FUNCTIONIZE_JIT=0).
-- wsum = 2*count + 3; exits at 201 (count 99), ~100 ticks on the fast
-- path. getpid is a silent libcall; the only stdout is the final "done".
-- expect: stdout = "done"
-- expect: exit = 0
import "stdlib/kernel.ev"

type Rect(x, y, w, h ∈ Int)

claim main
    count  ∈ Int
    _count ∈ Int
    count = (is_first_tick ? 0 : _count + 1)

    r0 ∈ Rect(count, 0, count + 1, 0)
    r1 ∈ Rect(0, 0, count + 2, 0)
    rs ∈ Seq(Rect) = ⟨r0, r1⟩

    wsum ∈ Int
    wsum = rs[0].w + rs[1].w

    npos ∈ Int
    npos = ((rs[0].x > 0 ? 1 : 0) + (rs[1].x > 0 ? 1 : 0))

    effects ∈ Seq(Effect) = (wsum < 201
        ? ⟨LibCall("libc", "getpid", ⟨⟩)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr("done")⟩), Exit(0)⟩)
