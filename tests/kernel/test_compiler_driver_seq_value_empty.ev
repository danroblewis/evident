-- ISOLATION: an EMPTY Seq literal `⟨⟩` in a Seq(T) payload position
-- lowers to `__Empty_T`, while `⟨⟩` with NO element-type hint keeps the
-- Z3 seq-theory empty form. Drives RenderExprToks on hand-built
-- TokenLists. Verified byte-identical to bootstrap's `evident emit`.
--
-- expect: stdout = "__Empty_LibArg"
-- expect: stdout = "(LibCall "libc" "puts" __Empty_LibArg)"
-- expect: stdout = "(as seq.empty (Seq Int))"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler/translate_ctor.ev"

claim main
    -- (a) ⟨⟩ with a LibArg hint → __Empty_LibArg.
    toks_a ∈ TokenList = TLCons(OpSeqOpen, TLCons(OpSeqClose, TLNil))
    out_a ∈ String
    rest_a ∈ TokenList
    ok_a ∈ Bool
    RenderExprToks(toks ↦ toks_a, out ↦ out_a, rest ↦ rest_a, ok ↦ ok_a,
        sigtab ↦ "", in_hint ↦ "LibArg")

    -- (b) LibCall("libc", "puts", ⟨⟩) — empty Seq(LibArg) payload via the
    -- variant-signature table.
    toks_b ∈ TokenList = TLCons(Ident("LibCall"), TLCons(LParen,
        TLCons(StringLit("libc"), TLCons(Comma,
        TLCons(StringLit("puts"), TLCons(Comma,
        TLCons(OpSeqOpen, TLCons(OpSeqClose,
        TLCons(RParen, TLNil)))))))))
    out_b ∈ String
    rest_b ∈ TokenList
    ok_b ∈ Bool
    RenderExprToks(toks ↦ toks_b, out ↦ out_b, rest ↦ rest_b, ok ↦ ok_b,
        sigtab ↦ "LibCall#2#LibArg;", in_hint ↦ "")

    -- (c) ⟨⟩ with NO hint → the seq-theory empty form is preserved.
    toks_c ∈ TokenList = TLCons(OpSeqOpen, TLCons(OpSeqClose, TLNil))
    out_c ∈ String
    rest_c ∈ TokenList
    ok_c ∈ Bool
    RenderExprToks(toks ↦ toks_c, out ↦ out_c, rest ↦ rest_c, ok ↦ ok_c,
        sigtab ↦ "", in_hint ↦ "")

    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    line ∈ String = (phase = 0 ? out_a : phase = 1 ? out_b : out_c)

    effects ∈ Seq(Effect) = (phase ≥ 2
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(line)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(line)⟩)⟩)
