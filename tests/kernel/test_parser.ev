-- Toy self-hosted parser: consumes a hardcoded TokenList
-- ⟨IntLit(1), Plus, IntLit(2), Plus, IntLit(3)⟩ and builds an Expr
-- via left-associative greedy binop combination, using Datatype
-- state carry across ticks. Final accumulated state:
--   EBinOp(OpPlus, EBinOp(OpPlus, EInt(1), EInt(2)), EInt(3))
--
-- expect: stdout = "[start]"
-- expect: stdout = "saw int"
-- expect: stdout = "saw op"
-- expect: stdout = "saw int"
-- expect: stdout = "saw op"
-- expect: stdout = "saw int"
-- expect: stdout = "done"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/parser.ev"

claim main
    initial ∈ TokenList = TLCons(IntLit(1), TLCons(Plus, TLCons(IntLit(2), TLCons(Plus, TLCons(IntLit(3), TLNil)))))

    list  ∈ TokenList
    _list ∈ TokenList

    current  ∈ Expr
    _current ∈ Expr

    pending  ∈ Op
    _pending ∈ Op

    next_list ∈ TokenList = match _list
        TLCons(_, tail) ⇒ tail
        TLNil ⇒ TLNil

    head_tok ∈ Token = match _list
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok

    is_nil ∈ Bool = match _list
        TLNil ⇒ true
        _ ⇒ false

    head_int ∈ Int = match head_tok
        IntLit(n) ⇒ n
        _ ⇒ 0 - 1
    is_int ∈ Bool = (head_int ≥ 0)

    head_op ∈ Op
    is_op ∈ Bool
    TokenToOp(t ↦ head_tok, o ↦ head_op, is_binop ↦ is_op)

    list = (is_first_tick ? initial : next_list)

    has_current ∈ Bool = ¬(_current matches ENoExpr)
    new_current_int ∈ Expr = (has_current ? EBinOp(_pending, _current, EInt(head_int)) : EInt(head_int))

    current = (is_first_tick ? ENoExpr : (is_int ? new_current_int : _current))
    pending = (is_first_tick ? OpPlus : (is_op ? head_op : _pending))

    label ∈ String = (is_first_tick ? "[start]" : (is_nil ? "[done]" : (is_int ? "saw int" : (is_op ? "saw op" : "skip"))))

    effects ∈ Seq(Effect) = (is_first_tick ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩ : (is_nil ? ⟨LibCall("libc", "puts", ⟨ArgStr("done")⟩), Exit(0)⟩ : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩))
