-- Queue FTI smoke test: enqueue 3, dequeue 2, watch the length evolve.
--
-- Drives stdlib/fti/queue.ev across 7 ticks. The Queue allocates its
-- backing region on tick 0 (libc malloc), stores each enqueued byte on
-- ticks 1-3 (libc memset), and drops cons-cell heads on the dequeues
-- (ticks 4-5, no libcall). The diagnostic puts the queue length each
-- tick, so stdout traces the length: 0 → 1 → 2 → 3 → 2 → 1.
--
-- FIFO check: the dequeues drop the FRONT (oldest), so phase 4 removes
-- the first-enqueued 10 and phase 5 removes 20 — exactly `tail`
-- (drop-head) on the head=front cons-list, the only difference from the
-- stack fixture's pops (which are structurally the same `tail` op).
--
-- The enqueue phases hand the FTI literal contents rather than deriving
-- them from `_contents`: appending at the tail of a singly-linked
-- cons-list is not a one-level wrap of the carried prev (the dual of
-- the stack, whose head-end push *was* a one-level wrap). The literals
-- are constructed to be exactly the enqueue results, so they match the
-- carried prev and the FTI's legal_enq predicate holds.
--
-- expect: stdout = "0"
-- expect: stdout = "1"
-- expect: stdout = "2"
-- expect: stdout = "3"
-- expect: stdout = "2"
-- expect: stdout = "1"
-- expect: exit = 0
import "stdlib/fti/queue.ev"

claim main
    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    contents  ∈ IntQueue
    _contents ∈ IntQueue
    depth  ∈ Int
    _depth ∈ Int

    -- Backing pointer: malloc's return arrives next tick in last_results;
    -- capture it once, then carry it forward (two-tick handle threading).
    base_in ∈ Int = match last_results[0]
        IntResult(p) ⇒ p
        _ ⇒ 0
    base  ∈ Int
    _base ∈ Int
    base = (is_first_tick ? 0 : (_base = 0 ? base_in : _base))

    -- "drop the front" view of the carried queue, for the dequeues.
    prev_tail ∈ IntQueue = match _contents
        QNode(h, t) ⇒ t
        QEmpty ⇒ QEmpty

    -- Phase-driven transitions: enqueue 10/20/30 (literals appended at
    -- the tail), then dequeue twice (drop the front).
    contents = (phase = 0 ? QEmpty
             : (phase = 1 ? QNode(10, QEmpty)
             : (phase = 2 ? QNode(10, QNode(20, QEmpty))
             : (phase = 3 ? QNode(10, QNode(20, QNode(30, QEmpty)))
             : (phase = 4 ? prev_tail
             : (phase = 5 ? prev_tail
             : _contents))))))

    depth = (phase = 0 ? 0
          : (phase ≤ 3 ? _depth + 1
          : (phase ≤ 5 ? _depth - 1
          : _depth)))

    -- The FTI: asserts the transition is legal, detects the enqueue, and
    -- surfaces the front-of-queue value for the store.
    enqueuing ∈ Bool
    front ∈ Int
    Queue(contents ↦ contents, prev ↦ _contents, depth ↦ depth, prev_depth ↦ _depth, is_init ↦ is_first_tick, enqueuing ↦ enqueuing, front ↦ front)

    -- Effect pieces. The libcall literals come from the FTI builders;
    -- the byte is stored at offset _depth (the pre-enqueue length). The
    -- smoke test asserts only the length trace, not the stored bytes.
    alloc_elem ∈ Effect
    BuildQueueAlloc(eff ↦ alloc_elem)
    store_elem ∈ Effect
    BuildQueueStore(base ↦ base, offset ↦ _depth, value ↦ front, eff ↦ store_elem)
    report_elem ∈ Effect = LibCall("libc", "puts", ⟨ArgStr(str_from_int(depth))⟩)

    alloc_part  ∈ Seq(Effect) = ⟨alloc_elem⟩
    store_part  ∈ Seq(Effect) = ⟨store_elem⟩
    report_part ∈ Seq(Effect) = ⟨report_elem⟩

    -- Single channel, single writer, `++` composition of the parts.
    effects ∈ Seq(Effect) = (is_first_tick ? alloc_part ++ report_part
                          : (phase ≥ 6 ? ⟨Exit(0)⟩
                          : (enqueuing ? store_part ++ report_part
                          : report_part ++ ⟨⟩)))
