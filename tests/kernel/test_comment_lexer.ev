-- Comment skipping: walks "x = 5 -- this is a comment\ny = 7\n" and
-- skips the "--" line comment. `mode` state: 0 = normal, 1 = inside
-- comment; enters on "-"+"-" lookahead, exits on "\n". The 19
-- "(in-comment)" ticks are one per char of " this is a comment".
--
-- expect: stdout = "ch: x"
-- expect: stdout = "  ws"
-- expect: stdout = "op: ="
-- expect: stdout = "  ws"
-- expect: stdout = "dig: 5"
-- expect: stdout = "  ws"
-- expect: stdout = "comment-start"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "  (in-comment)"
-- expect: stdout = "comment-end"
-- expect: stdout = "ch: y"
-- expect: stdout = "  ws"
-- expect: stdout = "op: ="
-- expect: stdout = "  ws"
-- expect: stdout = "dig: 7"
-- expect: stdout = "  ws"
-- expect: stdout = "[eof]"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/lexer.ev"

claim main
    input  ∈ String
    _input ∈ String
    read_result ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ "<no-read>"
    input = (is_first_tick ? "" : (_input = "" ? read_result : _input))

    pos  ∈ Int
    _pos ∈ Int
    pos = (is_first_tick ? 0 - 1 : (_input = "" ? 0 : _pos + 1))

    mode  ∈ Int
    _mode ∈ Int

    cur_char ∈ String = substr(input, pos, 1)
    next_char ∈ String = substr(input, pos + 1, 1)
    is_newline ∈ Bool = (cur_char = "\n")
    is_dash ∈ Bool = (cur_char = "-")
    is_next_dash ∈ Bool = (next_char = "-")
    is_dig ∈ Bool
    IsDigitChar(c ↦ cur_char, out ↦ is_dig)
    is_alpha ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)
    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)

    done ∈ Bool = ((pos ≥ #input) ∧ (#input > 0))
    in_range ∈ Bool = ((pos ≥ 0) ∧ ¬done)

    start_comment ∈ Bool = ((_mode = 0) ∧ is_dash ∧ is_next_dash ∧ in_range)
    end_comment   ∈ Bool = ((_mode = 1) ∧ is_newline)
    mode = (is_first_tick ? 0 : (start_comment ? 1 : (end_comment ? 0 : _mode)))

    in_comment ∈ Bool = (mode = 1)
    in_comment_now ∈ Bool = (_mode = 1)

    label ∈ String = (done ? "[eof]" : (pos < 0 ? "got input" : (start_comment ? "comment-start" : (in_comment_now ∧ is_newline ? "comment-end" : (in_comment ? "  (in-comment)" : (is_ws ? "  ws" : (is_alpha ? ("ch: " ++ cur_char) : (is_dig ? ("dig: " ++ cur_char) : ("op: " ++ cur_char)))))))))

    effects ∈ Seq(Effect) = (is_first_tick ? ⟨ReadFile("/tmp/evident_comment_input.txt")⟩ : (done ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩ : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩))
