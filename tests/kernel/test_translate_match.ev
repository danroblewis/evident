-- C8: match → nested ITE translation.
--
-- Builds a 2-arm match (Some(v) ⇒ 1 ; _ ⇒ 0) and folds the arms
-- back-to-front through MatchArmSmtlib. The expected SMT-LIB shape
-- for `match e { Some(v) ⇒ 1 ; _ ⇒ 0 }` is:
--
--     (ite ((_ is Some) e) 1 0)
--
-- The fold seeds `rest` with the wildcard arm's body string, then
-- wraps with the constructor arm:
--   call 1: arm=MArm(MPWildcard, EInt(0)), rest=""   → out_wild = "0"
--   call 2: arm=MArm(MPCtor("Some",...), EInt(1)),
--           rest=out_wild                           → "(ite ((_ is Some) e) 1 0)"
--
-- expect: stdout = "wild=0"
-- expect: stdout = "ctor=Some"
-- expect: stdout = "ite=(ite ((_ is Some) e) 1 0)"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "compiler/translate_match.ev"

claim main
    -- ── Build the 2-arm match ────────────────────────────────────
    -- Arm 1: `Some(v) ⇒ 1`
    arm1_binds ∈ MatchBindList = MBCons(MBName("v"), MBNil)
    arm1_pat   ∈ MatchPattern  = MPCtor("Some", arm1_binds)
    arm1       ∈ MatchArm      = MArm(arm1_pat, EInt(1))

    -- Arm 2: `_ ⇒ 0`
    arm2_pat ∈ MatchPattern = MPWildcard
    arm2     ∈ MatchArm     = MArm(arm2_pat, EInt(0))

    scrutinee ∈ String = "e"

    -- ── Fold back-to-front ──────────────────────────────────────
    -- First: wildcard arm seeds rest="".
    out_wild ∈ String
    MatchArmSmtlib(scrutinee ↦ scrutinee, arm ↦ arm2,
                   rest ↦ "", out ↦ out_wild)

    -- Then: constructor arm wraps with out_wild as rest.
    out_ite ∈ String
    MatchArmSmtlib(scrutinee ↦ scrutinee, arm ↦ arm1,
                   rest ↦ out_wild, out ↦ out_ite)

    -- For diagnostics, peel the constructor name out of arm1's pattern.
    ctor_name ∈ String
    PatternCtorName(p ↦ arm1_pat, name ↦ ctor_name)

    -- ── Step counter ────────────────────────────────────────────
    step ∈ Int
    _step ∈ Int
    step = (is_first_tick ? 0 : _step + 1)

    wild_str ∈ String = "wild=" ++ out_wild
    ctor_str ∈ String = "ctor=" ++ ctor_name
    ite_str  ∈ String = "ite=" ++ out_ite

    label ∈ String = (step = 0 ? wild_str
        : (step = 1 ? ctor_str
        : ite_str))

    done ∈ Bool = (step ≥ 2)

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩)
