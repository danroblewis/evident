-- __dlsym pseudo-library proof: resolves the address of Z3_mk_config
-- from libz3 without calling it; non-zero i64 = dlsym OK → exit 0.
-- Pre-condition: libz3.dylib is on the dyld path (.cargo/config.toml
-- sets DYLD_LIBRARY_PATH).
--
-- expect: stdout = ""
-- expect: exit = 0

import "stdlib/kernel.ev"

claim main
    phase  ∈ Int
    _phase ∈ Int
    phase = (is_first_tick ? 0 : _phase + 1)

    addr  ∈ Int
    _addr ∈ Int
    addr_capture ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    addr = (is_first_tick ? 0
        : phase = 1 ? addr_capture
        : _addr)

    exit_code ∈ Int = (addr ≠ 0 ? 0 : 1)

    effects ∈ Seq(Effect) = (phase = 0
        ? ⟨LibCall("__dlsym", "addr", ⟨ArgStr("libz3"), ArgStr("Z3_mk_config")⟩)⟩
        : ⟨Exit(exit_code)⟩)
