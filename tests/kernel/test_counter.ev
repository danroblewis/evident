-- Counter: 0..4 then exit. Validates multi-tick state + str_from_int.
--
-- expect: stdout = "count = 0"
-- expect: stdout = "count = 1"
-- expect: stdout = "count = 2"
-- expect: stdout = "count = 3"
-- expect: stdout = "count = 4"
-- expect: stdout = "done at 5"
-- expect: exit = 0
import "stdlib/kernel.ev"

claim main
    count  ∈ Int
    _count ∈ Int
    count = (is_first_tick ? 0 : _count + 1)

    msg ∈ String = "count = " ++ str_from_int(count)

    effects ∈ Seq(Effect) = (count ≤ 4
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr("done at " ++ str_from_int(count))⟩), Exit(0)⟩)
