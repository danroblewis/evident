-- Multi-tick + last_results carry.
-- Tick 0: LibCall("libc","getpid"). Kernel captures IntResult(pid).
-- Tick 1: puts "got pid", exit 0.
-- expect: stdout = "got pid"
-- expect: exit = 0
import "stdlib/kernel.ev"

claim main
    mode ∈ String = "Working"
    effects ∈ Seq(Effect) = (is_first_tick
        ? ⟨LibCall("libc", "getpid", ⟨⟩)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr("got pid")⟩), Exit(0)⟩)
