-- C4: SMT-LIB arithmetic translation.
--
-- Calls the ArithExprSmtlib claim from stdlib/translate_arith.ev on
-- three one-level binops covering the four arithmetic operators
-- (OpPlus + OpMul + OpSub; OpDiv is exercised in lang_tests). Each
-- tick prints the rendered string for one input and the test exits
-- after all three.
--
-- Inputs:
--   EBinOp(OpPlus, EInt(1), EInt(2))         → "(+ 1 2)"
--   EBinOp(OpMul,  EIdent("x"), EInt(3))     → "(* x 3)"
--   EBinOp(OpSub,  EIdent("a"), EIdent("b")) → "(- a b)"
--
-- expect: stdout = "(+ 1 2)"
-- expect: stdout = "(* x 3)"
-- expect: stdout = "(- a b)"
-- expect: exit = 0
import "stdlib/kernel.ev"
import "stdlib/translate_arith.ev"

claim main
    expr_plus ∈ Expr = EBinOp(OpPlus, EInt(1), EInt(2))
    expr_mul  ∈ Expr = EBinOp(OpMul, EIdent("x"), EInt(3))
    expr_sub  ∈ Expr = EBinOp(OpSub, EIdent("a"), EIdent("b"))

    out_plus ∈ String
    ok_plus ∈ Bool
    ArithExprSmtlib(e ↦ expr_plus, out ↦ out_plus, ok ↦ ok_plus)

    out_mul ∈ String
    ok_mul ∈ Bool
    ArithExprSmtlib(e ↦ expr_mul, out ↦ out_mul, ok ↦ ok_mul)

    out_sub ∈ String
    ok_sub ∈ Bool
    ArithExprSmtlib(e ↦ expr_sub, out ↦ out_sub, ok ↦ ok_sub)

    step ∈ Int
    _step ∈ Int
    step = (is_first_tick ? 0 : _step + 1)

    label ∈ String = (step = 0 ? out_plus
        : (step = 1 ? out_mul
        : out_sub))

    done ∈ Bool = (step ≥ 2)

    effects ∈ Seq(Effect) = (done
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(label)⟩)⟩)
