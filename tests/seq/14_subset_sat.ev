-- D14 subset ∀ x ∈ xs : x ∈ s. NOTE: Seq membership is dropped, but
-- SET membership (x ∈ Set) DOES compile — so the supported subset idiom
-- is "every element of the bounded seq is in the set". SAT → exit 0.
-- entry: main
-- expect: exit = 0
import "stdlib/kernel.ev"
claim main
    s ∈ Set(Int) = {1, 2, 3, 4, 5}
    xs ∈ Seq(Int) = ⟨2, 4⟩
    ∀ x ∈ xs : x ∈ s
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
