-- C9 coindexed violated: ys is not xs+1 elementwise → UNSAT → exit 2.
-- (Proves the quantifier is a real constraint, not silently dropped.)
-- entry: main
-- expect: exit = 2
import "stdlib/kernel.ev"
claim main
    xs ∈ Seq(Int) = ⟨1, 2, 3⟩
    ys ∈ Seq(Int) = ⟨5, 5, 5⟩
    ∀ (a, b) ∈ coindexed(xs, ys) : b = a + 1
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
