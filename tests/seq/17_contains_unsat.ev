-- E17 contains, no occurrence: ⟨9,9⟩ is nowhere in s → UNSAT → exit 2.
-- entry: main
-- expect: exit = 2
import "stdlib/kernel.ev"
claim main
    s ∈ Seq(Int) = ⟨1, 2, 3, 4, 5⟩
    sub ∈ Seq(Int) = ⟨9, 9⟩
    off ∈ Int
    0 ≤ off ∧ off ≤ 3
    ∀ j ∈ {0..1} : sub[j] = s[off + j]
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
