-- E18 fixed-window extract: w[j] = s[start+j] for j<#w. start=1, #w=2
-- extracts ⟨20,30⟩. SAT → exit 0.
-- entry: main
-- expect: exit = 0
import "stdlib/kernel.ev"
claim main
    s ∈ Seq(Int) = ⟨10, 20, 30, 40, 50⟩
    w ∈ Seq(Int)
    #w = 2
    ∀ j ∈ {0..1} : w[j] = s[1 + j]
    w[0] = 20
    w[1] = 30
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
