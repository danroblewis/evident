-- B5 concat a ++ b ++ ⟨x⟩ ++ c preserves order. ++ flattens at load
-- time into one bounded seq; indices map through to the sources.
-- entry: main
-- expect: exit = 0
import "stdlib/kernel.ev"
claim main
    a ∈ Seq(Int) = ⟨1, 2⟩
    b ∈ Seq(Int) = ⟨3, 4⟩
    c ∈ Seq(Int) = ⟨6⟩
    xs ∈ Seq(Int) = a ++ b ++ ⟨5⟩ ++ c
    #xs = 6
    xs[0] = 1
    xs[2] = 3
    xs[4] = 5
    xs[5] = 6
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
