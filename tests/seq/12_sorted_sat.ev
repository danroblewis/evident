-- D12 sortedness ∀ i : xs[i] ≤ xs[i+1] — find a sorted arrangement of a
-- free BOUNDED seq (#=4) with bounded elements and a pinned endpoint.
-- entry: main
-- expect: exit = 0
import "stdlib/kernel.ev"
claim main
    xs ∈ Seq(Int)
    #xs = 4
    ∀ x ∈ xs : 0 ≤ x ∧ x ≤ 9
    ∀ i ∈ {0..2} : xs[i] ≤ xs[i+1]
    xs[0] = 5
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
