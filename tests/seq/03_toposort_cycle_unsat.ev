-- A3 toposort with a cycle 0→1, 1→0. No permutation satisfies both
-- pos[0]<pos[1] and pos[1]<pos[0] → UNSAT → exit 2.
-- entry: main
-- expect: exit = 2
import "stdlib/kernel.ev"
claim main
    pos ∈ Seq(Int)
    #pos = 2
    ∀ i ∈ {0..1} : 0 ≤ pos[i] ∧ pos[i] ≤ 1
    distinct(pos)
    efrom ∈ Seq(Int) = ⟨0, 1⟩
    eto   ∈ Seq(Int) = ⟨1, 0⟩
    ∀ (u, v) ∈ coindexed(efrom, eto) : pos[u] < pos[v]
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
