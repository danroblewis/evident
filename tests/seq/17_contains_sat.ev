-- E17 contains (contiguous): ∃ off : ∀ j<sublen : s[off+j]=sub[j].
-- off is a bounded free Int; the inner ∀ is bounded. ⟨3,4⟩ occurs at
-- offset 2 → exit 0.
-- entry: main
-- expect: exit = 0
import "stdlib/kernel.ev"
claim main
    s ∈ Seq(Int) = ⟨1, 2, 3, 4, 5⟩
    sub ∈ Seq(Int) = ⟨3, 4⟩
    off ∈ Int
    0 ≤ off ∧ off ≤ 3
    ∀ j ∈ {0..1} : sub[j] = s[off + j]
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
