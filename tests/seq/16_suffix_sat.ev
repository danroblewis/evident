-- E16 suffix: p[i] = s[slen-plen+i] for i<plen. Mirror of prefix.
-- slen=5, plen=2 → p must equal s[3], s[4] = ⟨4,5⟩.
-- entry: main
-- expect: exit = 0
import "stdlib/kernel.ev"
claim main
    s ∈ Seq(Int) = ⟨1, 2, 3, 4, 5⟩
    p ∈ Seq(Int) = ⟨4, 5⟩
    ∀ i ∈ {0..1} : p[i] = s[3 + i]
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
