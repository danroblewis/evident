-- A1 ordering chain, contradictory: a<b<c plus a>c → UNSAT → exit 2.
-- entry: main
-- expect: exit = 2
import "stdlib/kernel.ev"
claim main
    a ∈ Int
    b ∈ Int
    c ∈ Int
    xs ∈ Seq(Int) = ⟨a, b, c⟩
    #xs = 3
    ∀ i ∈ {0..1} : xs[i] < xs[i+1]
    a > c
    effects ∈ Seq(Effect) = ⟨Exit(0)⟩
