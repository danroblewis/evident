-- Carry-preserving fsm composition: SLOT-BIND with NO carry.
--
-- AIsFive pins a = 5 and owns no carry (no `_a` reference). BIsFive
-- composes it with `AIsFive(a ↦ b)`. Because `a` is not a carry of
-- AIsFive, the transform injects NO `_a ↦ _b` binding — this is the
-- baseline that the existing slot-bind path keeps working.
--
-- entry: BIsFive
-- expect: stdout = "5"
-- expect: exit = 0
import "stdlib/kernel.ev"

fsm AIsFive
    a ∈ Int
    a = 5

fsm BIsFive
    b ∈ Int
    AIsFive(a ↦ b)
    msg ∈ String = str_from_int(b)
    effects ∈ Seq(Effect) = ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(b - 5)⟩
