-- Carry-preserving fsm composition: HEADER slot carry through a slot-bind.
--
-- Counter declares its interface as a header (claim-headers plan); its one
-- slot `n` is carried. The transform must:
--   1. append the carry dual to the HEADER     →  Counter(n ∈ Int, _n ∈ Int)
--      (the prev-tick dual of a carried interface slot is itself interface)
--   2. inject the carry sibling binding        →  Counter(n ↦ count, _n ↦ _count)
--   3. synthesize the parent carry             →  _count ∈ Int  in Main
-- so the kernel carries `count` across ticks under explicit-only mapping.
--
-- entry: Main
-- expect: stdout = "0"
-- expect: stdout = "1"
-- expect: stdout = "2"
-- expect: exit = 0
import "stdlib/kernel.ev"

fsm Counter(n ∈ Int)
    n = (is_first_tick ? 0 : _n + 1)

fsm Main
    count ∈ Int
    Counter(n ↦ count)
    msg ∈ String = str_from_int(count)
    effects ∈ Seq(Effect) = (count ≥ 2
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩)⟩)
