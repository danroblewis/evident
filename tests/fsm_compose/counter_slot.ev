-- Carry-preserving fsm composition: SLOT-BIND with carry (make-or-break).
--
-- Counter owns a carry: `n = (is_first_tick ? 0 : _n + 1)`. Main composes
-- it via `Counter(n ↦ count)`. The transform must:
--   1. inject the carry sibling binding  →  Counter(n ↦ count, _n ↦ _count)
--   2. synthesize the parent carry        →  _count ∈ Int  in Main
-- so the kernel carries `count` across ticks. If the carry composes, count
-- advances 0,1,2; without it count never carries and this prints garbage.
--
-- entry: Main
-- expect: stdout = "0"
-- expect: stdout = "1"
-- expect: stdout = "2"
-- expect: exit = 0
import "stdlib/kernel.ev"

fsm Counter
    n ∈ Int
    n = (is_first_tick ? 0 : _n + 1)

fsm Main
    count ∈ Int
    Counter(n ↦ count)
    msg ∈ String = str_from_int(count)
    effects ∈ Seq(Effect) = (count ≥ 2
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩)⟩)
