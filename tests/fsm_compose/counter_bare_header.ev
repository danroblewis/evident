-- Carry-preserving fsm composition: HEADER slot carry through a BARE mention.
--
-- Counter carries its header slot `n`; Main declares `n` and composes by
-- bare mention. Header-join binds `n` AND its dual `_n` (both interface
-- after the transform appends the dual to the header), and the fixpoint
-- marks `n` carried in Main so `_n ∈ Int` is synthesized there.
--
-- entry: Main
-- expect: stdout = "0"
-- expect: stdout = "1"
-- expect: stdout = "2"
-- expect: exit = 0
import "stdlib/kernel.ev"

fsm Counter(n ∈ Int)
    n = (is_first_tick ? 0 : _n + 1)

fsm Main
    n ∈ Int
    Counter
    msg ∈ String = str_from_int(n)
    effects ∈ Seq(Effect) = (n ≥ 2
        ? ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩), Exit(0)⟩
        : ⟨LibCall("libc", "puts", ⟨ArgStr(msg)⟩)⟩)
