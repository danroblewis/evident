-- class 2: renamed/restructured internals, same interface.
-- two helpers (`acc`, `bump`) instead of one (`dbl`); same out = 2x+3.
-- entry: main
import "stdlib/kernel.ev"

claim main
    x ∈ Int
    0 < x
    x < 100
    acc ∈ Int = x + x
    bump ∈ Int = acc + 3
    out ∈ Int = bump
    effects ∈ Seq(Effect) = ⟨Exit(out)⟩
