-- class 3: deliberately different — the reference. 0 < x < 10.
-- Paired against diff_super (B relaxes a bound → A ⊊ B),
-- diff_sub (B tightens → A ⊋ B), diff_overlap (B shifts → OVERLAP).
-- entry: main
import "stdlib/kernel.ev"

claim main
    x ∈ Int
    0 < x
    x < 10
    out ∈ Int = x + 1
    effects ∈ Seq(Effect) = ⟨Exit(out)⟩
