-- Tuple-in-claim membership: `(a, b, c) ∈ claim_name` is the
-- relational reading of a positional claim invocation. The tuple
-- elements bind positionally to the claim's parameters (same
-- arity-matched binding as `claim_name(a, b, c)` and as
-- `claim_name (p1 ↦ a, p2 ↦ b, p3 ↦ c)`).
--
-- The three invocation forms are equivalent at the constraint
-- level: each produces the same conjunction of body items with
-- the same slot-to-value mapping.

-- ── A simple 2-parameter relational claim ─────────────────────

claim add_one(x, y ∈ Int)
    y = x + 1


-- Tuple form pins the relation; b is forced to a + 1.
claim sat_tuple_pins_output
    a ∈ Int
    b ∈ Int
    a = 5
    (a, b) ∈ add_one
    b = 6

-- Equivalent: positional form binds the same way.
claim sat_positional_equivalence
    a ∈ Int
    b ∈ Int
    a = 5
    add_one(a, b)
    b = 6

-- Tuple form runs the relation backwards too: given the output,
-- the solver finds the input.
claim sat_tuple_runs_backwards
    a ∈ Int
    b ∈ Int
    (a, b) ∈ add_one
    b = 42
    a = 41

-- Wrong output value contradicts the relation.
claim unsat_tuple_wrong_output
    a ∈ Int
    b ∈ Int
    a = 5
    (a, b) ∈ add_one
    b = 7


-- ── A 3-parameter claim with String + Int + Bool ──────────────

claim describe(n ∈ Int, prefix ∈ String, big ∈ Bool)
    big = (n > 100)
    -- (prefix is unconstrained by the body — caller pins or
    -- the solver picks anything String.)

claim sat_three_arity
    n ∈ Int
    prefix ∈ String
    big ∈ Bool
    n = 250
    (n, prefix, big) ∈ describe
    big = true   -- forced by the body since 250 > 100


-- ── Subclaim invocation via tuple-in form ─────────────────────

claim outer
    sub_helper ∈ Int
    sub_helper = 7

    subclaim doubles_it(input ∈ Int, output ∈ Int)
        output = input * 2

claim sat_subclaim_via_tuple
    x ∈ Int
    y ∈ Int
    x = 10
    (x, y) ∈ doubles_it
    y = 20
