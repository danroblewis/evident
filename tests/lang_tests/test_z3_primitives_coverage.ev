-- Coverage test: every Z3 operator that Evident currently exposes via
-- surface syntax or named-call form. A failing test here points at a
-- Z3 op that's MISSING from the Evident surface — the gap goes to a
-- new translate_*.rs case in bootstrap (and eventually to a built-in
-- claim in compiler/sample.ev). Goal 1 closes when this file is
-- fully green AND any future Z3 op the user wants is one
-- translate_*.rs case away.

-- ── Equality / arithmetic / comparison (SMT-LIB: =, +, -, *, /, mod) ──

claim sat_basic_eq
    x ∈ Int = 5
    x = 5

claim sat_arith_add
    x ∈ Int = 3 + 4
    x = 7

claim sat_arith_sub
    x ∈ Int = 10 - 3
    x = 7

claim sat_arith_mul
    x ∈ Int = 6 * 7
    x = 42

claim sat_cmp_lt
    x ∈ Int = 5
    flag ∈ Bool = (x < 10)
    flag = true

claim sat_cmp_ge
    x ∈ Int = 5
    flag ∈ Bool = (x ≥ 5)
    flag = true

-- ── Boolean operators (and, or, not, xor, =>) ──────────────────

claim sat_bool_and
    p ∈ Bool = true
    q ∈ Bool = true
    r ∈ Bool = (p ∧ q)
    r = true

claim sat_bool_or
    p ∈ Bool = true
    q ∈ Bool = false
    r ∈ Bool = (p ∨ q)
    r = true

claim sat_bool_not
    p ∈ Bool = false
    r ∈ Bool = ¬p
    r = true

claim sat_bool_implies
    p ∈ Bool = false
    q ∈ Bool = true
    r ∈ Bool = (p ⇒ q)
    r = true

-- ── ITE (ternary) — lowers to (ite c a b) ──────────────────────

claim sat_ite_pick_then
    x ∈ Int = 5
    y ∈ Int = (x > 0 ? 1 : 0 - 1)
    y = 1

claim sat_ite_pick_else
    x ∈ Int = 0 - 3
    y ∈ Int = (x > 0 ? 1 : 0 - 1)
    y = 0 - 1

-- ── Datatype recognizer (_ is Ctor) via `matches` ──────────────

enum Color = Red | Green | Blue

claim sat_recognizer_match_true
    c ∈ Color = Red
    flag ∈ Bool = (c matches Red)
    flag = true

claim sat_recognizer_match_false
    c ∈ Color = Green
    flag ∈ Bool = (c matches Red)
    flag = false

-- ── distinct(args...) ──────────────────────────────────────────

claim sat_distinct_three_ints
    a ∈ Int = 1
    b ∈ Int = 2
    c ∈ Int = 3
    flag ∈ Bool = distinct(a, b, c)
    flag = true

claim unsat_distinct_with_duplicate
    a ∈ Int = 1
    b ∈ Int = 2
    c ∈ Int = 1
    flag ∈ Bool = distinct(a, b, c)
    flag = true

-- ── Pattern bind in match (destructuring datatype values) ──────

enum Maybe = None | Some(Int)

claim sat_match_destructure_some
    m ∈ Maybe = Some(42)
    n ∈ Int = match m
        Some(x) ⇒ x
        None ⇒ 0
    n = 42

claim sat_match_destructure_none
    m ∈ Maybe = None
    n ∈ Int = match m
        Some(x) ⇒ x
        None ⇒ 0
    n = 0

-- ── Seq (Array + len encoding) — element select via xs[i] ──────

claim sat_seq_index_basic
    xs ∈ Seq(Int) = ⟨10, 20, 30⟩
    y ∈ Int = xs[1]
    y = 20

-- ── String equality + length (str.len, str.++) ─────────────────

claim sat_str_eq
    s ∈ String = "hello"
    s = "hello"

claim sat_str_length_via_cardinality
    s ∈ String = "abc"
    n ∈ Int = #s
    n = 3

-- ── Existential / universal (over a Seq) ───────────────────────

claim sat_forall_over_seq
    xs ∈ Seq(Int) = ⟨1, 2, 3⟩
    ∀ x ∈ xs : x > 0

-- ── Z3 primitives added via the extension recipe ───────────────

claim sat_xor_true_false
    a ∈ Bool = true
    b ∈ Bool = false
    r ∈ Bool = xor(a, b)
    r = true

claim sat_xor_both_true
    a ∈ Bool = true
    b ∈ Bool = true
    r ∈ Bool = xor(a, b)
    r = false

claim sat_iff_basic
    a ∈ Bool = true
    b ∈ Bool = true
    r ∈ Bool = iff(a, b)
    r = true

claim sat_ite_function_form
    c ∈ Bool = true
    a ∈ Bool = true
    b ∈ Bool = false
    r ∈ Bool = ite(c, a, b)
    r = true
