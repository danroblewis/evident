-- Conformance tests for stdlib/passes/iter_types.ev — exercised
-- by hand-building Program/body/body_len values via stdlib/ast.ev.
--
-- Run with:
--     evident test tests/lang_tests/test_pass_iter_types.ev
--
-- Validates the iter_types pass logic in pure Evident, without
-- relying on the Rust runtime's encode/inject pipeline. A
-- regression in the pass file shows up here independently of any
-- Rust-side bugs.

import "stdlib/ast.ev"
import "stdlib/passes/iter_types.ev"

-- ── has_membership_of_var ──────────────────────────────────────

claim sat_iter_finds_single_membership
    program     ∈ Program
    body        ∈ Seq(BodyItem)
    body_len    ∈ Nat
    target_var  ∈ String
    target_type ∈ String
    pins_part   ∈ Pins

    -- Hand-build a 1-body program with a Membership.
    body_len = 1
    #body = 1
    body[0] = BIMembership("score", "Nat", PNone)
    program = MakeProgram(SchLNil, EDLNil)

    has_membership_of_var

    target_var  = "score"
    target_type = "Nat"

claim sat_iter_finds_membership_at_position_2
    program     ∈ Program
    body        ∈ Seq(BodyItem)
    body_len    ∈ Nat
    target_var  ∈ String
    target_type ∈ String
    pins_part   ∈ Pins

    -- 3-body, Membership last.
    body_len = 3
    #body = 3
    body[0] = BIConstraint(EBool(true))
    body[1] = BIPassthrough("foo")
    body[2] = BIMembership("score", "Nat", PNone)
    program = MakeProgram(SchLNil, EDLNil)

    has_membership_of_var

    target_var  = "score"
    target_type = "Nat"

claim unsat_iter_no_membership_in_body
    program     ∈ Program
    body        ∈ Seq(BodyItem)
    body_len    ∈ Nat
    target_var  ∈ String
    target_type ∈ String
    pins_part   ∈ Pins

    body_len = 2
    #body = 2
    body[0] = BIConstraint(EBool(true))
    body[1] = BIPassthrough("foo")
    program = MakeProgram(SchLNil, EDLNil)

    has_membership_of_var

-- ── has_string_assignment ──────────────────────────────────────

claim sat_iter_finds_string_assignment
    program     ∈ Program
    body        ∈ Seq(BodyItem)
    body_len    ∈ Nat
    target_var  ∈ String
    string_lit  ∈ String

    body_len = 2
    #body = 2
    body[0] = BIPassthrough("noop")
    body[1] = BIConstraint(EBinary(OpEq,
                                   EIdentifier("msg"),
                                   EStr("hello")))
    program = MakeProgram(SchLNil, EDLNil)

    has_string_assignment

    target_var = "msg"
    string_lit = "hello"

claim unsat_iter_no_string_assignment_when_only_int
    program     ∈ Program
    body        ∈ Seq(BodyItem)
    body_len    ∈ Nat
    target_var  ∈ String
    string_lit  ∈ String

    body_len = 1
    #body = 1
    body[0] = BIConstraint(EBinary(OpEq,
                                   EIdentifier("n"),
                                   EInt(5)))
    program = MakeProgram(SchLNil, EDLNil)

    has_string_assignment

-- ── has_int_assignment ─────────────────────────────────────────

claim sat_iter_finds_int_assignment_in_long_body
    program     ∈ Program
    body        ∈ Seq(BodyItem)
    body_len    ∈ Nat
    target_var  ∈ String
    int_lit     ∈ Int

    body_len = 4
    #body = 4
    body[0] = BIConstraint(EBool(true))
    body[1] = BIPassthrough("a")
    body[2] = BIConstraint(EBinary(OpEq,
                                   EIdentifier("count"),
                                   EInt(99)))
    body[3] = BIPassthrough("b")
    program = MakeProgram(SchLNil, EDLNil)

    has_int_assignment

    target_var = "count"
    int_lit    = 99

-- ── has_bool_assignment ────────────────────────────────────────

claim sat_iter_finds_bool_assignment
    program     ∈ Program
    body        ∈ Seq(BodyItem)
    body_len    ∈ Nat
    target_var  ∈ String
    bool_lit    ∈ Bool

    body_len = 1
    #body = 1
    body[0] = BIConstraint(EBinary(OpEq,
                                   EIdentifier("ready"),
                                   EBool(true)))
    program = MakeProgram(SchLNil, EDLNil)

    has_bool_assignment

    target_var = "ready"
    bool_lit   = true

-- ── Empty body edge case ──────────────────────────────────────

claim unsat_iter_empty_body
    program     ∈ Program
    body        ∈ Seq(BodyItem)
    body_len    ∈ Nat
    target_var  ∈ String
    target_type ∈ String
    pins_part   ∈ Pins

    body_len = 0
    #body = 0
    program = MakeProgram(SchLNil, EDLNil)

    has_membership_of_var
