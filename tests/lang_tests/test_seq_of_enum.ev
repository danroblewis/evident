-- Conformance tests for Stage 5: Seq of enum elements.
--
-- Run with:
--     evident test tests/lang_tests/test_seq_of_enum.ev
--
-- Stage 5 enables `body ∈ Seq(BodyItem)` (and any Seq(SomeEnum)),
-- with element access via `body[i]`, equality against constructor
-- applications (`body[i] = BIPassthrough("foo")`), and quantifier
-- iteration (`∀ i ∈ {0..n-1} : body[i] = …`).
--
-- The proofs below assert SAT for shapes that should hold and
-- UNSAT for contradictions, exercising the new declare + indexing +
-- equality machinery end-to-end.

import "stdlib/ast.ev"

-- ── Declaration + length ───────────────────────────────────────

claim sat_declare_seq_bodyitem
    body ∈ Seq(BodyItem)
    #body = 0

claim sat_declare_seq_bodyitem_with_length
    body ∈ Seq(BodyItem)
    #body = 5

claim sat_declare_seq_schemadecl
    -- Different enum, same machinery.
    schemas ∈ Seq(SchemaDecl)
    #schemas = 2

-- ── Indexing + assignment ──────────────────────────────────────

claim sat_pin_one_element
    body ∈ Seq(BodyItem)
    #body = 1
    body[0] = BIPassthrough("foo")

claim sat_pin_three_elements
    body ∈ Seq(BodyItem)
    #body = 3
    body[0] = BIPassthrough("first")
    body[1] = BIConstraint(EBool(true))
    body[2] = BIPassthrough("third")

claim unsat_same_index_different_values
    body ∈ Seq(BodyItem)
    #body = 1
    body[0] = BIPassthrough("a")
    body[0] = BIPassthrough("b")

claim unsat_pin_then_constraint_mismatch
    body ∈ Seq(BodyItem)
    #body = 1
    body[0] = BIPassthrough("p")
    body[0] = BIConstraint(EBool(true))

-- ── Quantifier iteration over a Seq(enum) ──────────────────────

claim sat_forall_all_passthroughs_with_same_name
    body ∈ Seq(BodyItem)
    #body = 3
    body[0] = BIPassthrough("x")
    body[1] = BIPassthrough("x")
    body[2] = BIPassthrough("x")
    ∀ i ∈ {0..2} : body[i] = BIPassthrough("x")

claim unsat_forall_when_one_differs
    body ∈ Seq(BodyItem)
    #body = 2
    body[0] = BIPassthrough("a")
    body[1] = BIPassthrough("b")
    -- All three would have to equal the same passthrough; they don't.
    name ∈ String
    ∀ i ∈ {0..1} : body[i] = BIPassthrough(name)

-- ── Existential ────────────────────────────────────────────────

claim sat_exists_one_passthrough_named_x
    body ∈ Seq(BodyItem)
    #body = 3
    body[0] = BIConstraint(EBool(true))
    body[1] = BIPassthrough("x")
    body[2] = BIConstraint(EBool(false))
    ∃ i ∈ {0..2} : body[i] = BIPassthrough("x")

claim unsat_exists_passthrough_named_y_when_none
    body ∈ Seq(BodyItem)
    #body = 2
    body[0] = BIConstraint(EBool(true))
    body[1] = BIConstraint(EBool(false))
    ∃ i ∈ {0..1} : body[i] = BIPassthrough("y")

-- ── Cross-enum: Seq(BinOp), Seq(Keyword) ───────────────────────

claim sat_seq_of_binop
    ops ∈ Seq(BinOp)
    #ops = 2
    ops[0] = OpAdd
    ops[1] = OpEq

claim unsat_seq_of_binop_contradiction
    ops ∈ Seq(BinOp)
    #ops = 1
    ops[0] = OpAdd
    ops[0] = OpEq

claim sat_seq_of_keyword
    kws ∈ Seq(Keyword)
    #kws = 3
    kws[0] = KSchema
    kws[1] = KClaim
    kws[2] = KType

-- ── A small inference-ish use case: count how many passthroughs ──

claim sat_count_passthroughs_via_pinning
    body ∈ Seq(BodyItem)
    n_pass ∈ Nat
    #body = 3
    body[0] = BIPassthrough("a")
    body[1] = BIConstraint(EBool(true))
    body[2] = BIPassthrough("b")
    -- Two of three are passthroughs. Manually pin n_pass = 2;
    -- demonstrates the ability to write counters once we have
    -- conditional accumulators (a Stage 6+ feature).
    n_pass = 2

-- ── Seq of payload-bearing enums ───────────────────────────────

-- A user-declared payload enum, separate from stdlib/ast.ev.
-- Verifies the Seq(enum) machinery isn't tied to ast.ev's enums.
enum Status = Pending | Done(Int) | Failed(String)

claim sat_seq_of_payload_enum_pin_each
    states ∈ Seq(Status)
    #states = 3
    states[0] = Pending
    states[1] = Done(42)
    states[2] = Failed("oops")

claim unsat_seq_of_payload_enum_payload_mismatch
    states ∈ Seq(Status)
    #states = 1
    states[0] = Done(1)
    states[0] = Done(2)

claim unsat_seq_of_payload_enum_variant_mismatch
    states ∈ Seq(Status)
    #states = 1
    states[0] = Done(1)
    states[0] = Failed("x")

claim sat_seq_of_payload_enum_forall_match
    states ∈ Seq(Status)
    #states = 2
    states[0] = Done(7)
    states[1] = Done(7)
    ∀ i ∈ {0..1} : states[i] = Done(7)

-- ── Seq of recursive (self-referencing) enum ───────────────────

enum Tree = Leaf | Node(Int, Tree, Tree)

claim sat_seq_of_recursive_enum
    forest ∈ Seq(Tree)
    #forest = 2
    forest[0] = Leaf
    forest[1] = Node(1, Leaf, Leaf)

claim sat_seq_of_recursive_enum_deep_nesting
    forest ∈ Seq(Tree)
    #forest = 1
    forest[0] = Node(1, Node(2, Leaf, Leaf), Node(3, Leaf, Leaf))

claim unsat_seq_of_recursive_enum_struct_mismatch
    forest ∈ Seq(Tree)
    #forest = 1
    forest[0] = Node(1, Leaf, Leaf)
    forest[0] = Node(1, Leaf, Node(2, Leaf, Leaf))

-- ── Mixed forms in iteration ──────────────────────────────────

claim sat_exists_done_with_specific_payload
    states ∈ Seq(Status)
    #states = 3
    states[0] = Pending
    states[1] = Failed("net")
    states[2] = Done(99)
    ∃ i ∈ {0..2} : states[i] = Done(99)

claim unsat_exists_done_with_wrong_payload
    states ∈ Seq(Status)
    #states = 3
    states[0] = Pending
    states[1] = Failed("net")
    states[2] = Done(99)
    ∃ i ∈ {0..2} : states[i] = Done(100)
