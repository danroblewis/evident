-- Conformance tests for stdlib/passes/literal_types.ev — exercised
-- by hand-building Program values via stdlib/ast.ev and asserting
-- the pass rules fire (or correctly don't fire).
--
-- Run with:
--     evident test tests/lang_tests/test_pass_literal_types.ev
--
-- These complement the Rust integration tests in
-- runtime/tests/self_hosted_pass.rs by testing the pass rules
-- in pure Evident, without depending on the encoder being correct.
-- A regression in the pass file shows up here independently of any
-- Rust-side bugs.

import "stdlib/ast.ev"
import "stdlib/passes/literal_types.ev"

-- ── Helpers: tiny constructors for hand-built programs ─────────

-- A Program containing exactly one claim with one body item: a
-- string assignment `var = literal`.
claim sat_single_string_assignment_pattern_matches
    program       ∈ Program
    inferred_var  ∈ String
    inferred_type ∈ String
    claim_name    ∈ String
    string_lit    ∈ String
    enums_part    ∈ EnumDeclList

    program = MakeProgram(
        SchLCons(
            MakeSchemaDecl(KClaim, "demo",
                BILCons(BIConstraint(EBinary(OpEq,
                                             EIdentifier("msg"),
                                             EStr("hello"))),
                       BILNil)),
            SchLNil),
        EDLNil)

    -- Now invoke the rule. Names match: `program`, `inferred_var`,
    -- `inferred_type`, `claim_name`, `string_lit`, plus the rule's
    -- own internal `enums_part` we hand-pin to EDLNil.
    infer_string_from_single_assignment

    inferred_var  = "msg"
    inferred_type = "String"
    claim_name    = "demo"

-- Same shape, Int variant.
claim sat_single_int_assignment_pattern_matches
    program       ∈ Program
    inferred_var  ∈ String
    inferred_type ∈ String
    claim_name    ∈ String
    int_lit       ∈ Int
    enums_part_int ∈ EnumDeclList

    program = MakeProgram(
        SchLCons(
            MakeSchemaDecl(KClaim, "counter",
                BILCons(BIConstraint(EBinary(OpEq,
                                             EIdentifier("n"),
                                             EInt(42))),
                       BILNil)),
            SchLNil),
        EDLNil)
    infer_int_from_single_assignment
    inferred_var  = "n"
    inferred_type = "Int"
    claim_name    = "counter"

-- Bool variant.
claim sat_single_bool_assignment_pattern_matches
    program       ∈ Program
    inferred_var  ∈ String
    inferred_type ∈ String
    claim_name    ∈ String
    bool_lit      ∈ Bool
    enums_part_bool ∈ EnumDeclList

    program = MakeProgram(
        SchLCons(
            MakeSchemaDecl(KClaim, "flag",
                BILCons(BIConstraint(EBinary(OpEq,
                                             EIdentifier("ready"),
                                             EBool(true))),
                       BILNil)),
            SchLNil),
        EDLNil)
    infer_bool_from_single_assignment
    inferred_var  = "ready"
    inferred_type = "Bool"

-- ── extract_first_membership ────────────────────────────────────

claim sat_extract_membership_no_trailing
    program       ∈ Program
    inferred_var  ∈ String
    inferred_type ∈ String
    claim_name    ∈ String
    pins_part     ∈ Pins
    rest_body     ∈ BodyItemList
    enums_em      ∈ EnumDeclList

    program = MakeProgram(
        SchLCons(
            MakeSchemaDecl(KClaim, "decl_only",
                BILCons(BIMembership("x", "Int", PNone), BILNil)),
            SchLNil),
        EDLNil)
    extract_first_membership
    inferred_var  = "x"
    inferred_type = "Int"
    claim_name    = "decl_only"

claim sat_extract_membership_with_trailing_constraint
    program       ∈ Program
    inferred_var  ∈ String
    inferred_type ∈ String
    claim_name    ∈ String
    pins_part     ∈ Pins
    rest_body     ∈ BodyItemList
    enums_em      ∈ EnumDeclList

    program = MakeProgram(
        SchLCons(
            MakeSchemaDecl(KClaim, "with_extra",
                BILCons(BIMembership("score", "Nat", PNone),
                BILCons(BIConstraint(EBinary(OpGt,
                                             EIdentifier("score"),
                                             EInt(0))),
                       BILNil))),
            SchLNil),
        EDLNil)
    extract_first_membership
    inferred_var  = "score"
    inferred_type = "Nat"
    claim_name    = "with_extra"

-- Negative: extract requires Membership at the head.
claim unsat_extract_membership_constraint_first
    program       ∈ Program
    inferred_var  ∈ String
    inferred_type ∈ String
    claim_name    ∈ String
    pins_part     ∈ Pins
    rest_body     ∈ BodyItemList
    enums_em      ∈ EnumDeclList

    -- First body item is a Constraint, not a Membership. Rule
    -- should fail to match → UNSAT.
    program = MakeProgram(
        SchLCons(
            MakeSchemaDecl(KClaim, "no_decl",
                BILCons(BIConstraint(EBool(true)), BILNil)),
            SchLNil),
        EDLNil)
    extract_first_membership

-- ── infer_*_from_membership_plus_assignment ────────────────────

claim sat_int_membership_plus_assignment_consistent
    program       ∈ Program
    inferred_var  ∈ String
    inferred_type ∈ String
    claim_name    ∈ String
    int_lit       ∈ Int
    pins2         ∈ Pins
    enums_2       ∈ EnumDeclList

    program = MakeProgram(
        SchLCons(
            MakeSchemaDecl(KClaim, "consistent",
                BILCons(BIMembership("x", "Int", PNone),
                BILCons(BIConstraint(EBinary(OpEq,
                                             EIdentifier("x"),
                                             EInt(5))),
                       BILNil))),
            SchLNil),
        EDLNil)
    infer_int_from_membership_plus_assignment
    inferred_var  = "x"
    inferred_type = "Int"

claim sat_string_membership_plus_assignment_consistent
    program       ∈ Program
    inferred_var  ∈ String
    inferred_type ∈ String
    claim_name    ∈ String
    str_lit       ∈ String
    pins_s        ∈ Pins
    enums_s       ∈ EnumDeclList

    program = MakeProgram(
        SchLCons(
            MakeSchemaDecl(KClaim, "greet",
                BILCons(BIMembership("msg", "String", PNone),
                BILCons(BIConstraint(EBinary(OpEq,
                                             EIdentifier("msg"),
                                             EStr("hi"))),
                       BILNil))),
            SchLNil),
        EDLNil)
    infer_string_from_membership_plus_assignment
    inferred_var = "msg"
    inferred_type = "String"

-- Selectivity: Int rule rejects String-declared variable with Int literal.
claim unsat_int_rule_rejects_string_decl
    program       ∈ Program
    inferred_var  ∈ String
    inferred_type ∈ String
    claim_name    ∈ String
    int_lit       ∈ Int
    pins2         ∈ Pins
    enums_2       ∈ EnumDeclList

    -- Membership says String, but assignment is Int. Rule's
    -- `inferred_type = "Int"` clashes with the membership's
    -- "String" → UNSAT.
    program = MakeProgram(
        SchLCons(
            MakeSchemaDecl(KClaim, "wrong_type",
                BILCons(BIMembership("x", "String", PNone),
                BILCons(BIConstraint(EBinary(OpEq,
                                             EIdentifier("x"),
                                             EInt(5))),
                       BILNil))),
            SchLNil),
        EDLNil)
    infer_int_from_membership_plus_assignment

-- Empty user program — extract rule must NOT match.
claim unsat_extract_membership_empty_program
    program       ∈ Program
    inferred_var  ∈ String
    inferred_type ∈ String
    claim_name    ∈ String
    pins_part     ∈ Pins
    rest_body     ∈ BodyItemList
    enums_em      ∈ EnumDeclList

    program = MakeProgram(SchLNil, EDLNil)
    extract_first_membership
