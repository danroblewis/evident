-- Conformance tests for enum variants with payloads, including
-- self-recursion (the recursion lives in the Z3 datatype).

enum Result = Ok(Int) | Err(String)
enum Maybe = None | Some(Int)
enum LinkedList = Nil | Cons(Int, LinkedList)

-- ── Result: Ok with payload ──────────────────────────────────────

claim sat_ok_with_payload
    r ∈ Result
    r = Ok(5)

claim sat_ok_with_other_int
    r ∈ Result
    r = Ok(0)

claim unsat_ok_two_different_ints
    r ∈ Result
    r = Ok(5)
    r = Ok(7)

claim unsat_ok_then_err
    r ∈ Result
    r = Ok(5)
    r = Err("boom")

-- ── Result: Err with string payload ─────────────────────────────

claim sat_err_with_string
    r ∈ Result
    r = Err("oops")

claim unsat_err_two_different_strings
    r ∈ Result
    r = Err("a")
    r = Err("b")

-- ── Maybe: nullary variant + payload variant in same enum ──────

claim sat_maybe_none
    m ∈ Maybe
    m = None

claim sat_maybe_some
    m ∈ Maybe
    m = Some(42)

claim unsat_maybe_none_then_some
    m ∈ Maybe
    m = None
    m = Some(0)

claim unsat_maybe_two_somes_differ
    m ∈ Maybe
    m = Some(1)
    m = Some(2)

-- ── Recursive: LinkedList ──────────────────────────────────────

claim sat_empty_list
    list ∈ LinkedList
    list = Nil

claim sat_one_element_list
    list ∈ LinkedList
    list = Cons(7, Nil)

claim sat_three_element_list
    list ∈ LinkedList
    list = Cons(7, Cons(2, Cons(9, Nil)))

claim unsat_list_head_mismatch
    list ∈ LinkedList
    list = Cons(7, Nil)
    list = Cons(8, Nil)

claim unsat_list_tail_mismatch
    list ∈ LinkedList
    list = Cons(7, Nil)
    list = Cons(7, Cons(8, Nil))

claim unsat_nil_vs_cons
    list ∈ LinkedList
    list = Nil
    list = Cons(7, Nil)

-- ── Cross-claim: payload-bearing enum threads through ──────────

claim is_ok_value
    r ∈ Result
    n ∈ Int
    r = Ok(n)

claim sat_ok_via_subclaim
    r ∈ Result
    n ∈ Int
    is_ok_value
    n = 99
    r = Ok(99)

claim unsat_ok_via_subclaim_mismatch
    r ∈ Result
    n ∈ Int
    is_ok_value
    n = 99
    r = Ok(100)
