-- Multi-FSM test: sibling FSMs with no shared world.
--
-- Validates:
--   * World is OPTIONAL — a multi-FSM program with zero `world`
--     memberships still runs both FSMs.
--   * Declaration order determines effect dispatch order when
--     there's no writer/reader distinction.
--
-- Expected output (--max-steps 4, so 4 ticks):
--   tick
--   beat
--   tick
--   beat
--   tick
--   beat
--   tick
--   beat
--
-- "tick" before "beat" each tick because `ticker` is declared first.
-- Both FSMs run forever (neither has a halt path); the program runs
-- until --max-steps.

import "stdlib/runtime.ev"

enum TickerState = T
enum BeatState   = B

fsm ticker(state ∈ TickerState)
    state_next = T
    effects = ⟨Println("tick")⟩

fsm heartbeat(state ∈ BeatState)
    state_next = B
    effects = ⟨Println("beat")⟩
