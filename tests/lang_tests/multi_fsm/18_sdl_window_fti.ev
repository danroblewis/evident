-- SDL_Window FTI bridge — typed declaration of a windowed
-- resource. The runtime calls SDL_Init + SDL_CreateWindow at
-- startup with the configured title/width/height; writes the
-- window pointer (cast to Int) into `win.handle`. The user FSM
-- can wait for handle > 0 to know the window is open.
--
-- This is the first FTI bridge that touches a real C library
-- via libloading. Demonstrates the pattern scales beyond
-- trivial timers — SDL_Window is a stateful OS resource with
-- lifecycle (init, create, destroy, quit).
--
-- macOS caveat: SDL_CreateWindow runs on the runtime's main
-- thread (synchronous bridge install). On macOS this is
-- required for AppKit; on Linux/X11 it's flexible. Cleanup
-- (SDL_DestroyWindow + SDL_Quit) is currently skipped — the
-- OS reclaims the window on process exit. v2 will add safer
-- teardown for long-running programs.
--
-- Run:
--     evident effect-run tests/lang_tests/multi_fsm/18_sdl_window_fti.ev
-- Expected:
--     A window briefly opens; output:
--       window opened via FTI bridge
--       window confirmed; closing
--     Exit 0.

import "stdlib/runtime.ev"

enum S = Waiting | Open | Done

claim app(state, state_next ∈ S,
          last_results ∈ ResultList,
          effects ∈ EffectList)
    win ∈ SDL_Window (title ↦ "FTI Window Test", width ↦ 640, height ↦ 480)
    state_next = match state
        Waiting ⇒ (win.handle > 0 ? Open : Waiting)
        Open    ⇒ Done
        Done    ⇒ Done
    effects = match state
        Waiting ⇒ (win.handle > 0 ? ⟨Println("window opened via FTI bridge")⟩ : ⟨⟩)
        Open    ⇒ ⟨Println("window confirmed; closing"), Exit(0)⟩
        Done    ⇒ ⟨⟩
