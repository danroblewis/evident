-- Multi-FSM test: setup-then-render lifecycle.
--
-- Validates:
--   * Per-FSM halt: setup halts after one tick (state == state_next
--     ∧ effects = ⟨⟩). Render keeps running.
--   * World persistence after halt: setup wrote world.ready = true;
--     after halt, render still sees world.ready = true on every
--     subsequent tick.
--   * Halt-doesn't-resume: setup is dropped from scheduler after
--     halt and never re-solved.
--
-- This is the GL killer case in miniature: setup pushes state once,
-- halts; render runs forever with a tiny constraint set.
--
-- Expected output (--max-steps 6, so 6 ticks):
--   setup: booting
--   render: ready
--   render: ready
--   render: ready
--   render: ready
--   render: ready
--   render: ready
--
-- "setup: booting" appears EXACTLY ONCE — proving setup halted
-- after its first tick and was dropped from the per-tick scheduler.

import "stdlib/runtime.ev"

type World
    ready ∈ Bool

enum SetupState =
    Booting
    Done

enum RenderState =
    Frame

fsm setup(world, world_next ∈ World,
            state ∈ SetupState)
    state_next = match state
        Booting ⇒ Done
        Done    ⇒ Done

    -- Set ready true on first tick; passthrough afterwards.
    world_next.ready = (state matches Booting ? true : world.ready)

    effects = match state
        Booting ⇒ ⟨Println("setup: booting")⟩
        Done    ⇒ ⟨⟩

fsm render(world ∈ World,
             state ∈ RenderState)
    state_next = Frame

    msg ∈ String
    msg = (world.ready ? "render: ready" : "render: waiting")

    effects = ⟨Println(msg)⟩
