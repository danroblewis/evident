-- FTI v1 — typed resource via parameter declaration.
--
-- The user declares `clock ∈ FrameClock` as a parameter. The
-- runtime sees the FTI type `FrameClock` and auto-installs a
-- bridge plugin that writes `clock.tick_count` at the
-- configured interval (default 100ms; via EVIDENT_TICK_MS).
-- The body reads `clock.tick_count` like any field access; the
-- runtime pins it to the bridge's value each tick.
--
-- This is the typed-resource shape — much cleaner than the
-- world-field reserved-name pattern, because the resource is a
-- TYPE (FrameClock has fields and structure), not a magic
-- field name. Multiple resource types (FrameClock, FileReader,
-- Socket, etc.) can be declared without name collisions.
--
-- v1 limitation: snapshot is shared. Two FSMs each declaring
-- `clock ∈ FrameClock` would share the same `clock.tick_count`
-- key. Per-instance namespacing is v2.
--
-- Run:
--     EVIDENT_TICK_MS=50 evident effect-run \
--         tests/lang_tests/multi_fsm/15_fti_frameclock.ev

import "stdlib/runtime.ev"

enum S = Watching

claim main(clock ∈ FrameClock,
           state, state_next ∈ S,
           last_results ∈ ResultList,
           effects ∈ EffectList)
    state_next = Watching
    effects = (clock.tick_count ≥ 3
               ? ⟨Println("3 ticks observed via FTI"), Exit(0)⟩
               : ⟨⟩)
