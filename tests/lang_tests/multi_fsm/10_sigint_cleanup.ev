-- SIGINT cleanup demo using the plugin-as-writer pattern.
--
-- World declares `signal_received: Int`. Runtime auto-installs
-- the SigintSource handler — increments the field on each
-- Ctrl-C. The Watcher FSM subscribes via its read; on the first
-- signal, transitions to a cleanup state, emits cleanup effects,
-- exits cleanly.
--
-- Run:
--     evident effect-run tests/lang_tests/multi_fsm/10_sigint_cleanup.ev --max-steps 1000 &
--     PID=$!
--     sleep 0.3 && kill -INT $PID
--     wait $PID
--     # → "caught signal — cleaning up" + exit 0

import "stdlib/runtime.ev"

type World
    signal_received ∈ Int   -- runtime-managed by SigintSource

enum WState =
    Listening
    Cleaning

claim watcher(state, state_next ∈ WState,
              world ∈ World,
              last_results ∈ ResultList,
              effects ∈ EffectList)

    is_caught ∈ Bool
    is_caught = (world.signal_received > 0)

    state_next = match state
        Listening ⇒ (is_caught ? Cleaning : Listening)
        Cleaning  ⇒ Cleaning

    effects = match state
        Listening ⇒ (is_caught
                     ? ⟨Println("caught signal — cleaning up"), Exit(0)⟩
                     : ⟨⟩)
        Cleaning  ⇒ ⟨⟩
