-- Multi-writer conflict (direct form). Two writer FSMs both write
-- the SAME world field (`score`) via direct `world_next.score = …`.
--
-- Expected: the runtime REJECTS this at load time with the
-- single-owner-rule error. Without the check, the second writer's
-- value would silently win each tick (a non-deterministic, silent
-- data race the type system can't catch — see CLAUDE.md
-- "Parallel Seqs are forbidden" for the same class of footgun).
--
-- Asserted by `runtime/tests/multi_fsm.rs::multiwriter_conflict_*`.

import "stdlib/runtime.ev"

type World
    score ∈ Int

enum AS = AGo
enum BS = BGo

fsm alpha(world, world_next ∈ World, state ∈ AS)
    state_next = AGo
    world_next.score = world.score + 1
    effects = ⟨⟩

fsm beta(world, world_next ∈ World, state ∈ BS)
    state_next = BGo
    world_next.score = world.score + 100
    effects = ⟨⟩
