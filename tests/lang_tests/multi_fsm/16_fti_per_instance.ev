-- FTI v1.5 — per-instance typed resources.
--
-- Two FSMs each declare `clock ∈ FrameClock`. The runtime gives
-- each FSM its own clock instance (via FSM-prefixed pin keys
-- internally). They tick independently — fast hits its threshold
-- (5) before slow's (8).
--
-- Demonstrates that the FTI machinery composes cleanly with
-- multi-FSM: each FSM sees its own bridge writes, no
-- cross-contamination from sibling FSMs sharing a parameter
-- name.
--
-- Run:
--     EVIDENT_TICK_MS=30 evident effect-run \
--         tests/lang_tests/multi_fsm/16_fti_per_instance.ev
-- Expected:
--     fast: 5 ticks    (fast's clock.tick_count ≥ 5)
--     slow: 8 ticks    (slow's clock.tick_count ≥ 8, then Exit)

import "stdlib/runtime.ev"

enum FastS = FA | FDone
enum SlowS = SA

fsm fast(clock ∈ FrameClock,
           state ∈ FastS)
    state_next = match state
        FA    ⇒ (clock.tick_count ≥ 5 ? FDone : FA)
        FDone ⇒ FDone
    effects = match state
        FA    ⇒ (clock.tick_count ≥ 5 ? ⟨Println("fast: 5 ticks")⟩ : ⟨⟩)
        FDone ⇒ ⟨⟩

fsm slow(clock ∈ FrameClock,
           state ∈ SlowS)
    state_next = SA
    effects = (clock.tick_count ≥ 8
               ? ⟨Println("slow: 8 ticks"), Exit(0)⟩
               : ⟨⟩)
