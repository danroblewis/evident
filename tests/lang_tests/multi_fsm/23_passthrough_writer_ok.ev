-- A single, legitimate writer whose world write lives in a
-- `..WritesCount` passthrough claim, observed by a reader FSM.
-- There is no conflict, so the write must TAKE EFFECT.
--
-- This is the positive companion to file 22: it pins the
-- silent-drop half of the passthrough bug. On tick 0 the writer
-- (writers run first) sets `count = world.count + 1 = 0 + 1 = 1`;
-- the reader then observes `world.count` in the same tick.
--
-- Before the transitive write-set fix the scheduler scoped
-- `world_next.count` against an EMPTY `my_writes` (the write lived
-- in the passthrough, so it wasn't in the inferred write-set),
-- dropped the write, and the reader saw `count = 0` → "write
-- dropped". With the fix the reader sees `count = 1` → "write
-- took effect" and exits cleanly.
--
-- Asserted by `runtime/tests/multi_fsm.rs::passthrough_writer_takes_effect`.

import "stdlib/runtime.ev"

type World
    count ∈ Int

enum WS = WGo
enum RS = RGo

claim WritesCount
    world, world_next ∈ World
    world_next.count = world.count + 1

fsm writer(world, world_next ∈ World, state ∈ WS)
    ..WritesCount
    state_next = WGo
    effects = ⟨⟩

fsm reader(world ∈ World, state ∈ RS)
    state_next = RGo
    effects = (world.count ≥ 1
               ? ⟨Println("write took effect"), Exit(0)⟩
               : ⟨Println("write dropped"), Exit(1)⟩)
