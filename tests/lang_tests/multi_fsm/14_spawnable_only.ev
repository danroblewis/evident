-- `spawnable_only` marker — claims that should ONLY run when
-- explicitly spawned via Effect::SpawnFsm, not auto-instantiated.
--
-- Without the marker, any claim with the FSM shape (state pair
-- + EffectList + ResultList) is auto-detected and run as an
-- FSM at startup. That's fine for top-level FSMs but pollutes
-- spawn-only patterns: when parent spawns 2 workers, you get 3
-- (1 auto + 2 spawned).
--
-- With `spawnable_only` in the body, the claim is registered as
-- a spawn template only. detect_all_fsms skips it; the parent's
-- SpawnFsm calls are the only path to instantiation.
--
-- Run:
--     evident effect-run tests/lang_tests/multi_fsm/14_spawnable_only.ev
-- Expected output (no "worker ?" line, since worker isn't auto-detected):
--   parent: spawning 2 workers
--   worker A
--   worker B

import "stdlib/runtime.ev"

enum PState = Spawning | Done

claim parent(state, state_next ∈ PState,
             last_results ∈ ResultList,
             effects ∈ EffectList)
    state_next = match state
        Spawning ⇒ Done
        Done     ⇒ Done
    effects = match state
        Spawning ⇒ ⟨Println("parent: spawning 2 workers"),
                    SpawnFsm("worker", 100),
                    SpawnFsm("worker", 200)⟩
        Done     ⇒ ⟨⟩

enum WState = WInit(Int) | WDone(Int)

claim worker(state, state_next ∈ WState,
             last_results ∈ ResultList,
             effects ∈ EffectList)
    spawnable_only

    my_id ∈ Int
    my_id = match state
        WInit(id) ⇒ id
        WDone(id) ⇒ id

    state_next = match state
        WInit(id) ⇒ WDone(id)
        WDone(id) ⇒ WDone(id)

    msg ∈ String
    msg = (my_id = 100 ? "worker A"
           : my_id = 200 ? "worker B"
           : "worker ?")

    effects = match state
        WInit(_) ⇒ ⟨Println(msg)⟩
        WDone(_) ⇒ ⟨⟩
