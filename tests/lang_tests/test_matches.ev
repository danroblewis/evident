-- Conformance tests for the `matches` operator.
--
-- `e matches Pattern` returns Bool — true iff `e`'s constructor
-- matches the pattern's name. Wildcard pattern (`_`) is always true.
-- Payload binds in patterns are IGNORED in this form (use `match`
-- expression to bind, or `e = Ctor(literal)` for value comparison).

enum Color = Red | Green | Blue
enum Shape = Circle(Int) | Square(Int) | Triangle(Int, Int)

claim sat_matches_nullary
    c ∈ Color
    c = Red
    c matches Red

claim unsat_matches_wrong_nullary
    c ∈ Color
    c = Red
    c matches Green

claim sat_matches_payload_wildcard
    s ∈ Shape
    s = Circle(7)
    s matches Circle(_)

claim sat_matches_two_arg_payload
    s ∈ Shape
    s = Triangle(3, 4)
    s matches Triangle(_, _)

claim unsat_matches_payload_wrong_variant
    s ∈ Shape
    s = Circle(7)
    s matches Square(_)

claim sat_matches_with_or
    s ∈ Shape
    flag ∈ Bool
    s = Square(5)
    flag = ((s matches Circle(_)) ∨ (s matches Square(_)))
    flag = true

claim sat_matches_with_and
    c ∈ Color
    s ∈ Shape
    pass ∈ Bool
    c = Red
    s = Circle(0)
    pass = ((c matches Red) ∧ (s matches Circle(_)))
    pass = true

claim sat_matches_in_implication_antecedent
    s ∈ Shape
    out ∈ Int
    s = Triangle(3, 4)
    s matches Triangle(_, _) ⇒ out = 99
    out = 99

claim sat_matches_wildcard_pattern_always_true
    s ∈ Shape
    s = Circle(0)
    s matches _

claim sat_matches_payload_binds_treated_as_wildcards
    s ∈ Shape
    s = Circle(99)
    s matches Circle(n)
