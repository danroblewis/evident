-- Conformance tests for the Cons/Nil enum SeqLit shorthand.
--
-- `var = ⟨a, b, c⟩` where `var` is enum-typed and the enum has a
-- 0-arity variant + a 2-arity self-recursive variant lowers to
-- `Cons(a, Cons(b, Cons(c, Nil)))`. EffectList (still Cons-shaped
-- pending Phase 6.4) and any user LinkedList qualify. The runtime's
-- ResultList / ArgList / StrList / IntList went to Seq(...) in
-- earlier Cons-removal phases — see test_seq_of_enum_lit.ev for
-- the Seq-targeted form of the same shorthand.

import "stdlib/runtime.ev"

claim sat_efflist_two_items
    effs ∈ EffectList
    effs = ⟨Println("a"), Println("b")⟩
    effs = EffCons(Println("a"), EffCons(Println("b"), EffNil))

claim sat_efflist_one_item
    effs ∈ EffectList
    effs = ⟨Time⟩
    effs = EffCons(Time, EffNil)

claim sat_efflist_empty
    effs ∈ EffectList
    effs = ⟨⟩
    effs = EffNil

-- User-defined Cons/Nil enum
enum IntList = INil | ICons(Int, IntList)

claim sat_user_intlist
    nums ∈ IntList
    nums = ⟨10, 20, 30⟩
    nums = ICons(10, ICons(20, ICons(30, INil)))
