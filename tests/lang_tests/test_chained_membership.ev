-- Conformance tests for chained-membership syntax.
--
-- Run with:
--     evident test tests/lang_tests/test_chained_membership.ev
--
-- The chain detector at body-item level recognizes
--   `[a comp]* IDENT ∈ TypeName [comp b]*`
-- and desugars into one Membership plus one Constraint per
-- comparison pair. Multi-name shorthand `x, y, z ∈ Int < 5`
-- emits per-name Memberships and per-name Constraints.

-- ── Pin form: x ∈ Int = N ────────────────────────────────────────

claim sat_pin_to_literal
    pos_x ∈ Int = 5
    pos_x = 5

claim unsat_pin_then_contradicts
    pos_x ∈ Int = 5
    pos_x = 7

-- ── Single-side bound ───────────────────────────────────────────

claim sat_upper_bound_only
    pos_x ∈ Int < 100

claim sat_upper_bound_with_value
    pos_x ∈ Int < 100
    pos_x = 99

claim unsat_upper_bound_violated
    pos_x ∈ Int < 100
    pos_x = 200

claim sat_lower_bound_only
    0 < pos_x ∈ Int

claim unsat_lower_bound_violated
    0 < pos_x ∈ Int
    pos_x = -1

-- ── Two-sided range ─────────────────────────────────────────────

claim sat_range_with_value
    0 < pos_x ∈ Int < 10
    pos_x = 5

claim unsat_range_below
    0 < pos_x ∈ Int < 10
    pos_x = -1

claim unsat_range_above
    0 < pos_x ∈ Int < 10
    pos_x = 100

claim sat_range_le_form
    0 ≤ score ∈ Nat ≤ 100
    score = 0

claim sat_range_le_top
    0 ≤ score ∈ Nat ≤ 100
    score = 100

claim unsat_range_le_overflow
    0 ≤ score ∈ Nat ≤ 100
    score = 101

-- ── Inequality in chain ─────────────────────────────────────────

claim sat_neq_in_chain
    pos_x ∈ Int ≠ 0
    pos_x = 5

claim unsat_neq_violated
    pos_x ∈ Int ≠ 0
    pos_x = 0

-- ── Multi-name in chains ────────────────────────────────────────

claim sat_multi_name_pin
    x, y ∈ Nat = 7
    x = 7
    y = 7

claim sat_multi_name_bound
    x, y, z ∈ Int < 5
    x = 1
    y = 2
    z = 3

claim unsat_multi_name_one_violates
    x, y, z ∈ Int < 5
    x = 1
    y = 2
    z = 100

claim sat_multi_name_range
    0 < x, y, z ∈ Int < 10
    x = 1
    y = 5
    z = 9

claim unsat_multi_name_range_violation
    0 < x, y, z ∈ Int < 10
    x = -5

-- ── Compound type in chain (no trailing comparison) ────────────

claim sat_compound_type_no_chain
    s ∈ Seq(Int)
    #s = 3
    s[0] = 1
    s[1] = 2
    s[2] = 3

-- ── Regression: set membership with `∧` still parses as expr ──

claim sat_set_membership_in_expr
    pts ∈ Set(Int)
    x ∈ Int
    x = 2
    -- The chain detector bails because `∧` follows the In, so this
    -- parses as `(x ∈ pts) ∧ (x > 0)` — a single boolean constraint,
    -- not a chained-membership decl.
    x ∈ pts ∧ x > 0
    -- Make pts contain 2 so it satisfies.
    2 ∈ pts

-- ── Regression: plain membership w/o trailing comp still works ──

claim sat_plain_membership
    pos_x ∈ Int
    pos_x = 42

-- ── Real type in chain ──────────────────────────────────────────

claim sat_real_pin
    -- The Real LRA path is separate from Int; verify the chain
    -- works there too.
    r ∈ Real = 1
    r = 1

claim sat_real_bound
    r ∈ Real
    r < 10
    r = 5

-- ── String type in chain ────────────────────────────────────────

claim sat_string_pin
    name ∈ String = "alice"
    name = "alice"

claim unsat_string_pin_contradicts
    name ∈ String = "alice"
    name = "bob"

-- ── Composition: chain inside a claim that's invoked elsewhere ──

claim bounded_score
    score ∈ Nat
    0 ≤ score ≤ 100

claim sat_chain_via_composition
    score ∈ Nat
    bounded_score
    score = 50

claim unsat_chain_via_composition_violates
    score ∈ Nat
    bounded_score
    score = 200
