-- Tests for binding an EXPRESSION (not just a variable name or literal)
-- to a claim-composition slot via `↦`. Currently failing: compiler.smt2
-- doesn't recognize an expression on the RHS of `↦`, so these claims
-- either drop the binding entirely (sat tests become vacuously sat or
-- unsat for the wrong reason) or fail to compile. A red bar against any
-- of them is the gap this file is meant to flag.

-- ── Bool expression in a Bool slot ──────────────────────────────

claim AcceptBool(p ∈ Bool, out ∈ Bool)
    out = p

claim sat_pass_true_comparison
    x ∈ Int = 5
    result ∈ Bool
    AcceptBool(p ↦ (x > 3), out ↦ result)
    result = true

claim unsat_pass_true_comparison_wrong_witness
    x ∈ Int = 5
    result ∈ Bool
    AcceptBool(p ↦ (x > 3), out ↦ result)
    result = false

claim sat_pass_false_comparison
    x ∈ Int = 1
    result ∈ Bool
    AcceptBool(p ↦ (x > 3), out ↦ result)
    result = false

claim sat_pass_conjunction
    x ∈ Int = 5
    y ∈ Int = 7
    result ∈ Bool
    AcceptBool(p ↦ (x > 0 ∧ y > 0), out ↦ result)
    result = true

claim unsat_pass_conjunction_witness_wrong
    x ∈ Int = 5
    y ∈ Int = 7
    result ∈ Bool
    AcceptBool(p ↦ (x > 0 ∧ y > 0), out ↦ result)
    result = false

-- ── Int expression in an Int slot ───────────────────────────────

claim AcceptInt(n ∈ Int, out ∈ Int)
    out = n

claim sat_pass_int_sum
    a ∈ Int = 3
    b ∈ Int = 4
    result ∈ Int
    AcceptInt(n ↦ (a + b), out ↦ result)
    result = 7

claim unsat_pass_int_sum_wrong_witness
    a ∈ Int = 3
    b ∈ Int = 4
    result ∈ Int
    AcceptInt(n ↦ (a + b), out ↦ result)
    result = 100

claim sat_pass_int_difference
    a ∈ Int = 10
    b ∈ Int = 3
    result ∈ Int
    AcceptInt(n ↦ (a - b), out ↦ result)
    result = 7

-- ── Negation expression (¬) in a Bool slot ──────────────────────

claim sat_pass_negation
    x ∈ Int = 5
    result ∈ Bool
    AcceptBool(p ↦ (¬(x > 10)), out ↦ result)
    result = true

-- ── Nested expression in a slot ─────────────────────────────────

claim sat_pass_nested_arith
    a ∈ Int = 2
    b ∈ Int = 3
    result ∈ Int
    AcceptInt(n ↦ (a * (b + 1)), out ↦ result)
    result = 8

-- ── Conditional (ternary) in a slot ─────────────────────────────

claim sat_pass_ternary
    x ∈ Int = 5
    result ∈ Int
    AcceptInt(n ↦ (x > 0 ? x : (0 - x)), out ↦ result)
    result = 5

claim sat_pass_ternary_negative_branch
    x ∈ Int = (0 - 7)
    result ∈ Int
    AcceptInt(n ↦ (x > 0 ? x : (0 - x)), out ↦ result)
    result = 7
