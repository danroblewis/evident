(assert (= did_prelude (ite is_first_tick false (ite emitting_block true _did_prelude))))
(assert (= need_prelude (and emitting_block (not _did_prelude))))
(assert (let ((a!1 (ite (= _phase 0)
                (ite lex_done 1 0)
                (ite (= _phase 1)
                     (ite work_is_nil 2 1)
                     (ite (= _phase 2) (ite all_done 3 2) 3)))))
  (= phase (ite is_first_tick 0 a!1))))
(assert (= emit_now all_done))
(assert (= ift_decl (ite _ift "" "(declare-fun is_first_tick () Bool)\u{a}")))
(assert (= datatypes
   (ite (= _esorts "")
        ""
        (str.++ "(declare-datatypes (" _esorts ") (" _ebodies "))\u{a}"))))
(assert (= prelude
   (ite _saw_result
        ""
        (str.++ "(declare-datatypes ((Result 0)) (((NoResult) (IntResult (IntResult__f0 Int)) (StringResult (StringResult__f0 String)) (RealResult (RealResult__f0 Real)) (EofResult) (ErrorResult (ErrorResult__f0 String)))))\u{a}"
                "(declare-fun last_results () (Array Int Result))\u{a}"
                "(declare-fun last_results__len () Int)\u{a}"
                "(assert (>= last_results__len 0))\u{a}"))))
(assert (= block_now (ite claim_done claim_block skip_block)))
(assert (= emit_payload (ite need_prelude (str.++ prelude block_now) block_now)))
(assert (let ((a!1 (=> is_first_tick
               (and (= effects__len 1) (= (select effects 0) ReadLine))))
      (a!2 (=> (not _got_path)
               (and (= effects__len 1)
                    (= (select effects 0) (ReadFile src_path)))))
      (a!3 (=> emit_now
               (and (= effects__len 1) (= (select effects 0) (Exit 0)))))
      (a!4 (= (select effects 0)
              (LibCall "libc"
                       "puts"
                       (__Cell_LibArg (ArgStr emit_payload) __Empty_LibArg))))
      (a!5 (=> (not emitting_block)
               (and (= effects__len 1)
                    (= (select effects 0)
                       (LibCall "libc" "getpid" __Empty_LibArg))))))
(let ((a!6 (and (=> emitting_block (and (= effects__len 1) a!4)) a!5)))
(let ((a!7 (=> (not (not _got_path)) (and a!3 (=> (not emit_now) a!6)))))
  (and a!1 (=> (not is_first_tick) (and a!2 a!7)))))))
