   (str.++ ";; claim: "
           claim_name
           "\u{a}(push)\u{a}"
           datatypes
           ift_decl
           _out
           "\u{a}(check-sat)\u{a}(pop)\u{a}")))
(assert (= skip_block
   (str.++ ";; claim: " claim_name "\u{a}(push)\u{a}(check-sat)\u{a}(pop)\u{a}")))
