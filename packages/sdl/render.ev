-- packages/sdl/render.ev — SDL2 renderer + drawing primitives via FFI.
--
-- This library covers the SDL functions that DON'T need an SDL_Rect
-- struct (which we can't construct from Evident yet):
--   SDL_CreateRenderer, SDL_DestroyRenderer
--   SDL_SetRenderDrawColor, SDL_RenderClear, SDL_RenderPresent
--   SDL_RenderDrawLine, SDL_RenderDrawPoint
--
-- For outlined rectangles: `draw_rect_outline` packages 4 line
-- draws into one `Seq(Effect)`. For filled rectangles, the
-- malloc'd-SDL_Rect path needs additional FFI plumbing — sketched
-- in docs/guide/ffi-bindings.md.
--
-- All call effects go through the cached LibCall — the runtime
-- resolves libSDL2 + each symbol once and reuses thereafter.

import "stdlib/runtime.ev"

-- ── Records ───────────────────────────────────────────────────

-- 2D integer vector — positions, sizes, deltas. Componentwise
-- arithmetic and chained comparisons work via the runtime's
-- record-lift (see CLAUDE.md "Records as vectors").
type IVec2(x, y ∈ Int)

-- RGBA color, 0..255 per channel. alpha 255 = opaque.
type Color(red, green, blue, alpha ∈ Int)

-- ── Renderer ──────────────────────────────────────────────────

-- SDL_CreateRenderer(window, index, flags) → SDL_Renderer*
-- index: -1 means "first matching driver".
-- flags: 0 = SDL_RENDERER_ACCELERATED is the default; 0x2 explicit accel.
claim create_renderer(window ∈ Int, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_CreateRenderer",
                  "p(pii)",
                  ⟨ArgHandle(window), ArgInt(0 - 1), ArgInt(0)⟩)

claim destroy_renderer(renderer ∈ Int, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_DestroyRenderer",
                  "v(p)", ⟨ArgHandle(renderer)⟩)

-- ── Color + clear + present ───────────────────────────────────

-- SDL_SetRenderDrawColor(renderer, color) → int.
claim set_draw_color(renderer ∈ Int, color ∈ Color, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_SetRenderDrawColor",
                  "i(piiii)",
                  ⟨ArgHandle(renderer), ArgInt(color.red), ArgInt(color.green), ArgInt(color.blue), ArgInt(color.alpha)⟩)

-- SDL_RenderClear(renderer) → int. Clears the entire viewport with
-- the current draw color.
claim render_clear(renderer ∈ Int, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_RenderClear",
                  "i(p)", ⟨ArgHandle(renderer)⟩)

-- SDL_RenderPresent(renderer) — flip the back buffer to screen.
-- Without this, nothing rendered is visible.
claim render_present(renderer ∈ Int, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_RenderPresent",
                  "v(p)", ⟨ArgHandle(renderer)⟩)

-- ── *_after variants: take a prior-result index, not a renderer ──
-- Use these inside an Effect::Seq when the renderer pointer
-- isn't known at constraint-solve time — typically after a
-- create_renderer call earlier in the same Seq. `prior_idx` is
-- the Seq position whose return value is the renderer handle.

claim create_renderer_after(prior_idx ∈ Int, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_CreateRenderer",
                  "p(pii)",
                  ⟨ArgPriorResult(prior_idx), ArgInt(0 - 1), ArgInt(0)⟩)

claim set_draw_color_after(prior_idx ∈ Int, color ∈ Color, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_SetRenderDrawColor",
                  "i(piiii)",
                  ⟨ArgPriorResult(prior_idx), ArgInt(color.red), ArgInt(color.green), ArgInt(color.blue), ArgInt(color.alpha)⟩)

claim render_clear_after(prior_idx ∈ Int, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_RenderClear",
                  "i(p)", ⟨ArgPriorResult(prior_idx)⟩)

claim render_present_after(prior_idx ∈ Int, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_RenderPresent",
                  "v(p)", ⟨ArgPriorResult(prior_idx)⟩)

-- SDL_RenderGeometry but takes the renderer pointer from the
-- Nth prior result of the enclosing Seq (instead of a known
-- Int handle). Use inside an Effect::Seq when the renderer
-- was created earlier in the same Seq.
claim render_geometry_after(prior_idx ∈ Int, vertices ∈ PackedFieldList,
                            n ∈ Int, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_RenderGeometry",
                  "i(pppipi)",
                  ⟨ArgPriorResult(prior_idx), ArgHandle(0), ArgPackedBuf(vertices), ArgInt(n), ArgHandle(0), ArgInt(0)⟩)

-- ── Lines + points ────────────────────────────────────────────

-- SDL_RenderDrawLine(renderer, from, to) → int.
-- Draws using the renderer's current draw color.
claim draw_line(renderer ∈ Int, from ∈ IVec2, to ∈ IVec2, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_RenderDrawLine",
                  "i(piiii)",
                  ⟨ArgHandle(renderer), ArgInt(from.x), ArgInt(from.y), ArgInt(to.x), ArgInt(to.y)⟩)

-- SDL_RenderDrawPoint(renderer, p) → int.
claim draw_point(renderer ∈ Int, p ∈ IVec2, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_RenderDrawPoint",
                  "i(pii)",
                  ⟨ArgHandle(renderer), ArgInt(p.x), ArgInt(p.y)⟩)

-- ── Rectangles ────────────────────────────────────────────────
--
-- Why no SDL_RenderDrawRect / SDL_RenderFillRect wrappers: those
-- take `const SDL_Rect*` — a 16-byte C struct of 4 ints (x, y, w, h).
-- Constructing that struct from Evident needs `malloc` + raw memory
-- writes via FFI, which we haven't built yet. Sketched out in
-- docs/guide/ffi-bindings.md as a future addition.
--
-- For now: outline rectangles via 4 line draws, returned as a single
-- `Seq(Effect)`. One library invocation, one state in the caller.
-- Filled rectangles need either:
--   (a) the malloc'd-SDL_Rect path (best, native C performance), or
--   (b) horizontal lines per row, where N = height
--       (very slow for large fills — h LibCalls per frame).

-- SDL_RenderGeometry(renderer, NULL_texture, vertices, n,
--                    NULL_indices, 0) — draws arbitrary triangles
-- with per-vertex colors. No texture / no indices in this minimal
-- form; vertex order = triangle list (every 3 vertices = 1 tri).
claim render_geometry(renderer ∈ Int, vertices ∈ PackedFieldList,
                      n ∈ Int, out ∈ Effect)
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_RenderGeometry",
                  "i(pppipi)",
                  ⟨ArgHandle(renderer), ArgHandle(0), ArgPackedBuf(vertices), ArgInt(n), ArgHandle(0), ArgInt(0)⟩)

-- Build one SDL_Vertex's field sequence and prepend it to `tail`.
-- SDL_Vertex is 20 bytes, no padding:
--   2 × f32  position
--   4 × u8   RGBA color
--   2 × f32  tex_coord
-- Chain vertices by passing the previous result as `tail`; pass
-- `PfNil` for the last vertex. Render with `render_geometry` /
-- `render_geometry_after`, with `n = #vertices`. SDL_RenderGeometry
-- expects a triangle list (every 3 vertices = 1 triangle).
claim sdl_vertex(pos_x, pos_y ∈ Real,
                 r, g, b, a ∈ Int,
                 tex_u, tex_v ∈ Real,
                 tail ∈ PackedFieldList,
                 out ∈ PackedFieldList)
    out = PfCons(PfF32(pos_x),
          PfCons(PfF32(pos_y),
          PfCons(PfU8(r),
          PfCons(PfU8(g),
          PfCons(PfU8(b),
          PfCons(PfU8(a),
          PfCons(PfF32(tex_u),
          PfCons(PfF32(tex_v), tail))))))))

-- SDL_RenderFillRect(renderer, *SDL_Rect) — filled rectangle in
-- the current draw color. The struct is built via the new
-- ArgI32Buf primitive: `⟨pos.x, pos.y, size.x, size.y⟩` packs into
-- a heap buffer that lives for the call's duration.
claim render_fill_rect(renderer ∈ Int, pos ∈ IVec2, size ∈ IVec2,
                       out ∈ Effect)
    rect_buf ∈ Seq(Int)
    rect_buf = ⟨pos.x, pos.y, size.x, size.y⟩
    out = LibCall("/opt/homebrew/lib/libSDL2.dylib", "SDL_RenderFillRect",
                  "i(pp)",
                  ⟨ArgHandle(renderer), ArgI32Buf(rect_buf)⟩)

-- Outline rectangle as 4 lines (top, right, bottom, left). All
-- drawn with the renderer's current draw color. Inclusive bounds:
-- the rect spans `pos` to `pos + size` (componentwise).
claim draw_rect_outline(renderer ∈ Int, pos ∈ IVec2, size ∈ IVec2,
                        out ∈ Seq(Effect))
    -- Pre-compute the four corners as IVec2s.
    tl ∈ IVec2
    tl = pos
    tr ∈ IVec2
    tr = IVec2(pos.x + size.x, pos.y)
    br ∈ IVec2
    br = IVec2(pos.x + size.x, pos.y + size.y)
    bl ∈ IVec2
    bl = IVec2(pos.x, pos.y + size.y)

    top_eff ∈ Effect
    draw_line(renderer, tl, tr, top_eff)
    right_eff ∈ Effect
    draw_line(renderer, tr, br, right_eff)
    bottom_eff ∈ Effect
    draw_line(renderer, br, bl, bottom_eff)
    left_eff ∈ Effect
    draw_line(renderer, bl, tl, left_eff)

    out = ⟨top_eff, right_eff, bottom_eff, left_eff⟩
