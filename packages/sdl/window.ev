-- packages/sdl/window.ev — SDL2 window via FFI.
--
-- Minimal v1 surface: SDL_Init / SDL_CreateWindow / SDL_Delay /
-- SDL_DestroyWindow / SDL_Quit.
--
-- SDL_INIT_VIDEO = 0x20.
-- SDL_WINDOWPOS_UNDEFINED = 0x1FFF0000 (we use 100 instead — works fine).
-- SDL_WINDOW_SHOWN = 0x4.
--
-- Programs build effects via the helper claims here, then extract
-- handles from last_results in their own state-transition logic.

import "stdlib/runtime.ev"

-- ── Shared records ────────────────────────────────────────────
-- 2D integer vector. Componentwise arithmetic and chained
-- comparisons work via the runtime's record-lift (see CLAUDE.md
-- "Records as vectors").
type IVec2(x, y ∈ Int)

-- RGBA color, 0..255 per channel. alpha 255 = opaque.
type Color(red, green, blue, alpha ∈ Int)

-- Filled rectangle: color + top-left + size. The natural unit
-- of 2D rendering for this stack. Drawing a `Rect` via
-- `win.draw_rect(rect, color_eff, fill_eff)` produces two
-- effects (set-color + fill); the rectangle itself is a
-- value-level thing the user can name, store, derive.
type Rect(color ∈ Color, pos ∈ IVec2, size ∈ IVec2)

-- ── FTI type contract ─────────────────────────────────────────
-- The Rust SDL_Window bridge (runtime/src/event_sources/sdl_window.rs)
-- looks for this name in the FTI registry. The declaration is a
-- documentation contract: it names the fields the bridge writes
-- (and the user pins) so callers can see at a glance which keys
-- live on the window resource.
--
-- Bridge behavior: at install time, calls SDL_Init +
-- SDL_CreateWindow with the configured title/width/height; writes
-- the window pointer (cast to Int) into `handle`. When `gl_handle`
-- is referenced, also creates a GL 3.3 Core context + default VAO
-- and writes those handles. When `renderer` is referenced, calls
-- SDL_CreateRenderer and writes the renderer pointer — the
-- persistent renderer handle that makes per-tick rendering work
-- (COUNTEREXAMPLES.md #9). At program end: SDL_DestroyWindow +
-- SDL_Quit.
--
--     fsm app
--         win ∈ SDL_Window (title  ↦ "App",
--                            width  ↦ 640,
--                            height ↦ 480)
--         -- once win.handle is non-zero, the window exists;
--         -- pass win.handle / win.renderer to SDL/GL effects.
-- Renderer-mode SDL window. Bridge is declarative — the install
-- Seq below drives SDL_Init + SDL_CreateWindow + SDL_CreateRenderer
-- via LibCall effects, captures the resulting handles, and writes
-- them to `handle` / `renderer` in the world snapshot. No Rust-side
-- SDL knowledge required.
--
-- For OpenGL-mode windows, use `SDL_GL_Window` instead. The two
-- can't share one declaration cleanly because a renderer and a
-- manual GL context on the same window conflict.
external type SDL_Window
    title          ∈ String
    width          ∈ Int
    height         ∈ Int
    handle         ∈ Int
    renderer       ∈ Int
    keyboard_state ∈ Int

    -- The persistent install Seq. ArgPriorResult(N) refers to
    -- the result of the Nth step earlier in this same Seq; that's
    -- how SDL_CreateRenderer threads in the window handle from
    -- SDL_CreateWindow without anyone declaring it as a positional
    -- arg outside the install context.
    install ∈ Seq(InstallStep) = ⟨
        Run(LibCall("libSDL2-2.0.so.0", "SDL_Init",
                    "i(i)", ⟨ArgInt(32)⟩)),
        Bind("handle", LibCall("libSDL2-2.0.so.0", "SDL_CreateWindow",
                                "p(siiiii)",
                                ⟨ArgStr(title), ArgInt(805240832), ArgInt(805240832),
                                 ArgInt(width), ArgInt(height), ArgInt(4)⟩)),
        Run(LibCall("libSDL2-2.0.so.0", "SDL_ShowWindow",
                    "v(p)", ⟨ArgPriorResult(1)⟩)),
        Run(LibCall("libSDL2-2.0.so.0", "SDL_RaiseWindow",
                    "v(p)", ⟨ArgPriorResult(1)⟩)),
        Bind("renderer", LibCall("libSDL2-2.0.so.0", "SDL_CreateRenderer",
                                  "p(pii)",
                                  ⟨ArgPriorResult(1), ArgInt(0 - 1), ArgInt(0)⟩)),
        Bind("keyboard_state", LibCall("libSDL2-2.0.so.0",
                                        "SDL_GetKeyboardState",
                                        "p(p)", ⟨ArgHandle(0)⟩))
    ⟩

    -- Read a single key's state. Returns 0 (up) or 1 (down). The
    -- caller passes SDL scancode values (SDL_SCANCODE_LEFT = 80,
    -- _RIGHT = 79, _UP = 82, _DOWN = 81, _SPACE = 44, etc.).
    -- For up-to-date state, SDL_PumpEvents must run earlier in
    -- the same effect Seq.
    subclaim is_key_down(scancode ∈ Int)
        out = ReadByte(keyboard_state, scancode)

    -- ── Render subclaims ─────────────────────────────────────
    -- Invoked as `win.set_draw_color(color_value, sky_eff)` etc.
    -- The runtime rebinds SDL_Window's `renderer` field onto the
    -- bare name when the subclaim body is inlined, so
    -- `ArgHandle(renderer)` resolves to the receiver's
    -- `win.renderer` Int leaf at the call site.
    --
    -- Conventions:
    --   * Caller-supplied inputs sit as first-line params
    --     (`color`, `pos`, `size`, `n`, …).
    --   * `out` is the produced Effect — its type is inferred
    --     from `out = LibCall(...)` (LibCall is an Effect
    --     variant), so we don't need a declaration line. The
    --     caller binds it positionally:
    --     `win.set_draw_color(some_color, my_eff_name)`.

    subclaim set_draw_color(color ∈ Color)
        out = LibCall("libSDL2-2.0.so.0", "SDL_SetRenderDrawColor",
                      "i(piiii)",
                      ⟨ArgHandle(renderer), ArgInt(color.red), ArgInt(color.green),
                       ArgInt(color.blue), ArgInt(color.alpha)⟩)

    subclaim render_clear
        out = LibCall("libSDL2-2.0.so.0", "SDL_RenderClear",
                      "i(p)", ⟨ArgHandle(renderer)⟩)

    subclaim render_present
        out = LibCall("libSDL2-2.0.so.0", "SDL_RenderPresent",
                      "v(p)", ⟨ArgHandle(renderer)⟩)

    subclaim render_fill_rect(pos ∈ IVec2, size ∈ IVec2)
        rect_buf ∈ Seq(Int)
        rect_buf = ⟨pos.x, pos.y, size.x, size.y⟩
        out = LibCall("libSDL2-2.0.so.0", "SDL_RenderFillRect",
                      "i(pp)",
                      ⟨ArgHandle(renderer), ArgI32Buf(rect_buf)⟩)

    -- `draw_rect(r, out)` is the declarative form: a Rect is a noun
    -- that names "this color filled at this position with this
    -- size." Invoking the subclaim emits the two effects (set
    -- color + fill rect) as a 2-element `out ∈ Seq(Effect)` —
    -- one logical operation, one output binding. Caller dispatch
    -- order within the Seq is preserved: color before fill.
    --
    --     win.draw_rect(mario.rects[0], hat_effs)
    --     win.draw_rect(mario.rects[1], face_effs)
    --
    -- Each `*_effs` is its own `Seq(Effect)` binding the runtime
    -- walks and dispatches (in Seq order). Replaces the older
    -- two-slot form (`draw_rect(r, color_eff, fill_eff)`) — that
    -- shape's two outputs were always paired anyway, and the new
    -- one consolidates them so ∀-render patterns don't need
    -- parallel Seq(Effect) outputs (which violate the
    -- parallel-Seqs anti-pattern in CLAUDE.md).
    subclaim draw_rect(r ∈ Rect, out ∈ Seq(Effect))
        color_eff ∈ Effect = LibCall("libSDL2-2.0.so.0",
                            "SDL_SetRenderDrawColor",
                            "i(piiii)",
                            ⟨ArgHandle(renderer),
                             ArgInt(r.color.red), ArgInt(r.color.green),
                             ArgInt(r.color.blue), ArgInt(r.color.alpha)⟩)
        rect_buf ∈ Seq(Int) = ⟨r.pos.x, r.pos.y, r.size.x, r.size.y⟩
        fill_eff ∈ Effect = LibCall("libSDL2-2.0.so.0",
                           "SDL_RenderFillRect",
                           "i(pp)",
                           ⟨ArgHandle(renderer), ArgI32Buf(rect_buf)⟩)
        out = ⟨color_eff, fill_eff⟩

    subclaim draw_line(p_from ∈ IVec2, p_to ∈ IVec2)
        out = LibCall("libSDL2-2.0.so.0", "SDL_RenderDrawLine",
                      "i(piiii)",
                      ⟨ArgHandle(renderer), ArgInt(p_from.x), ArgInt(p_from.y),
                       ArgInt(p_to.x), ArgInt(p_to.y)⟩)

    subclaim draw_point(p ∈ IVec2)
        out = LibCall("libSDL2-2.0.so.0", "SDL_RenderDrawPoint",
                      "i(pii)",
                      ⟨ArgHandle(renderer), ArgInt(p.x), ArgInt(p.y)⟩)

    subclaim render_geometry(vertices ∈ PackedFieldList, n ∈ Int)
        out = LibCall("libSDL2-2.0.so.0", "SDL_RenderGeometry",
                      "i(pppipi)",
                      ⟨ArgHandle(renderer), ArgHandle(0), ArgPackedBuf(vertices),
                       ArgInt(n), ArgHandle(0), ArgInt(0)⟩)

    subclaim destroy_renderer
        out = LibCall("libSDL2-2.0.so.0", "SDL_DestroyRenderer",
                      "v(p)", ⟨ArgHandle(renderer)⟩)

-- ── Library path ──────────────────────────────────────────────

claim sdl_lib_path_macos(p ∈ String)
    p = "libSDL2-2.0.so.0"

-- ── Init flag values ──────────────────────────────────────────

external claim sdl_init_video(n ∈ Int)
    n = 32      -- 0x20

-- ── Effect builders ───────────────────────────────────────────

-- FFIOpen("libSDL2-2.0.so.0") — returns a library handle.
external claim open_sdl_lib(e ∈ Effect)
    e = FFIOpen("libSDL2-2.0.so.0")

-- FFILookup(lib, "SDL_Init"). Returns the symbol handle.
external claim lookup_sdl_init(lib ∈ Int, e ∈ Effect)
    e = FFILookup(lib, "SDL_Init")

external claim lookup_sdl_create_window(lib ∈ Int, e ∈ Effect)
    e = FFILookup(lib, "SDL_CreateWindow")

external claim lookup_sdl_delay(lib ∈ Int, e ∈ Effect)
    e = FFILookup(lib, "SDL_Delay")

external claim lookup_sdl_destroy_window(lib ∈ Int, e ∈ Effect)
    e = FFILookup(lib, "SDL_DestroyWindow")

external claim lookup_sdl_quit(lib ∈ Int, e ∈ Effect)
    e = FFILookup(lib, "SDL_Quit")

-- ── Calls ─────────────────────────────────────────────────────

-- SDL_Init(flags) → int (0 on success, negative on error).
-- Signature: i(i)
external claim call_sdl_init(sym ∈ Int, flags ∈ Int, e ∈ Effect)
    e = FFICall(sym, "i(i)", ⟨ArgInt(flags)⟩)

-- SDL_CreateWindow(title, x, y, w, h, flags) → SDL_Window*
-- Signature: p(siiiii)
external claim call_sdl_create_window(sym ∈ Int, title ∈ String,
                             x ∈ Int, y ∈ Int, w ∈ Int, h ∈ Int,
                             flags ∈ Int, e ∈ Effect)
    e = FFICall(sym, "p(siiiii)",
                ⟨ArgStr(title), ArgInt(x), ArgInt(y), ArgInt(w), ArgInt(h), ArgInt(flags)⟩)

-- SDL_Delay(ms) — pause the calling thread.
-- Signature: v(i)
external claim call_sdl_delay(sym ∈ Int, ms ∈ Int, e ∈ Effect)
    e = FFICall(sym, "v(i)", ⟨ArgInt(ms)⟩)

-- SDL_DestroyWindow(window) — free the window resources.
-- Signature: v(p)
external claim call_sdl_destroy_window(sym ∈ Int, window ∈ Int, e ∈ Effect)
    e = FFICall(sym, "v(p)", ⟨ArgHandle(window)⟩)

-- SDL_Quit() — shut down the SDL subsystems.
-- Signature: v()
external claim call_sdl_quit(sym ∈ Int, e ∈ Effect)
    e = FFICall(sym, "v()", ⟨⟩)

-- ── One-shot LibCall wrappers (no FFILookup needed) ──────────
-- Use these in FTI-shaped programs where the SDL window is owned
-- by the SDL_Window FTI bridge, so there's no `sym` handle to
-- thread. Same end effect as the call_* claims above, just no
-- caller-provided sym.

-- SDL_PumpEvents() — pull pending events from the OS into SDL's
-- internal queue. macOS in particular needs this called regularly
-- or the window appears unresponsive.
external claim sdl_pump_events(out ∈ Effect)
    out = LibCall("libSDL2-2.0.so.0", "SDL_PumpEvents",
                  "v()", ⟨⟩)

-- SDL_Delay(ms) — sleep the calling thread. Useful as a crude
-- frame-rate limiter when you don't have a real vsync source.
external claim sdl_delay(ms ∈ Int, out ∈ Effect)
    out = LibCall("libSDL2-2.0.so.0", "SDL_Delay",
                  "v(i)", ⟨ArgInt(ms)⟩)

-- SDL_Init(flags) → int. flags=32 is SDL_INIT_VIDEO.
external claim sdl_init(flags ∈ Int, out ∈ Effect)
    out = LibCall("libSDL2-2.0.so.0", "SDL_Init",
                  "i(i)", ⟨ArgInt(flags)⟩)

-- SDL_CreateWindow(title, x, y, w, h, flags) → SDL_Window*.
-- Pass 805240832 (0x2FFF0000 = SDL_WINDOWPOS_CENTERED) for x/y
-- to center. Common flag values:
--   2 = SDL_WINDOW_OPENGL
--   4 = SDL_WINDOW_SHOWN  (default; SDL2 ignores)
external claim sdl_create_window(title ∈ String, x ∈ Int, y ∈ Int,
                        w ∈ Int, h ∈ Int, flags ∈ Int, out ∈ Effect)
    out = LibCall("libSDL2-2.0.so.0", "SDL_CreateWindow",
                  "p(siiiii)",
                  ⟨ArgStr(title), ArgInt(x), ArgInt(y), ArgInt(w), ArgInt(h), ArgInt(flags)⟩)

-- SDL_DestroyWindow(window). Currently a no-op on macOS via the
-- runtime (the window pointer must be released on the main
-- thread; the OS reclaims it on process exit).
external claim sdl_destroy_window(window ∈ Int, out ∈ Effect)
    out = LibCall("libSDL2-2.0.so.0", "SDL_DestroyWindow",
                  "v(p)", ⟨ArgHandle(window)⟩)

-- *_after variants for inside an Effect::Seq when the window
-- pointer comes from a prior result rather than a known Int.
external claim sdl_show_window_after(prior_idx ∈ Int, out ∈ Effect)
    out = LibCall("libSDL2-2.0.so.0", "SDL_ShowWindow",
                  "v(p)", ⟨ArgPriorResult(prior_idx)⟩)

external claim sdl_raise_window_after(prior_idx ∈ Int, out ∈ Effect)
    out = LibCall("libSDL2-2.0.so.0", "SDL_RaiseWindow",
                  "v(p)", ⟨ArgPriorResult(prior_idx)⟩)

-- SDL_Quit() — shut down all initialized SDL subsystems.
external claim sdl_quit(out ∈ Effect)
    out = LibCall("libSDL2-2.0.so.0", "SDL_Quit",
                  "v()", ⟨⟩)
