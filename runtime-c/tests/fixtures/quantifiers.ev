-- Cross-check fixture: finite quantifier unrolling (M4b). `∀ v ∈ {lo..hi} : body`
-- unrolls to a conjunction over the constant range (∃ → disjunction), exactly as
-- the Rust translator does (runtime/src/translate/exprs/quant.rs `literal_range`).
-- Every claim is in the seed subset and solvable by the Rust runtime.

-- SAT: ∀ over a range forces n above every element → n ≥ 4.
claim sat_forall_above_all
    n ∈ Int
    ∀ i ∈ {1..3} : n > i

-- UNSAT: can't be above 3 and below 1 at once.
claim unsat_forall_squeeze
    n ∈ Int
    ∀ i ∈ {1..3} : n > i
    ∀ i ∈ {1..3} : n < i

-- SAT: ∃ a square in {0..5}² equal to n.
claim sat_exists_square
    n ∈ Int
    ∃ i ∈ {0..5} : n = i * i

-- UNSAT: assert a body that's false somewhere in the range (i = 0 gives 0 > 2 false).
claim unsat_forall_false_at_zero
    ∀ i ∈ {0..4} : i > 2

-- SAT, forced: singleton range {3..3} pins n = 3.
claim forced_forall_singleton
    n ∈ Int
    ∀ i ∈ {3..3} : n = i

-- SAT, forced: block-form ∀ with a folded bound {0..(2+1-1)} = {0..2}; n above all → 3 is the min,
-- but we additionally pin n ≤ 3, forcing n = 3.
claim forced_forall_block
    n ∈ Int
    n ≤ 3
    ∀ i ∈ {0..2} :
        n > i

-- UNSAT: ∃ over an empty-after-fold range is false (lo > hi → no elements).
claim unsat_exists_empty
    n ∈ Int
    ∃ i ∈ {5..1} : n = i
