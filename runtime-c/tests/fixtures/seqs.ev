-- Cross-check fixture: Z3 sequence theory (M4d). `Seq(Int)`/`Seq(Bool)` declare a
-- `(Seq Elem)` const; `#xs` → `seq.len`, `xs[i]` → `seq.nth`, equality is Z3 seq
-- equality, and the model extracts as `[e0, e1, …]` — the Rust runtime's format.
-- Element types match the oracle's set; Real (oracle-dropped) and `++` runtime
-- concat (oracle-dropped) are out of subset. Every claim here is in the seed
-- subset AND solvable by the Rust runtime, so verdicts/models cross-check.
--
-- (Seq(String) is intentionally absent: it emits correct SMT-LIB but Z3's seq
-- theory returns `unknown` on the plain solver — a documented divergence; the
-- oracle's array representation decides it. See docs/design/c-runtime.md.)

-- SAT, forced: element constraints + scalar derivation. xs = [10, 20, 30], s = 60.
claim forced_seq_elems
    xs ∈ Seq(Int)
    #xs = 3
    xs[0] = 10
    xs[1] = 20
    xs[2] = 30
    s ∈ Int
    s = xs[0] + xs[1] + xs[2]

-- SAT, forced: `#xs` (seq.len) read into a scalar. n = 5.
claim forced_seq_len
    xs ∈ Seq(Int)
    #xs = 5
    n ∈ Int
    n = #xs

-- UNSAT: a sequence can't have two different lengths.
claim unsat_seq_len_conflict
    xs ∈ Seq(Int)
    #xs = 3
    #xs = 4

-- UNSAT: one index can't hold two distinct values.
claim unsat_seq_elem_conflict
    xs ∈ Seq(Int)
    #xs = 2
    xs[0] = 1
    xs[0] = 2

-- SAT, forced: bool-element sequence; bs = [true, false].
claim forced_bool_seq
    bs ∈ Seq(Bool)
    #bs = 2
    bs[0] = true
    bs[1] = false

-- SAT: length pinned, a middle element constrained, the rest free.
claim sat_seq_partial
    xs ∈ Seq(Int)
    #xs = 4
    xs[2] = 99
    m ∈ Int
    m = xs[2]
