-- Cross-check fixture: enums as Z3 datatypes (M4a). Nullary + payload variants,
-- equality, match (-> nested ite over recognizers), and the `matches`
-- recognizer. Every claim is in the seed subset and solvable by the Rust runtime.

enum Color = Red | Green | Blue
enum Result = Ok(Int) | Err(String)

-- SAT, forced: c = Green.
claim forced_color
    c ∈ Color
    c = Green

-- SAT, forced by elimination: not Red, not Blue -> Green.
claim forced_color_by_elim
    c ∈ Color
    c ≠ Red
    c ≠ Blue

-- UNSAT: a value can't be two distinct nullary variants.
claim unsat_color_two
    c ∈ Color
    c = Red
    c = Blue

-- SAT, forced: r = Ok(7); payload constructor.
claim forced_result_ok
    r ∈ Result
    r = Ok(7)

-- SAT, forced: match extracts the Ok payload; r pinned to Ok(42) -> n = 42.
claim forced_match_extract
    r ∈ Result
    n ∈ Int
    r = Ok(42)
    n = match r
        Ok(v) ⇒ v
        Err(s) ⇒ 0

-- SAT, forced: `matches` recognizer; r = Ok(1) -> b = true.
claim forced_matches_recognizer
    r ∈ Result
    b ∈ Bool
    r = Ok(1)
    b = (r matches Ok(_))

-- UNSAT: Ok(_) can never equal Err(_).
claim unsat_ok_is_err
    r ∈ Result
    r = Ok(5)
    r matches Err(_)
