-- Cross-check fixture: claims whose model is UNIQUELY FORCED, so the seed
-- runtime and the Rust runtime must agree not just on sat/unsat but on the
-- extracted model value (the strong form of the round-trip proof).

-- x is forced to 7.
claim forced_int
    x ∈ Int
    x = 7

-- x + x = 3.0 forces x = 1.5 (real arithmetic).
claim forced_real_half
    x ∈ Real
    x + x = 3.0

-- p ⇒ q with p true forces q = true.
claim forced_bool
    p ∈ Bool
    q ∈ Bool
    p = true
    p ⇒ q

-- A negative literal round-trips correctly.
claim forced_negative
    x ∈ Int
    x = -5

-- String equality forces the value.
claim forced_string
    s ∈ String
    s = "hello"
