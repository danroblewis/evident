-- Cross-check fixture: M5 — the seed RUNNING an Evident program that is a
-- *transform*. The AST is data (a recursive `enum`), the pass is an Evident
-- `claim` relating `input` and `output`, and the seed is just the engine: it
-- reflects the pinned input AST into the enum value, the solver computes
-- `output` from the transform constraint, and the model extractor reifies the
-- output AST. The transform logic lives in Evident, NOT in the seed's C++.
--
-- The same file runs on the Rust runtime, which produces the identical output
-- AST — the strongest form of the self-hosting proof (one pass, two engines,
-- one answer). See docs/design/c-runtime.md "M5".

-- A miniature expression AST as a recursive Evident enum.
enum Expr = Lit(Int) | Add(Expr, Expr) | Mul(Expr, Expr)

-- Identity pass: output is structurally the input. Proves the reflect → solve →
-- reify round-trip is faithful for a nested recursive value.
claim identity_pass
    input ∈ Expr
    output ∈ Expr
    input = Add(Lit(2), Mul(Lit(3), Lit(4)))
    output = input

-- A real rewrite: swap the operands of a top-level Add. The match arm constructs
-- a fresh node from the bound accessors — Add(b, a) from the peeled Add(a, b).
claim swap_add_pass
    input ∈ Expr
    output ∈ Expr
    input = Add(Lit(1), Mul(Lit(7), Lit(8)))
    output = match input
        Add(a, b) ⇒ Add(b, a)
        _         ⇒ input

-- A lowering-flavored rewrite: turn a top-level Mul(a, b) into Add(a, b).
claim mul_to_add_pass
    input ∈ Expr
    output ∈ Expr
    input = Mul(Lit(5), Add(Lit(6), Lit(7)))
    output = match input
        Mul(a, b) ⇒ Add(a, b)
        _         ⇒ input

-- A non-matching scrutinee falls through to the base arm (output = input).
claim passthrough_pass
    input ∈ Expr
    output ∈ Expr
    input = Lit(42)
    output = match input
        Add(a, b) ⇒ Add(b, a)
        _         ⇒ input
