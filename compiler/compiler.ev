-- compiler/compiler.ev — the self-hosted compiler driver (MVP).
--
-- This is the top-level program the whole project is building toward:
-- an Evident program that reads a `.ev` source file from disk, runs it
-- through lex → parse → translate, and emits the corresponding `.smt2`
-- to stdout. When compiled once via bootstrap to `compiler.smt2`, the
-- kernel runs THIS to compile every other `.ev` file, and bootstrap/
-- has no further role (see CLAUDE.md, "The architecture, in one
-- paragraph").
--
-- It composes the per-pass pieces that already exist:
--   compiler/lexer.ev            — char classifiers + Token enum
--   compiler/parser.ev           — Token/Expr/BodyItem AST + recognizers
--   compiler/translate_declare.ev — BIMembership → (declare-fun …)
--   compiler/translate_bool.ev    — EBinOp(OpEq,…) → (= … …)
--   compiler/translate_manifest.ev— the 5-line manifest header
--
-- Nothing is hardcoded as tokens or AST: the source text is read from
-- disk and lexed character-by-character; the parse + translate flow
-- from the actually-lexed token payloads. The driver is exercised
-- end-to-end (on a String constant rather than a file, so the kernel
-- test harness can run it deterministically) by
-- tests/kernel/test_compiler_driver_mvp.ev — read that fixture's header
-- for the full pipeline write-up.
--
-- MVP grammar scope (documented restriction): one schema head plus one
-- primitive membership with an `= N` pin —
--     <kw> Ident
--     Ident ∈ Type = N
-- Widening the grammar (multiple body items, more types, full
-- expression pins, layout-token-driven block parsing) is the work that
-- follows; this driver proves the wiring composes end-to-end.
--
-- Input path: /tmp/compiler-input.ev (read on the first tick via the
-- ReadFile effect; the consolidated-lexer last_results[0] pattern).

import "stdlib/kernel.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler/translate_declare.ev"
import "compiler/translate_bool.ev"
import "compiler/translate_manifest.ev"

claim main
    -- ── INPUT — read the source file on the first tick ───────────
    input  ∈ String
    _input ∈ String
    read_result ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ "<no-read>"
    input = (is_first_tick ? "" : (_input = "" ? read_result : _input))

    -- ── LEX state (consolidated-lexer FSM) ───────────────────────
    pos  ∈ Int
    _pos ∈ Int
    pos = (is_first_tick ? 0 - 1 : (_input = "" ? 0 : _pos + 1))

    partial_str  ∈ String
    _partial_str ∈ String
    partial_int  ∈ Int
    _partial_int ∈ Int

    cur_char ∈ String = substr(input, pos, 1)

    is_alpha ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)
    is_dig ∈ Bool
    IsDigitChar(c ↦ cur_char, out ↦ is_dig)
    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)
    op_tok ∈ Token
    is_op ∈ Bool
    SingleCharTok(c ↦ cur_char, t ↦ op_tok, recognized ↦ is_op)
    dig_val ∈ Int
    DigitToInt(c ↦ cur_char, n ↦ dig_val)

    done ∈ Bool = ((pos ≥ #input) ∧ (#input > 0))
    in_range ∈ Bool = ((pos ≥ 0) ∧ ¬done)

    was_collecting_str ∈ Bool = (#_partial_str > 0)
    was_collecting_int ∈ Bool = (_partial_int ≥ 0)

    str_continuing ∈ Bool = (was_collecting_str ∧ is_alpha ∧ in_range)
    str_finishing  ∈ Bool = (was_collecting_str ∧ ((¬is_alpha ∧ in_range) ∨ done))
    str_starting   ∈ Bool = ((¬was_collecting_str) ∧ is_alpha ∧ in_range)

    int_continuing ∈ Bool = (was_collecting_int ∧ is_dig ∧ in_range)
    int_finishing  ∈ Bool = (was_collecting_int ∧ ((¬is_dig ∧ in_range) ∨ done))
    int_starting   ∈ Bool = ((¬was_collecting_int) ∧ is_dig ∧ in_range)

    partial_str = (is_first_tick ? "" : (str_continuing ? _partial_str ++ cur_char : (str_starting ? cur_char : "")))
    partial_int = (is_first_tick ? 0 - 1 : (int_continuing ? (_partial_int * 10) + dig_val : (int_starting ? dig_val : 0 - 1)))

    classified_str ∈ Token
    MaybeKeyword(s ↦ _partial_str, t ↦ classified_str)
    int_tok ∈ Token = IntLit(_partial_int)

    finish_str_only    ∈ Bool = (str_finishing ∧ (is_ws ∨ done))
    finish_int_only    ∈ Bool = (int_finishing ∧ (is_ws ∨ done))
    finish_str_with_op ∈ Bool = (str_finishing ∧ is_op ∧ in_range)
    finish_int_with_op ∈ Bool = (int_finishing ∧ is_op ∧ in_range)
    char_only          ∈ Bool = ((¬was_collecting_str) ∧ (¬was_collecting_int) ∧ is_op ∧ in_range)

    tokens  ∈ TokenList
    _tokens ∈ TokenList
    tokens = (is_first_tick ? TLNil
            : (finish_str_with_op ? TLCons(op_tok, TLCons(classified_str, _tokens))
            : (finish_int_with_op ? TLCons(op_tok, TLCons(int_tok, _tokens))
            : (finish_str_only ? TLCons(classified_str, _tokens)
            : (finish_int_only ? TLCons(int_tok, _tokens)
            : (char_only ? TLCons(op_tok, _tokens)
            : _tokens))))))

    -- ── EMIT trigger ─────────────────────────────────────────────
    has_input ∈ Bool = (#input > 0)
    flush_done ∈ Bool = (done ∧ ¬was_collecting_str ∧ ¬was_collecting_int ∧ has_input)

    -- ── PARSE — peel the reverse-order TokenList into grammar roles ─
    --   rh1 IntLit(N)  rh2 Eq  rh3 Ident(Type)  rh4 OpIn  rh5 Ident(name)
    rh1 ∈ Token = match _tokens
        TLCons(h, _) ⇒ h
        TLNil ⇒ EofTok
    r1 ∈ TokenList = match _tokens
        TLCons(_, t) ⇒ t
        TLNil ⇒ TLNil
    rh2 ∈ Token = match r1
        TLCons(h, _) ⇒ h
        TLNil ⇒ EofTok
    r2 ∈ TokenList = match r1
        TLCons(_, t) ⇒ t
        TLNil ⇒ TLNil
    rh3 ∈ Token = match r2
        TLCons(h, _) ⇒ h
        TLNil ⇒ EofTok
    r3 ∈ TokenList = match r2
        TLCons(_, t) ⇒ t
        TLNil ⇒ TLNil
    rh4 ∈ Token = match r3
        TLCons(h, _) ⇒ h
        TLNil ⇒ EofTok
    r4 ∈ TokenList = match r3
        TLCons(_, t) ⇒ t
        TLNil ⇒ TLNil
    rh5 ∈ Token = match r4
        TLCons(h, _) ⇒ h
        TLNil ⇒ EofTok

    type_str ∈ String
    type_is_type ∈ Bool
    TypeTokenText(t ↦ rh3, s ↦ type_str, is_type_tok ↦ type_is_type)

    mem_item ∈ BodyItem
    mem_ok ∈ Bool
    ParseMembership(head1 ↦ rh5, head2 ↦ rh4, type_str ↦ type_str,
                    item ↦ mem_item, ok ↦ mem_ok)

    mem_name ∈ String = match mem_item
        BIMembership(n, _) ⇒ n
        _ ⇒ ""

    pin_val ∈ Int = match rh1
        IntLit(n) ⇒ n
        _ ⇒ 0 - 1
    pin_expr ∈ Expr = EBinOp(OpEq, EIdent(mem_name), EInt(pin_val))

    -- ── TRANSLATE ────────────────────────────────────────────────
    declare_line ∈ String
    declare_ok ∈ Bool
    DeclareFromMembership(item ↦ mem_item, out ↦ declare_line, ok ↦ declare_ok)

    eq_inner ∈ String
    eq_ok ∈ Bool
    BoolExprSmtlib(e ↦ pin_expr, out ↦ eq_inner, ok ↦ eq_ok)
    assert_line ∈ String = "(assert " ++ eq_inner ++ ")"

    fields ∈ StateFieldList = SFLCons(SField(mem_name, type_str), SFLNil)
    manifest ∈ String
    ManifestHeader(fields ↦ fields, max_effects ↦ 0, out ↦ manifest)

    smtlib ∈ String = manifest ++ "\n" ++ declare_line ++ "\n" ++ assert_line

    effects ∈ Seq(Effect) = (is_first_tick ? ⟨ReadFile("/tmp/compiler-input.ev")⟩
        : (flush_done
            ? ⟨LibCall("libc", "puts", ⟨ArgStr(smtlib)⟩), Exit(0)⟩
            : ⟨LibCall("libc", "getpid", ⟨⟩)⟩))
