-- WIP: replaces bootstrap/runtime/src/parser/mod.rs. STATUS: tiny Expr/binop-chain AST + per-shape productions; not composed into a full-file parser.

import "compiler/lexer.ev"

--
-- Tiny Expr AST for the binop-chain parser:
--   EInt(n)               вҖ” integer literal
--   EIdent(s)             вҖ” bare identifier
--   EBinOp(op, lhs, rhs)  вҖ” binary operation (Plus, Eq, вҖҰ)
--
-- The Op enum names the binary operator. For now we just have one
-- operator (Plus); extending to others is a stdlib change.

-- Op variants mirror the binary operator tokens the lexer emits. The
-- precedence layer (see Precedence below) groups them into "high"
-- (multiplicative) and "low" (additive) for the precedence-climbing
-- parser FSM.
--
-- OpImpl is the logical `вҮ’` operator (lexer token: OpImplies). It
-- carries CLAUDE.md composition mechanism #7 вҖ” guarded invocation
-- `cond вҮ’ ClaimName` parses as `EBinOp(OpImpl, cond, claim_call)`.
-- It has the lowest precedence in the binop ladder (n = 0, same as
-- Eq) вҖ” the Precedence claim below treats it as such. Wrapping a
-- compound consequent in parens is a documented user idiom (see the
-- "Boolean & precedence footguns" section in CLAUDE.md).
enum Op =
    OpPlus
    OpMul
    OpEq
    OpSub
    OpDiv
    OpImpl
    OpConcat

-- Quantifier variants (B8) carry the bound variable name, the
-- range expression (the source to iterate over, e.g. `items`), and
-- the body expression. Mirrors the Rust AST's `Expr::Forall(vars,
-- range, body)` / `Expr::Exists(...)` in runtime/src/core/ast.rs,
-- restricted to the single-name shape (`вҲҖ x вҲҲ S : body`); the
-- tuple-binding form (`вҲҖ (a, b) вҲҲ coindexed(...) : ...`) is a
-- later sub-step.
enum Expr =
    EInt(Int)
    EIdent(String)
    EBinOp(Op, Expr, Expr)
    EForall(String, Expr, Expr)
    EExists(String, Expr, Expr)
    EMatch(Expr, MatchArmList)
    ENoExpr

-- в”Җв”Җ Match patterns (B9) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- Mirrors runtime/src/parser/patterns.rs's `parse_match_pattern`:
-- a head Ident is either a constructor (uppercase) with optional
-- parenthesized binds, or `_` for the wildcard arm.
--
-- B9 covers the simplest useful shape: a flat constructor with
-- single-name binds (no nested patterns yet, no literal-payload
-- comparisons). The Rust path recurses inside parens вҖ” that's a
-- staged extension later.
--
-- MPCtor(name, binds) вҖ” constructor pattern `Ctor(b1, b2, вҖҰ)`.
-- MPWildcard          вҖ” the catch-all `_` arm.
enum MatchPattern =
    MPCtor(String, MatchBindList)
    MPWildcard

-- A single bind inside a constructor pattern. B9 only models the
-- "bind to a name" form; the `Ok(_)` underscore-skip case is a
-- later extension that needs an MBWildcard variant (and a match
-- arm in the translator that drops the bind).
enum MatchBind =
    MBName(String)

enum MatchBindList =
    MBNil
    MBCons(MatchBind, MatchBindList)

-- A match arm is `pattern вҮ’ body`. The body Expr is whatever
-- expression appears after `вҮ’`; the test fixture stays at the
-- atom level (EIdent, EInt) but the type admits any Expr.
enum MatchArm =
    MArm(MatchPattern, Expr)

enum MatchArmList =
    MANil
    MACons(MatchArm, MatchArmList)

-- A Cons-shaped list of Exprs, used as a work stack when walking
-- an Expr tree across multiple FSM ticks. See test_ast_walker.ev
-- for the depth-first walker pattern.
enum ExprList =
    ELNil
    ELCons(Expr, ExprList)

-- A work item for the ASTвҶ’text translator. The work stack interleaves
-- "process this Expr" with "emit this literal text" so structural
-- characters like "(", " ", ")" can be queued between subtree visits.
enum WorkItem =
    WIProcess(Expr)
    WIEmit(String)

enum WorkList =
    WLNil
    WLCons(WorkItem, WorkList)

-- в”Җв”Җ Import statements (B11) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
enum ImportStmt =
    ImportPath(String)
    NoImport
    BadImport(String)

-- в”Җв”Җ Type references (B3) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- The Rust parser carries types as opaque strings throughout the
-- AST: `"Int"` for a bare type, `"Seq(Int)"` for a compound, and
-- `"Edge<Rect>"` / `"Seq(Edge<Rect>)"` for generic instantiations
-- and their nestings (see runtime/src/core/ast.rs::BodyItem::Membership).
--
-- Mirroring that decision, `TypeRef` is a single-variant enum whose
-- payload is the fully-rendered type-name string. The Phase B3
-- self-hosted parser builds this string token-by-token in an
-- accumulator FSM (see tests/kernel/test_parser_types.ev).
--
-- TName(s) вҖ” the type name as a flat string. The accumulator handles
-- balancing nested `(`/`)` and `<`/`>` so the string round-trips
-- through later translator passes that key off the literal name.
-- TNoType вҖ” sentinel for "no type yet" / placeholder initialisations
-- (analogous to ENoExpr / WIEmit("") elsewhere in the parser).
enum TypeRef =
    TName(String)
    TNoType

-- в”Җв”Җ Type-name token rendering в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- Per-tick the type-parse FSM strips the head token off a TokenList
-- and asks: "what string does this token contribute to the final
-- type-name?" Mirrors the Rust parser's tokenвҶ’source-text mapping
-- in runtime/src/parser/types.rs: Ident вҶ’ its payload, LParen вҶ’ "(",
-- RParen вҶ’ ")", Lt вҶ’ "<", Gt вҶ’ ">", Comma вҶ’ ", ".
--
-- All other tokens (Newline, Indent, EofTok, вҖҰ) terminate the
-- type вҖ” the FSM treats them as the "done" signal and does not
-- include them in the accumulated string.
--
-- The `is_type_tok` Bool is what the per-tick FSM consults to
-- decide "consume this token + continue" vs "halt".

claim TypeTokenText
    t вҲҲ Token
    s вҲҲ String
    is_type_tok вҲҲ Bool
    ident_str вҲҲ String = match t
        Ident(n) вҮ’ n
        _ вҮ’ ""
    is_ident   вҲҲ Bool = (t matches Ident(_))
    is_lparen  вҲҲ Bool = (t matches LParen)
    is_rparen  вҲҲ Bool = (t matches RParen)
    is_lt      вҲҲ Bool = (t matches Lt)
    is_gt      вҲҲ Bool = (t matches Gt)
    is_comma   вҲҲ Bool = (t matches Comma)
    s = (is_ident  ? ident_str
        : is_lparen ? "("
        : is_rparen ? ")"
        : is_lt     ? "<"
        : is_gt     ? ">"
        : is_comma  ? ", "
        : "")
    is_type_tok = (is_ident вҲЁ is_lparen вҲЁ is_rparen вҲЁ is_lt вҲЁ is_gt вҲЁ is_comma)

-- в”Җв”Җ Bracket-depth delta в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- The FSM tracks paren/angle nesting so it can recognise "back to
-- depth 0" as the end of a generic / compound type. Open brackets
-- (`(`, `<`) increment depth by 1; close brackets (`)`, `>`)
-- decrement; everything else is 0. (Ident at depth 0 followed by
-- anything other than `(` or `<` is the bare-type halt case вҖ” handled
-- by the FSM itself, not by this claim.)

claim BracketDelta
    t вҲҲ Token
    d вҲҲ Int
    is_open  вҲҲ Bool = ((t matches LParen) вҲЁ (t matches Lt))
    is_close вҲҲ Bool = ((t matches RParen) вҲЁ (t matches Gt))
    d = (is_open ? 1 : (is_close ? 0 - 1 : 0))

-- в”Җв”Җ Token вҶ’ Op classifier в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- For a parser that handles binop tokens, this gives the operator
-- (or OpPlus as a placeholder if the token isn't an operator).

-- Note: first-line claim params of enum type have a translator gap
-- for `matches`/`match` (the param isn't put into env in a form the
-- recognizer translation can resolve). Workaround: put all vars in
-- the body; callers use names-match composition.
claim TokenToOp
    t вҲҲ Token
    o вҲҲ Op
    is_binop вҲҲ Bool
    is_plus  вҲҲ Bool = (t matches Plus)
    is_minus вҲҲ Bool = (t matches Minus)
    is_star  вҲҲ Bool = (t matches Star)
    is_slash вҲҲ Bool = (t matches Slash)
    is_eq    вҲҲ Bool = (t matches Eq)
    o = (is_plus  ? OpPlus
       : is_minus ? OpSub
       : is_star  ? OpMul
       : is_slash ? OpDiv
       : is_eq    ? OpEq
       : OpPlus)
    is_binop = (is_plus вҲЁ is_minus вҲЁ is_star вҲЁ is_slash вҲЁ is_eq)

-- в”Җв”Җ Operator precedence (B1) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- OpImpl (`вҮ’`) sits at the bottom (n = 0) alongside Eq. CLAUDE.md
-- documents `вҮ’` as binding tighter than `вҲ§`/`вҲЁ` (which aren't in
-- this binop set yet) but looser than `=` in the wider language вҖ”
-- B10 only needs an AST shape, so we shelve `вҮ’` next to `=` and let
-- a future precedence-ladder revision re-rank them.
claim Precedence
    op вҲҲ Op
    n вҲҲ Int
    is_mul  вҲҲ Bool = (op matches OpMul)
    is_div  вҲҲ Bool = (op matches OpDiv)
    is_add  вҲҲ Bool = (op matches OpPlus)
    is_sub  вҲҲ Bool = (op matches OpSub)
    is_eq   вҲҲ Bool = (op matches OpEq)
    is_impl вҲҲ Bool = (op matches OpImpl)
    n = (is_mul ? 2 : is_div ? 2 : is_add ? 1 : is_sub ? 1
        : is_eq ? 0 : is_impl ? 0 : 0)

-- в”Җв”Җ Enum declaration AST (B6) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
enum EnumVariantDecl =
    EVDecl(String)
    EVNoVariant

enum EnumVariantList =
    EVNil
    EVCons(EnumVariantDecl, EnumVariantList)

enum EnumDeclAst =
    EnumD(String, EnumVariantList)
    ENoEnum

-- в”Җв”Җ Paren-depth frame stack (B2) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
enum FrameList =
    FLNil
    FLCons(Expr, Op, FrameList)

-- в”Җв”Җ Claim-argument AST (B10: composition mechanism #5) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- A claim-call argument is a `slot вҶҰ expr` pair. Slot is a String
-- (the parameter name). For the zero-arg call form (mechanism #4,
-- "names-match"), the ClaimArgList is just CANil вҖ” no explicit
-- mapsto args. For mechanism #5, the list is one CACons per
-- `slot вҶҰ value` pair on the call site.
--
-- The Rust parser's call-site shape lives in
-- runtime/src/parser/exprs.rs (parse_call_args) and lowers to
-- ECall(name, Vec<(String, Expr)>) вҖ” this is the AST mirror.
enum ClaimArg =
    CArg(String, Expr)
    CANoArg

enum ClaimArgList =
    CANil
    CACons(ClaimArg, ClaimArgList)

-- в”Җв”Җ BodyItem AST (B4 + B7 + B10: composition mechanisms) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- The seven composition mechanisms from CLAUDE.md, mapped to
-- BodyItem variants (вң“ = AST shape currently lands in the indicated
-- sub-step; the deferred parse-FSM productions come later):
--
--   #1  `variable вҲҲ TypeName`             вҖ” BIMembership(name, type)   вң“ (B4)
--   #2  `ClaimName` (bare body item)      вҖ” BIClaimCall(name, CANil)   вң“ (B10)
--   #3  `..ClaimName`                     вҖ” BIPassthrough(name)         вң“ (B7)
--   #4  Names-match composition           вҖ” BIClaimCall(name, CANil)   вң“ (B10)
--   #5  `ClaimName(slot вҶҰ value)`         вҖ” BIClaimCall(name, args)    вң“ (B10)
--   #6  `subclaim Name bodyвҖҰ`             вҖ” BISubclaim(name, body)     вң“ (B10)
--   #7  `cond вҮ’ ClaimName`                вҖ” BIConstraint(EBinOp(OpImpl,вҖҰ)) вң“ (B10)
--
-- BIMembership(name, type_ref) вҖ” a `name вҲҲ Type` declaration
-- (mechanism #1), mirroring the Rust parser's
-- `BodyItem::Membership { name, type_name, pins }`
-- (runtime/src/core/ast.rs). The TypeRef payload carries the
-- fully-rendered type-name string (built by the B3 accumulator вҖ”
-- see TypeTokenText). Pins are NOT yet modeled here: the chained-
-- membership desugaring (`0 вүӨ x вҲҲ Int вүӨ 100`) emits a BIMembership
-- followed by separate BIConstraint items, exactly as the Rust
-- parser at runtime/src/parser/body_item.rs::try_parse_chained_membership
-- already does. Named-pins (`x вҲҲ Type(slot вҶҰ val)`) are a B5/later
-- extension.
--
-- BIClaimCall serves both mechanisms #2/#4 (when ClaimArgList is
-- CANil) and #5 (when there are CACons cells). The parse-side
-- discriminator is just "are there `slot вҶҰ value` tokens after the
-- bare name?" вҖ” collapsed at parse time.
--
-- BISubclaim's body is a BodyItemList вҖ” mutually recursive with
-- BodyItem to let nested subclaims contain further subclaims.
-- The forward reference works the same way as the LL/Cons example
-- in CLAUDE.md's "Enums" section.
enum BodyItem =
    BIPassthrough(String)
    BIConstraint(Expr)
    BIMembership(String, TypeRef)
    BIClaimCall(String, ClaimArgList)
    BISubclaim(String, BodyItemList)
    BINoItem

enum BodyItemList =
    BILNil
    BILCons(BodyItem, BodyItemList)

-- в”Җв”Җ Token recognizers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
claim IsDotDot
    t вҲҲ Token
    out вҲҲ Bool
    out = (t matches DotDot)

claim IsIdent
    t вҲҲ Token
    out вҲҲ Bool
    out = (t matches Ident(_))

claim IdentName
    t вҲҲ Token
    name вҲҲ String
    name = match t
        Ident(s) вҮ’ s
        _ вҮ’ ""

-- в”Җв”Җ Quantifier recognizers (B8) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
claim IsForall
    t вҲҲ Token
    out вҲҲ Bool
    out = (t matches OpForall)

claim IsExists
    t вҲҲ Token
    out вҲҲ Bool
    out = (t matches OpExists)

claim IsOpIn
    t вҲҲ Token
    out вҲҲ Bool
    out = (t matches OpIn)

claim IsColon
    t вҲҲ Token
    out вҲҲ Bool
    out = (t matches Colon)

-- в”Җв”Җ Quantifier parser (B8) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- Recognises the leading token sequence of a single-name quantifier:
--   вҹЁOpForall, Ident(x), OpIn, Ident(src), Colon, вҖҰbodyвҖҰвҹ©    or
--   вҹЁOpExists, Ident(x), OpIn, Ident(src), Colon, вҖҰbodyвҖҰвҹ©
--
-- Pre-extracted by the caller: the first four head tokens, plus the
-- already-parsed body Expr. `range_src` becomes an EIdent.
--
-- Mirrors runtime/src/parser/exprs.rs::parse_quantifier (single-name
-- branch). The tuple-binding branch + block-form body are future
-- sub-steps; this recogniser covers the inline `вҲҖ x вҲҲ S : body`
-- shape вҖ” the canonical case in stdlib/.
--
-- Output:
--   ok=true  вҶ’ expr is EForall(var, EIdent(src), body)
--                       or EExists(var, EIdent(src), body)
--   ok=false вҶ’ expr is ENoExpr (the head4 didn't match the shape;
--                callers fall through to non-quantifier parsing).
claim ParseQuantifier
    head1 вҲҲ Token
    head2 вҲҲ Token
    head3 вҲҲ Token
    head4 вҲҲ Token
    body вҲҲ Expr
    expr вҲҲ Expr
    ok вҲҲ Bool

    is_forall вҲҲ Bool
    IsForall(t вҶҰ head1, out вҶҰ is_forall)
    is_exists вҲҲ Bool
    IsExists(t вҶҰ head1, out вҶҰ is_exists)
    is_var_id вҲҲ Bool
    IsIdent(t вҶҰ head2, out вҶҰ is_var_id)
    var_name вҲҲ String
    IdentName(t вҶҰ head2, name вҶҰ var_name)
    is_in вҲҲ Bool
    IsOpIn(t вҶҰ head3, out вҶҰ is_in)
    is_src_id вҲҲ Bool
    IsIdent(t вҶҰ head4, out вҶҰ is_src_id)
    src_name вҲҲ String
    IdentName(t вҶҰ head4, name вҶҰ src_name)

    head1_ok вҲҲ Bool = (is_forall вҲЁ is_exists)
    ok = (head1_ok вҲ§ is_var_id вҲ§ is_in вҲ§ is_src_id)
    range_expr вҲҲ Expr = EIdent(src_name)
    expr = (ok вҲ§ is_forall ? EForall(var_name, range_expr, body)
        : (ok вҲ§ is_exists ? EExists(var_name, range_expr, body)
        : ENoExpr))

-- в”Җв”Җ Passthrough body-item parser (B7) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
claim ParsePassthrough
    head1 вҲҲ Token
    head2 вҲҲ Token
    item вҲҲ BodyItem
    ok вҲҲ Bool

    is_dd вҲҲ Bool
    IsDotDot(t вҶҰ head1, out вҶҰ is_dd)
    is_id вҲҲ Bool
    IsIdent(t вҶҰ head2, out вҶҰ is_id)
    name вҲҲ String
    IdentName(t вҶҰ head2, name вҶҰ name)

    ok = (is_dd вҲ§ is_id)
    item = (ok ? BIPassthrough(name) : BINoItem)

-- в”Җв”Җ Schema declarations (B5) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--
-- The Rust parser at runtime/src/parser/schema.rs recognizes four
-- declaration keywords (`claim`, `type`, `schema`, `fsm`) and
-- produces the same `SchemaDecl` AST node with a `keyword`
-- discriminator. The shape on the wire is:
--
--   <schema-kw> Ident(name) [type-params]? [(first-line-params)]?
--   Newline Indent(n) <body-itemsвҖҰ>
--
-- where the body-items are BodyItem entries (BIMembership from B4,
-- BIPassthrough from B7, ClaimCall from B10, etc.).
--
-- This sub-step adds:
--   * Keyword вҖ” the four-variant enum naming which keyword opened
--     the declaration. The Rust side calls this Keyword too
--     (runtime/src/core/ast.rs::Keyword), with the same four
--     variants in the same order. (We prefix variants with `KK` so
--     they don't collide with the lexer's Kw* token variants.)
--   * BodyItemList вҖ” Cons-shaped list of BodyItems, used as the
--     SchemaDecl body field. Same shape as EnumVariantList /
--     TokenList: a recursive Cons-cell so it can be built across
--     ticks and walked by a downstream pass.
--   * SchemaDecl вҖ” the AST node itself. SDecl(kw, name, body) is the
--     success case; SNoDecl is the sentinel for "not yet" / "shape
--     didn't match" / placeholder. The variant name is SDecl rather
--     than `SchemaD` to avoid clashing with B6's EnumD naming.
--   * KeywordOfTok(t, kw, ok) вҖ” recognizer mapping a head token to
--     its Keyword. ok=false means "this token is not a schema
--     keyword" (kw is then a placeholder KKClaim).
--   * ParseSchemaHead(head1, head2, kw, name, ok) вҖ” recognizer for
--     the `<schema-kw> Ident` head sequence. ok=true iff head1 is
--     one of the four schema keywords AND head2 is an Ident. The
--     full multi-tick body consumer is a later sub-step; this is
--     the recognizer layer that mirrors ParsePassthrough /
--     ParseMembership.

enum Keyword =
    KKClaim
    KKType
    KKSchema
    KKFsm

-- BodyItemList already declared by B10 (mutual recursion with BISubclaim).

enum SchemaDecl =
    SDecl(Keyword, String, BodyItemList)
    SNoDecl

-- KeywordOfTok: classify a head token as a schema-keyword.
--
-- Mirrors the `match self.bump()` in parse_schema_decl
-- (runtime/src/parser/schema.rs:59). Token::Claim вҶ’ KKClaim, etc.
-- ok=false means "this token is not a schema keyword."
--
-- Same vars-in-body shape as TokenToOp: first-line claim params of
-- enum type have a translator gap for `matches`/`match`, so all the
-- pattern-matching happens via per-variant Bool intermediates in the
-- body and the caller composes with names-match binding.
claim KeywordOfTok
    t вҲҲ Token
    kw вҲҲ Keyword
    ok вҲҲ Bool
    is_claim  вҲҲ Bool = (t matches KwClaim)
    is_type   вҲҲ Bool = (t matches KwType)
    is_schema вҲҲ Bool = (t matches KwSchema)
    is_fsm    вҲҲ Bool = (t matches KwFsm)
    kw = (is_claim  ? KKClaim
        : is_type   ? KKType
        : is_schema ? KKSchema
        : is_fsm    ? KKFsm
        : KKClaim)
    ok = (is_claim вҲЁ is_type вҲЁ is_schema вҲЁ is_fsm)

-- ParseSchemaHead: recognize `<schema-kw> Ident(name)` at the head
-- of a token stream and emit the (Keyword, name) pair.
--
-- Inputs:
--   head1 вҖ” should be KwClaim/KwType/KwSchema/KwFsm for ok=true.
--   head2 вҖ” should be Ident(_) for ok=true.
--
-- Outputs:
--   kw    вҖ” the Keyword from head1 (KKClaim placeholder if !ok).
--   name  вҖ” the Ident payload from head2 ("" if !ok).
--   ok    вҖ” both head positions matched.
--
-- The multi-tick body consumer that wraps this recognizer is a
-- later sub-step; here we only handle the two-token head shape.
claim ParseSchemaHead
    head1 вҲҲ Token
    head2 вҲҲ Token
    kw вҲҲ Keyword
    name вҲҲ String
    ok вҲҲ Bool

    kw_ok вҲҲ Bool
    KeywordOfTok(t вҶҰ head1, kw вҶҰ kw, ok вҶҰ kw_ok)

    is_id вҲҲ Bool
    IsIdent(t вҶҰ head2, out вҶҰ is_id)
    ident_name вҲҲ String
    IdentName(t вҶҰ head2, name вҶҰ ident_name)

    ok = (kw_ok вҲ§ is_id)
    name = (ok ? ident_name : "")

-- в”Җв”Җ Membership body-item parser (B4) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--
-- Recognize the head sequence `Ident(name) вҲҲ <TypeRef tokensвҖҰ>` and
-- emit a BIMembership(name, TName(type_str)). The TypeRef string is
-- accumulated by the caller's consumer FSM (Pattern 2 in
-- docs/plans/NEXT.md) using the B3 TypeTokenText helper.
--
-- This recognizer fires when:
--   head1 is Ident(_)
--   head2 is OpIn (`вҲҲ`)
--   type_str is non-empty (the FSM finished accumulating the type)
--
-- Shape mirrors ParsePassthrough: the FSM extracts the first two
-- tokens, dispatches the type-name accumulator across subsequent
-- ticks, then on the boundary token (Newline / Indent / Eof) it
-- calls ParseMembership with the captured name + accumulated type
-- string. The Rust parser's chained-membership desugaring (range
-- bounds) is folded in by the FSM as extra BIConstraint emits вҖ”
-- ParseMembership itself only handles the bare `x вҲҲ T` shape.
claim ParseMembership
    head1 вҲҲ Token
    head2 вҲҲ Token
    type_str вҲҲ String
    item вҲҲ BodyItem
    ok вҲҲ Bool

    is_id вҲҲ Bool
    IsIdent(t вҶҰ head1, out вҶҰ is_id)
    is_in вҲҲ Bool
    IsOpIn(t вҶҰ head2, out вҶҰ is_in)
    name вҲҲ String
    IdentName(t вҶҰ head1, name вҶҰ name)

    has_type вҲҲ Bool = (В¬ (type_str = ""))
    ok = (is_id вҲ§ is_in вҲ§ has_type)
    item = (ok ? BIMembership(name, TName(type_str)) : BINoItem)

-- в”Җв”Җ KwMatch recognizer в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- A separate-claim Bool-returning recognizer so the per-tick FSM in
-- the test fixture can ask "is this token a KwMatch?" the same way
-- it asks IsDotDot / IsIdent. The `matches` form is in the body
-- (not on a first-line param) to avoid the translator gap noted
-- above on TokenToOp.

claim IsKwMatch
    t вҲҲ Token
    out вҲҲ Bool
    out = (t matches KwMatch)

-- в”Җв”Җ Match-expression assembler (B9) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
-- Given a `KwMatch` head, a pre-parsed scrutinee Expr, and a
-- pre-built MatchArmList (in encounter order), assemble an EMatch.
-- Mirrors the tail of runtime/src/parser/patterns.rs::parse_match:
-- once the arms vector has at least one arm, the function returns
-- `Expr::Match(scrutinee, arms)`. The B9 acceptance demands "at
-- least 2 arms", which we surface via the `has_two_arms` Bool вҖ” the
-- caller is responsible for collecting at least two arms before
-- invoking this claim; ParseMatch then signals `ok` iff the head
-- token is right AND the arm-list has length вүҘ 2.
--
-- This recognizer mirrors ParsePassthrough's shape: it doesn't
-- consume tokens itself, it just composes pre-extracted parts.
-- The token-walking FSM lives in the test fixture (where it can
-- be inspected per-tick), the same way ParseEnum's FSM lives in
-- test_parser_enum.ev.

-- HasTwoArms: pattern-match the arm list once to check shape
-- `MACons(_, MACons(_, _))`. Used by ParseMatch to enforce the B9
-- "at least two arms" acceptance criterion without a recursive
-- length-counter (which would also tempt us to add Int arithmetic
-- inside a nested match вҖ” unnecessary for the acceptance check).

claim HasTwoArms
    arms вҲҲ MatchArmList
    out вҲҲ Bool
    rest вҲҲ MatchArmList = match arms
        MACons(_, r) вҮ’ r
        MANil вҮ’ MANil
    head_present вҲҲ Bool = (arms matches MACons(_, _))
    rest_present вҲҲ Bool = (rest matches MACons(_, _))
    out = (head_present вҲ§ rest_present)

claim ParseMatch
    head_tok вҲҲ Token
    scrutinee вҲҲ Expr
    arms вҲҲ MatchArmList
    out вҲҲ Expr
    ok вҲҲ Bool

    is_match вҲҲ Bool
    IsKwMatch(t вҶҰ head_tok, out вҶҰ is_match)

    has_two_arms вҲҲ Bool
    HasTwoArms(arms вҶҰ arms, out вҶҰ has_two_arms)

    ok = (is_match вҲ§ has_two_arms)
    out = (ok ? EMatch(scrutinee, arms) : ENoExpr)
