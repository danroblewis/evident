-- MODULE DriverExpr
-- CONSUMES: a Token stream (TokenList) + the Pratt parser stacks/depths
--           carried by the caller (PrOps op-stack, ExprList output-stack,
--           expop / pd / qd / cd / qstop). Pure: value-in, value-out.
-- PRODUCES: per token, the classification (C2TokOp t→Op, C2AtomE t→Expr),
--           the precedence row (C2Prec o→level/assoc/chain), and ONE
--           shunting-yard action (C2PrattStep): the next stacks + a
--           finished Expr when the expression closes.
-- MAINTAINS: the oracle-verified precedence ladder (⇒1 · ?:2 · ∨3 · ∧4 ·
--           chain-cmp 5 · +-6 · */7 · unary 8); right-assoc ternary;
--           comparison-chain folding to a conjunction of consecutive
--           pairs. No FSM carry of its own — these are pure helper claims.
--
-- Tokens → expression tree (precedence-climbing Pratt, incl. ternary).
-- The driver's parse FSM (driver_main, parse_mode 3) drives C2PrattStep one
-- action per tick over the shared token window; these claims are the
-- pure folding core it calls. Owns the ternary PARSE path (the C2Ite
-- handle-stack underflow bug lives downstream in the build step, not here).
-- ── Token → Op classifier (wider than parser.ev's TokenToOp) ──────
claim C2TokOp(t ∈ Token, o ∈ Op, rec ∈ Bool)
    is_plus ∈ Bool = (t matches Plus)
    is_minus ∈ Bool = (t matches Minus)
    is_star ∈ Bool = (t matches Star)
    is_slash ∈ Bool = (t matches Slash)
    is_eq_tok ∈ Bool = (t matches Eq)
    is_lt_tok ∈ Bool = (t matches Lt)
    is_gt_tok ∈ Bool = (t matches Gt)
    is_le_tok ∈ Bool = (t matches OpLe)
    is_ge_tok ∈ Bool = (t matches OpGe)
    is_ne_tok ∈ Bool = (t matches OpNe)
    is_and_tok ∈ Bool = (t matches OpAnd)
    is_or_tok ∈ Bool = (t matches OpOr)
    is_implies_tok ∈ Bool = (t matches OpImplies)
    is_concat_tok ∈ Bool = (t matches PlusPlus)
    o = (is_plus ? OpPlus
       : is_minus ? OpSub
       : is_star ? OpMul
       : is_slash ? OpDiv
       : is_eq_tok ? OpEq
       : is_lt_tok ? OpLt
       : is_gt_tok ? OpGt
       : is_le_tok ? OpLeq
       : is_ge_tok ? OpGeq
       : is_ne_tok ? OpNeq
       : is_and_tok ? OpConj
       : is_or_tok ? OpDisj
       : is_implies_tok ? OpImpl
       : is_concat_tok ? OpConcat
       : OpPlus)
    rec = (is_plus ∨ is_minus ∨ is_star ∨ is_slash ∨ is_eq_tok
         ∨ is_lt_tok ∨ is_gt_tok ∨ is_le_tok ∨ is_ge_tok ∨ is_ne_tok
         ∨ is_and_tok ∨ is_or_tok ∨ is_implies_tok ∨ is_concat_tok)

-- ── Token → atomic Expr ───────────────────────────────────────────
claim C2AtomE(t ∈ Token, e ∈ Expr, ok ∈ Bool)
    int ∈ Bool = (t matches IntLit(_))
    is_ident  ∈ Bool = (t matches Ident(_))
    is_true  ∈ Bool = (t matches KwTrue)
    is_false  ∈ Bool = (t matches KwFalse)
    is_string_lit  ∈ Bool = (t matches StringLit(_))
    is_float_lit  ∈ Bool = (t matches FloatLit(_, _, _))
    int_value ∈ Int = match t
        IntLit(n) ⇒ n
        _ ⇒ 0
    ident_name ∈ String = match t
        Ident(s) ⇒ s
        _ ⇒ ""
    string_value ∈ String = match t
        StringLit(s) ⇒ s
        _ ⇒ ""
    whole_part ∈ Int = match t
        FloatLit(w, _, _) ⇒ w
        _ ⇒ 0
    fraction_part ∈ Int = match t
        FloatLit(_, f, _) ⇒ f
        _ ⇒ 0
    e = (int ? EInt(int_value)
       : is_ident ? EIdent(ident_name)
       : is_true ? EIdent("true")
       : is_false ? EIdent("false")
       : is_string_lit ? EStr(string_value)
       : is_float_lit ? ECall2("__real", EInt(whole_part), EInt(fraction_part))
       : ENoExpr)
    ok = (int ∨ is_ident ∨ is_true ∨ is_false ∨ is_string_lit ∨ is_float_lit)

-- ── Operator precedence (oracle-verified ladder, P3c) ─────────────
-- Probed empirically against the frozen bootstrap oracle:
--   ⇒ 1 (right-assoc) · ?: 2 (right) · ∨ 3 · ∧ 4 ·
--   chain ops < > ≤ ≥ = ≠ all at 5 (a run of them lowers to a
--   conjunction of consecutive pairs: `flag = x < 5` →
--   (and (= flag x) (< x 5)), `0 < x < 5` → (and (< 0 x) (< x 5)))
--   · + - 6 · * / 7 · unary ¬ 8.
-- NOTE: CLAUDE.md's footgun section claims ⇒ binds TIGHTER than ∧;
-- the oracle disagrees (`a ∧ b ⇒ c` → (=> (and a b) c),
-- `a ⇒ b ∧ c` → (=> a (and b c))). The oracle is the reference
-- semantics; the divergence is pinned in
-- docs/plans/compiler2-driver-notes.md.
claim C2Prec(o ∈ Op, n ∈ Int, right ∈ Bool, chain ∈ Bool)
    is_implies ∈ Bool = (o matches OpImpl)
    is_disj ∈ Bool = (o matches OpDisj)
    is_conj ∈ Bool = (o matches OpConj)
    is_lt ∈ Bool = (o matches OpLt)
    is_gt ∈ Bool = (o matches OpGt)
    is_le ∈ Bool = (o matches OpLeq)
    is_ge ∈ Bool = (o matches OpGeq)
    is_ne ∈ Bool = (o matches OpNeq)
    is_eq ∈ Bool = (o matches OpEq)
    is_add ∈ Bool = (o matches OpPlus)
    is_sub ∈ Bool = (o matches OpSub)
    is_mul ∈ Bool = (o matches OpMul)
    is_div ∈ Bool = (o matches OpDiv)
    is_concat ∈ Bool = (o matches OpConcat)
    chain = (is_lt ∨ is_gt ∨ is_le ∨ is_ge ∨ is_ne ∨ is_eq)
    n = (is_implies ? 1
       : is_disj ? 3
       : is_conj ? 4
       : chain ? 5
       : (is_add ∨ is_sub ∨ is_concat) ? 6
       : (is_mul ∨ is_div) ? 7
       : 0)
    right = is_implies

-- Pratt operator stack. PrLP/PrQuest/PrCall/PrIdx are floor markers:
-- never auto-reduced, prec -1. PrCall's Int payload is the COMMA count
-- so far, NOT argc — argc at close is k+1 (no zero-arg calls exist).
-- `[` bumps pd like `(`, so `]` can never terminate the expression
-- while a PrIdx floor is open.
enum PrOp =
    PrBin(Op)
    PrLP
    PrQuest
    PrTern
    PrNot
    PrHash
    PrCall(String, Int)
    PrIdx
    PrNone

enum PrOps =
    PrNil
    PrCons(PrOp, PrOps)

-- ── Pratt parser step (shunting-yard; ONE action per invocation) ──
-- State in: (toks, outs, ops, expop, pd, qd, cd); state out: the n*
-- mirrors. Each call performs exactly one action:
--   shift   — consume an atom / `(` / `¬` / `#` / binary op / `?`,
--             or an Ident + `(` CALL HEAD (the only 2-token action;
--             scons = 2) pushing the PrCall floor
--   reduce  — pop the top operator, apply it to the operand stack
--   close   — consume `)` matching the PrLP at top (pd > 0), or the
--             PrCall at top (build ECall1/2/3 from the top k+1
--             operands)
--   bump    — consume `,` over a PrCall top: arg count + 1 (a `,`
--             below a non-floor top reduces first, like `)`)
--   swap    — consume `:`, arm the pending PrQuest into PrTern
--   done    — head token can't extend the expression and the op
--             stack is empty; sres = the single operand left
-- expop: true when the next token must START an operand. pd / qd /
-- cd: open-paren, pending-`?` and open-call depths — they decide
-- whether `)` / `:` / `,` continue the expression or terminate it
-- (the driver's expression contexts end at the first token that
-- can't continue: the next body line's head, the effects literal's
-- `,` / `) ⟩`, EOF — a call's `(` bumps pd too, so its `)` never
-- terminates; a `,` only continues when cd > 0).
-- A token that can't start an operand while expop holds is a
-- malformed line: done fires with sres = ENoExpr.
-- qstop (D2): when set, a `?` at top level (pd = 0, qd = 0) in
-- operator position TERMINATES the expression instead of arming a
-- ternary — the conditional-effects chain walk parses its branch
-- GUARDS this way (the `?` belongs to the chain, not the guard).
claim C2PrattStep(toks ∈ TokenList, outs ∈ ExprList, ops ∈ PrOps,
        expop ∈ Bool, pd ∈ Int, qd ∈ Int, cd ∈ Int, qstop ∈ Bool,
        calls ∈ String,
        ntoks ∈ TokenList, nouts ∈ ExprList, nops ∈ PrOps,
        nexpop ∈ Bool, npd ∈ Int, nqd ∈ Int, ncd ∈ Int,
        sdone ∈ Bool, sres ∈ Expr, scons ∈ Int)
    head_token ∈ Token = match toks
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    rest_tokens ∈ TokenList = match toks
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    next1 ∈ Token = match rest_tokens
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    rest2 ∈ TokenList = match rest_tokens
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    next2 ∈ Token = match rest2
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    rest3 ∈ TokenList = match rest2
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    next3 ∈ Token = match rest3
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    rest4 ∈ TokenList = match rest3
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    next4 ∈ Token = match rest4
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    rest5 ∈ TokenList = match rest4
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    next5 ∈ Token = match rest5
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    rest6 ∈ TokenList = match rest5
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    next6 ∈ Token = match rest6
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    rest7 ∈ TokenList = match rest6
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil

    stack_top ∈ PrOp = match ops
        PrCons(o2, _) ⇒ o2
        PrNil ⇒ PrNone
    orest_tokens ∈ PrOps = match ops
        PrCons(_, r) ⇒ r
        PrNil ⇒ PrNil
    ops_nil ∈ Bool = (ops matches PrNil)

    out1 ∈ Expr = match outs
        ELCons(e1, _) ⇒ e1
        ELNil ⇒ ENoExpr
    o_t1 ∈ ExprList = match outs
        ELCons(_, r) ⇒ r
        ELNil ⇒ ELNil
    out2 ∈ Expr = match o_t1
        ELCons(e1, _) ⇒ e1
        ELNil ⇒ ENoExpr
    o_t2 ∈ ExprList = match o_t1
        ELCons(_, r) ⇒ r
        ELNil ⇒ ELNil
    out3 ∈ Expr = match o_t2
        ELCons(e1, _) ⇒ e1
        ELNil ⇒ ENoExpr
    o_t3 ∈ ExprList = match o_t2
        ELCons(_, r) ⇒ r
        ELNil ⇒ ELNil

    atom_e ∈ Expr
    head_is_atom ∈ Bool
    C2AtomE(t ↦ head_token, e ↦ atom_e, ok ↦ head_is_atom)
    bin_o ∈ Op
    bin_ok ∈ Bool
    C2TokOp(t ↦ head_token, o ↦ bin_o, rec ↦ bin_ok)
    is_q ∈ Bool = (head_token matches Question)
    is_col ∈ Bool = (head_token matches Colon)
    is_lp ∈ Bool = (head_token matches LParen)
    is_rp ∈ Bool = (head_token matches RParen)
    head_is_not ∈ Bool = (head_token matches OpNot)
    is_hash ∈ Bool = (head_token matches Hash)
    is_com ∈ Bool = (head_token matches Comma)
    is_lb ∈ Bool = (head_token matches LBracket)
    is_rb ∈ Bool = (head_token matches RBracket)
    head_name ∈ String = match head_token
        Ident(s2) ⇒ s2
        _ ⇒ ""
    next_is_lparen ∈ Bool = (next1 matches LParen)

    o1_id ∈ Bool = (out1 matches EIdent(_))
    o1_nm ∈ String = match out1
        EIdent(s6) ⇒ s6
        _ ⇒ ""
    next_name ∈ String = match next1
        Ident(s7) ⇒ s7
        _ ⇒ ""
    dotf ∈ Bool = ((¬expop) ∧ (head_token matches Dot)
        ∧ (next1 matches Ident(_)) ∧ o1_id)
    o1_some ∈ Bool = (¬(outs matches ELNil))
    dotf2 ∈ Bool = ((¬expop) ∧ (head_token matches Dot)
        ∧ (next1 matches Ident(_)) ∧ (¬o1_id) ∧ o1_some)

    is_kwm ∈ Bool = (head_token matches KwMatches)
    match_head ∈ Bool = ((¬expop) ∧ is_kwm ∧ (next1 matches Ident(_)))
    match_name ∈ String = match next1
        Ident(s3) ⇒ s3
        _ ⇒ ""
    match_lparen ∈ Bool = (next2 matches LParen)
    match_pat1 ∈ Bool = (match_lparen ∧ (next3 matches Ident(_))
        ∧ (next4 matches RParen))
    match_pat2 ∈ Bool = (match_lparen ∧ (next3 matches Ident(_))
        ∧ (next4 matches Comma) ∧ (next5 matches Ident(_))
        ∧ (next6 matches RParen))
    is_match ∈ Bool = (match_head ∧ ((¬match_lparen) ∨ match_pat1 ∨ match_pat2))
    mt_cons ∈ Int = (match_pat2 ? 7 : match_pat1 ? 5 : 2)

    in_p0 ∈ Int
    in_r0 ∈ Bool
    in_ch0 ∈ Bool
    C2Prec(o ↦ bin_o, n ↦ in_p0, right ↦ in_r0, chain ↦ in_ch0)
    in_p ∈ Int = (is_q ? 2 : in_p0)
    in_right ∈ Bool = (is_q ? true : in_r0)

    top_op ∈ Op = match stack_top
        PrBin(o2) ⇒ o2
        _ ⇒ OpPlus
    top_bin ∈ Bool = (stack_top matches PrBin(_))
    top_not ∈ Bool = (stack_top matches PrNot)
    top_hash ∈ Bool = (stack_top matches PrHash)
    top_tern ∈ Bool = (stack_top matches PrTern)
    top_quest ∈ Bool = (stack_top matches PrQuest)
    top_lp ∈ Bool = (stack_top matches PrLP)
    top_call ∈ Bool = (stack_top matches PrCall(_, _))
    top_idx ∈ Bool = (stack_top matches PrIdx)
    top_call_name ∈ String = match stack_top
        PrCall(n2, _) ⇒ n2
        _ ⇒ ""
    top_call_argn ∈ Int = match stack_top
        PrCall(_, k2) ⇒ k2
        _ ⇒ 0
    top_precedence ∈ Int
    top_right_assoc ∈ Bool
    top_chain ∈ Bool
    C2Prec(o ↦ top_op, n ↦ top_precedence, right ↦ top_right_assoc, chain ↦ top_chain)
    top_p ∈ Int = (top_bin ? top_precedence
        : (top_not ∨ top_hash) ? 8
        : top_tern ? 2
        : 0 - 1)
    top_red ∈ Bool = (top_bin ∨ top_not ∨ top_tern ∨ top_hash)

    -- chain-comparison lowering parts (lhs = out2 when reducing a
    -- PrBin whose op is a chain op): a chain-shaped lhs turns
    -- `l op r` into (and l (op middle r)), duplicating the shared
    -- middle operand — same lowering the oracle performs.
    l_op ∈ Op
    left_lhs ∈ Expr
    left_rhs ∈ Expr
    l_bin ∈ Bool
    BoolExprBinopParts(e ↦ out2, op ↦ l_op, lhs ↦ left_lhs,
        rhs ↦ left_rhs, is_binop ↦ l_bin)
    left_precedence ∈ Int
    left_right_assoc ∈ Bool
    l_chain ∈ Bool
    C2Prec(o ↦ l_op, n ↦ left_precedence, right ↦ left_right_assoc, chain ↦ l_chain)
    l_conj ∈ Bool = (l_op matches OpConj)
    lr_op ∈ Op
    leftright_lhs ∈ Expr
    leftright_rhs ∈ Expr
    lr_bin ∈ Bool
    BoolExprBinopParts(e ↦ left_rhs, op ↦ lr_op, lhs ↦ leftright_lhs,
        rhs ↦ leftright_rhs, is_binop ↦ lr_bin)
    leftright_precedence ∈ Int
    leftright_right_assoc ∈ Bool
    lr_chain ∈ Bool
    C2Prec(o ↦ lr_op, n ↦ leftright_precedence, right ↦ leftright_right_assoc, chain ↦ lr_chain)
    chain1 ∈ Bool = (top_chain ∧ l_bin ∧ l_chain)
    chain2 ∈ Bool = (top_chain ∧ l_bin ∧ l_conj
        ∧ lr_bin ∧ lr_chain)
    apply_bin ∈ Expr = (chain1
            ? EBinOp(OpConj, out2, EBinOp(top_op, left_rhs, out1))
        : chain2
            ? EBinOp(OpConj, out2, EBinOp(top_op, leftright_rhs, out1))
        : EBinOp(top_op, out2, out1))

    call_key ∈ String
    FtiNameEntry(name ↦ head_name, entry ↦ call_key)
    call_ok ∈ Bool = (index_of(calls, call_key, 0) ≥ 0)
    call_shift ∈ Bool = (expop ∧ (head_token matches Ident(_)) ∧ next_is_lparen
        ∧ call_ok)
    atom_shift ∈ Bool = (expop ∧ head_is_atom ∧ (¬call_shift))
    shift_lparen ∈ Bool = (expop ∧ is_lp)
    not_shift ∈ Bool = (expop ∧ head_is_not)
    hash_shift ∈ Bool = (expop ∧ is_hash)
    syntax_error ∈ Bool = (expop ∧ (¬head_is_atom) ∧ (¬is_lp) ∧ (¬head_is_not)
        ∧ (¬is_hash))

    quant_stop ∈ Bool = (qstop ∧ is_q ∧ (pd = 0) ∧ (qd = 0))
    cont ∈ Bool = (bin_ok ∨ (is_q ∧ (¬quant_stop)) ∨ is_lb
        ∨ is_match ∨ dotf ∨ dotf2
        ∨ (is_col ∧ (qd > 0)) ∨ (is_rp ∧ (pd > 0))
        ∨ (is_rb ∧ (pd > 0))
        ∨ (is_com ∧ (cd > 0)))
    arr ∈ Bool = ((¬expop) ∧ (bin_ok ∨ (is_q ∧ (¬quant_stop))))
    arr_red ∈ Bool = (arr ∧ top_red
        ∧ (in_right ? top_p > in_p : top_p ≥ in_p))
    arr_shift ∈ Bool = (arr ∧ (¬arr_red))
    col ∈ Bool = ((¬expop) ∧ is_col ∧ (qd > 0))
    col_swap ∈ Bool = (col ∧ top_quest)
    close_rparen ∈ Bool = ((¬expop) ∧ is_rp ∧ (pd > 0))
    rp_close ∈ Bool = (close_rparen ∧ top_lp)
    rp_call ∈ Bool = (close_rparen ∧ top_call)
    index_shift ∈ Bool = ((¬expop) ∧ is_lb)
    close_rbracket ∈ Bool = ((¬expop) ∧ is_rb ∧ (pd > 0))
    rb_close ∈ Bool = (close_rbracket ∧ top_idx)
    com ∈ Bool = ((¬expop) ∧ is_com ∧ (cd > 0))
    com_bump ∈ Bool = (com ∧ top_call)
    expr_end ∈ Bool = ((¬expop) ∧ (¬cont))
    need_red ∈ Bool = ((col ∧ (¬col_swap))
        ∨ (close_rparen ∧ (¬rp_close) ∧ (¬rp_call))
        ∨ (close_rbracket ∧ (¬rb_close))
        ∨ (com ∧ (¬com_bump))
        ∨ (expr_end ∧ (¬ops_nil))
        ∨ arr_red)
    reduce ∈ Bool = (need_red ∧ top_red)
    discard ∈ Bool = (need_red ∧ (¬top_red))

    sdone = (syntax_error ∨ (expr_end ∧ ops_nil))
    sres = (syntax_error ? ENoExpr : out1)

    consume_token ∈ Bool = (atom_shift ∨ shift_lparen ∨ not_shift ∨ hash_shift
        ∨ arr_shift ∨ col_swap ∨ rp_close ∨ rp_call
        ∨ com_bump ∨ index_shift ∨ rb_close)
    scons = (call_shift ? 2
        : is_match ? mt_cons
        : (dotf ∨ dotf2) ? 2
        : consume_token ? 1 : 0)
    ntoks = (call_shift ? rest2
        : is_match ? (match_pat2 ? rest7 : match_pat1 ? rest5 : rest2)
        : (dotf ∨ dotf2) ? rest2
        : consume_token ? rest_tokens : toks)

    call_arg_count ∈ Int = top_call_argn + 1
    call_e ∈ Expr = (call_arg_count = 1 ? ECall1(top_call_name, out1)
        : call_arg_count = 2 ? ECall2(top_call_name, out2, out1)
        : ECall3(top_call_name, out3, out2, out1))
    call_base ∈ ExprList = (call_arg_count = 1 ? o_t1
        : call_arg_count = 2 ? o_t2
        : o_t3)

    red_e ∈ Expr = (top_not ? ENot(out1)
        : top_hash ? ECall1("str_len", out1)
        : top_tern ? ETernary(out3, out2, out1)
        : apply_bin)
    red_base ∈ ExprList = ((top_not ∨ top_hash) ? o_t1
        : top_tern ? o_t3
        : o_t2)
    idx_e ∈ Expr = ECall2("__index", out2, out1)
    nouts = (atom_shift ? ELCons(atom_e, outs)
        : reduce ? ELCons(red_e, red_base)
        : rp_call ? ELCons(call_e, call_base)
        : rb_close ? ELCons(idx_e, o_t2)
        : is_match ? ELCons(EMatches(match_name, out1), o_t1)
        : dotf ? ELCons(EIdent(o1_nm ++ "." ++ next_name), o_t1)
        : dotf2 ? ELCons(ECall2("__field", out1, EIdent(next_name)), o_t1)
        : outs)

    push ∈ PrOp = (is_q ? PrQuest : PrBin(bin_o))
    nops = (shift_lparen ? PrCons(PrLP, ops)
        : not_shift ? PrCons(PrNot, ops)
        : hash_shift ? PrCons(PrHash, ops)
        : call_shift ? PrCons(PrCall(head_name, 0), ops)
        : index_shift ? PrCons(PrIdx, ops)
        : arr_shift ? PrCons(push, ops)
        : col_swap ? PrCons(PrTern, orest_tokens)
        : com_bump ? PrCons(PrCall(top_call_name, top_call_argn + 1), orest_tokens)
        : (rp_close ∨ rp_call ∨ rb_close ∨ reduce
            ∨ discard) ? orest_tokens
        : ops)

    nexpop = (atom_shift ? false
        : (rp_close ∨ rp_call ∨ rb_close) ? false
        : (arr_shift ∨ col_swap ∨ shift_lparen ∨ not_shift
            ∨ hash_shift ∨ call_shift ∨ com_bump ∨ index_shift) ? true
        : expop)

    npd = ((shift_lparen ∨ call_shift ∨ index_shift) ? pd + 1
        : (rp_close ∨ rp_call ∨ rb_close) ? pd - 1
        : pd)
    nqd = ((arr_shift ∧ is_q) ? qd + 1 : col_swap ? qd - 1 : qd)
    ncd = (call_shift ? cd + 1 : rp_call ? cd - 1 : cd)
