-- compiler2/translate2_ctor.ev — P2: enum/datatype declaration + constructor
-- application as Z3-AST-building per-STEP claims.
--
-- ── Architecture (the compiler2 convention) ─────────────────────────────
--
-- Each claim binds parsed enum data (parser.ev's EnumDeclAst /
-- EnumVariantDecl / EVFieldList) to ONE Z3-builder LibCall — the `eff`
-- for one FSM tick. The DRIVER owns the walking strategy: it sequences
-- these steps one libcall per tick (every libcall's return lands in
-- `last_results` on the NEXT tick), captures handles into Int state,
-- and threads them into the next step. Same separation as
-- compiler/translate_arith.ev's BuildZ3 claims; same proven C-API
-- sequence as tests/kernel/z3_datatypes/sugar_datatypes.ev:
--
--   mk_string_symbol (per variant: name + recognizer + one per field)
--     → mk_constructor (per variant, with field arrays)
--     → mk_constructor_list (per enum)
--     → mk_datatypes (out-array harvested with __mem.read_long)
--     → query_constructor (per variant: ctor decl / tester / accessors)
--     → mk_app (apply the harvested decls)
--
-- ── Why the legacy Exit(3+4) bug class disappears BY CONSTRUCTION ──────
--
-- The legacy pass (compiler/translate_ctor.ev) rendered constructor
-- application as TEXT via depth-unrolled RenderExprL0/L1/L2/L3: each
-- level only recognised children one level shallower, so a compound
-- argument below the unroll floor — `Exit(3 + 4)`, an arith binop where
-- L0 expects an atom — silently rendered as the empty string and the
-- constraint dropped (`(assert (= eff ))`). Here a constructor argument
-- is a Z3_ast HANDLE (an Int). Whatever pass built that node — arith,
-- bool, a nested ctor app, a quantifier — its handle is the same i64,
-- and CtorAppStep neither knows nor cares how deep the tree behind it
-- is. There is no renderer to be incomplete: compound args come free.
--
-- ── Recursive / mutually-recursive enums: sort_refs mechanics ──────────
--
-- Z3_mk_constructor takes parallel field arrays: field_names[] and
-- sorts[] (8-byte handle slots), and sort_refs[] (4-byte unsigneds).
-- A field whose type is one of the datatypes being declared in the SAME
-- Z3_mk_datatypes call gets sorts[i] = 0 and sort_refs[i] = the index
-- of that datatype in the call's sort list. Single recursion
-- (enum LL = Nil | Cons(Int, LL)) is the one-sort case: the LL field
-- gets sorts[1] = 0, sort_refs[1] = 0. Mutual recursion
-- (enum A = X(B) ; enum B = Y(A)) is the same mechanism with n_sorts =
-- 2 and cross-indices: A's B-field gets ref 1, B's A-field gets ref 0.
--
-- WIDTH CAVEAT (from stdlib/z3_datatypes.ev): sort_refs[] slots are
-- 4 bytes, but __mem only has write_long (8 bytes). One write_long at
-- refs_p + 8*j covers unsigned slots 2j and 2j+1, so for ≥ 2 fields the
-- driver packs TWO refs per write: SortRefsPack2(lo, hi) = lo + hi·2³².
-- For a single-field constructor write_long(refs_p, ref) is exactly
-- right. field_names[] / sorts[] are unaffected (pointer-wide).
--
-- ── The Effect enum is just a datatype at this layer ───────────────────
--
-- The kernel manifest's effect-enum (ReadLine / ReadFile / WriteFile /
-- LibCall / Exit) has no special status here: EffectEnumDecl below is
-- its parsed EnumDeclAst, and the driver declares it through the same
-- step claims as any user enum. `Exit(code)` in a user program is
-- CtorAppStep on the harvested Exit decl with a code HANDLE — which,
-- per the section above, may be any built node (Exit(3 + 4) included).
--
-- Field-sort resolution scope: FieldSortSlot maps primitive field types
-- (Int / Bool / String) to driver-cached sort handles and self-references
-- to (0, ref). Non-primitive non-self field types (another enum, a Seq
-- sort — e.g. LibCall's Seq(LibArg)) resolve through the DRIVER's sort
-- registry; that registry is P3 wiring, not per-step shape, so it lives
-- with the driver.

import "compiler/parser.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_core.ev"
import "stdlib/z3_datatypes.ev"

-- ── Parsed-data peel claims (driver iteration) ──────────────────────────

-- EnumVariantListOf: project the variant list out of an EnumDeclAst.
claim EnumVariantListOf(decl ∈ EnumDeclAst, vs ∈ EnumVariantList)
    vs = match decl
        EnumD(_, l) ⇒ l
        ENoEnum ⇒ EVNil

-- EnumVariantsHead: one-step peel of the variant list. The driver walks
-- the enum's variants one per FSM round with this.
claim EnumVariantsHead(vs ∈ EnumVariantList, v ∈ EnumVariantDecl, rest ∈ EnumVariantList, nonempty ∈ Bool)
    nonempty = (vs matches EVCons(_, _))
    v = match vs
        EVCons(h, _) ⇒ h
        EVNil ⇒ EVNoVariant
    rest = match vs
        EVCons(_, t) ⇒ t
        EVNil ⇒ EVNil

-- VariantFieldsHead: one-step peel of a payload field list.
claim VariantFieldsHead(fs ∈ EVFieldList, ty ∈ String, rest ∈ EVFieldList, nonempty ∈ Bool)
    nonempty = (fs matches EVFCons(_, _))
    vfh_f ∈ EVField = match fs
        EVFCons(h, _) ⇒ h
        EVFNil ⇒ EVFNone
    ty = match vfh_f
        EVFType(s) ⇒ s
        EVFNone ⇒ ""
    rest = match fs
        EVFCons(_, t) ⇒ t
        EVFNil ⇒ EVFNil

-- VariantFieldCount: payload arity, bounded ≤ 3 (the corpus arity —
-- same bound as the legacy VariantText; a wider variant is a driver
-- walk over VariantFieldsHead).
claim VariantFieldCount(v ∈ EnumVariantDecl, n ∈ Int)
    vfc_fs ∈ EVFieldList = match v
        EVDeclP(_, fs) ⇒ fs
        _ ⇒ EVFNil
    vfc_r1 ∈ EVFieldList = match vfc_fs
        EVFCons(_, r) ⇒ r
        EVFNil ⇒ EVFNil
    vfc_r2 ∈ EVFieldList = match vfc_r1
        EVFCons(_, r) ⇒ r
        EVFNil ⇒ EVFNil
    vfc_has0 ∈ Bool = (vfc_fs matches EVFCons(_, _))
    vfc_has1 ∈ Bool = (vfc_r1 matches EVFCons(_, _))
    vfc_has2 ∈ Bool = (vfc_r2 matches EVFCons(_, _))
    n = (¬vfc_has0 ? 0 : ¬vfc_has1 ? 1 : ¬vfc_has2 ? 2 : 3)

-- VariantFieldType: the type-name string of payload field `idx` (0-2);
-- "" past the end.
claim VariantFieldType(v ∈ EnumVariantDecl, idx ∈ Int, ty ∈ String)
    vft_fs ∈ EVFieldList = match v
        EVDeclP(_, fs) ⇒ fs
        _ ⇒ EVFNil
    vft_r1 ∈ EVFieldList = match vft_fs
        EVFCons(_, r) ⇒ r
        EVFNil ⇒ EVFNil
    vft_r2 ∈ EVFieldList = match vft_r1
        EVFCons(_, r) ⇒ r
        EVFNil ⇒ EVFNil
    vft_pick ∈ EVFieldList = (idx = 0 ? vft_fs : idx = 1 ? vft_r1 : vft_r2)
    vft_f ∈ EVField = match vft_pick
        EVFCons(h, _) ⇒ h
        EVFNil ⇒ EVFNone
    ty = match vft_f
        EVFType(s) ⇒ s
        EVFNone ⇒ ""

-- ── (a) Enum declaration steps ──────────────────────────────────────────

-- EnumSortSymStep: mk_string_symbol for the enum's sort name. One per
-- enum, fed to mk_datatypes' sort_names[] IN-array.
claim EnumSortSymStep(ctx_h ∈ Int, decl ∈ EnumDeclAst, eff ∈ Effect)
    ess_name ∈ String = match decl
        EnumD(n, _) ⇒ n
        ENoEnum ⇒ ""
    BuildZ3MkStringSymbol(ctx_h ↦ ctx_h, name ↦ ess_name, eff ↦ eff)

-- VariantNameSymStep: mk_string_symbol for one variant's constructor
-- name.
claim VariantNameSymStep(ctx_h ∈ Int, v ∈ EnumVariantDecl, eff ∈ Effect)
    vns_name ∈ String = match v
        EVDecl(n) ⇒ n
        EVDeclP(n, _) ⇒ n
        EVNoVariant ⇒ ""
    BuildZ3MkStringSymbol(ctx_h ↦ ctx_h, name ↦ vns_name, eff ↦ eff)

-- VariantRecognizerSymStep: mk_string_symbol for the variant's tester,
-- named `is_<Variant>` (the spelling sugar_datatypes proved).
claim VariantRecognizerSymStep(ctx_h ∈ Int, v ∈ EnumVariantDecl, eff ∈ Effect)
    vrs_name ∈ String = match v
        EVDecl(n) ⇒ n
        EVDeclP(n, _) ⇒ n
        EVNoVariant ⇒ ""
    vrs_recog ∈ String = "is_" ++ vrs_name
    BuildZ3MkStringSymbol(ctx_h ↦ ctx_h, name ↦ vrs_recog, eff ↦ eff)

-- VariantFieldSymStep: mk_string_symbol for payload field `idx`'s
-- accessor, named `<Variant>__f<idx>` — the language's auto-accessor
-- convention (CLAUDE.md "Enums"), same as the legacy VariantText.
claim VariantFieldSymStep(ctx_h ∈ Int, v ∈ EnumVariantDecl, idx ∈ Int, eff ∈ Effect)
    vfs_name ∈ String = match v
        EVDecl(n) ⇒ n
        EVDeclP(n, _) ⇒ n
        EVNoVariant ⇒ ""
    vfs_acc ∈ String = vfs_name ++ "__f" ++ str_from_int(idx)
    BuildZ3MkStringSymbol(ctx_h ↦ ctx_h, name ↦ vfs_acc, eff ↦ eff)

-- FieldSortSlot: resolve one payload field's (sorts[i], sort_refs[i])
-- pair. Self-reference (ty = the enum being declared) → (0, self_sort_idx)
-- per the sort_refs mechanics in the header; primitives map to the
-- driver's cached sort handles with ref 0 (ignored by Z3 when
-- sorts[i] ≠ 0). Unknown types also yield (0, self_sort_idx ⊥ 0) only
-- when self — otherwise (0, 0) with is_self false, which the driver
-- must resolve from its own sort registry before writing the slot.
claim FieldSortSlot(
        enum_name ∈ String, ty ∈ String,
        int_sort_h ∈ Int, bool_sort_h ∈ Int, string_sort_h ∈ Int,
        self_sort_idx ∈ Int,
        sort_slot ∈ Int, ref_slot ∈ Int, is_self ∈ Bool)
    is_self = (ty = enum_name)
    sort_slot = (is_self ? 0
        : ty = "Int" ? int_sort_h
        : ty = "Nat" ? int_sort_h
        : ty = "Bool" ? bool_sort_h
        : ty = "String" ? string_sort_h
        : 0)
    ref_slot = (is_self ? self_sort_idx : 0)

-- SortRefsPack2: pack two 4-byte sort_refs into one write_long payload
-- (the width caveat — see header). write_long(refs_p + 8*j, packed)
-- fills unsigned slots 2j (ref_lo) and 2j+1 (ref_hi).
claim SortRefsPack2(ref_lo ∈ Int, ref_hi ∈ Int, packed ∈ Int)
    packed = ref_lo + ref_hi * 4294967296

-- VariantMkConstructorStep: the Z3_mk_constructor call for one variant.
-- Field arity comes from the parsed variant itself; for a nullary
-- variant the three array pointers are forced to 0 (the C API's null
-- contract, proven by sugar_datatypes phase 10), so the driver may pass
-- its arena pointers unconditionally.
-- The driver must have populated, on PRIOR ticks:
--   fnames_p — n write_long slots, each a VariantFieldSymStep handle
--   fsorts_p — n write_long slots, each a FieldSortSlot sort_slot
--   srefs_p  — ⌈n/2⌉ write_long slots of SortRefsPack2 payloads
--              (single-field: one write_long of the bare ref)
claim VariantMkConstructorStep(
        ctx_h ∈ Int, v ∈ EnumVariantDecl,
        name_sym_h ∈ Int, recog_sym_h ∈ Int,
        fnames_p ∈ Int, fsorts_p ∈ Int, srefs_p ∈ Int,
        eff ∈ Effect)
    vmc_n ∈ Int
    VariantFieldCount(v ↦ v, n ↦ vmc_n)
    vmc_nullary ∈ Bool = (vmc_n = 0)
    vmc_fn ∈ Int = (vmc_nullary ? 0 : fnames_p)
    vmc_fs ∈ Int = (vmc_nullary ? 0 : fsorts_p)
    vmc_sr ∈ Int = (vmc_nullary ? 0 : srefs_p)
    BuildZ3MkConstructor(ctx_h ↦ ctx_h, name_sym_h ↦ name_sym_h,
        recognizer_sym_h ↦ recog_sym_h, n_fields ↦ vmc_n,
        field_names_arr_p ↦ vmc_fn, field_sorts_arr_p ↦ vmc_fs,
        sort_refs_arr_p ↦ vmc_sr, eff ↦ eff)

-- Per-enum list / datatype-creation / harvest steps are the stdlib
-- claims directly — no enum-AST data to bind, so no wrapper here:
--   BuildZ3MkConstructorList(ctx, n_ctors, ctors_p)   one per enum
--   BuildZ3MkDatatypes(ctx, n_sorts, names_p, sorts_out_p, clists_p)
--   BuildMemReadLong(sorts_out_p + 8*i)               harvest each sort
-- (mutually-recursive enums = ONE BuildZ3MkDatatypes call with
-- n_sorts > 1; the cross-references are sort_refs indices, above).

-- VariantQueryStep: Z3_query_constructor for one variant after its
-- container went through mk_datatypes. The driver allocates one
-- out-block of 16 + 8·n_fields bytes at out_base_p:
--   ctor decl   OUT at out_base_p
--   tester decl OUT at out_base_p + 8
--   accessors   OUT-array at out_base_p + 16  (one slot per field)
-- and harvests each Z3_func_decl with BuildMemReadLong on later ticks.
claim VariantQueryStep(ctx_h ∈ Int, ctor_h ∈ Int, v ∈ EnumVariantDecl, out_base_p ∈ Int, eff ∈ Effect)
    vq_n ∈ Int
    VariantFieldCount(v ↦ v, n ↦ vq_n)
    BuildZ3QueryConstructor(ctx_h ↦ ctx_h, ctor_h ↦ ctor_h,
        n_fields ↦ vq_n, ctor_decl_out_p ↦ out_base_p,
        tester_decl_out_p ↦ out_base_p + 8,
        accessors_out_arr_p ↦ out_base_p + 16, eff ↦ eff)

-- ── (b) Constructor application steps ───────────────────────────────────

-- CtorArgWriteStep: write argument `idx`'s HANDLE into the mk_app args
-- array. arg_h is any built Z3_ast — an atom, an arith tree, a nested
-- ctor app — the depth of the tree behind the handle is invisible here
-- (the header's by-construction argument).
claim CtorArgWriteStep(args_p ∈ Int, idx ∈ Int, arg_h ∈ Int, eff ∈ Effect)
    caw_addr ∈ Int = args_p + 8 * idx
    BuildMemWriteLong(addr ↦ caw_addr, value ↦ arg_h, eff ↦ eff)

-- CtorAppStep: `Green(x)` → Z3_mk_app(green_decl, [x_h]). ctor_decl_h
-- is the decl harvested by VariantQueryStep; n_args slots at args_p
-- were written by CtorArgWriteStep on prior ticks. A nullary variant
-- value is n_args = 0 with args_p = 0. The SAME step applies a
-- harvested tester decl (1 arg → `((_ is Green) x)`) or accessor decl
-- (1 arg → field projection) — they are all just Z3_func_decls.
claim CtorAppStep(ctx_h ∈ Int, ctor_decl_h ∈ Int, n_args ∈ Int, args_p ∈ Int, eff ∈ Effect)
    BuildZ3MkApp(ctx_h ↦ ctx_h, decl_h ↦ ctor_decl_h,
        num_args ↦ n_args, args_arr_p ↦ args_p, eff ↦ eff)

-- ── (c) The Effect enum at this layer ───────────────────────────────────

-- EffectEnumDecl: the kernel's Effect-enum floor as parsed data, so the
-- driver declares it through the SAME steps as user enums. The
-- Seq(LibArg) field of LibCall resolves through the driver's sort
-- registry (see header scope note).
claim EffectEnumDecl(decl ∈ EnumDeclAst)
    decl = EnumD("Effect",
        EVCons(EVDecl("ReadLine"),
        EVCons(EVDeclP("ReadFile", EVFCons(EVFType("String"), EVFNil)),
        EVCons(EVDeclP("WriteFile",
            EVFCons(EVFType("String"), EVFCons(EVFType("String"), EVFNil))),
        EVCons(EVDeclP("LibCall",
            EVFCons(EVFType("String"), EVFCons(EVFType("String"),
                EVFCons(EVFType("Seq(LibArg)"), EVFNil)))),
        EVCons(EVDeclP("Exit", EVFCons(EVFType("Int"), EVFNil)),
        EVNil))))))

-- EffectCtorArity: payload arity of each kernel-native Effect variant —
-- the count the driver feeds to CtorAppStep when building an effects
-- value (e.g. Exit is mk_app(exit_decl, 1, [code_h])).
claim EffectCtorArity(name ∈ String, n ∈ Int, known ∈ Bool)
    eca_rl ∈ Bool = (name = "ReadLine")
    eca_rf ∈ Bool = (name = "ReadFile")
    eca_wf ∈ Bool = (name = "WriteFile")
    eca_lc ∈ Bool = (name = "LibCall")
    eca_ex ∈ Bool = (name = "Exit")
    known = (eca_rl ∨ eca_rf ∨ eca_wf ∨ eca_lc ∨ eca_ex)
    n = (eca_rl ? 0 : eca_rf ? 1 : eca_wf ? 2 : eca_lc ? 3 : eca_ex ? 1 : 0)

-- ── Probe (oracle-compile smoke; pure data, single tick) ────────────────
claim translate2_ctor_probe
    p_v ∈ EnumVariantDecl = EVDeclP("B", EVFCons(EVFType("Int"), EVFNil))
    p_n ∈ Int
    VariantFieldCount(v ↦ p_v, n ↦ p_n)
    p_ty ∈ String
    VariantFieldType(v ↦ p_v, idx ↦ 0, ty ↦ p_ty)
    p_arity ∈ Int
    p_known ∈ Bool
    EffectCtorArity(name ↦ "LibCall", n ↦ p_arity, known ↦ p_known)
    p_slot ∈ Int
    p_ref ∈ Int
    p_self ∈ Bool
    FieldSortSlot(enum_name ↦ "LL", ty ↦ "LL",
        int_sort_h ↦ 77, bool_sort_h ↦ 0, string_sort_h ↦ 0,
        self_sort_idx ↦ 0,
        sort_slot ↦ p_slot, ref_slot ↦ p_ref, is_self ↦ p_self)
    p_packed ∈ Int
    SortRefsPack2(ref_lo ↦ 1, ref_hi ↦ 2, packed ↦ p_packed)
    p_ed ∈ EnumDeclAst
    EffectEnumDecl(decl ↦ p_ed)
    p_ed_name ∈ String = match p_ed
        EnumD(n, _) ⇒ n
        ENoEnum ⇒ ""
    p_ok ∈ Bool = (p_n = 1 ∧ p_ty = "Int" ∧ p_arity = 3 ∧ p_known
        ∧ p_self ∧ p_slot = 0 ∧ p_packed = 8589934593
        ∧ p_ed_name = "Effect")
    effects ∈ Seq(Effect) = ⟨Exit(p_ok ? 0 : 1)⟩
