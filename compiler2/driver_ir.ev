-- MODULE driver_ir ‚Äî the shared C2 work-item IR vocabulary
-- The intermediate representation produced by the line classifier and
-- consumed by the work-item interpreter / dispatch: one claim-body line
-- compiles to a small C2Items program over a C2H handle stack, with
-- C2Binds/C2Frames carrying the composition-inline frame state. Hoisted
-- out of driver.ev so the extracted modules (and their isolation tests)
-- share the same IR definitions.
import "compiler/parser.ev"

-- ‚îÄ‚îÄ FTI buffers: base + write cursor + capacity travel together ‚îÄ‚îÄ‚îÄ‚îÄ
-- The recurring base+cursor+cap triple behind every FTI-resident buffer
-- (the token buffer, the symbol table, the claim index). `base` is the
-- calloc'd region start (pinned once during zinit); `count` is the
-- append cursor (carried); `cap` is the region's slot capacity (pinned).
-- The `0 ‚â§ count ‚â§ cap` invariant lifts the per-site capacity bound into
-- the type ‚Äî the cursor-in-region memory-safety contract, now checked
-- every tick for every buffer rather than ad-hoc at each use-site. Plain
-- bounds like these functionize for free (see the Z3SolverCtx note for
-- the kind of invariant this type deliberately does NOT carry).
type FtiBuffer(base ‚àà Int, count ‚àà Int, cap ‚àà Int)
    base ‚â• 0           -- a calloc'd region start, never negative
    cap  ‚â• 0           -- the region holds `cap` slots
    0 ‚â§ count ‚â§ cap    -- the write cursor never passes the last slot;
                       -- an overrun makes the tick UNSAT, halting the
                       -- kernel instead of writing out of region

-- ‚îÄ‚îÄ Named FTI buffer append: cursor + parallel name registry ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
-- The shared "append a named row" step behind every FTI buffer that
-- keeps a companion name string (the symbol table's `st_names`, the
-- claim index's `ci_names`): on the `add` gate, the cursor climbs by 1
-- and `entry` is concatenated onto the names registry; off the gate
-- both hold; on the first tick both seed. One tested definition instead
-- of a copy per consumer. Compose with the buffer's cursor + names as
-- outputs, e.g. `count ‚Ü¶ stbuf.count, names ‚Ü¶ st_names`.
claim FtiNamedAppend(first ‚àà Bool, add ‚àà Bool, prev_count ‚àà Int,
        prev_names ‚àà String, init_count ‚àà Int, seed_names ‚àà String,
        entry ‚àà String, count ‚àà Int, names ‚àà String)
    count = (first ? init_count : (add ? prev_count + 1 : prev_count))
    names = (first ? seed_names : (add ? prev_names ++ entry : prev_names))

-- ‚îÄ‚îÄ FTI name-registry entry: a fixed-width 32-byte "|name<pad>" row ‚îÄ
-- Every name registry stores fixed-width rows: a "|" delimiter then the
-- name padded/truncated to 31 chars, so row N lives at a known offset.
-- The same formatter behind the symbol table's `st_entry` and the claim
-- index's `ci_entry`. Feed the resulting `entry` to FtiNamedAppend.
claim FtiNameEntry(name ‚àà String, entry ‚àà String)
    entry = "|" ++ substr(name ++ "                               ", 0, 31)

-- ‚îÄ‚îÄ Z3 solver lifecycle: the three handles created together at boot ‚îÄ
-- cfg ‚Üí ctx ‚Üí sol: the Z3 config, the context derived from it, and the
-- solver derived from the context (zinit zsteps 1/2/3). They travel as
-- one unit ‚Äî every Build*Z3 effect threads `ctx`, asserts go through
-- `sol`. Pinned once during zinit, carried thereafter.
--
-- The lifecycle invariant `sol > 0 ‚áí (ctx > 0 ‚àß cfg > 0)` binds the
-- relationship: a live solver implies a live context and config. It is
-- vacuous during boot (all 0) and enforced once the handles latch.
--
-- PERF NOTE ‚Äî the liveness test MUST be `> 0`, not `‚âÝ 0`. Disequality is
-- non-convex (Z3 reads `x ‚âÝ 0` as `x < 0 ‚à® x > 0` and case-splits), and on
-- these handles ‚Äî which the model references everywhere ‚Äî that splitting
-- compounds every tick across thousands of ticks per compile and explodes:
-- the `‚âÝ 0` form took fixture-001 from 19 s to a >30-min timeout (measured
-- 2026-06-08). The `> 0` form (handles are positive pointers) is convex,
-- stays fully functionized (0.0 ms z3), and is guarded by
-- scripts/functionization-gate.sh. The `‚áí` itself is fine; never the `‚âÝ`.
type Z3SolverCtx(cfg ‚àà Int, ctx ‚àà Int, sol ‚àà Int)
    cfg ‚â• 0
    ctx ‚â• 0
    sol ‚â• 0
    sol > 0 ‚áí (ctx > 0 ‚àß cfg > 0)

-- ‚îÄ‚îÄ Z3 base sorts: the four primitive sort handles made at boot ‚îÄ‚îÄ‚îÄ‚îÄ
-- Int / Bool / String / Real sort handles (zinit zsteps 5/6/7/8). Every
-- type-directed Build*Z3 step picks one of these by the field/atom type
-- string. Pinned once during zinit, carried thereafter, and (like the
-- solver triple) driven every tick so all four stay live.
type Z3Sorts(isort ‚àà Int, bsort ‚àà Int, ssort ‚àà Int, rsort ‚àà Int)
    isort ‚â• 0
    bsort ‚â• 0
    ssort ‚â• 0
    rsort ‚â• 0
    -- rsort latches last of the four, so a live rsort implies the rest
    -- are live (convex `> 0` test ‚Äî see the Z3SolverCtx perf note).
    rsort > 0 ‚áí (isort > 0 ‚àß bsort > 0 ‚àß ssort > 0)

-- ‚îÄ‚îÄ Z3 numeral cache: the small int constants 0..4 made once at boot ‚îÄ
-- effects-array indices and lengths only ever need 0..4, so zinit makes
-- those five Z3 int-numeral handles once (zsteps 16/17/18/33/34) instead
-- of re-minting them per use. Pinned once, carried, driven every tick.
type Z3Numerals(zero ‚àà Int, one ‚àà Int, two ‚àà Int, three ‚àà Int, four ‚àà Int)
    zero  ‚â• 0
    one   ‚â• 0
    two   ‚â• 0
    three ‚â• 0
    four  ‚â• 0
    -- `four` is minted last, so a live `four` implies the whole cache is
    -- live (convex `> 0` test ‚Äî see the Z3SolverCtx perf note).
    four > 0 ‚áí (zero > 0 ‚àß one > 0 ‚àß two > 0 ‚àß three > 0)

-- ‚îÄ‚îÄ Record-type registry entry: one registered `type Name(...)` ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
-- One slot of the record-type registry (DriverRecord builds ‚â§3). name =
-- the type name; fnames/ftypes = the fixed-width 32-byte "|field<pad31>"
-- record strings (field names / normalized types); nf = field count;
-- sort/ctor/asort/ssort = the Z3 tuple sort + ctor decl + (Array Int T) /
-- (Set T) handles; a0..a5 = the ‚â§6 field-accessor decls. A slot whose
-- `sort` is still 0 is "not finished" and never matches a registry lookup.
type RecTypeEntry(name ‚àà String, fnames ‚àà String, ftypes ‚àà String,
    nf ‚àà Int, sort ‚àà Int, ctor ‚àà Int, asort ‚àà Int, ssort ‚àà Int,
    a0 ‚àà Int, a1 ‚àà Int, a2 ‚àà Int, a3 ‚àà Int, a4 ‚àà Int, a5 ‚àà Int)
    -- a registry slot holds 0 fields (empty) up to 6 (a0..a5 are the
    -- ‚â§6 field-accessor decls ‚Äî the registry's hard structural bound).
    0 ‚â§ nf ‚â§ 6

-- ‚îÄ‚îÄ One field of a record being lowered ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
-- A single field of a `RecTypeEntry`, decoded for the C2RecVal/C2RecDecl
-- expansion: `name` (the field name), `type` (its type string), and
-- `kidx` (the field type's slot in the record-type registry ‚Äî 0/1/2 if
-- the field is itself a record, ‚àí1 if scalar/Seq). Replaces the parallel
-- rv_f*/rv_t*/rv_k* scalar arrays with a record so the expansion reads
-- `f.name`/`f.type`/`f.kidx` instead of three coindexed lookups.
type RecField(name ‚àà String, ty ‚àà String, kidx ‚àà Int)
    -- kidx is RtIdxOf's result: a registry hit (0/1/2) or a miss (‚àí1).
    -- (`ty`, not `type`: `type` is a reserved keyword, unusable as `.type`.)
    0 - 1 ‚â§ kidx ‚â§ 2

-- ‚îÄ‚îÄ Work items: one line of claim body = one small program ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
enum C2Item =
    C2Process(Expr)
    C2Op(Op)
    C2Ite
    C2Not
    C2DeclConst(String, Int)
    C2NatBound
    C2PinEq
    C2AssertTop
    C2Drop
    C2PushH(Int)
    C2App(Int, Int)
    C2SelectEq(Int)
    C2LenEq(Int)
    C2StrOp(String, Int)
    C2SelH
    C2SelEqH(Int)
    C2LenEqH(Int)
    C2Dup3
    C2Swap
    C2Rot3
    C2BindScope(String, Int)
    C2BindEnd
    C2Real(Int, Int)
    C2MkEmptySet(Int)
    C2SetAdd
    C2RecVal(String, Int)
    C2RecDecl(String, Int)

enum C2Items =
    C2INil
    C2ICons(C2Item, C2Items)

-- Handle stack (Z3_ast handles, post-order operand order).
enum C2H =
    C2HNil
    C2HCons(Int, C2H)

-- ‚îÄ‚îÄ F2: composition-inline frames ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
-- A slot-call binding table: slot name ‚Üí the CALLER's value HANDLE
-- (built by the Pratt FSM + walker before the jump ‚Äî values may be
-- arbitrary expressions). ‚â§ 4 entries per call.
enum C2Binds =
    CBNil
    CBCons(String, Int, C2Binds)

-- The suspended-frame stack: (return cursor, saved Œ±-prefix, saved
-- binds, rest). A slot call pushes the CURRENT (pfx, binds) and
-- installs fresh ones; a bare names-match inline pushes and KEEPS
-- them (pure splice). Depth ‚â§ 8.
enum C2Frames =
    CFNil
    CFCons(Int, String, C2Binds, C2Frames)
