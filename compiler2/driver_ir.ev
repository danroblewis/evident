-- MODULE driver_ir — the shared C2 work-item IR vocabulary
-- The intermediate representation produced by the line classifier and
-- consumed by the work-item interpreter / dispatch: one claim-body line
-- compiles to a small C2Items program over a C2H handle stack, with
-- C2Binds/C2Frames carrying the composition-inline frame state. Hoisted
-- out of driver.ev so the extracted modules (and their isolation tests)
-- share the same IR definitions.
import "compiler/parser.ev"

-- ── FTI buffers: base + write cursor + capacity travel together ────
-- The base+cursor+cap triple behind every FTI-resident buffer (token
-- buffer, symbol table, claim index): `base` = calloc'd region start
-- (pinned once during zinit), `count` = append cursor (carried),
-- `cap` = slot capacity (pinned). An overrun makes the tick UNSAT —
-- the kernel halts instead of writing out of region. Plain bounds
-- functionize for free (see the Z3SolverCtx perf note).
type FtiBuffer(base ∈ Int, count ∈ Int, cap ∈ Int)
    base ≥ 0
    cap  ≥ 0
    0 ≤ count ≤ cap

-- ── Named FTI buffer append: cursor + parallel name registry ──────
-- The shared "append a named row" step behind every FTI buffer with a
-- companion name string (the symbol table's `sym_names`, the claim
-- index's `ci_names`).
claim FtiNamedAppend(first ∈ Bool, add ∈ Bool, prev_count ∈ Int,
        prev_names ∈ String, init_count ∈ Int, seed_names ∈ String,
        entry ∈ String, count ∈ Int, names ∈ String)
    count = (first ? init_count : (add ? prev_count + 1 : prev_count))
    names = (first ? seed_names : (add ? prev_names ++ entry : prev_names))

-- ── FTI name-registry entry: a fixed-width 32-byte "|name<pad>" row ─
-- Every name registry stores fixed-width rows: a "|" delimiter then the
-- name padded/truncated to 31 chars, so row N lives at a known offset.
claim FtiNameEntry(name ∈ String, entry ∈ String)
    entry = "|" ++ substr(name ++ "                               ", 0, 31)

-- ── Z3 solver lifecycle: the three handles created together at boot ─
-- cfg → ctx → sol (zinit zsteps 1/2/3). Pinned once during zinit,
-- carried thereafter; every Build*Z3 effect threads `ctx`, asserts go
-- through `sol`.
--
-- PERF NOTE — the liveness test MUST be `> 0`, not `≠ 0`. Disequality is
-- non-convex (Z3 reads `x ≠ 0` as `x < 0 ∨ x > 0` and case-splits), and on
-- these handles — which the model references everywhere — that splitting
-- compounds every tick across thousands of ticks per compile and explodes:
-- the `≠ 0` form took fixture-001 from 19 s to a >30-min timeout (measured
-- 2026-06-08). The `> 0` form (handles are positive pointers) is convex,
-- stays fully functionized (0.0 ms z3), and is guarded by
-- scripts/functionization-gate.sh. The `⇒` itself is fine; never the `≠`.
type Z3SolverCtx(cfg ∈ Int, ctx ∈ Int, sol ∈ Int)
    cfg ≥ 0
    ctx ≥ 0
    sol ≥ 0
    sol > 0 ⇒ (ctx > 0 ∧ cfg > 0)

type Z3Sorts(isort ∈ Int, bsort ∈ Int, ssort ∈ Int, rsort ∈ Int)
    isort ≥ 0
    bsort ≥ 0
    ssort ≥ 0
    rsort ≥ 0
    -- rsort latches last of the four, so a live rsort implies the rest
    -- are live (convex `> 0` test — see the Z3SolverCtx perf note).
    rsort > 0 ⇒ (isort > 0 ∧ bsort > 0 ∧ ssort > 0)

type Z3Numerals(zero ∈ Int, one ∈ Int, two ∈ Int, three ∈ Int, four ∈ Int)
    zero  ≥ 0
    one   ≥ 0
    two   ≥ 0
    three ≥ 0
    four  ≥ 0
    -- `four` is minted last, so a live `four` implies the whole cache is
    -- live (convex `> 0` test — see the Z3SolverCtx perf note).
    four > 0 ⇒ (zero > 0 ∧ one > 0 ∧ two > 0 ∧ three > 0)

-- ── Record-type registry entry: one registered `type Name(...)` ─────
-- One slot of the record-type registry (DriverRecord builds ≤3). name =
-- the type name; fnames/ftypes = the fixed-width 32-byte "|field<pad31>"
-- record strings (field names / normalized types); n_fields = field count;
-- sort/ctor/asort/ssort = the Z3 tuple sort + ctor decl + (Array Int T) /
-- (Set T) handles; acc0..acc5 = the ≤6 field-accessor decls. A slot whose
-- `sort` is still 0 is "not finished" and never matches a registry lookup.
type RecTypeEntry(name ∈ String, fnames ∈ String, ftypes ∈ String,
    n_fields ∈ Int, sort ∈ Int, ctor ∈ Int, asort ∈ Int, ssort ∈ Int,
    acc0 ∈ Int, acc1 ∈ Int, acc2 ∈ Int, acc3 ∈ Int, acc4 ∈ Int, acc5 ∈ Int)
    0 ≤ n_fields ≤ 6

type RecField(name ∈ String, ty ∈ String, kidx ∈ Int)
    -- kidx is RtIdxOf's result: a registry hit (0/1/2) or a miss (−1).
    -- (`ty`, not `type`: `type` is a reserved keyword, unusable as `.type`.)
    0 - 1 ≤ kidx ≤ 2

-- One row of the user-enum VALUE table: a nullary variant's name and
-- the Z3 handle of its constant. Used as `enum_values ∈ Seq(EnumVariantVal)` with
-- `#enum_values ≤ 6` — the bounded-Seq lowering (scripts/lower-bounded-seq.sh)
-- flattens it to scalars pre-oracle, so the oracle never sees the Seq.
type EnumVariantVal(name ∈ String, value ∈ Int)

-- One row of the user-enum DECL registry: variant name, ctor func_decl,
-- tester decl, field-0 accessor decl. `user_variants ∈ Seq(UserEnumVariant)`,
-- lowered by the bounded-Seq pass; rows are written by INDEX (the ED
-- machine's _enum_vidx / acc-pend walk), so the registry has no length.
type UserEnumVariant(name ∈ String, ctor ∈ Int, tester ∈ Int, acc ∈ Int)

-- One row of the Set(T)-variable registry: var name, the element type's
-- registry slot (kidx), the packed 32-byte-row element-name string, and
-- the element count. `stv ∈ Seq(SetVar)`; rows written by index
-- (_stv_cnt / c_stv_idx / _sv_cur), so no length.
type SetVar(name ∈ String, kidx ∈ Int, elems ∈ String, count ∈ Int)

-- ── Work items: one line of claim body = one small program ────────
enum C2Item =
    C2Process(Expr)
    C2Op(Op)
    C2Ite
    C2Not
    C2DeclConst(String, Int)
    C2NatBound
    C2PinEq
    C2AssertTop
    C2Drop
    C2PushH(Int)
    C2App(Int, Int)
    C2SelectEq(Int)
    C2LenEq(Int)
    C2StrOp(String, Int)
    C2SelH
    C2SelEqH(Int)
    C2LenEqH(Int)
    C2Dup3
    C2Swap
    C2Rot3
    C2BindScope(String, Int)
    C2BindEnd
    C2Real(Int, Int)
    C2MkEmptySet(Int)
    C2SetAdd
    C2RecVal(String, Int)
    C2RecDecl(String, Int)

enum C2Items =
    C2INil
    C2ICons(C2Item, C2Items)

enum C2H =
    C2HNil
    C2HCons(Int, C2H)

enum C2Binds =
    CBNil
    CBCons(String, Int, C2Binds)

enum C2Frames =
    CFNil
    CFCons(Int, String, C2Binds, C2Frames)
