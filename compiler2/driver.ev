-- compiler2/driver.ev — P3a: the compiler2 driver skeleton.
--
-- An Evident program that, run under the kernel, COMPILES a small .ev
-- file end-to-end by building Z3 ASTs in memory (the compiler2
-- architecture, docs/plans/z3-ast-compiler2-plan.md) instead of
-- concatenating SMT-LIB text (the fossil's approach, and the source
-- of its dropped-compound-expression bug class).
--
-- Wire protocol (wave 4o, same as compiler.smt2):
--   stdin line 1 = flattened source path, line 2 = target claim name.
--   tick 0: ReadLine ×2 · tick 1: ReadFile(path) · output: the .smt2
--   translation unit on stdout via puts, then Exit(0).
--
-- Pipeline:
--   INPUT   ticks 0-1 (fossil's wave-4o block, verbatim).
--   ZINIT   ticks 2-33: Z3 lifecycle (config/context/solver/sorts) +
--           the Effect datatype declared IN THE BUILD CONTEXT via
--           translate2_ctor.ev's step claims + the `effects` /
--           `effects__len` consts + cached 0/1 numerals + the FTI
--           token buffer (calloc'd; 32 bytes/token).
--   LEX     the fossil's per-char scanner FSM (one token per tick,
--           whitespace/comment bulk-skip) feeding compiler2/
--           lex_fti.ev's LexFtiPlan: tokens are written to the FTI
--           buffer in APPEND (source) order via __mem.write_long;
--           string payloads (Ident/StringLit) are strdup'd char*s.
--           Z3-carried lexer state = five Ints (tbase, lx_count,
--           lx_last, lx_prev, lx_pend) — no TokenList anywhere.
--           The old REVERSE pop loop is GONE (P3d): append order
--           makes it dead weight; phase goes 0 → 2 directly, after
--           flushing any pending string write + the EofTok sentinel.
--   FETCH   the parse phases read tokens through a sliding 8-token
--           decoded window (wtoks, head = token tcur). A refill is
--           a 3-tick burst: 16 __mem.read_long (8 tags + 8
--           payloads, one tick), then 8 slot-aligned __cstr.copy /
--           getpid-filler effects (string payloads), then the pure
--           rebuild. Entries past the EofTok sentinel read 0 from
--           the calloc'd region and decode to EofTok.
--   PARSE   top-level dispatch: enums and parametrized / non-target
--           claims are SKIPPED (one token per tick); the target
--           bare-head claim enters the claim walk. All consumption
--           is cursor arithmetic (tcur += k) + window tails.
--   WALK    per body line: a one-tick PURE classifier picks the line
--           kind; lines carrying an expression run the Pratt FSM
--           (pmode 3, one parser action per tick) to an Expr, which
--           becomes a work-item program (C2Items); subsequent ticks run
--           one item micro-step per tick, each step one Z3-builder
--           LibCall, dispatching per-node choices to the pass claims:
--             arith binop  → translate_arith.ev  ArithBinopBuildZ3
--             cmp/eq       → translate2_bool.ev  BoolCmpBuildZ3
--             ∧/∨ (n-ary)  → translate2_bool.ev  BoolNaryBuildZ3
--             ternary      → translate2_bool.ev  TernaryBuildZ3
--             ctor app     → translate2_ctor.ev  CtorArgWriteStep/CtorAppStep
--           Built handles live on a parallel handle stack (C2H);
--           captures follow the PROVEN discipline: a builder's result
--           is read from last_results on the NEXT tick (the `pend`
--           mechanism below) and used the same tick it lands.
--   EMIT    Z3_solver_to_string (which serializes declare-datatypes +
--           declare-funs + asserts — verified empirically) → __cstr.copy
--           → manifest header + Result/last_results textual prelude +
--           the solver body → puts → Exit(0).
--
-- Scope (P3a skeleton + P3b widening + P3c Pratt parser — enough for
-- the census arithmetic/comparison/logic/implies/ternary classes,
-- NOT the full language; see docs/plans/compiler2-driver-notes.md):
--   · scalar memberships `x ∈ Int|Nat|Bool [= pin | < bound]`
--   · GENERAL expressions everywhere an expression is parsed (pins,
--     bare `name = <expr>` lines, standalone constraint lines, the
--     effects literal's Exit argument): the P3b bounded shape
--     parsers (C2ParseExpr / C2ParseCons) are REPLACED by a Pratt /
--     shunting-yard FSM (C2PrattStep, pmode 3 — one shift or one
--     reduce per tick) with arbitrary nesting/parens, all binary
--     ops (+ - * / = < > ≤ ≥ ≠ ∧ ∨ ⇒), unary ¬, ternary ?:,
--     chained comparisons (`0 < x < 5` → conjunction; `=` is a
--     chain member, matching the legacy parser), and the
--     oracle-verified precedence ladder (see C2Prec)
--   · `true` / `false` atoms (cached Z3_mk_true/false handles)
--   · negative int literals (sign folded at lex time when the Minus
--     has no atom before it)
--   · effects literals with 1-2 elements (P3e): `⟨Exit(<expr>)⟩`,
--     `⟨LibCall("lib","fn",⟨ArgStr(<lit-or-ident>)⟩), Exit(<expr>)⟩`
--     — Exit args go through the Pratt FSM; LibCall elements parse
--     as a fixed two-bite shape (pmode 5 element walk)
--   · OpNeq lowers as mk_eq + mk_not (C2Not item); ENot likewise
--   · the build-context Effect floor is FULL (P3e): LibArg,
--     __SeqOf_LibArg, and all five Effect variants are declared by
--     the ED machine (translate2_ctor.ev's step claims) at ZINIT
--   · USER ENUMS (P3e): one nullary-variant enum per compile
--     (`enum Color = Red | Green | Blue`) — declared in the build
--     context via the same ED machine at parse time; variant values
--     resolve in expressions; enum-typed memberships declare consts
--     of the enum sort and land in the manifest as `name:Enum`
--   · String memberships/pins, string literals, `++` (str.++)
--   · symbol table: 8 fixed slots; enum-value table: 6
--   · no `_<name>` carry-over decls in the emitted unit (fixtures
--     exit on tick 0; multi-tick user programs are later)
--   · NOT covered: Real membership / float literals (021 — needs
--     FloatLit lexing in this FSM + mk_numeral), match/matches
--     (006), payloaded user enum variants, multiple user enums,
--     3+-element effects literals, quantifiers, Seq values,
--     composition lines, multi-name memberships

import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_core.ev"
import "stdlib/z3_seq.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/lex_fti.ev"
import "compiler/translate_arith.ev"
import "compiler2/translate2_bool.ev"
import "compiler2/translate2_ctor.ev"

-- ── Work items: one line of claim body = one small program ────────
enum C2Item =
    C2Process(Expr)
    C2Op(Op)
    C2Ite
    C2Not
    C2DeclConst(String, Int)
    C2NatBound
    C2PinEq
    C2AssertTop
    C2Drop
    C2PushH(Int)
    C2App(Int, Int)
    C2SelectEq(Int)
    C2LenEq(Int)

enum C2Items =
    C2INil
    C2ICons(C2Item, C2Items)

-- Handle stack (Z3_ast handles, post-order operand order).
enum C2H =
    C2HNil
    C2HCons(Int, C2H)

-- ── Token → Op classifier (wider than parser.ev's TokenToOp) ──────
claim C2TokOp(t ∈ Token, o ∈ Op, rec ∈ Bool)
    c2to_pl ∈ Bool = (t matches Plus)
    c2to_mi ∈ Bool = (t matches Minus)
    c2to_st ∈ Bool = (t matches Star)
    c2to_sl ∈ Bool = (t matches Slash)
    c2to_eq ∈ Bool = (t matches Eq)
    c2to_lt ∈ Bool = (t matches Lt)
    c2to_gt ∈ Bool = (t matches Gt)
    c2to_le ∈ Bool = (t matches OpLe)
    c2to_ge ∈ Bool = (t matches OpGe)
    c2to_ne ∈ Bool = (t matches OpNe)
    c2to_an ∈ Bool = (t matches OpAnd)
    c2to_or ∈ Bool = (t matches OpOr)
    c2to_im ∈ Bool = (t matches OpImplies)
    c2to_cc ∈ Bool = (t matches PlusPlus)
    o = (c2to_pl ? OpPlus
       : c2to_mi ? OpSub
       : c2to_st ? OpMul
       : c2to_sl ? OpDiv
       : c2to_eq ? OpEq
       : c2to_lt ? OpLt
       : c2to_gt ? OpGt
       : c2to_le ? OpLeq
       : c2to_ge ? OpGeq
       : c2to_ne ? OpNeq
       : c2to_an ? OpConj
       : c2to_or ? OpDisj
       : c2to_im ? OpImpl
       : c2to_cc ? OpConcat
       : OpPlus)
    rec = (c2to_pl ∨ c2to_mi ∨ c2to_st ∨ c2to_sl ∨ c2to_eq
         ∨ c2to_lt ∨ c2to_gt ∨ c2to_le ∨ c2to_ge ∨ c2to_ne
         ∨ c2to_an ∨ c2to_or ∨ c2to_im ∨ c2to_cc)

-- ── Token → atomic Expr ───────────────────────────────────────────
claim C2AtomE(t ∈ Token, e ∈ Expr, ok ∈ Bool)
    c2a_int ∈ Bool = (t matches IntLit(_))
    c2a_id  ∈ Bool = (t matches Ident(_))
    c2a_tr  ∈ Bool = (t matches KwTrue)
    c2a_fa  ∈ Bool = (t matches KwFalse)
    c2a_sl  ∈ Bool = (t matches StringLit(_))
    c2a_n ∈ Int = match t
        IntLit(n) ⇒ n
        _ ⇒ 0
    c2a_s ∈ String = match t
        Ident(s) ⇒ s
        _ ⇒ ""
    c2a_ls ∈ String = match t
        StringLit(s) ⇒ s
        _ ⇒ ""
    e = (c2a_int ? EInt(c2a_n)
       : c2a_id ? EIdent(c2a_s)
       : c2a_tr ? EIdent("true")
       : c2a_fa ? EIdent("false")
       : c2a_sl ? EStr(c2a_ls)
       : ENoExpr)
    ok = (c2a_int ∨ c2a_id ∨ c2a_tr ∨ c2a_fa ∨ c2a_sl)

-- ── FTI token decode: (tag, payload0, string) → Token ─────────────
-- Inverse of LexCharTag / LexKeywordTag plus the literal tags
-- (stdlib/fti/token_stack.ev's table). Tags the driver lexer never
-- writes (FloatLit, PlusPlus, DotDot, ErrTok, Newline, Indent) and
-- the calloc'd 0 past the EofTok sentinel decode to EofTok.
claim FtiTok(tag ∈ Int, p0 ∈ Int, s ∈ String, t ∈ Token)
    t = (tag = 1 ? Ident(s)
       : tag = 2 ? IntLit(p0)
       : tag = 3 ? StringLit(s)
       : tag = 5 ? LParen
       : tag = 6 ? RParen
       : tag = 7 ? Comma
       : tag = 8 ? Plus
       : tag = 9 ? Star
       : tag = 10 ? Slash
       : tag = 11 ? Minus
       : tag = 12 ? Eq
       : tag = 15 ? KwClaim
       : tag = 16 ? KwType
       : tag = 17 ? KwSchema
       : tag = 18 ? KwFsm
       : tag = 19 ? KwEnum
       : tag = 20 ? KwImport
       : tag = 21 ? KwMatch
       : tag = 22 ? KwSubclaim
       : tag = 23 ? KwExternal
       : tag = 24 ? KwMatches
       : tag = 25 ? KwIn
       : tag = 26 ? KwTrue
       : tag = 27 ? KwFalse
       : tag = 28 ? KwMapsTo
       : tag = 40 ? OpIn
       : tag = 41 ? OpImplies
       : tag = 42 ? OpSeqOpen
       : tag = 43 ? OpSeqClose
       : tag = 44 ? OpMapsto
       : tag = 45 ? OpLe
       : tag = 46 ? OpGe
       : tag = 47 ? OpNe
       : tag = 48 ? OpAnd
       : tag = 49 ? OpOr
       : tag = 50 ? OpNot
       : tag = 51 ? OpForall
       : tag = 52 ? OpExists
       : tag = 60 ? PlusPlus
       : tag = 62 ? Lt
       : tag = 63 ? Gt
       : tag = 64 ? Dot
       : tag = 65 ? Pipe
       : tag = 66 ? Question
       : tag = 67 ? Hash
       : tag = 68 ? Colon
       : EofTok)

-- ── Operator precedence (oracle-verified ladder, P3c) ─────────────
-- Probed empirically against the frozen bootstrap oracle:
--   ⇒ 1 (right-assoc) · ?: 2 (right) · ∨ 3 · ∧ 4 ·
--   chain ops < > ≤ ≥ = ≠ all at 5 (a run of them lowers to a
--   conjunction of consecutive pairs: `flag = x < 5` →
--   (and (= flag x) (< x 5)), `0 < x < 5` → (and (< 0 x) (< x 5)))
--   · + - 6 · * / 7 · unary ¬ 8.
-- NOTE: CLAUDE.md's footgun section claims ⇒ binds TIGHTER than ∧;
-- the oracle disagrees (`a ∧ b ⇒ c` → (=> (and a b) c),
-- `a ⇒ b ∧ c` → (=> a (and b c))). The oracle is the reference
-- semantics; the divergence is pinned in
-- docs/plans/compiler2-driver-notes.md.
claim C2Prec(o ∈ Op, n ∈ Int, right ∈ Bool, chain ∈ Bool)
    pc_im ∈ Bool = (o matches OpImpl)
    pc_or ∈ Bool = (o matches OpDisj)
    pc_an ∈ Bool = (o matches OpConj)
    pc_lt ∈ Bool = (o matches OpLt)
    pc_gt ∈ Bool = (o matches OpGt)
    pc_le ∈ Bool = (o matches OpLeq)
    pc_ge ∈ Bool = (o matches OpGeq)
    pc_ne ∈ Bool = (o matches OpNeq)
    pc_eq ∈ Bool = (o matches OpEq)
    pc_pl ∈ Bool = (o matches OpPlus)
    pc_su ∈ Bool = (o matches OpSub)
    pc_mu ∈ Bool = (o matches OpMul)
    pc_dv ∈ Bool = (o matches OpDiv)
    pc_cc ∈ Bool = (o matches OpConcat)
    chain = (pc_lt ∨ pc_gt ∨ pc_le ∨ pc_ge ∨ pc_ne ∨ pc_eq)
    n = (pc_im ? 1
       : pc_or ? 3
       : pc_an ? 4
       : chain ? 5
       : (pc_pl ∨ pc_su ∨ pc_cc) ? 6
       : (pc_mu ∨ pc_dv) ? 7
       : 0)
    right = pc_im

-- Operator-stack entries for the Pratt FSM. PrLP / PrQuest are
-- floor markers (never auto-reduced; prec -1); PrTern is the armed
-- ternary (pops 3 operands); PrNot the prefix ¬ (pops 1); PrBin a
-- binary operator (pops 2). PrNone is the empty-stack sentinel.
enum PrOp =
    PrBin(Op)
    PrLP
    PrQuest
    PrTern
    PrNot
    PrNone

enum PrOps =
    PrNil
    PrCons(PrOp, PrOps)

-- ── Pratt parser step (shunting-yard; ONE action per invocation) ──
-- State in: (toks, outs, ops, expop, pd, qd); state out: the n*
-- mirrors. Each call performs exactly one action:
--   shift   — consume an atom / `(` / `¬` / binary op / `?`
--   reduce  — pop the top operator, apply it to the operand stack
--   close   — consume `)` matching the PrLP at top (pd > 0)
--   swap    — consume `:`, arm the pending PrQuest into PrTern
--   done    — head token can't extend the expression and the op
--             stack is empty; sres = the single operand left
-- expop: true when the next token must START an operand. pd / qd:
-- open-paren and pending-`?` depths — they decide whether `)` / `:`
-- continue the expression or terminate it (the driver's expression
-- contexts end at the first token that can't continue: the next
-- body line's head, the effects literal's closing `) ⟩`, EOF).
-- A token that can't start an operand while expop holds is a
-- malformed line: done fires with sres = ENoExpr.
-- The driver runs this once per tick under pmode = 3;
-- tests/kernel/compiler2/pratt_fixture.ev runs the same claim
-- standalone.
claim C2PrattStep(toks ∈ TokenList, outs ∈ ExprList, ops ∈ PrOps,
        expop ∈ Bool, pd ∈ Int, qd ∈ Int,
        ntoks ∈ TokenList, nouts ∈ ExprList, nops ∈ PrOps,
        nexpop ∈ Bool, npd ∈ Int, nqd ∈ Int,
        sdone ∈ Bool, sres ∈ Expr, scons ∈ Bool)
    ps_hd ∈ Token = match toks
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    ps_tl ∈ TokenList = match toks
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil

    ps_top ∈ PrOp = match ops
        PrCons(o2, _) ⇒ o2
        PrNil ⇒ PrNone
    ps_ops_tl ∈ PrOps = match ops
        PrCons(_, r) ⇒ r
        PrNil ⇒ PrNil
    ps_ops_nil ∈ Bool = (ops matches PrNil)

    ps_o1 ∈ Expr = match outs
        ELCons(e1, _) ⇒ e1
        ELNil ⇒ ENoExpr
    ps_o_t1 ∈ ExprList = match outs
        ELCons(_, r) ⇒ r
        ELNil ⇒ ELNil
    ps_o2 ∈ Expr = match ps_o_t1
        ELCons(e1, _) ⇒ e1
        ELNil ⇒ ENoExpr
    ps_o_t2 ∈ ExprList = match ps_o_t1
        ELCons(_, r) ⇒ r
        ELNil ⇒ ELNil
    ps_o3 ∈ Expr = match ps_o_t2
        ELCons(e1, _) ⇒ e1
        ELNil ⇒ ENoExpr
    ps_o_t3 ∈ ExprList = match ps_o_t2
        ELCons(_, r) ⇒ r
        ELNil ⇒ ELNil

    -- head-token classification
    ps_atom_e ∈ Expr
    ps_atom_ok ∈ Bool
    C2AtomE(t ↦ ps_hd, e ↦ ps_atom_e, ok ↦ ps_atom_ok)
    ps_bin_o ∈ Op
    ps_bin_ok ∈ Bool
    C2TokOp(t ↦ ps_hd, o ↦ ps_bin_o, rec ↦ ps_bin_ok)
    ps_is_q ∈ Bool = (ps_hd matches Question)
    ps_is_col ∈ Bool = (ps_hd matches Colon)
    ps_is_lp ∈ Bool = (ps_hd matches LParen)
    ps_is_rp ∈ Bool = (ps_hd matches RParen)
    ps_is_not ∈ Bool = (ps_hd matches OpNot)

    ps_in_p0 ∈ Int
    ps_in_r0 ∈ Bool
    ps_in_ch0 ∈ Bool
    C2Prec(o ↦ ps_bin_o, n ↦ ps_in_p0, right ↦ ps_in_r0, chain ↦ ps_in_ch0)
    ps_in_p ∈ Int = (ps_is_q ? 2 : ps_in_p0)
    ps_in_right ∈ Bool = (ps_is_q ? true : ps_in_r0)

    -- top-of-op-stack decomposition
    ps_top_op ∈ Op = match ps_top
        PrBin(o2) ⇒ o2
        _ ⇒ OpPlus
    ps_top_bin ∈ Bool = (ps_top matches PrBin(_))
    ps_top_not ∈ Bool = (ps_top matches PrNot)
    ps_top_tern ∈ Bool = (ps_top matches PrTern)
    ps_top_quest ∈ Bool = (ps_top matches PrQuest)
    ps_top_lp ∈ Bool = (ps_top matches PrLP)
    ps_tb_p ∈ Int
    ps_tb_r ∈ Bool
    ps_top_chain ∈ Bool
    C2Prec(o ↦ ps_top_op, n ↦ ps_tb_p, right ↦ ps_tb_r, chain ↦ ps_top_chain)
    ps_top_p ∈ Int = (ps_top_bin ? ps_tb_p
        : ps_top_not ? 8
        : ps_top_tern ? 2
        : 0 - 1)
    ps_top_red ∈ Bool = (ps_top_bin ∨ ps_top_not ∨ ps_top_tern)

    -- chain-comparison lowering parts (lhs = ps_o2 when reducing a
    -- PrBin whose op is a chain op): a chain-shaped lhs turns
    -- `l op r` into (and l (op middle r)), duplicating the shared
    -- middle operand — same lowering the oracle performs.
    ps_l_op ∈ Op
    ps_l_l ∈ Expr
    ps_l_r ∈ Expr
    ps_l_bin ∈ Bool
    BoolExprBinopParts(e ↦ ps_o2, op ↦ ps_l_op, lhs ↦ ps_l_l,
        rhs ↦ ps_l_r, is_binop ↦ ps_l_bin)
    ps_l_p ∈ Int
    ps_l_rt ∈ Bool
    ps_l_chain ∈ Bool
    C2Prec(o ↦ ps_l_op, n ↦ ps_l_p, right ↦ ps_l_rt, chain ↦ ps_l_chain)
    ps_l_conj ∈ Bool = (ps_l_op matches OpConj)
    ps_lr_op ∈ Op
    ps_lr_l ∈ Expr
    ps_lr_r ∈ Expr
    ps_lr_bin ∈ Bool
    BoolExprBinopParts(e ↦ ps_l_r, op ↦ ps_lr_op, lhs ↦ ps_lr_l,
        rhs ↦ ps_lr_r, is_binop ↦ ps_lr_bin)
    ps_lr_p ∈ Int
    ps_lr_rt ∈ Bool
    ps_lr_chain ∈ Bool
    C2Prec(o ↦ ps_lr_op, n ↦ ps_lr_p, right ↦ ps_lr_rt, chain ↦ ps_lr_chain)
    ps_chain1 ∈ Bool = (ps_top_chain ∧ ps_l_bin ∧ ps_l_chain)
    ps_chain2 ∈ Bool = (ps_top_chain ∧ ps_l_bin ∧ ps_l_conj
        ∧ ps_lr_bin ∧ ps_lr_chain)
    ps_apply_bin ∈ Expr = (ps_chain1
            ? EBinOp(OpConj, ps_o2, EBinOp(ps_top_op, ps_l_r, ps_o1))
        : ps_chain2
            ? EBinOp(OpConj, ps_o2, EBinOp(ps_top_op, ps_lr_r, ps_o1))
        : EBinOp(ps_top_op, ps_o2, ps_o1))

    -- action selection (exactly one fires)
    ps_sh_atom ∈ Bool = (expop ∧ ps_atom_ok)
    ps_sh_lp ∈ Bool = (expop ∧ ps_is_lp)
    ps_sh_not ∈ Bool = (expop ∧ ps_is_not)
    ps_bad ∈ Bool = (expop ∧ (¬ps_atom_ok) ∧ (¬ps_is_lp) ∧ (¬ps_is_not))

    ps_cont ∈ Bool = (ps_bin_ok ∨ ps_is_q
        ∨ (ps_is_col ∧ (qd > 0)) ∨ (ps_is_rp ∧ (pd > 0)))
    ps_arr ∈ Bool = ((¬expop) ∧ (ps_bin_ok ∨ ps_is_q))
    ps_arr_red ∈ Bool = (ps_arr ∧ ps_top_red
        ∧ (ps_in_right ? ps_top_p > ps_in_p : ps_top_p ≥ ps_in_p))
    ps_arr_shift ∈ Bool = (ps_arr ∧ (¬ps_arr_red))
    ps_col ∈ Bool = ((¬expop) ∧ ps_is_col ∧ (qd > 0))
    ps_col_swap ∈ Bool = (ps_col ∧ ps_top_quest)
    ps_rp ∈ Bool = ((¬expop) ∧ ps_is_rp ∧ (pd > 0))
    ps_rp_close ∈ Bool = (ps_rp ∧ ps_top_lp)
    ps_end ∈ Bool = ((¬expop) ∧ (¬ps_cont))
    ps_need_red ∈ Bool = ((ps_col ∧ (¬ps_col_swap))
        ∨ (ps_rp ∧ (¬ps_rp_close))
        ∨ (ps_end ∧ (¬ps_ops_nil))
        ∨ ps_arr_red)
    ps_reduce ∈ Bool = (ps_need_red ∧ ps_top_red)
    ps_discard ∈ Bool = (ps_need_red ∧ (¬ps_top_red))

    sdone = (ps_bad ∨ (ps_end ∧ ps_ops_nil))
    sres = (ps_bad ? ENoExpr : ps_o1)

    ps_consume ∈ Bool = (ps_sh_atom ∨ ps_sh_lp ∨ ps_sh_not
        ∨ ps_arr_shift ∨ ps_col_swap ∨ ps_rp_close)
    scons = ps_consume
    ntoks = (ps_consume ? ps_tl : toks)

    ps_red_e ∈ Expr = (ps_top_not ? ENot(ps_o1)
        : ps_top_tern ? ETernary(ps_o3, ps_o2, ps_o1)
        : ps_apply_bin)
    ps_red_base ∈ ExprList = (ps_top_not ? ps_o_t1
        : ps_top_tern ? ps_o_t3
        : ps_o_t2)
    nouts = (ps_sh_atom ? ELCons(ps_atom_e, outs)
        : ps_reduce ? ELCons(ps_red_e, ps_red_base)
        : outs)

    ps_push ∈ PrOp = (ps_is_q ? PrQuest : PrBin(ps_bin_o))
    nops = (ps_sh_lp ? PrCons(PrLP, ops)
        : ps_sh_not ? PrCons(PrNot, ops)
        : ps_arr_shift ? PrCons(ps_push, ops)
        : ps_col_swap ? PrCons(PrTern, ps_ops_tl)
        : (ps_rp_close ∨ ps_reduce ∨ ps_discard) ? ps_ops_tl
        : ops)

    nexpop = (ps_sh_atom ? false
        : ps_rp_close ? false
        : (ps_arr_shift ∨ ps_col_swap ∨ ps_sh_lp ∨ ps_sh_not) ? true
        : expop)

    npd = (ps_sh_lp ? pd + 1 : ps_rp_close ? pd - 1 : pd)
    nqd = ((ps_arr_shift ∧ ps_is_q) ? qd + 1 : ps_col_swap ? qd - 1 : qd)

claim driver_main
    -- ── INPUT — per-process source path via stdin (wave 4o) ──────
    got_path  ∈ Bool
    _got_path ∈ Bool
    got_path = (is_first_tick ? false : true)

    src_path  ∈ String
    _src_path ∈ String
    path_read ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""
    src_path = (is_first_tick ? "" : ((¬_got_path) ? path_read : _src_path))

    input  ∈ String
    _input ∈ String
    content_read ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ "<no-read>"
    input = (is_first_tick ? "" : ((¬_got_path) ? "" : (_input = "" ? content_read : _input)))

    target  ∈ String
    _target ∈ String
    target_read ∈ String = match last_results[1]
        StringResult(s) ⇒ s
        _ ⇒ ""
    target = (is_first_tick ? "" : ((¬_got_path) ? target_read : _target))

    -- Shared per-tick result captures.
    d_cap_int ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    d_cap_str ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""

    -- ── ZINIT — Z3 lifecycle + Effect-floor datatypes + consts ───
    -- zstep: -2 on tick 0, -1 on tick 1, then 0,1,2,… (capped).
    -- zstep HOLDS at 9 while the ED machine (below) declares the
    -- three Effect-floor datatypes (LibArg → __SeqOf_LibArg →
    -- Effect) in the build context; it resumes at 10 when ed_src
    -- reaches 3 with the machine idle.
    zstep  ∈ Int
    _zstep ∈ Int
    ed_hold ∈ Bool = (_ed_act ≠ 0 ∨ _ed_src < 3)
    zstep = (is_first_tick ? 0 - 2
        : (_zstep = 9 ∧ ed_hold) ? 9
        : (_zstep < 60 ? _zstep + 1 : _zstep))

    z_cfg ∈ Int
    _z_cfg ∈ Int
    z_cfg = (is_first_tick ? 0 : zstep = 1 ? d_cap_int : _z_cfg)
    z_ctx ∈ Int
    _z_ctx ∈ Int
    z_ctx = (is_first_tick ? 0 : zstep = 2 ? d_cap_int : _z_ctx)
    z_sol ∈ Int
    _z_sol ∈ Int
    z_sol = (is_first_tick ? 0 : zstep = 3 ? d_cap_int : _z_sol)
    z_isort ∈ Int
    _z_isort ∈ Int
    z_isort = (is_first_tick ? 0 : zstep = 5 ? d_cap_int : _z_isort)
    z_bsort ∈ Int
    _z_bsort ∈ Int
    z_bsort = (is_first_tick ? 0 : zstep = 6 ? d_cap_int : _z_bsort)
    z_ssort ∈ Int
    _z_ssort ∈ Int
    z_ssort = (is_first_tick ? 0 : zstep = 7 ? d_cap_int : _z_ssort)
    z_rsort ∈ Int
    _z_rsort ∈ Int
    z_rsort = (is_first_tick ? 0 : zstep = 8 ? d_cap_int : _z_rsort)
    -- zstep holds at 9; latch the arena only on the FIRST 9-tick.
    z_arena ∈ Int
    _z_arena ∈ Int
    z_arena = (is_first_tick ? 0
        : (zstep = 9 ∧ _zstep = 8) ? d_cap_int : _z_arena)
    z_arrsort ∈ Int
    _z_arrsort ∈ Int
    z_arrsort = (is_first_tick ? 0 : zstep = 11 ? d_cap_int : _z_arrsort)
    z_sym_effs ∈ Int
    _z_sym_effs ∈ Int
    z_sym_effs = (is_first_tick ? 0 : zstep = 12 ? d_cap_int : _z_sym_effs)
    z_effs ∈ Int
    _z_effs ∈ Int
    z_effs = (is_first_tick ? 0 : zstep = 13 ? d_cap_int : _z_effs)
    z_sym_elen ∈ Int
    _z_sym_elen ∈ Int
    z_sym_elen = (is_first_tick ? 0 : zstep = 14 ? d_cap_int : _z_sym_elen)
    z_elen ∈ Int
    _z_elen ∈ Int
    z_elen = (is_first_tick ? 0 : zstep = 15 ? d_cap_int : _z_elen)
    z_zero ∈ Int
    _z_zero ∈ Int
    z_zero = (is_first_tick ? 0 : zstep = 16 ? d_cap_int : _z_zero)
    z_one ∈ Int
    _z_one ∈ Int
    z_one = (is_first_tick ? 0 : zstep = 17 ? d_cap_int : _z_one)
    z_two ∈ Int
    _z_two ∈ Int
    z_two = (is_first_tick ? 0 : zstep = 18 ? d_cap_int : _z_two)
    z_true ∈ Int
    _z_true ∈ Int
    z_true = (is_first_tick ? 0 : zstep = 19 ? d_cap_int : _z_true)
    z_false ∈ Int
    _z_false ∈ Int
    z_false = (is_first_tick ? 0 : zstep = 20 ? d_cap_int : _z_false)
    tbase ∈ Int
    _tbase ∈ Int
    tbase = (is_first_tick ? 0 : zstep = 21 ? d_cap_int : _tbase)

    -- ── ED — the enum-declaration machine ────────────────────────
    -- ONE FSM declares any enum (parsed EnumDeclAst data) in the
    -- build context through translate2_ctor.ev's step claims, then
    -- harvests each variant's ctor func_decl + (nullary) value.
    -- It runs FOUR times: three ZINIT floor runs (ed_src 0 LibArg,
    -- 1 __SeqOf_LibArg, 2 Effect — zstep holds at 9) and once per
    -- USER enum at parse time (pmode 4, ed_user).
    --
    -- Acts/steps (ed_act · ed_step; one effect per tick, captures
    -- land next tick keyed off the (_ed_act, _ed_step) that ran):
    --   act 1 (declare, per variant; n = field count):
    --     0 name sym · 1 recog sym · 2..4 field syms (skip by n) ·
    --     5 array-write batch (≤8 effects) · 6 mk_constructor ·
    --     7 write ctor → ctors[vidx], advance variant
    --   act 2 (finalize): 0 enum sort sym · 1 mk_constructor_list ·
    --     2 write batch (sort name + clist) · 3 mk_datatypes ·
    --     4 read sort · 5 capture sort, reset walk → harvest
    --   act 3 (harvest, per variant): 0 read ctor handle · 1 query ·
    --     2 read ctor decl · 3 capture decl (+ floor-decl register
    --     latches), mk_app for nullary · 4 capture value (evt / floor
    --     value latches), advance variant
    --
    -- Arena layout for the machine (reused per run; the WALK's
    -- regions live at +200..247 and never overlap in time):
    --   +0 fnames[3] · +24 fsorts[3] · +48 srefs (2 packed writes) ·
    --   +64 ctors[5] · +104 sort_names[1] · +112 sorts_out[1] ·
    --   +120 clists[1] · +128 query out block (16 + 8·3)
    ed_act ∈ Int
    _ed_act ∈ Int
    ed_step ∈ Int
    _ed_step ∈ Int
    ed_src ∈ Int
    _ed_src ∈ Int
    ed_user ∈ Bool
    _ed_user ∈ Bool
    ed_name ∈ String
    _ed_name ∈ String
    ed_all ∈ EnumVariantList
    _ed_all ∈ EnumVariantList
    ed_vs ∈ EnumVariantList
    _ed_vs ∈ EnumVariantList
    ed_vidx ∈ Int
    _ed_vidx ∈ Int
    ed_nv ∈ Int
    _ed_nv ∈ Int
    ed_h_name ∈ Int
    _ed_h_name ∈ Int
    ed_h_rec ∈ Int
    _ed_h_rec ∈ Int
    ed_h_f0 ∈ Int
    _ed_h_f0 ∈ Int
    ed_h_f1 ∈ Int
    _ed_h_f1 ∈ Int
    ed_h_f2 ∈ Int
    _ed_h_f2 ∈ Int

    -- Floor enum decls as parsed data (pinned body vars — the oracle
    -- gap forbids ctor literals in slot bindings). The Effect floor
    -- comes from translate2_ctor.ev's EffectEnumDecl.
    d_la_decl ∈ EnumDeclAst = EnumD("LibArg",
        EVCons(EVDeclP("ArgInt", EVFCons(EVFType("Int"), EVFNil)),
        EVCons(EVDeclP("ArgStr", EVFCons(EVFType("String"), EVFNil)),
        EVCons(EVDeclP("ArgReal", EVFCons(EVFType("Real"), EVFNil)),
        EVNil))))
    d_sq_decl ∈ EnumDeclAst = EnumD("__SeqOf_LibArg",
        EVCons(EVDecl("__Empty_LibArg"),
        EVCons(EVDeclP("__Cell_LibArg",
            EVFCons(EVFType("LibArg"),
                EVFCons(EVFType("__SeqOf_LibArg"), EVFNil))),
        EVNil)))
    d_eff_decl ∈ EnumDeclAst
    EffectEnumDecl(decl ↦ d_eff_decl)
    d_la_vs ∈ EnumVariantList
    EnumVariantListOf(decl ↦ d_la_decl, vs ↦ d_la_vs)
    d_sq_vs ∈ EnumVariantList
    EnumVariantListOf(decl ↦ d_sq_decl, vs ↦ d_sq_vs)
    d_eff_vs ∈ EnumVariantList
    EnumVariantListOf(decl ↦ d_eff_decl, vs ↦ d_eff_vs)

    -- Start triggers. Floor runs start when zstep first parks at 9
    -- and after each completed floor run; the user run starts from
    -- the pmode-4 collection (ec_start, defined with the dispatcher).
    ed_go_floor ∈ Bool = ((¬is_first_tick) ∧ (zstep = 9)
        ∧ (_ed_act = 0) ∧ (_ed_src < 3))
    ed_go ∈ Bool = (ed_go_floor ∨ ec_start)
    ed_go_vs ∈ EnumVariantList = (ec_start ? ec_list_n
        : _ed_src = 0 ? d_la_vs
        : _ed_src = 1 ? d_sq_vs
        : d_eff_vs)
    ed_go_name ∈ String = (ec_start ? _ue_name
        : _ed_src = 0 ? "LibArg"
        : _ed_src = 1 ? "__SeqOf_LibArg"
        : "Effect")

    -- Current variant (head of the remaining list) + its shape.
    -- The START tick already runs step 0 (the first variant's name
    -- sym), so the peel must see the NEW list on that tick.
    ed_vs_eff ∈ EnumVariantList = (ed_go ? ed_go_vs : _ed_vs)
    ed_v ∈ EnumVariantDecl
    ed_vrest ∈ EnumVariantList
    ed_vs_nonempty ∈ Bool
    EnumVariantsHead(vs ↦ ed_vs_eff, v ↦ ed_v, rest ↦ ed_vrest,
        nonempty ↦ ed_vs_nonempty)
    ed_n ∈ Int
    VariantFieldCount(v ↦ ed_v, n ↦ ed_n)
    ed_vname ∈ String = match ed_v
        EVDecl(n) ⇒ n
        EVDeclP(n, _) ⇒ n
        EVNoVariant ⇒ ""
    ed_nullary ∈ Bool = (ed_n = 0)

    -- Field sort slots (FieldSortSlot + the driver's sort registry
    -- for non-primitive field types — the translate2_ctor.ev header's
    -- "driver registry" scope note).
    ed_ty0 ∈ String
    VariantFieldType(v ↦ ed_v, idx ↦ 0, ty ↦ ed_ty0)
    ed_ty1 ∈ String
    VariantFieldType(v ↦ ed_v, idx ↦ 1, ty ↦ ed_ty1)
    ed_ty2 ∈ String
    VariantFieldType(v ↦ ed_v, idx ↦ 2, ty ↦ ed_ty2)
    ed_fs0 ∈ Int
    ed_fr0 ∈ Int
    ed_fself0 ∈ Bool
    FieldSortSlot(enum_name ↦ _ed_name, ty ↦ ed_ty0,
        int_sort_h ↦ z_isort, bool_sort_h ↦ z_bsort, string_sort_h ↦ z_ssort,
        self_sort_idx ↦ 0,
        sort_slot ↦ ed_fs0, ref_slot ↦ ed_fr0, is_self ↦ ed_fself0)
    ed_fs1 ∈ Int
    ed_fr1 ∈ Int
    ed_fself1 ∈ Bool
    FieldSortSlot(enum_name ↦ _ed_name, ty ↦ ed_ty1,
        int_sort_h ↦ z_isort, bool_sort_h ↦ z_bsort, string_sort_h ↦ z_ssort,
        self_sort_idx ↦ 0,
        sort_slot ↦ ed_fs1, ref_slot ↦ ed_fr1, is_self ↦ ed_fself1)
    ed_fs2 ∈ Int
    ed_fr2 ∈ Int
    ed_fself2 ∈ Bool
    FieldSortSlot(enum_name ↦ _ed_name, ty ↦ ed_ty2,
        int_sort_h ↦ z_isort, bool_sort_h ↦ z_bsort, string_sort_h ↦ z_ssort,
        self_sort_idx ↦ 0,
        sort_slot ↦ ed_fs2, ref_slot ↦ ed_fr2, is_self ↦ ed_fself2)
    ed_slot0 ∈ Int = ((ed_fs0 ≠ 0 ∨ ed_fself0) ? ed_fs0
        : ed_ty0 = "Real" ? z_rsort
        : ed_ty0 = "LibArg" ? la_sort
        : ed_ty0 = "Seq(LibArg)" ? sq_sort
        : 0)
    ed_slot1 ∈ Int = ((ed_fs1 ≠ 0 ∨ ed_fself1) ? ed_fs1
        : ed_ty1 = "Real" ? z_rsort
        : ed_ty1 = "LibArg" ? la_sort
        : ed_ty1 = "Seq(LibArg)" ? sq_sort
        : 0)
    ed_slot2 ∈ Int = ((ed_fs2 ≠ 0 ∨ ed_fself2) ? ed_fs2
        : ed_ty2 = "Real" ? z_rsort
        : ed_ty2 = "LibArg" ? la_sort
        : ed_ty2 = "Seq(LibArg)" ? sq_sort
        : 0)
    ed_pack01 ∈ Int
    SortRefsPack2(ref_lo ↦ ed_fr0, ref_hi ↦ ed_fr1, packed ↦ ed_pack01)

    -- The step to RUN this tick (pure transition off last tick).
    ed_cur_act ∈ Int = (ed_go ? 1
        : _ed_act = 1 ?
            (_ed_step = 7 ? (ed_vs_nonempty ? 1 : 2) : 1)
        : _ed_act = 2 ? (_ed_step = 5 ? 3 : 2)
        : _ed_act = 3 ?
            (_ed_step = 4 ? (ed_vs_nonempty ? 3 : 0) : 3)
        : 0)
    ed_cur_step ∈ Int = (ed_go ? 0
        : _ed_act = 1 ?
            (_ed_step = 0 ? 1
            : _ed_step = 1 ? (ed_n = 0 ? 6 : 2)
            : _ed_step = 2 ? (ed_n = 1 ? 5 : 3)
            : _ed_step = 3 ? (ed_n = 2 ? 5 : 4)
            : _ed_step = 4 ? 5
            : _ed_step = 5 ? 6
            : _ed_step = 6 ? 7
            : 0)
        : _ed_act = 2 ? (_ed_step = 5 ? 0 : _ed_step + 1)
        : _ed_act = 3 ? (_ed_step = 4 ? 0 : _ed_step + 1)
        : 0)
    ed_running ∈ Bool = (ed_go ∨ _ed_act ≠ 0)
    ed_done ∈ Bool = (_ed_act = 3 ∧ _ed_step = 4 ∧ (¬ed_vs_nonempty))
    ed_done_user ∈ Bool = (ed_done ∧ _ed_user)

    -- State carry. The variant walk advances at act-1 step 7 and
    -- act-3 step 4; the harvest walk restarts at act-2 step 5.
    ed_adv ∈ Bool = (ed_running ∧
        ((ed_cur_act = 1 ∧ ed_cur_step = 7)
        ∨ (ed_cur_act = 3 ∧ ed_cur_step = 4)))
    ed_act = (is_first_tick ? 0
        : ed_done ? 0
        : ed_running ? ed_cur_act
        : 0)
    ed_step = (is_first_tick ? 0 : ed_running ? ed_cur_step : 0)
    ed_src = (is_first_tick ? 0
        : (ed_done ∧ (¬_ed_user)) ? _ed_src + 1
        : _ed_src)
    ed_user = (is_first_tick ? false
        : ec_start ? true
        : ed_done ? false
        : _ed_user)
    ed_name = (is_first_tick ? "" : ed_go ? ed_go_name : _ed_name)
    ed_all = (is_first_tick ? EVNil : ed_go ? ed_go_vs : _ed_all)
    ed_vs = (is_first_tick ? EVNil
        : ed_go ? ed_go_vs
        : ed_adv ? ed_vrest
        : (ed_cur_act = 2 ∧ ed_cur_step = 5) ? _ed_all
        : _ed_vs)
    ed_vidx = (is_first_tick ? 0
        : ed_go ? 0
        : ed_adv ? _ed_vidx + 1
        : (ed_cur_act = 2 ∧ ed_cur_step = 5) ? 0
        : _ed_vidx)
    ed_nv = (is_first_tick ? 0
        : (ed_cur_act = 1 ∧ ed_cur_step = 7) ? _ed_vidx + 1
        : _ed_nv)

    -- Captures (keyed off the step that ran LAST tick).
    ed_h_name = (is_first_tick ? 0
        : (_ed_act = 1 ∧ _ed_step = 0) ? d_cap_int
        : (_ed_act = 2 ∧ _ed_step = 0) ? d_cap_int
        : _ed_h_name)
    ed_h_rec = (is_first_tick ? 0
        : (_ed_act = 1 ∧ _ed_step = 1) ? d_cap_int : _ed_h_rec)
    ed_h_f0 = (is_first_tick ? 0
        : (_ed_act = 1 ∧ _ed_step = 2) ? d_cap_int : _ed_h_f0)
    ed_h_f1 = (is_first_tick ? 0
        : (_ed_act = 1 ∧ _ed_step = 3) ? d_cap_int : _ed_h_f1)
    ed_h_f2 = (is_first_tick ? 0
        : (_ed_act = 1 ∧ _ed_step = 4) ? d_cap_int : _ed_h_f2)

    -- Sort + floor-decl registers.
    la_sort ∈ Int
    _la_sort ∈ Int
    sq_sort ∈ Int
    _sq_sort ∈ Int
    z_effsort ∈ Int
    _z_effsort ∈ Int
    ue_sort ∈ Int
    _ue_sort ∈ Int
    ed_sort_cap ∈ Bool = (_ed_act = 2 ∧ _ed_step = 4)
    la_sort = (is_first_tick ? 0
        : (ed_sort_cap ∧ (¬_ed_user) ∧ _ed_src = 0) ? d_cap_int : _la_sort)
    sq_sort = (is_first_tick ? 0
        : (ed_sort_cap ∧ (¬_ed_user) ∧ _ed_src = 1) ? d_cap_int : _sq_sort)
    z_effsort = (is_first_tick ? 0
        : (ed_sort_cap ∧ (¬_ed_user) ∧ _ed_src = 2) ? d_cap_int : _z_effsort)
    ue_sort = (is_first_tick ? 0
        : (ed_sort_cap ∧ _ed_user) ? d_cap_int : _ue_sort)

    ed_decl_cap ∈ Bool = (_ed_act = 3 ∧ _ed_step = 2)
    z_exitdecl ∈ Int
    _z_exitdecl ∈ Int
    z_exitdecl = (is_first_tick ? 0
        : (ed_decl_cap ∧ ed_vname = "Exit") ? d_cap_int : _z_exitdecl)
    z_lc_decl ∈ Int
    _z_lc_decl ∈ Int
    z_lc_decl = (is_first_tick ? 0
        : (ed_decl_cap ∧ ed_vname = "LibCall") ? d_cap_int : _z_lc_decl)
    z_argstr_decl ∈ Int
    _z_argstr_decl ∈ Int
    z_argstr_decl = (is_first_tick ? 0
        : (ed_decl_cap ∧ ed_vname = "ArgStr") ? d_cap_int : _z_argstr_decl)
    z_argint_decl ∈ Int
    _z_argint_decl ∈ Int
    z_argint_decl = (is_first_tick ? 0
        : (ed_decl_cap ∧ ed_vname = "ArgInt") ? d_cap_int : _z_argint_decl)
    z_cell_decl ∈ Int
    _z_cell_decl ∈ Int
    z_cell_decl = (is_first_tick ? 0
        : (ed_decl_cap ∧ ed_vname = "__Cell_LibArg") ? d_cap_int : _z_cell_decl)
    ed_val_cap ∈ Bool = (_ed_act = 3 ∧ _ed_step = 3 ∧ ed_nullary)
    z_empty_val ∈ Int
    _z_empty_val ∈ Int
    z_empty_val = (is_first_tick ? 0
        : (ed_val_cap ∧ ed_vname = "__Empty_LibArg") ? d_cap_int : _z_empty_val)

    -- User-enum variant VALUE table (nullary variants of the one
    -- supported user enum; `Red` in an expression resolves here).
    evt_cnt ∈ Int
    _evt_cnt ∈ Int
    evt_n0 ∈ String
    _evt_n0 ∈ String
    evt_v0 ∈ Int
    _evt_v0 ∈ Int
    evt_n1 ∈ String
    _evt_n1 ∈ String
    evt_v1 ∈ Int
    _evt_v1 ∈ Int
    evt_n2 ∈ String
    _evt_n2 ∈ String
    evt_v2 ∈ Int
    _evt_v2 ∈ Int
    evt_n3 ∈ String
    _evt_n3 ∈ String
    evt_v3 ∈ Int
    _evt_v3 ∈ Int
    evt_n4 ∈ String
    _evt_n4 ∈ String
    evt_v4 ∈ Int
    _evt_v4 ∈ Int
    evt_n5 ∈ String
    _evt_n5 ∈ String
    evt_v5 ∈ Int
    _evt_v5 ∈ Int
    evt_add ∈ Bool = (ed_val_cap ∧ _ed_user)
    evt_cnt = (is_first_tick ? 0 : evt_add ? _evt_cnt + 1 : _evt_cnt)
    evt_n0 = (is_first_tick ? "" : (evt_add ∧ _evt_cnt = 0) ? ed_vname : _evt_n0)
    evt_v0 = (is_first_tick ? 0 : (evt_add ∧ _evt_cnt = 0) ? d_cap_int : _evt_v0)
    evt_n1 = (is_first_tick ? "" : (evt_add ∧ _evt_cnt = 1) ? ed_vname : _evt_n1)
    evt_v1 = (is_first_tick ? 0 : (evt_add ∧ _evt_cnt = 1) ? d_cap_int : _evt_v1)
    evt_n2 = (is_first_tick ? "" : (evt_add ∧ _evt_cnt = 2) ? ed_vname : _evt_n2)
    evt_v2 = (is_first_tick ? 0 : (evt_add ∧ _evt_cnt = 2) ? d_cap_int : _evt_v2)
    evt_n3 = (is_first_tick ? "" : (evt_add ∧ _evt_cnt = 3) ? ed_vname : _evt_n3)
    evt_v3 = (is_first_tick ? 0 : (evt_add ∧ _evt_cnt = 3) ? d_cap_int : _evt_v3)
    evt_n4 = (is_first_tick ? "" : (evt_add ∧ _evt_cnt = 4) ? ed_vname : _evt_n4)
    evt_v4 = (is_first_tick ? 0 : (evt_add ∧ _evt_cnt = 4) ? d_cap_int : _evt_v4)
    evt_n5 = (is_first_tick ? "" : (evt_add ∧ _evt_cnt = 5) ? ed_vname : _evt_n5)
    evt_v5 = (is_first_tick ? 0 : (evt_add ∧ _evt_cnt = 5) ? d_cap_int : _evt_v5)

    -- ED arena pointers.
    ed_fn_p ∈ Int = z_arena
    ed_fsort_p ∈ Int = z_arena + 24
    ed_sr_p ∈ Int = z_arena + 48
    ed_ctors_p ∈ Int = z_arena + 64
    ed_names_p ∈ Int = z_arena + 104
    ed_souts_p ∈ Int = z_arena + 112
    ed_clists_p ∈ Int = z_arena + 120
    ed_qout_p ∈ Int = z_arena + 128

    -- ED effects. Sym handles emitted at step k are captured at the
    -- k+1 tick; the write batch uses the just-landed one directly.
    ed_f0u ∈ Int = (_ed_step = 2 ? d_cap_int : _ed_h_f0)
    ed_f1u ∈ Int = (_ed_step = 3 ? d_cap_int : _ed_h_f1)
    ed_f2u ∈ Int = (_ed_step = 4 ? d_cap_int : _ed_h_f2)
    ede_nsym ∈ Effect
    VariantNameSymStep(ctx_h ↦ z_ctx, v ↦ ed_v, eff ↦ ede_nsym)
    ede_rsym ∈ Effect
    VariantRecognizerSymStep(ctx_h ↦ z_ctx, v ↦ ed_v, eff ↦ ede_rsym)
    ede_fsym0 ∈ Effect
    VariantFieldSymStep(ctx_h ↦ z_ctx, v ↦ ed_v, idx ↦ 0, eff ↦ ede_fsym0)
    ede_fsym1 ∈ Effect
    VariantFieldSymStep(ctx_h ↦ z_ctx, v ↦ ed_v, idx ↦ 1, eff ↦ ede_fsym1)
    ede_fsym2 ∈ Effect
    VariantFieldSymStep(ctx_h ↦ z_ctx, v ↦ ed_v, idx ↦ 2, eff ↦ ede_fsym2)
    edw_fn0 ∈ Effect
    BuildMemWriteLong(addr ↦ ed_fn_p, value ↦ ed_f0u, eff ↦ edw_fn0)
    edw_fn1 ∈ Effect
    BuildMemWriteLong(addr ↦ ed_fn_p + 8, value ↦ ed_f1u, eff ↦ edw_fn1)
    edw_fn2 ∈ Effect
    BuildMemWriteLong(addr ↦ ed_fn_p + 16, value ↦ ed_f2u, eff ↦ edw_fn2)
    edw_fs0 ∈ Effect
    BuildMemWriteLong(addr ↦ ed_fsort_p, value ↦ ed_slot0, eff ↦ edw_fs0)
    edw_fs1 ∈ Effect
    BuildMemWriteLong(addr ↦ ed_fsort_p + 8, value ↦ ed_slot1, eff ↦ edw_fs1)
    edw_fs2 ∈ Effect
    BuildMemWriteLong(addr ↦ ed_fsort_p + 16, value ↦ ed_slot2, eff ↦ edw_fs2)
    edw_sr01 ∈ Effect
    BuildMemWriteLong(addr ↦ ed_sr_p, value ↦ ed_pack01, eff ↦ edw_sr01)
    edw_sr2 ∈ Effect
    BuildMemWriteLong(addr ↦ ed_sr_p + 8, value ↦ ed_fr2, eff ↦ edw_sr2)
    ede_mkctor ∈ Effect
    VariantMkConstructorStep(ctx_h ↦ z_ctx, v ↦ ed_v,
        name_sym_h ↦ ed_h_name, recog_sym_h ↦ ed_h_rec,
        fnames_p ↦ ed_fn_p, fsorts_p ↦ ed_fsort_p, srefs_p ↦ ed_sr_p,
        eff ↦ ede_mkctor)
    edw_ctor ∈ Effect
    BuildMemWriteLong(addr ↦ ed_ctors_p + (8 * _ed_vidx), value ↦ d_cap_int,
        eff ↦ edw_ctor)
    ed_sortsym_decl ∈ EnumDeclAst = EnumD(_ed_name, EVNil)
    ede_ssym ∈ Effect
    EnumSortSymStep(ctx_h ↦ z_ctx, decl ↦ ed_sortsym_decl, eff ↦ ede_ssym)
    ede_clist ∈ Effect
    BuildZ3MkConstructorList(ctx_h ↦ z_ctx, n_ctors ↦ _ed_nv,
        ctors_arr_p ↦ ed_ctors_p, eff ↦ ede_clist)
    edw_nm ∈ Effect
    BuildMemWriteLong(addr ↦ ed_names_p, value ↦ ed_h_name, eff ↦ edw_nm)
    edw_cl ∈ Effect
    BuildMemWriteLong(addr ↦ ed_clists_p, value ↦ d_cap_int, eff ↦ edw_cl)
    ede_mkdt ∈ Effect
    BuildZ3MkDatatypes(ctx_h ↦ z_ctx, n_sorts ↦ 1,
        sort_names_arr_p ↦ ed_names_p, sorts_out_arr_p ↦ ed_souts_p,
        ctor_lists_arr_p ↦ ed_clists_p, eff ↦ ede_mkdt)
    ede_rdsort ∈ Effect
    BuildMemReadLong(addr ↦ ed_souts_p, eff ↦ ede_rdsort)
    ede_rdctor ∈ Effect
    BuildMemReadLong(addr ↦ ed_ctors_p + (8 * _ed_vidx), eff ↦ ede_rdctor)
    ede_query ∈ Effect
    VariantQueryStep(ctx_h ↦ z_ctx, ctor_h ↦ d_cap_int, v ↦ ed_v,
        out_base_p ↦ ed_qout_p, eff ↦ ede_query)
    ede_rddecl ∈ Effect
    BuildMemReadLong(addr ↦ ed_qout_p, eff ↦ ede_rddecl)
    ede_app0 ∈ Effect
    CtorAppStep(ctx_h ↦ z_ctx, ctor_decl_h ↦ d_cap_int, n_args ↦ 0,
        args_p ↦ 0, eff ↦ ede_app0)
    ede_filler ∈ Effect = LibCall("libc", "getpid", ⟨⟩)

    ed_eff1 ∈ Effect = (ed_cur_act = 1 ?
            (ed_cur_step = 0 ? ede_nsym
            : ed_cur_step = 1 ? ede_rsym
            : ed_cur_step = 2 ? ede_fsym0
            : ed_cur_step = 3 ? ede_fsym1
            : ed_cur_step = 4 ? ede_fsym2
            : ed_cur_step = 6 ? ede_mkctor
            : edw_ctor)
        : ed_cur_act = 2 ?
            (ed_cur_step = 0 ? ede_ssym
            : ed_cur_step = 1 ? ede_clist
            : ed_cur_step = 3 ? ede_mkdt
            : ed_cur_step = 4 ? ede_rdsort
            : ede_filler)
        : ed_cur_act = 3 ?
            (ed_cur_step = 0 ? ede_rdctor
            : ed_cur_step = 1 ? ede_query
            : ed_cur_step = 2 ? ede_rddecl
            : ed_cur_step = 3 ? (ed_nullary ? ede_app0 : ede_filler)
            : ede_filler)
        : ede_filler)
    ed_w5 ∈ Bool = (ed_cur_act = 1 ∧ ed_cur_step = 5)
    ed_w2 ∈ Bool = (ed_cur_act = 2 ∧ ed_cur_step = 2)

    -- ZINIT effects (one per zstep).
    ze_cfg ∈ Effect
    BuildZ3MkConfig(eff ↦ ze_cfg)
    ze_ctx ∈ Effect
    BuildZ3MkContext(cfg_h ↦ z_cfg, eff ↦ ze_ctx)
    ze_sol ∈ Effect
    BuildZ3MkSolver(ctx_h ↦ z_ctx, eff ↦ ze_sol)
    ze_sinc ∈ Effect
    BuildZ3SolverIncRef(ctx_h ↦ z_ctx, solver_h ↦ z_sol, eff ↦ ze_sinc)
    ze_isort ∈ Effect
    BuildZ3MkIntSort(ctx_h ↦ z_ctx, eff ↦ ze_isort)
    ze_bsort ∈ Effect
    BuildZ3MkBoolSort(ctx_h ↦ z_ctx, eff ↦ ze_bsort)
    ze_ssort ∈ Effect
    BuildZ3MkStringSort(ctx_h ↦ z_ctx, eff ↦ ze_ssort)
    ze_rsort ∈ Effect
    BuildZ3MkRealSort(ctx_h ↦ z_ctx, eff ↦ ze_rsort)
    ze_arena ∈ Effect
    BuildMalloc(n_bytes ↦ 512, eff ↦ ze_arena)
    ze_arrsort ∈ Effect
    BuildZ3MkArraySort(ctx_h ↦ z_ctx, idx_sort_h ↦ z_isort,
        val_sort_h ↦ z_effsort, eff ↦ ze_arrsort)
    ze_sym_effs ∈ Effect
    BuildZ3MkStringSymbol(ctx_h ↦ z_ctx, name ↦ "effects", eff ↦ ze_sym_effs)
    ze_effs ∈ Effect
    BuildZ3MkConst(ctx_h ↦ z_ctx, sym_h ↦ z_sym_effs, sort_h ↦ z_arrsort,
        eff ↦ ze_effs)
    ze_sym_elen ∈ Effect
    BuildZ3MkStringSymbol(ctx_h ↦ z_ctx, name ↦ "effects__len", eff ↦ ze_sym_elen)
    ze_elen ∈ Effect
    BuildZ3MkConst(ctx_h ↦ z_ctx, sym_h ↦ z_sym_elen, sort_h ↦ z_isort,
        eff ↦ ze_elen)
    ze_zero ∈ Effect
    BuildZ3MkInt(ctx_h ↦ z_ctx, val ↦ 0, sort_h ↦ z_isort, eff ↦ ze_zero)
    ze_one ∈ Effect
    BuildZ3MkInt(ctx_h ↦ z_ctx, val ↦ 1, sort_h ↦ z_isort, eff ↦ ze_one)
    ze_two ∈ Effect
    BuildZ3MkInt(ctx_h ↦ z_ctx, val ↦ 2, sort_h ↦ z_isort, eff ↦ ze_two)
    ze_true ∈ Effect
    BuildZ3MkTrue(ctx_h ↦ z_ctx, eff ↦ ze_true)
    ze_false ∈ Effect
    BuildZ3MkFalse(ctx_h ↦ z_ctx, eff ↦ ze_false)
    -- FTI token buffer: 4096 entries × 32 bytes, calloc'd (zeroed
    -- slots ⇒ deterministic nullary payloads + EofTok past the end).
    ze_tbuf ∈ Effect = LibCall("libc", "calloc", ⟨ArgInt(4096), ArgInt(32)⟩)

    -- ── LEX (fossil FSM; gated to start after ZINIT) ──────────────
    pos  ∈ Int
    _pos ∈ Int
    next_pos  ∈ Int
    _next_pos ∈ Int
    pos = (is_first_tick ? 0 - 1
        : ((¬_got_path) ? 0 - 1
        : (_zstep < 21 ? 0 - 1
        : (_pos < 0 ? 0 : _next_pos))))

    partial_str  ∈ String
    _partial_str ∈ String
    partial_int  ∈ Int
    _partial_int ∈ Int

    cur_char ∈ String = substr(input, pos, 1)

    is_alpha ∈ Bool
    IsAlphaChar(c ↦ cur_char, out ↦ is_alpha)
    is_dig ∈ Bool
    IsDigitChar(c ↦ cur_char, out ↦ is_dig)
    is_ws ∈ Bool
    IsWhitespace(c ↦ cur_char, out ↦ is_ws)
    is_quote ∈ Bool
    IsQuote(c ↦ cur_char, out ↦ is_quote)
    cc_tag ∈ Int
    is_op ∈ Bool
    LexCharTag(c ↦ cur_char, tag ↦ cc_tag, recognized ↦ is_op)
    dig_val ∈ Int
    DigitToInt(c ↦ cur_char, n ↦ dig_val)

    done ∈ Bool = ((pos ≥ #input) ∧ (#input > 0))
    in_range ∈ Bool = ((pos ≥ 0) ∧ ¬done)

    was_collecting_str ∈ Bool = (#_partial_str > 0)
    was_collecting_int ∈ Bool = (_partial_int ≥ 0)

    in_strlit  ∈ Bool
    _in_strlit ∈ Bool
    partial_strlit  ∈ String
    _partial_strlit ∈ String

    -- A2 (gap census): escape-pending mode. `\` inside a strlit
    -- appends nothing and arms esc_pend; the NEXT char appends its
    -- EscapeChar translation (\t \n \" \\ → the real byte — the
    -- legacy lexer's table, runtime/src/lexer.rs). An escaped quote
    -- does NOT close the literal. Unknown escapes pass the char
    -- through (the oracle lex-errors; the driver has no error
    -- channel — the corpus only carries the four).
    is_bs ∈ Bool
    IsBackslash(c ↦ cur_char, out ↦ is_bs)
    esc_tr ∈ String
    EscapeChar(c ↦ cur_char, out ↦ esc_tr)
    esc_pend ∈ Bool
    _esc_pend ∈ Bool

    strlit_open       ∈ Bool = ((¬_in_strlit) ∧ is_quote ∧ in_range ∧ (¬was_collecting_str) ∧ (¬was_collecting_int))
    strlit_esc_open   ∈ Bool = (_in_strlit ∧ (¬_esc_pend) ∧ is_bs ∧ in_range)
    strlit_esc_char   ∈ Bool = (_in_strlit ∧ _esc_pend ∧ in_range)
    strlit_continuing ∈ Bool = (_in_strlit ∧ (¬_esc_pend) ∧ (¬is_quote) ∧ (¬is_bs) ∧ in_range)
    strlit_closing    ∈ Bool = (_in_strlit ∧ (¬_esc_pend) ∧ is_quote ∧ in_range)

    esc_pend = (is_first_tick ? false : strlit_esc_open)
    in_strlit = (is_first_tick ? false
        : (strlit_open ? true
        : (strlit_closing ? false
        : _in_strlit)))
    partial_strlit = (is_first_tick ? ""
        : (strlit_open ? ""
        : (strlit_esc_char ? _partial_strlit ++ esc_tr
        : (strlit_continuing ? _partial_strlit ++ cur_char
        : (strlit_closing ? ""
        : _partial_strlit)))))

    -- A1 (gap census): idents continue through digits — `t0`, `r_l1`,
    -- `cs_t2` lex as single Idents (the legacy lexer's
    -- is_ident_continue = alnum + `_`). A digit only STARTS an int
    -- when no ident is collecting; an int finishing at an alpha char
    -- pushes the IntLit and the ident starts the same tick
    -- (`10x` → IntLit(10) + Ident("x"), oracle-probed).
    is_alnum ∈ Bool = (is_alpha ∨ is_dig)
    str_continuing ∈ Bool = (was_collecting_str ∧ is_alnum ∧ in_range ∧ ¬_in_strlit)
    str_finishing  ∈ Bool = (was_collecting_str ∧ ((¬is_alnum ∧ in_range) ∨ done))
    str_starting   ∈ Bool = ((¬was_collecting_str) ∧ is_alpha ∧ in_range ∧ ¬_in_strlit)

    int_continuing ∈ Bool = (was_collecting_int ∧ is_dig ∧ in_range ∧ ¬_in_strlit)
    int_finishing  ∈ Bool = (was_collecting_int ∧ ((¬is_dig ∧ in_range) ∨ done))
    int_starting   ∈ Bool = ((¬was_collecting_int) ∧ (¬was_collecting_str) ∧ is_dig ∧ in_range ∧ ¬_in_strlit)

    partial_str = (is_first_tick ? "" : (str_continuing ? _partial_str ++ cur_char : (str_starting ? cur_char : "")))
    partial_int = (is_first_tick ? 0 - 1 : (int_continuing ? (_partial_int * 10) + dig_val : (int_starting ? dig_val : 0 - 1)))

    finish_str_only    ∈ Bool = (str_finishing ∧ (is_ws ∨ done))
    finish_int_only    ∈ Bool = (int_finishing ∧ (is_ws ∨ done ∨ is_alpha))
    finish_str_with_op ∈ Bool = (str_finishing ∧ is_op ∧ in_range)
    finish_int_with_op ∈ Bool = (int_finishing ∧ is_op ∧ in_range)
    char_only          ∈ Bool = ((¬was_collecting_str) ∧ (¬was_collecting_int) ∧ is_op ∧ in_range ∧ ¬_in_strlit)

    -- FTI lexer state: five Ints, no TokenList. The negative-literal
    -- fold (`= -3` folds, `10 - 2` stays binary) is decided inside
    -- LexFtiPlan from the cached lx_last/lx_prev tag pair.
    lx_count ∈ Int
    _lx_count ∈ Int
    lx_last ∈ Int
    _lx_last ∈ Int
    lx_prev ∈ Int
    _lx_prev ∈ Int
    lx_pend ∈ Int
    _lx_pend ∈ Int

    k_kind ∈ Int
    k_tag0 ∈ Int
    k_p0 ∈ Int
    k_str0 ∈ String
    k_tag1 ∈ Int
    k_atag0 ∈ Int
    k_ap0 ∈ Int
    k_atag1 ∈ Int
    k_cn ∈ Int
    k_ln ∈ Int
    k_pn ∈ Int
    LexFtiPlan(lx_comment ↦ lx_comment, strlit_closing ↦ strlit_closing,
        fs_op ↦ finish_str_with_op, fi_op ↦ finish_int_with_op,
        fs_only ↦ finish_str_only, fi_only ↦ finish_int_only,
        ch_only ↦ char_only,
        cur_char ↦ cur_char, partial_str ↦ _partial_str,
        partial_strlit ↦ _partial_strlit, partial_int ↦ _partial_int,
        base ↦ tbase, count ↦ _lx_count,
        last_tag ↦ _lx_last, prev_tag ↦ _lx_prev,
        kind ↦ k_kind, tag0 ↦ k_tag0, p0 ↦ k_p0, str0 ↦ k_str0,
        tag1 ↦ k_tag1, a_tag0 ↦ k_atag0, a_p0 ↦ k_ap0, a_tag1 ↦ k_atag1,
        count_n ↦ k_cn, last_n ↦ k_ln, prev_n ↦ k_pn)

    -- `++` (PlusPlus, tag 60): a two-char ASCII token the per-char
    -- scanner can't see. Detected by peeking the next char (same
    -- trick as the `--` comment); the written op tag is overridden
    -- 8 → 60 and the scan advances 2.
    lx_pp ∈ Bool = ((cur_char = "+") ∧ (lx_next_char = "+")
        ∧ in_range ∧ (¬_in_strlit))
    k_tag0pp ∈ Int = ((lx_pp ∧ k_kind = 1) ? 60 : k_tag0)
    k_tag1pp ∈ Int = ((lx_pp ∧ (k_kind = 4 ∨ k_kind = 5 ∨ k_kind = 6))
        ? 60 : k_tag1)

    lx_count = (is_first_tick ? 0 : k_cn)
    lx_last = (is_first_tick ? 0
        : (lx_pp ∧ k_kind ≠ 0) ? 60
        : k_ln)
    lx_prev = (is_first_tick ? 0 : k_pn)
    lx_pend = (is_first_tick ? 0 - 1
        : ((k_kind = 3 ∨ k_kind = 5) ? k_ap0 : 0 - 1))
    lx_have_pend ∈ Bool = (_lx_pend ≥ 0)

    w_tag0e ∈ Effect = LibCall("__mem", "write_long", ⟨ArgInt(k_atag0), ArgInt(k_tag0pp)⟩)
    w_p0e   ∈ Effect = LibCall("__mem", "write_long", ⟨ArgInt(k_ap0), ArgInt(k_p0)⟩)
    w_tag1e ∈ Effect = LibCall("__mem", "write_long", ⟨ArgInt(k_atag1), ArgInt(k_tag1pp)⟩)
    e_dup   ∈ Effect = LibCall("libc", "strdup", ⟨ArgStr(k_str0)⟩)
    w_pend  ∈ Effect = LibCall("__mem", "write_long", ⟨ArgInt(_lx_pend), ArgInt(d_cap_int)⟩)
    w_eof   ∈ Effect = LibCall("__mem", "write_long", ⟨ArgInt(tbase + (lx_count * 32)), ArgInt(13)⟩)

    has_input ∈ Bool = (#input > 0)
    lex_done ∈ Bool = (done ∧ ¬was_collecting_str ∧ ¬was_collecting_int ∧ ¬_in_strlit ∧ has_input)

    lx_next_char ∈ String = substr(input, pos + 1, 1)
    lx_collecting ∈ Bool = (was_collecting_str ∨ was_collecting_int)
    lx_is_dash    ∈ Bool = (cur_char = "-")
    lx_next_dash  ∈ Bool = (lx_next_char = "-")
    lx_comment ∈ Bool = (lx_is_dash ∧ lx_next_dash ∧ in_range ∧ (¬lx_collecting) ∧ (¬_in_strlit))
    lx_nl ∈ Int = index_of(input, "\n", pos)
    lx_comment_to ∈ Int = (lx_nl < 0 ? #input : lx_nl)
    lx_skip_ws ∈ Bool = (is_ws ∧ in_range ∧ (¬_in_strlit))
    lx_ws_adv ∈ Int
    WsRunLen(s ↦ input, p ↦ pos, adv ↦ lx_ws_adv)
    next_pos = (is_first_tick ? 0
        : (lx_comment ? lx_comment_to
        : (lx_skip_ws ? pos + lx_ws_adv
        : (lx_pp ? pos + 2
        : pos + 1))))

    -- ── PHASE control (0 lex · 2 parse · 3 emit; REVERSE deleted) ─
    phase  ∈ Int
    _phase ∈ Int

    -- entering_parse = the lex_done tick: flush any pending string
    -- write, write the EofTok sentinel, then parse starts next tick.
    entering_parse ∈ Bool = ((¬is_first_tick) ∧ (_phase = 0) ∧ lex_done)
    in_parse       ∈ Bool = (_phase = 2)

    -- ── TOKEN WINDOW (FTI cursor + 8-token decoded window) ────────
    -- The parse phases never hold an unbounded TokenList: tcur is
    -- the absolute index of the next unconsumed token; wtoks is a
    -- decoded window of the 8 buffer entries starting at tcur
    -- (entries past the sentinel decode to EofTok); wend is the
    -- buffer index one past the fetched coverage. A consumer may
    -- only act when the window holds its lookahead need (w_need);
    -- otherwise the 3-tick fetch burst refills from tcur.
    tcur ∈ Int
    _tcur ∈ Int
    wend ∈ Int
    _wend ∈ Int
    fmode ∈ Int
    _fmode ∈ Int
    wtoks ∈ TokenList
    _wtoks ∈ TokenList

    w_rem ∈ Int = _wend - _tcur

    -- latched tags/payloads between the read tick and the copy tick
    wt0 ∈ Int
    _wt0 ∈ Int
    wt1 ∈ Int
    _wt1 ∈ Int
    wt2 ∈ Int
    _wt2 ∈ Int
    wt3 ∈ Int
    _wt3 ∈ Int
    wt4 ∈ Int
    _wt4 ∈ Int
    wt5 ∈ Int
    _wt5 ∈ Int
    wt6 ∈ Int
    _wt6 ∈ Int
    wt7 ∈ Int
    _wt7 ∈ Int
    wq0 ∈ Int
    _wq0 ∈ Int
    wq1 ∈ Int
    _wq1 ∈ Int
    wq2 ∈ Int
    _wq2 ∈ Int
    wq3 ∈ Int
    _wq3 ∈ Int
    wq4 ∈ Int
    _wq4 ∈ Int
    wq5 ∈ Int
    _wq5 ∈ Int
    wq6 ∈ Int
    _wq6 ∈ Int
    wq7 ∈ Int
    _wq7 ∈ Int

    f_ir0 ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir1 ∈ Int = match last_results[1]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir2 ∈ Int = match last_results[2]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir3 ∈ Int = match last_results[3]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir4 ∈ Int = match last_results[4]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir5 ∈ Int = match last_results[5]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir6 ∈ Int = match last_results[6]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir7 ∈ Int = match last_results[7]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir8 ∈ Int = match last_results[8]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir9 ∈ Int = match last_results[9]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir10 ∈ Int = match last_results[10]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir11 ∈ Int = match last_results[11]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir12 ∈ Int = match last_results[12]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir13 ∈ Int = match last_results[13]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir14 ∈ Int = match last_results[14]
        IntResult(n) ⇒ n
        _ ⇒ 0
    f_ir15 ∈ Int = match last_results[15]
        IntResult(n) ⇒ n
        _ ⇒ 0

    f_cap ∈ Bool = (_fmode = 1)
    wt0 = (is_first_tick ? 0 : f_cap ? f_ir0 : _wt0)
    wq0 = (is_first_tick ? 0 : f_cap ? f_ir1 : _wq0)
    wt1 = (is_first_tick ? 0 : f_cap ? f_ir2 : _wt1)
    wq1 = (is_first_tick ? 0 : f_cap ? f_ir3 : _wq1)
    wt2 = (is_first_tick ? 0 : f_cap ? f_ir4 : _wt2)
    wq2 = (is_first_tick ? 0 : f_cap ? f_ir5 : _wq2)
    wt3 = (is_first_tick ? 0 : f_cap ? f_ir6 : _wt3)
    wq3 = (is_first_tick ? 0 : f_cap ? f_ir7 : _wq3)
    wt4 = (is_first_tick ? 0 : f_cap ? f_ir8 : _wt4)
    wq4 = (is_first_tick ? 0 : f_cap ? f_ir9 : _wq4)
    wt5 = (is_first_tick ? 0 : f_cap ? f_ir10 : _wt5)
    wq5 = (is_first_tick ? 0 : f_cap ? f_ir11 : _wq5)
    wt6 = (is_first_tick ? 0 : f_cap ? f_ir12 : _wt6)
    wq6 = (is_first_tick ? 0 : f_cap ? f_ir13 : _wq6)
    wt7 = (is_first_tick ? 0 : f_cap ? f_ir14 : _wt7)
    wq7 = (is_first_tick ? 0 : f_cap ? f_ir15 : _wq7)

    -- copy-tick effects: slot-aligned — a string-carrying slot emits
    -- __cstr.copy of its just-captured pointer; every other slot a
    -- getpid filler, so slot i's result is last_results[i] exactly.
    f_s0 ∈ Bool = (f_ir0 = 1 ∨ f_ir0 = 3)
    f_s1 ∈ Bool = (f_ir2 = 1 ∨ f_ir2 = 3)
    f_s2 ∈ Bool = (f_ir4 = 1 ∨ f_ir4 = 3)
    f_s3 ∈ Bool = (f_ir6 = 1 ∨ f_ir6 = 3)
    f_s4 ∈ Bool = (f_ir8 = 1 ∨ f_ir8 = 3)
    f_s5 ∈ Bool = (f_ir10 = 1 ∨ f_ir10 = 3)
    f_s6 ∈ Bool = (f_ir12 = 1 ∨ f_ir12 = 3)
    f_s7 ∈ Bool = (f_ir14 = 1 ∨ f_ir14 = 3)
    cp0 ∈ Effect = (f_s0 ? LibCall("__cstr", "copy", ⟨ArgInt(f_ir1)⟩) : LibCall("libc", "getpid", ⟨⟩))
    cp1 ∈ Effect = (f_s1 ? LibCall("__cstr", "copy", ⟨ArgInt(f_ir3)⟩) : LibCall("libc", "getpid", ⟨⟩))
    cp2 ∈ Effect = (f_s2 ? LibCall("__cstr", "copy", ⟨ArgInt(f_ir5)⟩) : LibCall("libc", "getpid", ⟨⟩))
    cp3 ∈ Effect = (f_s3 ? LibCall("__cstr", "copy", ⟨ArgInt(f_ir7)⟩) : LibCall("libc", "getpid", ⟨⟩))
    cp4 ∈ Effect = (f_s4 ? LibCall("__cstr", "copy", ⟨ArgInt(f_ir9)⟩) : LibCall("libc", "getpid", ⟨⟩))
    cp5 ∈ Effect = (f_s5 ? LibCall("__cstr", "copy", ⟨ArgInt(f_ir11)⟩) : LibCall("libc", "getpid", ⟨⟩))
    cp6 ∈ Effect = (f_s6 ? LibCall("__cstr", "copy", ⟨ArgInt(f_ir13)⟩) : LibCall("libc", "getpid", ⟨⟩))
    cp7 ∈ Effect = (f_s7 ? LibCall("__cstr", "copy", ⟨ArgInt(f_ir15)⟩) : LibCall("libc", "getpid", ⟨⟩))

    f_sr0 ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""
    f_sr1 ∈ String = match last_results[1]
        StringResult(s) ⇒ s
        _ ⇒ ""
    f_sr2 ∈ String = match last_results[2]
        StringResult(s) ⇒ s
        _ ⇒ ""
    f_sr3 ∈ String = match last_results[3]
        StringResult(s) ⇒ s
        _ ⇒ ""
    f_sr4 ∈ String = match last_results[4]
        StringResult(s) ⇒ s
        _ ⇒ ""
    f_sr5 ∈ String = match last_results[5]
        StringResult(s) ⇒ s
        _ ⇒ ""
    f_sr6 ∈ String = match last_results[6]
        StringResult(s) ⇒ s
        _ ⇒ ""
    f_sr7 ∈ String = match last_results[7]
        StringResult(s) ⇒ s
        _ ⇒ ""

    f_tok0 ∈ Token
    FtiTok(tag ↦ _wt0, p0 ↦ _wq0, s ↦ f_sr0, t ↦ f_tok0)
    f_tok1 ∈ Token
    FtiTok(tag ↦ _wt1, p0 ↦ _wq1, s ↦ f_sr1, t ↦ f_tok1)
    f_tok2 ∈ Token
    FtiTok(tag ↦ _wt2, p0 ↦ _wq2, s ↦ f_sr2, t ↦ f_tok2)
    f_tok3 ∈ Token
    FtiTok(tag ↦ _wt3, p0 ↦ _wq3, s ↦ f_sr3, t ↦ f_tok3)
    f_tok4 ∈ Token
    FtiTok(tag ↦ _wt4, p0 ↦ _wq4, s ↦ f_sr4, t ↦ f_tok4)
    f_tok5 ∈ Token
    FtiTok(tag ↦ _wt5, p0 ↦ _wq5, s ↦ f_sr5, t ↦ f_tok5)
    f_tok6 ∈ Token
    FtiTok(tag ↦ _wt6, p0 ↦ _wq6, s ↦ f_sr6, t ↦ f_tok6)
    f_tok7 ∈ Token
    FtiTok(tag ↦ _wt7, p0 ↦ _wq7, s ↦ f_sr7, t ↦ f_tok7)
    f_built ∈ TokenList = TLCons(f_tok0, TLCons(f_tok1, TLCons(f_tok2,
        TLCons(f_tok3, TLCons(f_tok4, TLCons(f_tok5, TLCons(f_tok6,
        TLCons(f_tok7, TLNil))))))))

    -- window views (head + lookahead, ≤ depth 5 inspected)
    ww_t0 ∈ Token = match _wtoks
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    ww_l1 ∈ TokenList = match _wtoks
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    ww_t1 ∈ Token = match ww_l1
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    ww_l2 ∈ TokenList = match ww_l1
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    ww_t2 ∈ Token = match ww_l2
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    ww_l3 ∈ TokenList = match ww_l2
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    ww_t3 ∈ Token = match ww_l3
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    ww_l4 ∈ TokenList = match ww_l3
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    ww_t4 ∈ Token = match ww_l4
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    ww_l5 ∈ TokenList = match ww_l4
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    ww_t5 ∈ Token = match ww_l5
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    ww_l6 ∈ TokenList = match ww_l5
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    ww_t6 ∈ Token = match ww_l6
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    ww_l7 ∈ TokenList = match ww_l6
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil

    -- per-mode lookahead need; gate + fetch trigger. pmode 4 only
    -- reads tokens while COLLECTING variant names (the ED machine,
    -- once started, consumes none); pmode 5 (effects elements) may
    -- need the full window for the LibCall bites.
    w_need ∈ Int = (¬in_parse ? 0
        : _pmode = 0 ? 3
        : _pmode = 1 ? 1
        : _pmode = 3 ? 1
        : _pmode = 4 ? (_ed_act = 0 ? 2 : 0)
        : _pmode = 5 ? (d_witems_nil ? 8 : 0)
        : d_witems_nil ? 5
        : 0)
    tok_ready ∈ Bool = ((_fmode = 0) ∧ (w_need > 0) ∧ (w_rem ≥ w_need))
    fetch_go ∈ Bool = ((_fmode = 0) ∧ (w_need > 0) ∧ (w_rem < w_need))

    fmode = (is_first_tick ? 0
        : fetch_go ? 1
        : _fmode = 1 ? 2
        : 0)

    f_a ∈ Int = tbase + (_tcur * 32)
    rd_t0 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a)⟩)
    rd_q0 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 8)⟩)
    rd_t1 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 32)⟩)
    rd_q1 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 40)⟩)
    rd_t2 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 64)⟩)
    rd_q2 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 72)⟩)
    rd_t3 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 96)⟩)
    rd_q3 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 104)⟩)
    rd_t4 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 128)⟩)
    rd_q4 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 136)⟩)
    rd_t5 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 160)⟩)
    rd_q5 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 168)⟩)
    rd_t6 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 192)⟩)
    rd_q6 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 200)⟩)
    rd_t7 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 224)⟩)
    rd_q7 ∈ Effect = LibCall("__mem", "read_long", ⟨ArgInt(f_a + 232)⟩)

    -- ── PARSE dispatch (pmode 0 dispatch · 1 skip · 2 claim) ──────
    -- All modes read the shared token window; "nil" = EofTok head
    -- (the sentinel / past-end decode). Actions are tok_ready-gated.
    pmode  ∈ Int
    _pmode ∈ Int

    d_items_nil ∈ Bool = (ww_t0 matches EofTok)
    d_head_is_claim ∈ Bool = (ww_t0 matches KwClaim)
    d_cl_name ∈ String = match ww_t1
        Ident(s) ⇒ s
        _ ⇒ ""
    d_name_ok ∈ Bool = (d_cl_name = target)
    d_is_param ∈ Bool = (ww_t2 matches LParen)

    -- user enum declarations: a KwEnum head whose name is NOT one
    -- of the floor enums already declared at ZINIT enters the
    -- collection mode (pmode 4) instead of the skip walk. One user
    -- enum per compile (ue_done gates re-entry); nullary variants
    -- only (a LParen after a variant name bails to skip).
    d_head_is_enum ∈ Bool = (ww_t0 matches KwEnum)
    d_en_reserved ∈ Bool = (d_cl_name = "Effect" ∨ d_cl_name = "Result"
        ∨ d_cl_name = "LibArg")

    d_in_dispatch ∈ Bool = (in_parse ∧ (_pmode = 0) ∧ tok_ready)
    d_enter_claim ∈ Bool = (d_in_dispatch ∧ (¬d_items_nil) ∧ d_head_is_claim ∧ d_name_ok ∧ (¬d_is_param))
    d_enter_edecl ∈ Bool = (d_in_dispatch ∧ (¬d_items_nil)
        ∧ d_head_is_enum ∧ (¬d_en_reserved) ∧ (¬_ue_done)
        ∧ (ww_t1 matches Ident(_)) ∧ (ww_t2 matches Eq))
    d_enter_skip  ∈ Bool = (d_in_dispatch ∧ (¬d_items_nil) ∧ (¬d_enter_claim) ∧ (¬d_enter_edecl))
    d_all_done    ∈ Bool = (d_in_dispatch ∧ d_items_nil)
    d_in_skip     ∈ Bool = (in_parse ∧ (_pmode = 1) ∧ tok_ready)
    d_in_claim    ∈ Bool = (in_parse ∧ (_pmode = 2))

    -- user enum name + done flag
    ue_name ∈ String
    _ue_name ∈ String
    ue_name = (is_first_tick ? "" : d_enter_edecl ? d_cl_name : _ue_name)
    ue_done ∈ Bool
    _ue_done ∈ Bool
    ue_done = (is_first_tick ? false : ed_done_user ? true : _ue_done)

    -- pmode 4 collection: one `Vname |` (or final `Vname`) per tick,
    -- prepend-accumulated (the declared variant order is REVERSED vs
    -- source — harmless: declaration and harvest peel the same list).
    ec_active ∈ Bool = (in_parse ∧ (_pmode = 4) ∧ (_ed_act = 0)
        ∧ (¬ed_done_user) ∧ tok_ready)
    ec_vname ∈ String = match ww_t0
        Ident(s) ⇒ s
        _ ⇒ ""
    ec_v_ok ∈ Bool = (ww_t0 matches Ident(_))
    ec_more ∈ Bool = (ww_t1 matches Pipe)
    ec_payload ∈ Bool = (ww_t1 matches LParen)
    ec_bail ∈ Bool = (ec_active ∧ (ec_payload ∨ (¬ec_v_ok)))
    ec_take ∈ Bool = (ec_active ∧ ec_v_ok ∧ (¬ec_payload))
    ec_start ∈ Bool = (ec_take ∧ (¬ec_more))
    ec_list ∈ EnumVariantList
    _ec_list ∈ EnumVariantList
    ec_list_n ∈ EnumVariantList = (ec_take
        ? EVCons(EVDecl(ec_vname), _ec_list) : _ec_list)
    ec_list = (is_first_tick ? EVNil
        : d_enter_edecl ? EVNil
        : ec_take ? ec_list_n
        : _ec_list)

    -- pmode 5: effects-literal element walk. Items run under pmode 5
    -- exactly as under the claim walk; this dispatcher fires only
    -- when the element items have drained.
    el_cnt ∈ Int
    _el_cnt ∈ Int
    el_lc ∈ Int
    _el_lc ∈ Int
    el_lib ∈ String
    _el_lib ∈ String
    el_fn ∈ String
    _el_fn ∈ String

    d_in_el ∈ Bool = (in_parse ∧ (_pmode = 5) ∧ d_witems_nil ∧ tok_ready)
    el_w_t2s ∈ String = match ww_t2
        StringLit(s) ⇒ s
        _ ⇒ ""
    el_w_t4s ∈ String = match ww_t4
        StringLit(s) ⇒ s
        _ ⇒ ""
    el_head_name ∈ String = match ww_t0
        Ident(s) ⇒ s
        _ ⇒ ""
    -- element dispatch (el_lc = 0)
    el_exit_enter ∈ Bool = (d_in_el ∧ (_el_lc = 0)
        ∧ (el_head_name = "Exit") ∧ (ww_t1 matches LParen))
    el_lc_enter ∈ Bool = (d_in_el ∧ (_el_lc = 0)
        ∧ (el_head_name = "LibCall") ∧ (ww_t1 matches LParen)
        ∧ (ww_t2 matches StringLit(_)) ∧ (ww_t3 matches Comma)
        ∧ (ww_t4 matches StringLit(_)) ∧ (ww_t5 matches Comma))
    el_comma ∈ Bool = (d_in_el ∧ (_el_lc = 0) ∧ (ww_t0 matches Comma))
    el_close ∈ Bool = (d_in_el ∧ (_el_lc = 0) ∧ (ww_t0 matches OpSeqClose))
    -- LibCall bite 2: `⟨ ArgStr ( X ) ⟩ )` with X a string literal,
    -- an ident, or an int literal (ArgInt).
    el_arg_name ∈ String = match ww_t1
        Ident(s) ⇒ s
        _ ⇒ ""
    el_arg_e ∈ Expr
    el_arg_ok ∈ Bool
    C2AtomE(t ↦ ww_t3, e ↦ el_arg_e, ok ↦ el_arg_ok)
    el_b2_shape ∈ Bool = ((ww_t0 matches OpSeqOpen)
        ∧ (ww_t1 matches Ident(_)) ∧ (ww_t2 matches LParen)
        ∧ el_arg_ok ∧ (ww_t4 matches RParen)
        ∧ (ww_t5 matches OpSeqClose) ∧ (ww_t6 matches RParen))
    el_b2 ∈ Bool = (d_in_el ∧ (_el_lc = 1) ∧ el_b2_shape)
    el_b2_bad ∈ Bool = (d_in_el ∧ (_el_lc = 1) ∧ (¬el_b2_shape))
    el_bad ∈ Bool = (d_in_el ∧ (_el_lc = 0)
        ∧ (¬el_exit_enter) ∧ (¬el_lc_enter) ∧ (¬el_comma) ∧ (¬el_close))
    el_argdecl ∈ Int = (el_arg_name = "ArgInt" ? z_argint_decl
        : z_argstr_decl)
    el_lc_items ∈ C2Items = C2ICons(C2Process(EStr(_el_lib)),
        C2ICons(C2Process(EStr(_el_fn)),
        C2ICons(C2Process(el_arg_e),
        C2ICons(C2App(el_argdecl, 1),
        C2ICons(C2PushH(z_empty_val),
        C2ICons(C2App(z_cell_decl, 2),
        C2ICons(C2App(z_lc_decl, 3),
        C2ICons(C2SelectEq(_el_cnt), C2INil))))))))

    el_lc = (is_first_tick ? 0
        : el_lc_enter ? 1
        : (el_b2 ∨ el_b2_bad) ? 0
        : _el_lc)
    el_lib = (is_first_tick ? "" : el_lc_enter ? el_w_t2s : _el_lib)
    el_fn = (is_first_tick ? "" : el_lc_enter ? el_w_t4s : _el_fn)
    el_cnt = (is_first_tick ? 0
        : d_enter_el ? 0
        : ((p_done ∧ (¬pr_bad) ∧ _pk_kind = 3) ∨ el_b2) ? _el_cnt + 1
        : _el_cnt)

    -- skip machine: walk one token per tick to the next top-level kw.
    d_skipl_nil ∈ Bool = (ww_t0 matches EofTok)
    d_skip_at_tlkw ∈ Bool = ((ww_t0 matches KwEnum) ∨ (ww_t0 matches KwClaim)
        ∨ (ww_t0 matches KwType) ∨ (ww_t0 matches KwFsm) ∨ (ww_t0 matches KwSchema))
    d_skip_stop ∈ Bool = (d_in_skip ∧ (d_skipl_nil ∨ d_skip_at_tlkw))

    -- ── CLAIM WALK state ──────────────────────────────────────────
    witems  ∈ C2Items
    _witems ∈ C2Items
    hstk  ∈ C2H
    _hstk ∈ C2H
    istep  ∈ Int
    _istep ∈ Int
    pend  ∈ Int
    _pend ∈ Int
    pend_name  ∈ String
    _pend_name ∈ String
    tmp_h  ∈ Int
    _tmp_h ∈ Int
    fstr  ∈ String
    _fstr ∈ String
    cdstr  ∈ String
    _cdstr ∈ String

    -- pend application (the capture tick of the previous builder).
    d_hstk_in ∈ C2H = ((_pend = 1 ∨ _pend = 3) ? C2HCons(d_cap_int, _hstk) : _hstk)
    d_tmp_in ∈ Int = (_pend = 2 ? d_cap_int : _tmp_h)
    tmp_h = (is_first_tick ? 0 : d_tmp_in)

    -- 8-slot symbol table; appended on decl completion (pend = 3).
    st_cnt  ∈ Int
    _st_cnt ∈ Int
    st_n0 ∈ String
    _st_n0 ∈ String
    st_h0 ∈ Int
    _st_h0 ∈ Int
    st_n1 ∈ String
    _st_n1 ∈ String
    st_h1 ∈ Int
    _st_h1 ∈ Int
    st_n2 ∈ String
    _st_n2 ∈ String
    st_h2 ∈ Int
    _st_h2 ∈ Int
    st_n3 ∈ String
    _st_n3 ∈ String
    st_h3 ∈ Int
    _st_h3 ∈ Int
    st_n4 ∈ String
    _st_n4 ∈ String
    st_h4 ∈ Int
    _st_h4 ∈ Int
    st_n5 ∈ String
    _st_n5 ∈ String
    st_h5 ∈ Int
    _st_h5 ∈ Int
    st_n6 ∈ String
    _st_n6 ∈ String
    st_h6 ∈ Int
    _st_h6 ∈ Int
    st_n7 ∈ String
    _st_n7 ∈ String
    st_h7 ∈ Int
    _st_h7 ∈ Int
    d_st_add ∈ Bool = (_pend = 3)
    st_cnt = (is_first_tick ? 0 : (d_st_add ? _st_cnt + 1 : _st_cnt))
    st_n0 = (is_first_tick ? "" : (d_st_add ∧ (_st_cnt = 0) ? _pend_name : _st_n0))
    st_h0 = (is_first_tick ? 0 : (d_st_add ∧ (_st_cnt = 0) ? d_cap_int : _st_h0))
    st_n1 = (is_first_tick ? "" : (d_st_add ∧ (_st_cnt = 1) ? _pend_name : _st_n1))
    st_h1 = (is_first_tick ? 0 : (d_st_add ∧ (_st_cnt = 1) ? d_cap_int : _st_h1))
    st_n2 = (is_first_tick ? "" : (d_st_add ∧ (_st_cnt = 2) ? _pend_name : _st_n2))
    st_h2 = (is_first_tick ? 0 : (d_st_add ∧ (_st_cnt = 2) ? d_cap_int : _st_h2))
    st_n3 = (is_first_tick ? "" : (d_st_add ∧ (_st_cnt = 3) ? _pend_name : _st_n3))
    st_h3 = (is_first_tick ? 0 : (d_st_add ∧ (_st_cnt = 3) ? d_cap_int : _st_h3))
    st_n4 = (is_first_tick ? "" : (d_st_add ∧ (_st_cnt = 4) ? _pend_name : _st_n4))
    st_h4 = (is_first_tick ? 0 : (d_st_add ∧ (_st_cnt = 4) ? d_cap_int : _st_h4))
    st_n5 = (is_first_tick ? "" : (d_st_add ∧ (_st_cnt = 5) ? _pend_name : _st_n5))
    st_h5 = (is_first_tick ? 0 : (d_st_add ∧ (_st_cnt = 5) ? d_cap_int : _st_h5))
    st_n6 = (is_first_tick ? "" : (d_st_add ∧ (_st_cnt = 6) ? _pend_name : _st_n6))
    st_h6 = (is_first_tick ? 0 : (d_st_add ∧ (_st_cnt = 6) ? d_cap_int : _st_h6))
    st_n7 = (is_first_tick ? "" : (d_st_add ∧ (_st_cnt = 7) ? _pend_name : _st_n7))
    st_h7 = (is_first_tick ? 0 : (d_st_add ∧ (_st_cnt = 7) ? d_cap_int : _st_h7))

    -- handle-stack views (post pend application).
    d_h_top ∈ Int = match d_hstk_in
        C2HCons(h, _) ⇒ h
        C2HNil ⇒ 0
    d_h_t1 ∈ C2H = match d_hstk_in
        C2HCons(_, r) ⇒ r
        C2HNil ⇒ C2HNil
    d_h_2nd ∈ Int = match d_h_t1
        C2HCons(h, _) ⇒ h
        C2HNil ⇒ 0
    d_h_t2 ∈ C2H = match d_h_t1
        C2HCons(_, r) ⇒ r
        C2HNil ⇒ C2HNil
    d_h_3rd ∈ Int = match d_h_t2
        C2HCons(h, _) ⇒ h
        C2HNil ⇒ 0
    d_h_t3 ∈ C2H = match d_h_t2
        C2HCons(_, r) ⇒ r
        C2HNil ⇒ C2HNil

    -- current work item.
    d_witems_nil ∈ Bool = match _witems
        C2INil ⇒ true
        _ ⇒ false
    d_whead ∈ C2Item = match _witems
        C2ICons(h, _) ⇒ h
        C2INil ⇒ C2Drop
    d_wtail ∈ C2Items = match _witems
        C2ICons(_, r) ⇒ r
        C2INil ⇒ C2INil

    d_classify   ∈ Bool = (d_in_claim ∧ d_witems_nil ∧ tok_ready)
    -- items drain identically under the claim walk and the effects
    -- element walk (pmode 5)
    d_processing ∈ Bool = ((d_in_claim ∨ (in_parse ∧ (_pmode = 5)))
        ∧ (¬d_witems_nil))

    d_it_proc    ∈ Bool = (d_whead matches C2Process(_))
    d_it_op      ∈ Bool = (d_whead matches C2Op(_))
    d_it_ite     ∈ Bool = (d_whead matches C2Ite)
    d_it_not     ∈ Bool = (d_whead matches C2Not)
    d_it_decl    ∈ Bool = (d_whead matches C2DeclConst(_, _))
    d_it_nat     ∈ Bool = (d_whead matches C2NatBound)
    d_it_pineq   ∈ Bool = (d_whead matches C2PinEq)
    d_it_assert  ∈ Bool = (d_whead matches C2AssertTop)
    d_it_drop    ∈ Bool = (d_whead matches C2Drop)
    d_it_pushh   ∈ Bool = (d_whead matches C2PushH(_))
    d_it_app     ∈ Bool = (d_whead matches C2App(_, _))
    d_it_seleq   ∈ Bool = (d_whead matches C2SelectEq(_))
    d_it_leneq   ∈ Bool = (d_whead matches C2LenEq(_))

    d_pe ∈ Expr = match d_whead
        C2Process(e) ⇒ e
        _ ⇒ ENoExpr
    d_op ∈ Op = match d_whead
        C2Op(o) ⇒ o
        _ ⇒ OpPlus
    d_dc_name ∈ String = match d_whead
        C2DeclConst(n, _) ⇒ n
        _ ⇒ ""
    d_dc_sc ∈ Int = match d_whead
        C2DeclConst(_, s) ⇒ s
        _ ⇒ 0
    d_ph_h ∈ Int = match d_whead
        C2PushH(h) ⇒ h
        _ ⇒ 0
    d_app_d ∈ Int = match d_whead
        C2App(h, _) ⇒ h
        _ ⇒ 0
    d_app_n ∈ Int = match d_whead
        C2App(_, n) ⇒ n
        _ ⇒ 0
    d_sel_i ∈ Int = match d_whead
        C2SelectEq(i) ⇒ i
        _ ⇒ 0
    d_len_n ∈ Int = match d_whead
        C2LenEq(n) ⇒ n
        _ ⇒ 0

    -- Expr-node decomposition via the pass claims.
    d_pe_is_int ∈ Bool = (d_pe matches EInt(_))
    d_pe_is_id  ∈ Bool = (d_pe matches EIdent(_))
    d_pe_is_str ∈ Bool = (d_pe matches EStr(_))
    d_pe_str ∈ String = match d_pe
        EStr(s) ⇒ s
        _ ⇒ ""
    d_lkname ∈ String = match d_pe
        EIdent(s) ⇒ s
        _ ⇒ ""
    d_pe_op ∈ Op
    d_pe_l ∈ Expr
    d_pe_r ∈ Expr
    d_pe_is_bin ∈ Bool
    BoolExprBinopParts(e ↦ d_pe, op ↦ d_pe_op, lhs ↦ d_pe_l,
        rhs ↦ d_pe_r, is_binop ↦ d_pe_is_bin)
    d_pe_c ∈ Expr
    d_pe_t ∈ Expr
    d_pe_e ∈ Expr
    d_pe_is_tern ∈ Bool
    TernaryExprParts(e ↦ d_pe, cond_e ↦ d_pe_c, then_e ↦ d_pe_t,
        else_e ↦ d_pe_e, is_tern ↦ d_pe_is_tern)
    d_pe_ni ∈ Expr
    d_pe_is_not ∈ Bool
    NotExprParts(e ↦ d_pe, inner ↦ d_pe_ni, is_not ↦ d_pe_is_not)
    d_pe_op_ne ∈ Bool = (d_pe_op matches OpNeq)

    -- symbol-table lookup (post-update slots: a decl completed this
    -- tick is visible to the same tick's item). true/false resolve to
    -- the cached Z3_mk_true/Z3_mk_false handles.
    d_lk ∈ Int = (d_lkname = "true" ? z_true
        : d_lkname = "false" ? z_false
        : st_n0 = d_lkname ? st_h0
        : st_n1 = d_lkname ? st_h1
        : st_n2 = d_lkname ? st_h2
        : st_n3 = d_lkname ? st_h3
        : st_n4 = d_lkname ? st_h4
        : st_n5 = d_lkname ? st_h5
        : st_n6 = d_lkname ? st_h6
        : st_n7 = d_lkname ? st_h7
        : evt_n0 = d_lkname ? evt_v0
        : evt_n1 = d_lkname ? evt_v1
        : evt_n2 = d_lkname ? evt_v2
        : evt_n3 = d_lkname ? evt_v3
        : evt_n4 = d_lkname ? evt_v4
        : evt_n5 = d_lkname ? evt_v5
        : 0)

    -- Op family flags (via the pass discriminators).
    d_op_arith_arr ∈ Bool
    BinopIsArray(op ↦ d_op, out ↦ d_op_arith_arr)
    d_op_bool_arr ∈ Bool
    BoolOpIsArray(op ↦ d_op, out ↦ d_op_bool_arr)
    d_op_is_div ∈ Bool = (d_op matches OpDiv)
    d_op_cc ∈ Bool = (d_op matches OpConcat)
    d_op_arr ∈ Bool = (d_op_arith_arr ∨ d_op_bool_arr ∨ d_op_cc)

    -- ── LINE CLASSIFIER (pure; runs when witems is empty) ─────────
    -- Reads the shared window: c_t0..c_t4 = ww_t0..ww_t4 (lookahead
    -- need 5). Consumption is cursor arithmetic via dcons below.
    c_rem_nil ∈ Bool = (ww_t0 matches EofTok)
    c_t0 ∈ Token = ww_t0
    c_t1 ∈ Token = ww_t1
    c_t2 ∈ Token = ww_t2
    c_t3 ∈ Token = ww_t3
    c_t4 ∈ Token = ww_t4

    c_t0_is_ident ∈ Bool = (c_t0 matches Ident(_))
    c_t0_is_tlkw ∈ Bool = ((c_t0 matches KwEnum) ∨ (c_t0 matches KwClaim)
        ∨ (c_t0 matches KwType) ∨ (c_t0 matches KwFsm) ∨ (c_t0 matches KwSchema))
    c_name ∈ String = match c_t0
        Ident(s) ⇒ s
        _ ⇒ ""

    c_is_mem ∈ Bool = (c_t1 matches OpIn)
    c_eff_line ∈ Bool = (c_is_mem ∧ (c_name = "effects"))
    c_type_str ∈ String = match c_t2
        Ident(s) ⇒ s
        _ ⇒ ""
    c_is_nat ∈ Bool = (c_type_str = "Nat")
    -- sort class: 0 Int (incl Nat) · 1 Bool · 2 the user enum ·
    -- 3 String
    c_sc ∈ Int = (c_type_str = "Bool" ? 1
        : (_ue_done ∧ (c_type_str = _ue_name)) ? 2
        : c_type_str = "String" ? 3
        : 0)
    c_pinned ∈ Bool = (c_is_mem ∧ (¬c_eff_line) ∧ (c_t3 matches Eq))
    c_bnd_op ∈ Op
    c_t3_is_op ∈ Bool
    C2TokOp(t ↦ c_t3, o ↦ c_bnd_op, rec ↦ c_t3_is_op)
    c_bound ∈ Bool = (c_is_mem ∧ (¬c_eff_line) ∧ (¬c_pinned) ∧ c_t3_is_op)
    c_bnd_e ∈ Expr
    c_bnd_ok ∈ Bool
    C2AtomE(t ↦ c_t4, e ↦ c_bnd_e, ok ↦ c_bnd_ok)

    -- Lines needing an expression parsed (membership pins, the
    -- effects literal's Exit argument, and every standalone
    -- constraint / bare-equality line) enter the Pratt FSM
    -- (pmode 3); plain / bounded memberships build items directly.
    c_can_expr ∈ Bool = (c_t0_is_ident ∨ (c_t0 matches IntLit(_))
        ∨ (c_t0 matches OpNot) ∨ (c_t0 matches LParen)
        ∨ (c_t0 matches KwTrue) ∨ (c_t0 matches KwFalse))
    d_claim_end ∈ Bool = (d_classify ∧ (c_rem_nil ∨ c_t0_is_tlkw
        ∨ (¬c_can_expr)))
    -- the effects literal enters the ELEMENT walk (pmode 5) after
    -- its 8-token head `effects ∈ Seq ( Effect ) = ⟨`; element
    -- bodies re-enter the Pratt FSM per Exit argument.
    d_enter_el ∈ Bool = (d_classify ∧ (¬d_claim_end) ∧ c_eff_line)
    d_enter_pratt0 ∈ Bool = (d_classify ∧ (¬d_claim_end)
        ∧ (¬c_eff_line) ∧ (c_pinned ∨ (¬c_is_mem)))
    d_enter_pratt ∈ Bool = (d_enter_pratt0 ∨ el_exit_enter)
    -- tokens consumed before the expression starts: a pin's
    -- `name ∈ Type =` is 4; an element's `Exit (` is 2; standalone
    -- constraint / bare-equality lines start at the expression.
    d_pratt_cons0 ∈ Int = (el_exit_enter ? 2 : c_pinned ? 4 : 0)
    d_pratt_kind0 ∈ Int = (el_exit_enter ? 3 : c_pinned ? 1 : 2)

    c_seg_bound ∈ C2Items = C2ICons(C2Process(c_bnd_e),
        C2ICons(C2Op(c_bnd_op), C2ICons(C2AssertTop, C2INil)))
    c_seg_drop ∈ C2Items = C2ICons(C2Drop, C2INil)
    c_tailseg ∈ C2Items = (c_bound ? c_seg_bound : c_seg_drop)
    c_natseg ∈ C2Items = (c_is_nat
        ? C2ICons(C2NatBound, C2ICons(C2AssertTop, c_tailseg))
        : c_tailseg)
    c_mem_items ∈ C2Items = C2ICons(C2DeclConst(c_name, c_sc), c_natseg)

    d_new_items ∈ C2Items = ((d_claim_end ∨ d_enter_pratt0 ∨ d_enter_el)
        ? C2INil : c_mem_items)
    -- a direct (non-pratt) membership line consumes `x ∈ Type` = 3
    -- tokens, or 5 with a single `op atom` bound.
    d_mem_line ∈ Bool = (d_classify ∧ (¬d_claim_end) ∧ (¬d_enter_pratt0)
        ∧ (¬d_enter_el))
    d_mem_cons ∈ Int = (c_bound ? 5 : 3)
    c_tyname ∈ String = (c_sc = 1 ? "Bool"
        : c_sc = 2 ? c_type_str
        : c_sc = 3 ? "String"
        : "Int")
    c_field ∈ String = c_name ++ ":" ++ c_tyname
    -- `_<name>` carry-over DECLARES (fossil parity): the kernel pins
    -- `_<name> = <prev>` from tick 1 on — and the functionizer's
    -- verify solves tick 1 even for tick-0-exit programs. Z3 only
    -- serializes consts the asserts mention, so the carries must be
    -- textual lines in the emitted unit.
    c_cdecl ∈ String = "(declare-fun _" ++ c_name ++ " () " ++ c_tyname ++ ")\n"

    -- ── PRATT FSM state (pmode 3; reads the shared window) ────────
    d_in_pratt ∈ Bool = (in_parse ∧ (_pmode = 3) ∧ tok_ready)

    p_out ∈ ExprList
    _p_out ∈ ExprList
    p_ops ∈ PrOps
    _p_ops ∈ PrOps
    p_expop ∈ Bool
    _p_expop ∈ Bool
    p_pd ∈ Int
    _p_pd ∈ Int
    p_qd ∈ Int
    _p_qd ∈ Int
    pk_kind ∈ Int
    _pk_kind ∈ Int
    pk_name ∈ String
    _pk_name ∈ String
    pk_sc ∈ Int
    _pk_sc ∈ Int
    pk_nat ∈ Bool
    _pk_nat ∈ Bool

    pr_ntoks ∈ TokenList
    pr_nouts ∈ ExprList
    pr_nops ∈ PrOps
    pr_nexpop ∈ Bool
    pr_npd ∈ Int
    pr_nqd ∈ Int
    pr_sdone ∈ Bool
    pr_sres ∈ Expr
    pr_scons ∈ Bool
    C2PrattStep(toks ↦ _wtoks, outs ↦ _p_out, ops ↦ _p_ops,
        expop ↦ _p_expop, pd ↦ _p_pd, qd ↦ _p_qd,
        ntoks ↦ pr_ntoks, nouts ↦ pr_nouts, nops ↦ pr_nops,
        nexpop ↦ pr_nexpop, npd ↦ pr_npd, nqd ↦ pr_nqd,
        sdone ↦ pr_sdone, sres ↦ pr_sres, scons ↦ pr_scons)

    p_out = (is_first_tick ? ELNil
        : d_enter_pratt ? ELNil
        : d_in_pratt ? pr_nouts
        : _p_out)
    p_ops = (is_first_tick ? PrNil
        : d_enter_pratt ? PrNil
        : d_in_pratt ? pr_nops
        : _p_ops)
    p_expop = (is_first_tick ? true
        : d_enter_pratt ? true
        : d_in_pratt ? pr_nexpop
        : _p_expop)
    p_pd = (is_first_tick ? 0
        : d_enter_pratt ? 0
        : d_in_pratt ? pr_npd
        : _p_pd)
    p_qd = (is_first_tick ? 0
        : d_enter_pratt ? 0
        : d_in_pratt ? pr_nqd
        : _p_qd)
    pk_kind = (is_first_tick ? 0 : d_enter_pratt ? d_pratt_kind0 : _pk_kind)
    pk_name = (is_first_tick ? "" : d_enter_pratt ? c_name : _pk_name)
    pk_sc = (is_first_tick ? 0 : d_enter_pratt ? c_sc : _pk_sc)
    pk_nat = (is_first_tick ? false : d_enter_pratt ? c_is_nat : _pk_nat)

    -- parse completion → build the line's work-item program.
    p_done ∈ Bool = (d_in_pratt ∧ pr_sdone)
    pr_bad ∈ Bool = (p_done ∧ (pr_sres matches ENoExpr))
    d_pk_pinseg ∈ C2Items = C2ICons(C2Process(pr_sres),
        C2ICons(C2PinEq, C2ICons(C2AssertTop, C2INil)))
    d_pk_natseg ∈ C2Items = (_pk_nat
        ? C2ICons(C2NatBound, C2ICons(C2AssertTop, d_pk_pinseg))
        : d_pk_pinseg)
    d_pratt_items ∈ C2Items = (pr_bad ? C2INil
        : _pk_kind = 3 ? C2ICons(C2Process(pr_sres),
            C2ICons(C2App(z_exitdecl, 1),
            C2ICons(C2SelectEq(_el_cnt), C2INil)))
        : _pk_kind = 1 ? C2ICons(C2DeclConst(_pk_name, _pk_sc), d_pk_natseg)
        : C2ICons(C2Process(pr_sres), C2ICons(C2AssertTop, C2INil)))
    -- kind 3: the Exit argument closes with `)` — consume it; the
    -- element walk (pmode 5) handles the following `,` / `⟩`. On a
    -- malformed line skip one token so the walk always progresses.
    d_done_cons ∈ Int = (pr_bad ? 1 : _pk_kind = 3 ? 1 : 0)

    -- ── state transitions ─────────────────────────────────────────
    d_pops ∈ Int = (¬d_processing ? 0
        : d_it_proc ? 0
        : d_it_op ? (d_op_arr ? (_istep = 2 ? 2 : 0) : 2)
        : d_it_ite ? 3
        : d_it_not ? 1
        : d_it_pineq ? 2
        : d_it_assert ? 1
        : d_it_drop ? 1
        : d_it_app ? (_istep = d_app_n ? d_app_n : 0)
        : d_it_seleq ? (_istep = 1 ? 1 : 0)
        : 0)
    d_push_ident ∈ Bool = (d_processing ∧ d_it_proc ∧ d_pe_is_id)
    d_push_h ∈ Bool = (d_processing ∧ d_it_pushh)

    hstk = (is_first_tick ? C2HNil
        : d_enter_claim ? C2HNil
        : d_push_ident ? C2HCons(d_lk, d_hstk_in)
        : d_push_h ? C2HCons(d_ph_h, d_hstk_in)
        : d_pops = 3 ? d_h_t3
        : d_pops = 2 ? d_h_t2
        : d_pops = 1 ? d_h_t1
        : d_hstk_in)

    witems = (is_first_tick ? C2INil
        : d_enter_claim ? C2INil
        : d_classify ? d_new_items
        : p_done ? d_pratt_items
        : el_b2 ? el_lc_items
        : el_close ? C2ICons(C2LenEq(_el_cnt), C2INil)
        : ¬d_processing ? _witems
        : d_it_proc ∧ d_pe_is_bin ∧ d_pe_op_ne ? C2ICons(C2Process(d_pe_l), C2ICons(C2Process(d_pe_r), C2ICons(C2Op(OpEq), C2ICons(C2Not, d_wtail))))
        : d_it_proc ∧ d_pe_is_bin ? C2ICons(C2Process(d_pe_l), C2ICons(C2Process(d_pe_r), C2ICons(C2Op(d_pe_op), d_wtail)))
        : d_it_proc ∧ d_pe_is_tern ? C2ICons(C2Process(d_pe_c), C2ICons(C2Process(d_pe_t), C2ICons(C2Process(d_pe_e), C2ICons(C2Ite, d_wtail))))
        : d_it_proc ∧ d_pe_is_not ? C2ICons(C2Process(d_pe_ni), C2ICons(C2Not, d_wtail))
        : d_it_proc ? d_wtail
        : d_it_op ? (d_op_arr ? (_istep = 2 ? d_wtail : _witems) : d_wtail)
        : d_it_decl ? (_istep = 1 ? d_wtail : _witems)
        : d_it_app ? (_istep = d_app_n ? d_wtail : _witems)
        : d_it_seleq ? (_istep = 2 ? d_wtail : _witems)
        : d_it_leneq ? (_istep = 1 ? d_wtail : _witems)
        : d_wtail)

    d_multi_cont ∈ Bool = (d_processing ∧
        ((d_it_op ∧ d_op_arr ∧ (_istep < 2))
        ∨ (d_it_decl ∧ (_istep < 1))
        ∨ (d_it_app ∧ (_istep < d_app_n))
        ∨ (d_it_seleq ∧ (_istep < 2))
        ∨ (d_it_leneq ∧ (_istep < 1))))
    istep = (is_first_tick ? 0
        : d_multi_cont ? _istep + 1
        : 0)

    pend = (is_first_tick ? 0
        : ¬d_processing ? 0
        : d_it_proc ? ((d_pe_is_int ∨ d_pe_is_str) ? 1 : 0)
        : d_it_op ? (d_op_arr ? (_istep = 2 ? 1 : 0) : 1)
        : d_it_ite ? 1
        : d_it_not ? 1
        : d_it_decl ? (_istep = 0 ? 2 : 3)
        : d_it_nat ? 1
        : d_it_pineq ? 1
        : d_it_app ? (_istep = d_app_n ? 1 : 0)
        : d_it_seleq ? ((_istep = 0 ∨ _istep = 1) ? 2 : 0)
        : d_it_leneq ? (_istep = 0 ? 2 : 0)
        : 0)
    pend_name = (is_first_tick ? ""
        : (d_processing ∧ d_it_decl ∧ (_istep = 1)) ? d_dc_name
        : _pend_name)

    -- ── token consumption (cursor arithmetic + window tail) ───────
    -- Exactly one consumer acts per tick (mode bools are mutually
    -- exclusive and tok_ready-gated); fetch ticks consume nothing.
    dcons ∈ Int = (d_enter_claim ? 2
        : d_enter_edecl ? 3
        : d_enter_skip ? 1
        : (d_in_skip ∧ (¬d_skip_stop)) ? 1
        : (ec_active ∧ ec_payload) ? 1
        : ec_take ? (ec_more ? 2 : 1)
        : d_enter_el ? 8
        : el_lc_enter ? 6
        : el_b2 ? 7
        : (el_comma ∨ el_close) ? 1
        : d_enter_pratt ? d_pratt_cons0
        : d_mem_line ? d_mem_cons
        : p_done ? d_done_cons
        : (d_in_pratt ∧ pr_scons) ? 1
        : 0)
    tcur = (is_first_tick ? 0 : _tcur + dcons)
    wend = (is_first_tick ? 0 : _fmode = 2 ? _tcur + 8 : _wend)
    w_after ∈ TokenList = (dcons = 0 ? _wtoks
        : dcons = 1 ? ww_l1
        : dcons = 2 ? ww_l2
        : dcons = 3 ? ww_l3
        : dcons = 4 ? ww_l4
        : dcons = 5 ? ww_l5
        : dcons = 6 ? ww_l6
        : dcons = 7 ? ww_l7
        : TLNil)
    wtoks = (is_first_tick ? TLNil
        : _fmode = 2 ? f_built
        : w_after)

    fstr = (is_first_tick ? ""
        : (d_classify ∧ (¬d_claim_end) ∧ c_is_mem ∧ (¬c_eff_line))
            ? (_fstr = "" ? c_field : _fstr ++ " " ++ c_field)
        : _fstr)
    cdstr = (is_first_tick ? ""
        : (d_classify ∧ (¬d_claim_end) ∧ c_is_mem ∧ (¬c_eff_line))
            ? _cdstr ++ c_cdecl
        : _cdstr)

    pmode = (is_first_tick ? 0
        : entering_parse ? 0
        : d_enter_claim ? 2
        : d_enter_edecl ? 4
        : d_enter_skip ? 1
        : d_skip_stop ? 0
        : d_claim_end ? 0
        : d_enter_el ? 5
        : d_enter_pratt ? 3
        : p_done ? (_pk_kind = 3 ? 5 : 2)
        : (ec_active ∧ ec_payload) ? 1
        : (ec_active ∧ (¬ec_v_ok)) ? 0
        : ed_done_user ? 0
        : el_close ? 2
        : (el_bad ∨ el_b2_bad) ? 2
        : _pmode)

    phase = (is_first_tick ? 0
        : (_phase = 0 ? (lex_done ? 2 : 0)
        : (_phase = 2 ? (d_all_done ? 3 : 2)
        : 3)))

    -- ── per-item build effects (pass-claim dispatch) ──────────────
    d_eff_mkint ∈ Effect
    d_atom_ok ∈ Bool
    AtomBuildZ3(ctx_h ↦ z_ctx, int_sort_h ↦ z_isort, sym_h ↦ 0,
        e ↦ d_pe, eff ↦ d_eff_mkint, ok ↦ d_atom_ok)
    d_eff_cmp ∈ Effect
    d_cmp_ok ∈ Bool
    d_cmp_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op, l_h ↦ d_h_2nd, r_h ↦ d_h_top,
        eff ↦ d_eff_cmp, ok ↦ d_cmp_ok, needs_not ↦ d_cmp_nn)
    d_eff_arith ∈ Effect
    d_arith_ok ∈ Bool
    ArithBinopBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op,
        l_h ↦ d_h_2nd, r_h ↦ d_h_top, args_arr_ptr ↦ z_arena + 200,
        eff ↦ d_eff_arith, ok ↦ d_arith_ok)
    d_eff_nary ∈ Effect
    d_nary_ok ∈ Bool
    BoolNaryBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op, num_args ↦ 2,
        args_arr_ptr ↦ z_arena + 200, eff ↦ d_eff_nary, ok ↦ d_nary_ok)
    -- `++` → (str.++ l r) via the same 2-slot args buffer
    d_eff_concat ∈ Effect
    BuildZ3MkSeqConcat(ctx_h ↦ z_ctx, num_args ↦ 2,
        args_arr_ptr ↦ z_arena + 200, eff ↦ d_eff_concat)
    d_eff_ite ∈ Effect
    TernaryBuildZ3(ctx_h ↦ z_ctx, cond_h ↦ d_h_3rd, then_h ↦ d_h_2nd,
        else_h ↦ d_h_top, eff ↦ d_eff_ite)
    d_eff_not ∈ Effect
    BoolNotBuildZ3(ctx_h ↦ z_ctx, x_h ↦ d_h_top, eff ↦ d_eff_not)
    d_eff_wl0 ∈ Effect
    BuildMemWriteLong(addr ↦ z_arena + 200, value ↦ d_h_2nd, eff ↦ d_eff_wl0)
    d_eff_wl1 ∈ Effect
    BuildMemWriteLong(addr ↦ z_arena + 208, value ↦ d_h_top, eff ↦ d_eff_wl1)
    d_eff_mkstring ∈ Effect
    BuildZ3MkString(ctx_h ↦ z_ctx, s ↦ d_pe_str, eff ↦ d_eff_mkstring)
    d_eff_sym ∈ Effect
    BuildZ3MkStringSymbol(ctx_h ↦ z_ctx, name ↦ d_dc_name, eff ↦ d_eff_sym)
    d_eff_const ∈ Effect
    BuildZ3MkConst(ctx_h ↦ z_ctx, sym_h ↦ d_tmp_in,
        sort_h ↦ (d_dc_sc = 1 ? z_bsort
            : d_dc_sc = 2 ? ue_sort
            : d_dc_sc = 3 ? z_ssort
            : z_isort), eff ↦ d_eff_const)
    -- oracle gap: a ctor literal in a slot binding breaks the callee's
    -- `matches` translation — pass pinned body vars instead.
    d_op_geq ∈ Op = OpGeq
    d_op_eq ∈ Op = OpEq
    d_eff_natge ∈ Effect
    d_nat_ok ∈ Bool
    d_nat_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op_geq, l_h ↦ d_h_top, r_h ↦ z_zero,
        eff ↦ d_eff_natge, ok ↦ d_nat_ok, needs_not ↦ d_nat_nn)
    d_eff_pineq ∈ Effect
    d_pin_ok2 ∈ Bool
    d_pin_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op_eq, l_h ↦ d_h_2nd, r_h ↦ d_h_top,
        eff ↦ d_eff_pineq, ok ↦ d_pin_ok2, needs_not ↦ d_pin_nn)
    d_eff_assert ∈ Effect
    BuildZ3SolverAssert(ctx_h ↦ z_ctx, solver_h ↦ z_sol, ast_h ↦ d_h_top,
        eff ↦ d_eff_assert)
    d_eff_asserttmp ∈ Effect
    BuildZ3SolverAssert(ctx_h ↦ z_ctx, solver_h ↦ z_sol, ast_h ↦ d_tmp_in,
        eff ↦ d_eff_asserttmp)
    -- C2App: istep k < n writes args[n-1-k] from stack depth k
    -- (top/2nd/3rd — post-order means the TOP is the LAST arg);
    -- istep n applies the harvested decl over the args array.
    d_app_arg ∈ Int = (_istep = 0 ? d_h_top
        : _istep = 1 ? d_h_2nd
        : d_h_3rd)
    d_eff_caw ∈ Effect
    CtorArgWriteStep(args_p ↦ z_arena + 224, idx ↦ d_app_n - 1 - _istep,
        arg_h ↦ d_app_arg, eff ↦ d_eff_caw)
    d_eff_app ∈ Effect
    CtorAppStep(ctx_h ↦ z_ctx, ctor_decl_h ↦ d_app_d, n_args ↦ d_app_n,
        args_p ↦ z_arena + 224, eff ↦ d_eff_app)
    d_sel_idx_h ∈ Int = (d_sel_i = 0 ? z_zero
        : d_sel_i = 1 ? z_one
        : z_two)
    d_eff_sel ∈ Effect
    BuildZ3MkSelect(ctx_h ↦ z_ctx, arr_h ↦ z_effs, idx_h ↦ d_sel_idx_h,
        eff ↦ d_eff_sel)
    d_eff_seleq ∈ Effect
    d_seleq_ok ∈ Bool
    d_seleq_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op_eq, l_h ↦ d_tmp_in, r_h ↦ d_h_top,
        eff ↦ d_eff_seleq, ok ↦ d_seleq_ok, needs_not ↦ d_seleq_nn)
    d_len_n_h ∈ Int = (d_len_n = 1 ? z_one
        : d_len_n = 2 ? z_two
        : z_zero)
    d_eff_leneq ∈ Effect
    d_leneq_ok ∈ Bool
    d_leneq_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op_eq, l_h ↦ z_elen, r_h ↦ d_len_n_h,
        eff ↦ d_eff_leneq, ok ↦ d_leneq_ok, needs_not ↦ d_leneq_nn)
    d_eff_filler ∈ Effect = LibCall("libc", "getpid", ⟨⟩)

    d_eff_lib ∈ Effect = (d_it_proc ∧ d_pe_is_int ? d_eff_mkint
        : d_it_proc ∧ d_pe_is_str ? d_eff_mkstring
        : d_it_op ∧ d_op_arr ∧ (_istep = 0) ? d_eff_wl0
        : d_it_op ∧ d_op_arr ∧ (_istep = 1) ? d_eff_wl1
        : d_it_op ∧ d_op_arr ? (d_op_bool_arr ? d_eff_nary
            : d_op_cc ? d_eff_concat
            : d_eff_arith)
        : d_it_op ∧ d_op_is_div ? d_eff_arith
        : d_it_op ? d_eff_cmp
        : d_it_ite ? d_eff_ite
        : d_it_not ? d_eff_not
        : d_it_decl ? (_istep = 0 ? d_eff_sym : d_eff_const)
        : d_it_nat ? d_eff_natge
        : d_it_pineq ? d_eff_pineq
        : d_it_assert ? d_eff_assert
        : d_it_app ? (_istep < d_app_n ? d_eff_caw : d_eff_app)
        : d_it_seleq ? (_istep = 0 ? d_eff_sel
            : _istep = 1 ? d_eff_seleq
            : d_eff_asserttmp)
        : d_it_leneq ? (_istep = 0 ? d_eff_leneq : d_eff_asserttmp)
        : d_eff_filler)

    -- ── EMIT ──────────────────────────────────────────────────────
    estep  ∈ Int
    _estep ∈ Int
    estep = (is_first_tick ? 0 - 1
        : _estep ≥ 0 ? (_estep < 5 ? _estep + 1 : _estep)
        : d_all_done ? 0
        : 0 - 1)

    sptr  ∈ Int
    _sptr ∈ Int
    sptr = (is_first_tick ? 0 : estep = 1 ? d_cap_int : _sptr)
    rendered  ∈ String
    _rendered ∈ String
    rendered = (is_first_tick ? "" : estep = 2 ? d_cap_str : _rendered)

    e_s2s ∈ Effect
    BuildZ3SolverToString(ctx_h ↦ z_ctx, solver_h ↦ z_sol, eff ↦ e_s2s)
    e_copy ∈ Effect
    BuildCstrCopy(addr ↦ sptr, eff ↦ e_copy)

    d_manifest ∈ String = (";; manifest: state-fields = " ++ _fstr ++ "\n"
        ++ ";; manifest: effects-name = effects\n"
        ++ ";; manifest: effect-enum-name = Effect\n"
        ++ ";; manifest: result-enum-name = Result\n"
        ++ ";; manifest: max-effects = 16")
    d_prelude ∈ String = ("(declare-datatypes ((Result 0)) (((NoResult) (IntResult (IntResult__f0 Int)) (StringResult (StringResult__f0 String)) (RealResult (RealResult__f0 Real)) (EofResult) (ErrorResult (ErrorResult__f0 String)))))\n"
        ++ "(declare-fun last_results () (Array Int Result))\n"
        ++ "(declare-fun last_results__len () Int)\n"
        ++ "(assert (>= last_results__len 0))\n"
        ++ "(declare-fun is_first_tick () Bool)\n")
    -- carry declares go AFTER the solver body: an enum-typed carry
    -- (`_c () Color`) needs its sort, and the declare-datatypes live
    -- in the rendered serialization.
    d_unit ∈ String = d_manifest ++ "\n\n" ++ d_prelude ++ rendered ++ cdstr

    e_puts ∈ Effect
    BuildPrintln(s ↦ d_unit, eff ↦ e_puts)
    e_free_tbuf ∈ Effect = LibCall("libc", "free", ⟨ArgInt(tbase)⟩)

    -- ── effects schedule ──────────────────────────────────────────
    effects ∈ Seq(Effect) = (is_first_tick ? ⟨ReadLine, ReadLine⟩
        : (¬_got_path) ? ⟨ReadFile(src_path)⟩
        : zstep = 0 ? ⟨ze_cfg⟩
        : zstep = 1 ? ⟨ze_ctx⟩
        : zstep = 2 ? ⟨ze_sol⟩
        : zstep = 3 ? ⟨ze_sinc⟩
        : zstep = 4 ? ⟨ze_isort⟩
        : zstep = 5 ? ⟨ze_bsort⟩
        : zstep = 6 ? ⟨ze_ssort⟩
        : zstep = 7 ? ⟨ze_rsort⟩
        : zstep = 8 ? ⟨ze_arena⟩
        : ed_running ? (ed_w5
            ? (ed_n = 1 ? ⟨edw_fn0, edw_fs0, edw_sr01⟩
              : ed_n = 2 ? ⟨edw_fn0, edw_fn1, edw_fs0, edw_fs1, edw_sr01⟩
              : ⟨edw_fn0, edw_fn1, edw_fn2, edw_fs0, edw_fs1, edw_fs2,
                 edw_sr01, edw_sr2⟩)
            : ed_w2 ? ⟨edw_nm, edw_cl⟩
            : ⟨ed_eff1⟩)
        : zstep = 10 ? ⟨ze_arrsort⟩
        : zstep = 11 ? ⟨ze_sym_effs⟩
        : zstep = 12 ? ⟨ze_effs⟩
        : zstep = 13 ? ⟨ze_sym_elen⟩
        : zstep = 14 ? ⟨ze_elen⟩
        : zstep = 15 ? ⟨ze_zero⟩
        : zstep = 16 ? ⟨ze_one⟩
        : zstep = 17 ? ⟨ze_two⟩
        : zstep = 18 ? ⟨ze_true⟩
        : zstep = 19 ? ⟨ze_false⟩
        : zstep = 20 ? ⟨ze_tbuf⟩
        : entering_parse ? (lx_have_pend ? ⟨w_pend, w_eof⟩ : ⟨w_eof⟩)
        : estep = 0 ? ⟨e_s2s⟩
        : estep = 1 ? ⟨e_copy⟩
        : estep ≥ 2 ? ⟨e_free_tbuf, e_puts, Exit(0)⟩
        : fetch_go ? ⟨rd_t0, rd_q0, rd_t1, rd_q1, rd_t2, rd_q2,
            rd_t3, rd_q3, rd_t4, rd_q4, rd_t5, rd_q5, rd_t6, rd_q6,
            rd_t7, rd_q7⟩
        : _fmode = 1 ? ⟨cp0, cp1, cp2, cp3, cp4, cp5, cp6, cp7⟩
        : d_processing ? ⟨d_eff_lib⟩
        : (k_kind = 1 ∧ lx_have_pend) ? ⟨w_pend, w_tag0e⟩
        : k_kind = 1 ? ⟨w_tag0e⟩
        : k_kind = 2 ? ⟨w_tag0e, w_p0e⟩
        : k_kind = 3 ? ⟨e_dup, w_tag0e⟩
        : k_kind = 4 ? ⟨w_tag0e, w_tag1e⟩
        : k_kind = 5 ? ⟨e_dup, w_tag0e, w_tag1e⟩
        : k_kind = 6 ? ⟨w_tag0e, w_p0e, w_tag1e⟩
        : lx_have_pend ? ⟨w_pend⟩
        : ⟨d_eff_filler⟩)
