-- compiler2/driver.ev — P3a: the compiler2 driver skeleton.
--
-- An Evident program that, run under the kernel, COMPILES a small .ev
-- file end-to-end by building Z3 ASTs in memory (the compiler2
-- architecture, docs/plans/z3-ast-compiler2-plan.md) instead of
-- concatenating SMT-LIB text (the fossil's approach, and the source
-- of its dropped-compound-expression bug class).
--
-- Wire protocol (wave 4o, same as compiler.smt2):
--   stdin line 1 = flattened source path, line 2 = target claim name.
--   tick 0: ReadLine ×2 · tick 1: ReadFile(path) · output: the .smt2
--   translation unit on stdout via puts, then Exit(0).
--
-- Pipeline:
--   INPUT   ticks 0-1 (fossil's wave-4o block, verbatim).
--   ZINIT   ticks 2-33: Z3 lifecycle (config/context/solver/sorts) +
--           the Effect datatype declared IN THE BUILD CONTEXT via
--           translate2_ctor.ev's step claims + the `effects` /
--           `effects__len` consts + cached 0/1 numerals + the FTI
--           token buffer (calloc'd; 32 bytes/token).
--   LEX     the fossil's per-char scanner FSM (one token per tick,
--           whitespace/comment bulk-skip) feeding compiler2/
--           lex_fti.ev's LexFtiPlan: tokens are written to the FTI
--           buffer in APPEND (source) order via __mem.write_long;
--           string payloads (Ident/StringLit) are strdup'd char*s.
--           Z3-carried lexer state = five Ints (tbase, lx_count,
--           lx_last, lx_prev, lx_pend) — no TokenList anywhere.
--           The old REVERSE pop loop is GONE (P3d): append order
--           makes it dead weight; phase goes 0 → 2 directly, after
--           flushing any pending string write + the EofTok sentinel.
--   FETCH   the parse phases read tokens through a sliding 8-token
--           decoded window (wtoks, head = token tcur). A refill is
--           a 3-tick burst: 16 __mem.read_long (8 tags + 8
--           payloads, one tick), then 8 slot-aligned __cstr.copy /
--           getpid-filler effects (string payloads), then the pure
--           rebuild. Entries past the EofTok sentinel read 0 from
--           the calloc'd region and decode to EofTok.
--   PARSE   top-level dispatch: enums and non-target claims are
--           SKIPPED (one token per tick); the target claim enters
--           the claim walk — through the pmode-9 group walk first
--           when it carries a first-line param list (F1). All
--           consumption is cursor arithmetic (tcur += k) + window
--           tails.
--   WALK    per body line: a one-tick PURE classifier picks the line
--           kind; lines carrying an expression run the Pratt FSM
--           (pmode 3, one parser action per tick) to an Expr, which
--           becomes a work-item program (C2Items); subsequent ticks run
--           one item micro-step per tick, each step one Z3-builder
--           LibCall, dispatching per-node choices to the pass claims:
--             arith binop  → translate_arith.ev  ArithBinopBuildZ3
--             cmp/eq       → translate2_bool.ev  BoolCmpBuildZ3
--             ∧/∨ (n-ary)  → translate2_bool.ev  BoolNaryBuildZ3
--             ternary      → translate2_bool.ev  TernaryBuildZ3
--             ctor app     → translate2_ctor.ev  CtorArgWriteStep/CtorAppStep
--           Built handles live on a parallel handle stack (C2H);
--           captures follow the PROVEN discipline: a builder's result
--           is read from last_results on the NEXT tick (the `pend`
--           mechanism below) and used the same tick it lands.
--   EMIT    Z3_solver_to_string (which serializes declare-datatypes +
--           declare-funs + asserts — verified empirically) → __cstr.copy
--           → manifest header + Result/last_results textual prelude +
--           the solver body → puts → Exit(0).
--
-- Scope (P3a skeleton + P3b widening + P3c Pratt parser — enough for
-- the census arithmetic/comparison/logic/implies/ternary classes,
-- NOT the full language; see docs/plans/compiler2-driver-notes.md):
--   · scalar memberships `x ∈ Int|Nat|Bool [= pin | < bound]`
--   · GENERAL expressions everywhere an expression is parsed (pins,
--     bare `name = <expr>` lines, standalone constraint lines, the
--     effects literal's Exit argument): the P3b bounded shape
--     parsers (C2ParseExpr / C2ParseCons) are REPLACED by a Pratt /
--     shunting-yard FSM (C2PrattStep, pmode 3 — one shift or one
--     reduce per tick) with arbitrary nesting/parens, all binary
--     ops (+ - * / = < > ≤ ≥ ≠ ∧ ∨ ⇒), unary ¬, ternary ?:,
--     chained comparisons (`0 < x < 5` → conjunction; `=` is a
--     chain member, matching the legacy parser), and the
--     oracle-verified precedence ladder (see C2Prec)
--   · `true` / `false` atoms (cached Z3_mk_true/false handles)
--   · negative int literals (sign folded at lex time when the Minus
--     has no atom before it)
--   · effects literals with 0-4 elements (P3e, widened D2):
--     `⟨Exit(<expr>)⟩`, `⟨LibCall("lib","fn",⟨ArgStr(<lit-or-ident>)⟩),
--     Exit(<expr>)⟩`, the empty `⟨⟩`, and LibCall's empty-args
--     `⟨⟩` (the getpid shape) — Exit args go through the Pratt FSM;
--     LibCall elements parse as a fixed two-bite shape (pmode 5)
--   · CONDITIONAL EFFECTS (D2): the corpus's nested-ternary chain
--     `effects ∈ Seq(Effect) = (g1 ? ⟨…⟩ : (g2 ? ⟨…⟩ : ⟨…⟩))` —
--     guards are full Pratt expressions (terminated at the chain's
--     `?` via qstop); each branch's select/len eqs fold into a
--     conjunction HANDLE and the chain end emits the oracle's
--     nested `(and (=> g B) (=> (not g) T))` guard tree (≤ 4
--     guards / 5 branches; then-branches must be literals,
--     chains nest in else position only — the corpus shape)
--   · OpNeq lowers as mk_eq + mk_not (C2Not item); ENot likewise
--   · the build-context Effect floor is FULL (P3e): LibArg,
--     __SeqOf_LibArg, and all five Effect variants are declared by
--     the ED machine (translate2_ctor.ev's step claims) at ZINIT
--   · USER ENUMS (P3e, payloads C3): one enum per compile
--     (`enum Color = Red | Green | Blue`,
--     `enum E = A | B(Int) | C(Int, String)` — payload variants up
--     to TWO fields of Int/Bool/String/Real/self) — declared in the
--     build context via the same ED machine at parse time; nullary
--     variant values resolve in expressions; enum-typed memberships
--     declare consts of the enum sort and land in the manifest as
--     `name:Enum`
--   · CTOR APPLICATIONS (C3): `B(7)`, `B(3 + 4)`, `Cons(1, Nil)` as
--     EXPRESSIONS — a call whose name resolves in the user-enum
--     registry (per-variant ctor decls harvested by the ED machine)
--     lowers to C2App(decl, argc) = mk_app; compound args come free
--     (they are handles — the legacy dropped-Exit(3+4) bug class
--     cannot exist here)
--   · MATCHES RECOGNIZERS (C4): `e matches B(_)` / `e matches A` as
--     Bool expressions anywhere — parsed in the Pratt FSM as a
--     postfix action (consumes `matches Ctor[(_[, _])]`, builds
--     EMatches(ctor, e)), lowered to mk_app of the harvested tester
--     decl (user variants + the IntResult/StringResult floor)
--   · N-ARM MATCH-PIN (C4 gate, C5 binds + expr bodies): pmode 6 —
--     up to 2 TESTED arms + a default (wildcard arm or the last
--     arm, test dropped, per the legacy fold rule); arm patterns
--     are nullary ctors or 1-payload-bind ctors; arm BODIES are
--     full Pratt expressions (each body re-enters the Pratt FSM,
--     pk_kind 4); a payload bind shadows ONLY within its arm body,
--     where it reads through the harvested accessor decl as
--     mk_app(acc, scrut) — user enums (uev registry) AND the
--     IntResult/StringResult floor
--   · String memberships/pins, string literals, `++` (str.++)
--   · STRING BUILTIN CALL SYNTAX (B3): `f(a[, b[, c]])` parses in
--     the Pratt FSM via a PrCall operator-stack floor marker (an
--     Ident in operand position followed by `(` shifts name + paren
--     in one 2-token action; `,` reduces to the call floor then
--     bumps its arg count; `)` over the floor builds ECall1/2/3).
--     `#e` is a prec-8 prefix op (PrHash) reducing to
--     ECall1("str_len", e). The walker lowers calls to
--     translate2_seq.ev's StrOpBuildZ3 table (substr / char_at /
--     index_of 2-3 / str_contains / starts_with / ends_with) +
--     BuildZ3MkSeqLength for str_len/`#`; str_from_int expands to
--     the oracle's ite composite
--     `(ite (>= e 0) (str.from_int e) (str.++ "-" (str.from_int (- 0 e))))`;
--     an unknown call name pushes handle 0 (unbound-ident parity)
--   · symbol table: FTI buffer at corpus scale (B1) — 1024 handle
--     slots in a calloc'd buffer + fixed-width-32 name records in a
--     Z3 String; lookup = pure index_of/32 + one __mem.read_long.
--     Enum-value table: 6. Slots 0/1 pre-seeded with the
--     kernel-provided last_results / is_first_tick consts (D3).
--   · D3: the Result floor is a FOURTH ED run (sort + the
--     IntResult/StringResult tester+accessor decls harvested);
--     last_results ((Array Int Result)) / last_results__len /
--     is_first_tick are build-context consts; `e[i]` parses as a
--     PrIdx postfix floor in the Pratt FSM → ECall2("__index") →
--     C2SelH (mk_select); a RESTRICTED match-pin shape
--     `name ∈ Type = match scrut · Ctor(b) ⇒ atom · _ ⇒ atom`
--     (scrut = ident | last_results[i]; Ctor ∈ {IntResult,
--     StringResult}) lowers to the fossil's tester/accessor ite
--   · C2: set-literal memberships `x ∈ {…}` / `x ∉ {…}` (int
--     elements, any count, ⟨⟩ empty → false) or-fold one element
--     per tick and assert at the closing brace
--   · USER Seq(Int) VALUES (D2: 051/052/057/065): `s ∈ Seq(Int)`
--     memberships (array const + `s__len` + the ≥0 floor, manifest
--     `s:Seq(Int)`, two carry declares), `s = ⟨e0, e1, …⟩` literal
--     lines (pmode 8 — one full-Pratt element per tick, select-eq
--     per element + len-eq at close), `#s` → the s__len const,
--     `s[i]` via the existing PrIdx/SelH path; ONE registered seq
--     var per compile
--   · STATE CARRIES (E1): `_name ∈ Type` memberships are explicit
--     carry declarations (the corpus idiom; the oracle REQUIRES the
--     explicit membership — an unbound `_count` mention is a dropped
--     constraint). They declare build-context consts + symtab
--     entries but are NOT state fields and get no `__name` carry;
--     the first MENTION of a carry splices the base field's textual
--     carry declare out of cdstr (the serialization now carries it).
--     `(assert (>= effects__len 0))` floor at ZINIT (zsteps 35-36),
--     oracle parity.
--   · FIRST-LINE PARAM LISTS + MULTI-NAME GROUPS (F1): the pmode-9
--     group walk — a parametrized TARGET claim's params and body
--     `x, y, z ∈ Nat` lines declare each name as a typed const
--     (decl + manifest field + carry declare, like memberships);
--     multi-name groups collect one name per tick and drain one
--     decl per tick with the latched group type. Scalar types only.
--   · CLAIM-CALL COMPOSITION (F2): `Helper(slot ↦ value, …)` body
--     lines, bare `Helper` lines and `..Helper` passthroughs INLINE
--     the callee's body through the normal classifier/walker. The
--     skip pass builds a claim index (name → body-start cursor in
--     the FTI buffer); a composition line reads the cursor, parses
--     each slot value through the Pratt FSM to a HANDLE (pk_kind 8
--     — values are arbitrary expressions), pushes an inline frame
--     (return cursor + binds + α-prefix; depth ≤ 8, slots ≤ 4) and
--     jumps; the body's end pops. Slot-call body locals α-rename
--     under "__cN_" (per call site); bare/`..` splices are
--     names-match (inherit scope, no renaming). Memberships of
--     bound or already-declared names resolve instead of
--     redeclaring (no duplicate declares/fields/carries).
--   · G1 (2026-06-08): RECORD TYPE SPLICES (`type Name` indexed by
--     the skip pass; `p ∈ Point` / `f ∈ Foo (p ↦ 5)` flatten fields
--     to dotted consts under prefix "name." — Pratt dot-fold reads
--     them back; type-frame memberships are not state fields),
--     CONDITIONAL INLINE (`cond ⇒ ClaimName` — guard handle +
--     il_guard-wrapped asserts; the Pratt call-head shift is now
--     whitelist-gated so a claim name before a `(`-headed line no
--     longer parses as a call), BOUNDED QUANTIFIERS
--     (`∀|∃ v ∈ {lo..hi} : body`, `∀ v ∈ seq : body` — one Pratt
--     body parse + the fl re-walk loop), POSITIONAL BINDING
--     (`(a, b, c) ∈ add`, `recv.add(args)`, `add(args)` statement
--     calls, `(args) ∈ recv.add` — param names harvested by the
--     param-skip walk, zipped at ips_done; lone undeclared ident
--     args declare Int consts — arg inference), infix contains
--     (`"lit" ∈ s`), replace() → str.replace, slot width 6.
--   · NOT covered: Real membership / float literals (021 — needs
--     FloatLit lexing in this FSM + mk_numeral), match as a general
--     EXPRESSION (only the pmode-6 match-pin shape; bare `y = match`
--     pins without a membership type), 3-field payload variants
--     (the 8-token window caps collection at 2), multiple user
--     enums, 5+-element effects literals, guarded-writer effects
--     lines (`cond ⇒ effects = ⟨…⟩` — zero corpus occurrences; the
--     corpus's only conditional effects shape is the ternary chain),
--     quantifiers in EXPRESSION position (123), record arithmetic
--     broadcast (121/122), tuple→record coercion (090-093),
--     composite seq/set elements (125-132, 137/138 — need record
--     DATATYPES with plain-named accessors), Seq(...)-typed /
--     bounded / pinned multi-name groups, callees AFTER the call
--     site textually (one-pass index), composition calls in
--     EXPRESSION position, carry (`_x`) memberships inside inline
--     frames, nested guarded splices

import "stdlib/kernel.ev"
import "stdlib/z3_ast.ev"
import "stdlib/z3_core.ev"
import "stdlib/z3_seq.ev"
import "stdlib/z3_datatypes.ev"
import "compiler/lexer.ev"
import "compiler/parser.ev"
import "compiler2/lex_fti.ev"
import "compiler/translate_arith.ev"
import "compiler2/translate2_bool.ev"
import "compiler2/translate2_ctor.ev"
import "compiler2/translate2_seq.ev"
import "compiler2/driver_lex.ev"
import "compiler2/driver_expr.ev"
import "compiler2/driver_record.ev"
import "compiler2/driver_enum.ev"
import "compiler2/driver_window.ev"
import "compiler2/driver_classify.ev"
import "compiler2/driver_compose.ev"

import "compiler2/driver_ir.ev"




-- ── D2: one fold level of the conditional-effects chain ──────────
-- Stack in: [g, B, T] (T = running else handle, top). Emits the
-- item run that rewrites it to [(and (=> g B) (=> (not g) T))] —
-- the oracle's nested guard shape, one (guard, branch) pair per
-- level:  Dup3 [g,B,T,g] · Not [g,B,T,¬g] · Swap [g,B,¬g,T] ·
-- Impl [g,B,M] · Rot3 [M,g,B] · Impl [M,A] · Swap [A,M] · Conj.
claim C2ChainLvl(tail ∈ C2Items, out ∈ C2Items)
    out = C2ICons(C2Dup3, C2ICons(C2Not, C2ICons(C2Swap,
        C2ICons(C2Op(OpImpl), C2ICons(C2Rot3, C2ICons(C2Op(OpImpl),
        C2ICons(C2Swap, C2ICons(C2Op(OpConj), tail))))))))


fsm driver_main
    -- ── INPUT — per-process source path via stdin (wave 4o) ──────
    got_path  ∈ Bool
    got_path = (is_first_tick ? false : true)

    src_path  ∈ String
    path_read ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""
    src_path = (is_first_tick ? "" : ((¬_got_path) ? path_read : _src_path))

    input  ∈ String
    content_read ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ "<no-read>"
    input = (is_first_tick ? "" : ((¬_got_path) ? "" : (_input = "" ? content_read : _input)))

    target  ∈ String
    target_read ∈ String = match last_results[1]
        StringResult(s) ⇒ s
        _ ⇒ ""
    target = (is_first_tick ? "" : ((¬_got_path) ? target_read : _target))

    -- Shared per-tick result captures.
    d_cap_int ∈ Int = match last_results[0]
        IntResult(n) ⇒ n
        _ ⇒ 0
    d_cap_str ∈ String = match last_results[0]
        StringResult(s) ⇒ s
        _ ⇒ ""

    -- ── ZINIT — Z3 lifecycle + Effect-floor datatypes + consts ───
    -- zstep: -2 on tick 0, -1 on tick 1, then 0,1,2,… (capped).
    -- zstep HOLDS at 9 while the ED machine (below) declares the
    -- three Effect-floor datatypes (LibArg → __SeqOf_LibArg →
    -- Effect) in the build context; it resumes at 10 when ed_src
    -- reaches 3 with the machine idle.
    zstep  ∈ Int
    ed_hold ∈ Bool = (_ed_act ≠ 0 ∨ _ed_src < 4)
    zstep = (is_first_tick ? 0 - 2
        : (_zstep = 9 ∧ ed_hold) ? 9
        : (_zstep < 60 ? _zstep + 1 : _zstep))

    z_cfg ∈ Int
    z_cfg = (is_first_tick ? 0 : zstep = 1 ? d_cap_int : _z_cfg)
    z_ctx ∈ Int
    z_ctx = (is_first_tick ? 0 : zstep = 2 ? d_cap_int : _z_ctx)
    z_sol ∈ Int
    z_sol = (is_first_tick ? 0 : zstep = 3 ? d_cap_int : _z_sol)
    z_isort ∈ Int
    z_isort = (is_first_tick ? 0 : zstep = 5 ? d_cap_int : _z_isort)
    z_bsort ∈ Int
    z_bsort = (is_first_tick ? 0 : zstep = 6 ? d_cap_int : _z_bsort)
    z_ssort ∈ Int
    z_ssort = (is_first_tick ? 0 : zstep = 7 ? d_cap_int : _z_ssort)
    z_rsort ∈ Int
    z_rsort = (is_first_tick ? 0 : zstep = 8 ? d_cap_int : _z_rsort)
    -- zstep holds at 9; latch the arena only on the FIRST 9-tick.
    z_arena ∈ Int
    z_arena = (is_first_tick ? 0
        : (zstep = 9 ∧ _zstep = 8) ? d_cap_int : _z_arena)
    z_arrsort ∈ Int
    z_arrsort = (is_first_tick ? 0 : zstep = 11 ? d_cap_int : _z_arrsort)
    z_sym_effs ∈ Int
    z_sym_effs = (is_first_tick ? 0 : zstep = 12 ? d_cap_int : _z_sym_effs)
    z_effs ∈ Int
    z_effs = (is_first_tick ? 0 : zstep = 13 ? d_cap_int : _z_effs)
    z_sym_elen ∈ Int
    z_sym_elen = (is_first_tick ? 0 : zstep = 14 ? d_cap_int : _z_sym_elen)
    z_elen ∈ Int
    z_elen = (is_first_tick ? 0 : zstep = 15 ? d_cap_int : _z_elen)
    z_zero ∈ Int
    z_zero = (is_first_tick ? 0 : zstep = 16 ? d_cap_int : _z_zero)
    z_one ∈ Int
    z_one = (is_first_tick ? 0 : zstep = 17 ? d_cap_int : _z_one)
    z_two ∈ Int
    z_two = (is_first_tick ? 0 : zstep = 18 ? d_cap_int : _z_two)
    z_true ∈ Int
    z_true = (is_first_tick ? 0 : zstep = 19 ? d_cap_int : _z_true)
    z_false ∈ Int
    z_false = (is_first_tick ? 0 : zstep = 20 ? d_cap_int : _z_false)
    tbase ∈ Int
    tbase = (is_first_tick ? 0 : zstep = 21 ? d_cap_int : _tbase)
    st_base ∈ Int
    st_base = (is_first_tick ? 0 : zstep = 22 ? d_cap_int : _st_base)
    -- D3: last_results / last_results__len / is_first_tick as real
    -- build-context consts (zsteps 22-31), so user constraints can
    -- reference them. The last_results__len floor assert moves INTO
    -- the build context (it always serializes, so the textual
    -- prelude drops its len lines unconditionally; the Result
    -- datatype + last_results decl lines drop only when a user
    -- constraint mentioned last_results — see saw_lr).
    z_lrsort ∈ Int
    z_lrsort = (is_first_tick ? 0 : zstep = 23 ? d_cap_int : _z_lrsort)
    z_sym_lr ∈ Int
    z_sym_lr = (is_first_tick ? 0 : zstep = 24 ? d_cap_int : _z_sym_lr)
    z_lastres ∈ Int
    z_lastres = (is_first_tick ? 0 : zstep = 25 ? d_cap_int : _z_lastres)
    z_sym_lrl ∈ Int
    z_sym_lrl = (is_first_tick ? 0 : zstep = 26 ? d_cap_int : _z_sym_lrl)
    z_lrlen ∈ Int
    z_lrlen = (is_first_tick ? 0 : zstep = 27 ? d_cap_int : _z_lrlen)
    z_sym_ift ∈ Int
    z_sym_ift = (is_first_tick ? 0 : zstep = 28 ? d_cap_int : _z_sym_ift)
    z_ift ∈ Int
    z_ift = (is_first_tick ? 0 : zstep = 29 ? d_cap_int : _z_ift)
    z_lrge ∈ Int
    z_lrge = (is_first_tick ? 0 : zstep = 30 ? d_cap_int : _z_lrge)
    -- D2: 3/4 numerals (effects literals up to 4 elements) + the
    -- (Array Int Int) sort for user Seq(Int) memberships.
    z_three ∈ Int
    z_three = (is_first_tick ? 0 : zstep = 33 ? d_cap_int : _z_three)
    z_four ∈ Int
    z_four = (is_first_tick ? 0 : zstep = 34 ? d_cap_int : _z_four)
    z_iarr ∈ Int
    z_iarr = (is_first_tick ? 0 : zstep = 35 ? d_cap_int : _z_iarr)
    -- E1: the effects floor `(assert (>= effects__len 0))` lives in
    -- the BUILD context (zsteps 35-36, the ze_lrge/ze_lrassert
    -- pattern) — the oracle emits it unconditionally for every unit.
    z_ege ∈ Int
    z_ege = (is_first_tick ? 0 : zstep = 36 ? d_cap_int : _z_ege)
    -- F2: the claim-index cursor buffer (256 entries × 8 bytes; the
    -- body-start token cursor of every skipped claim, decl order —
    -- names live in ci_names, the st_names pattern).
    ci_base ∈ Int
    ci_base = (is_first_tick ? 0 : zstep = 38 ? d_cap_int : _ci_base)

    -- ── ED — enum-declaration machine (see compiler2/driver_enum.ev) ──
    ..DriverEnum
    -- ── G2: the record-type registry + the RD machine ─────────────
    ..DriverRecord
    -- ── LEX (fossil FSM; gated to start after ZINIT) ──────────────
    ..DriverLex

    -- ── PHASE control (0 lex · 2 parse · 3 emit; REVERSE deleted) ─
    phase  ∈ Int

    -- entering_parse = the lex_done tick: flush any pending string
    -- write, write the EofTok sentinel, then parse starts next tick.
    entering_parse ∈ Bool = ((¬is_first_tick) ∧ (_phase = 0) ∧ lex_done)
    in_parse       ∈ Bool = (_phase = 2)

    -- ── TOKEN WINDOW (see compiler2/driver_window.ev) ────────────
    ..DriverWindow

    -- ── PARSE dispatch (pmode 0 dispatch · 1 skip · 2 claim) ──────
    -- All modes read the shared token window; "nil" = EofTok head
    -- (the sentinel / past-end decode). Actions are tok_ready-gated.
    pmode  ∈ Int

    d_items_nil ∈ Bool = (ww_t0 matches EofTok)
    d_head_is_claim ∈ Bool = (ww_t0 matches KwClaim)
    d_cl_name ∈ String = match ww_t1
        Ident(s) ⇒ s
        _ ⇒ ""
    d_name_ok ∈ Bool = (d_cl_name = target)
    d_is_param ∈ Bool = (ww_t2 matches LParen)

    -- user enum declarations: a KwEnum head whose name is NOT one
    -- of the floor enums already declared at ZINIT enters the
    -- collection mode (pmode 4) instead of the skip walk. One user
    -- enum per compile (ue_done gates re-entry); variants are
    -- nullary or 1-2-field payloads (C3 — a malformed/3-field
    -- payload bails to skip).
    d_head_is_enum ∈ Bool = (ww_t0 matches KwEnum)
    d_en_reserved ∈ Bool = (d_cl_name = "Effect" ∨ d_cl_name = "Result"
        ∨ d_cl_name = "LibArg")

    d_in_dispatch ∈ Bool = (in_parse ∧ (_pmode = 0) ∧ tok_ready)
    d_enter_claim ∈ Bool = (d_in_dispatch ∧ (¬d_items_nil) ∧ d_head_is_claim ∧ d_name_ok ∧ (¬d_is_param))
    -- F1: a PARAMETRIZED target claim enters the pmode-9 group walk
    -- (`claim main (` = 3 tokens); params declare + manifest like
    -- memberships. Non-target parametrized claims still skip.
    d_enter_claimp ∈ Bool = (d_in_dispatch ∧ (¬d_items_nil) ∧ d_head_is_claim ∧ d_name_ok ∧ d_is_param)
    d_enter_edecl ∈ Bool = (d_in_dispatch ∧ (¬d_items_nil)
        ∧ d_head_is_enum ∧ (¬d_en_reserved) ∧ (¬_ue_done)
        ∧ (ww_t1 matches Ident(_)) ∧ (ww_t2 matches Eq))
    d_enter_skip  ∈ Bool = (d_in_dispatch ∧ (¬d_items_nil) ∧ (¬d_enter_claim) ∧ (¬d_enter_claimp) ∧ (¬d_enter_edecl))
    d_all_done    ∈ Bool = (d_in_dispatch ∧ d_items_nil)
    d_in_skip     ∈ Bool = (in_parse ∧ (_pmode = 1) ∧ tok_ready)
    d_in_claim    ∈ Bool = (in_parse ∧ (_pmode = 2))

    -- user enum name + done flag
    ue_name ∈ String
    ue_name = (is_first_tick ? "" : d_enter_edecl ? d_cl_name : _ue_name)
    ue_done ∈ Bool
    ue_done = (is_first_tick ? false : ed_done_user ? true : _ue_done)

    -- ── F2: the claim index ───────────────────────────────────────
    -- Built during the skip pass: every skipped `claim Name …` top
    -- records its name (ci_names — fixed-width 32-byte records, the
    -- B1 st_names pattern) and its body-start cursor (_tcur + 2 —
    -- the token after `claim Name`, which is `(` for parametrized
    -- claims; the call-time param-skip walks over it). Cursors live
    -- in the ci_base buffer (256 × 8 bytes), written one per skipped
    -- claim on the skip-entry tick. Composition can only call claims
    -- that PRECEDE the call site textually (one-pass index — true
    -- for the corpus: stdlib then helpers then main).
    -- FTI bounds constraint: ci_base holds 2048 claim-index entries.
    -- ci_cnt < 2048 makes an index past the buffer end UNSAT (the model
    -- refuses it) rather than a native overrun.
    ci_cnt ∈ Int < 2048
    ci_names ∈ String
    ci_add ∈ Bool = (d_enter_skip
        ∧ (d_head_is_claim ∨ (ww_t0 matches KwType))
        ∧ (ww_t1 matches Ident(_)))
    ci_entry ∈ String = "|" ++ substr(d_cl_name ++ "                               ", 0, 31)
    ci_cnt = (is_first_tick ? 0 : ci_add ? _ci_cnt + 1 : _ci_cnt)
    ci_names = (is_first_tick ? ""
        : ci_add ? _ci_names ++ ci_entry
        : _ci_names)
    e_ciw ∈ Effect
    BuildMemWriteLong(addr ↦ ci_base + (8 * _ci_cnt), value ↦ _tcur + 2,
        eff ↦ e_ciw)

    -- pmode 4 collection: one variant per tick — `Vname [|]` or a
    -- PAYLOADED `Vname ( Ty [, Ty] ) [|]` (C3; up to TWO fields of
    -- Int/Bool/String/Real/self — a third field would need a
    -- 9-token lookahead past the 8-token window; an unknown field
    -- type would mis-resolve to sort 0). Prepend-accumulated (the
    -- declared variant order is REVERSED vs source — harmless:
    -- declaration and harvest peel the same list).
    ec_active ∈ Bool = (in_parse ∧ (_pmode = 4) ∧ (_ed_act = 0)
        ∧ (¬ed_done_user) ∧ tok_ready)
    ec_vname ∈ String = match ww_t0
        Ident(s) ⇒ s
        _ ⇒ ""
    ec_v_ok ∈ Bool = (ww_t0 matches Ident(_))
    ec_more ∈ Bool = (ww_t1 matches Pipe)
    ec_payload ∈ Bool = (ww_t1 matches LParen)
    ec_ty0 ∈ String = match ww_t2
        Ident(s) ⇒ s
        _ ⇒ ""
    ec_ty1 ∈ String = match ww_t4
        Ident(s) ⇒ s
        _ ⇒ ""
    ec_ty0_ok ∈ Bool = (ec_ty0 = "Int" ∨ ec_ty0 = "Bool"
        ∨ ec_ty0 = "String" ∨ ec_ty0 = "Real" ∨ ec_ty0 = _ue_name)
    ec_ty1_ok ∈ Bool = (ec_ty1 = "Int" ∨ ec_ty1 = "Bool"
        ∨ ec_ty1 = "String" ∨ ec_ty1 = "Real" ∨ ec_ty1 = _ue_name)
    ec_p1 ∈ Bool = (ec_payload ∧ (ww_t2 matches Ident(_)) ∧ ec_ty0_ok
        ∧ (ww_t3 matches RParen))
    ec_p2 ∈ Bool = (ec_payload ∧ (ww_t2 matches Ident(_)) ∧ ec_ty0_ok
        ∧ (ww_t3 matches Comma) ∧ (ww_t4 matches Ident(_)) ∧ ec_ty1_ok
        ∧ (ww_t5 matches RParen))
    ec_p_ok ∈ Bool = (ec_p1 ∨ ec_p2)
    ec_more_p ∈ Bool = (ec_p2 ? (ww_t6 matches Pipe)
        : (ww_t4 matches Pipe))
    ec_more_u ∈ Bool = (ec_payload ? ec_more_p : ec_more)
    ec_bail ∈ Bool = (ec_active
        ∧ ((ec_payload ∧ (¬ec_p_ok)) ∨ (¬ec_v_ok)))
    ec_take ∈ Bool = (ec_active ∧ ec_v_ok ∧ ((¬ec_payload) ∨ ec_p_ok))
    ec_start ∈ Bool = (ec_take ∧ (¬ec_more_u))
    ec_fields ∈ EVFieldList = (ec_p2
        ? EVFCons(EVFType(ec_ty0), EVFCons(EVFType(ec_ty1), EVFNil))
        : EVFCons(EVFType(ec_ty0), EVFNil))
    ec_v ∈ EnumVariantDecl = (ec_payload
        ? EVDeclP(ec_vname, ec_fields)
        : EVDecl(ec_vname))
    ec_cons ∈ Int = (ec_p2 ? (ec_more_p ? 7 : 6)
        : ec_p1 ? (ec_more_p ? 5 : 4)
        : ec_more ? 2 : 1)
    ec_list ∈ EnumVariantList
    ec_list_n ∈ EnumVariantList = (ec_take
        ? EVCons(ec_v, _ec_list) : _ec_list)
    ec_list = (is_first_tick ? EVNil
        : d_enter_edecl ? EVNil
        : ec_take ? ec_list_n
        : _ec_list)

    -- pmode 5: effects-literal element walk. Items run under pmode 5
    -- exactly as under the claim walk; this dispatcher fires only
    -- when the element items have drained.
    -- D2: the walk is now a CHAIN walk over the corpus's conditional
    -- shape `effects ∈ Seq(Effect) = (g1 ? ⟨…⟩ : (g2 ? ⟨…⟩ : ⟨…⟩))`
    -- as well as the plain literal. Chain substates (el_st):
    --   0 = expect a branch head (`⟨` literal / `(` nested chain) or
    --       walk the current literal's elements (the P3e machinery);
    --   1 = expect a branch GUARD — a full Pratt expression parsed
    --       under pk_kind 6 with qstop (the top-level `?` terminates
    --       it and is consumed on completion);
    --   2 = after a branch literal closed — `:` returns to 0 (else
    --       branch), `)` closes one chain paren (the LAST one fires
    --       the guard fold).
    -- In a chain, element select-eqs and the branch len-eq become
    -- HANDLES (C2SelEqH / C2LenEqH) folded into a per-branch
    -- conjunction on the stack; the chain end folds (g_k, B_k)
    -- pairs bottom-up via C2ChainLvl into the oracle's nested
    --   (and (=> g B) (=> (not g) T))
    -- shape and asserts it. Unconditional literals keep the P3e
    -- per-element asserts byte-for-byte.
    el_cnt ∈ Int
    el_lc ∈ Int
    el_lib ∈ String
    el_fn ∈ String
    el_st ∈ Int
    ch_on ∈ Bool
    ch_pd ∈ Int
    ch_n ∈ Int

    d_in_el ∈ Bool = (in_parse ∧ (_pmode = 5) ∧ d_witems_nil ∧ tok_ready)
    el_w_t2s ∈ String = match ww_t2
        StringLit(s) ⇒ s
        _ ⇒ ""
    el_w_t4s ∈ String = match ww_t4
        StringLit(s) ⇒ s
        _ ⇒ ""
    el_head_name ∈ String = match ww_t0
        Ident(s) ⇒ s
        _ ⇒ ""
    -- chain dispatch
    el_g_enter ∈ Bool = (d_in_el ∧ (_el_st = 1))
    el_open ∈ Bool = (d_in_el ∧ (_el_st = 0) ∧ _ch_on ∧ (_el_lc = 0)
        ∧ (ww_t0 matches OpSeqOpen))
    el_nest ∈ Bool = (d_in_el ∧ (_el_st = 0) ∧ _ch_on ∧ (_el_lc = 0)
        ∧ (ww_t0 matches LParen))
    el_st2 ∈ Bool = (d_in_el ∧ (_el_st = 2))
    el_colon ∈ Bool = (el_st2 ∧ (ww_t0 matches Colon))
    el_rp ∈ Bool = (el_st2 ∧ (ww_t0 matches RParen))
    ch_fire ∈ Bool = (el_rp ∧ (_ch_pd = 1))
    el_st2_bad ∈ Bool = (el_st2 ∧ (¬el_colon) ∧ (¬el_rp))
    -- element dispatch (el_st = 0, el_lc = 0)
    el_exit_enter ∈ Bool = (d_in_el ∧ (_el_st = 0) ∧ (_el_lc = 0)
        ∧ (el_head_name = "Exit") ∧ (ww_t1 matches LParen))
    el_lc_enter ∈ Bool = (d_in_el ∧ (_el_st = 0) ∧ (_el_lc = 0)
        ∧ (el_head_name = "LibCall") ∧ (ww_t1 matches LParen)
        ∧ (ww_t2 matches StringLit(_)) ∧ (ww_t3 matches Comma)
        ∧ (ww_t4 matches StringLit(_)) ∧ (ww_t5 matches Comma))
    el_comma ∈ Bool = (d_in_el ∧ (_el_st = 0) ∧ (_el_lc = 0)
        ∧ (ww_t0 matches Comma))
    el_close ∈ Bool = (d_in_el ∧ (_el_st = 0) ∧ (_el_lc = 0)
        ∧ (ww_t0 matches OpSeqClose))
    -- LibCall bite 2: `⟨ ArgStr ( X ) ⟩ )` with X a string literal,
    -- an ident, or an int literal (ArgInt) — or the EMPTY args seq
    -- `⟨ ⟩ )` (the corpus getpid shape).
    el_arg_name ∈ String = match ww_t1
        Ident(s) ⇒ s
        _ ⇒ ""
    el_arg_e ∈ Expr
    el_arg_ok ∈ Bool
    C2AtomE(t ↦ ww_t3, e ↦ el_arg_e, ok ↦ el_arg_ok)
    el_b2_shape ∈ Bool = ((ww_t0 matches OpSeqOpen)
        ∧ (ww_t1 matches Ident(_)) ∧ (ww_t2 matches LParen)
        ∧ el_arg_ok ∧ (ww_t4 matches RParen)
        ∧ (ww_t5 matches OpSeqClose) ∧ (ww_t6 matches RParen))
    el_b2e_shape ∈ Bool = ((ww_t0 matches OpSeqOpen)
        ∧ (ww_t1 matches OpSeqClose) ∧ (ww_t2 matches RParen))
    el_b2 ∈ Bool = (d_in_el ∧ (_el_lc = 1) ∧ el_b2_shape)
    el_b2e ∈ Bool = (d_in_el ∧ (_el_lc = 1) ∧ el_b2e_shape)
    el_b2_bad ∈ Bool = (d_in_el ∧ (_el_lc = 1) ∧ (¬el_b2_shape)
        ∧ (¬el_b2e_shape))
    el_bad ∈ Bool = (d_in_el ∧ (_el_st = 0) ∧ (_el_lc = 0)
        ∧ (¬el_exit_enter) ∧ (¬el_lc_enter) ∧ (¬el_comma) ∧ (¬el_close)
        ∧ (¬el_open) ∧ (¬el_nest))
    el_argdecl ∈ Int = (el_arg_name = "ArgInt" ? z_argint_decl
        : z_argstr_decl)
    -- in a chain, the element eq is a HANDLE, not an assert
    el_seleq_item ∈ C2Item = (_ch_on ? C2SelEqH(_el_cnt)
        : C2SelectEq(_el_cnt))
    el_lc_items ∈ C2Items = C2ICons(C2Process(EStr(_el_lib)),
        C2ICons(C2Process(EStr(_el_fn)),
        C2ICons(C2Process(el_arg_e),
        C2ICons(C2App(el_argdecl, 1),
        C2ICons(C2PushH(z_empty_val),
        C2ICons(C2App(z_cell_decl, 2),
        C2ICons(C2App(z_lc_decl, 3),
        C2ICons(el_seleq_item, C2INil))))))))
    el_lce_items ∈ C2Items = C2ICons(C2Process(EStr(_el_lib)),
        C2ICons(C2Process(EStr(_el_fn)),
        C2ICons(C2PushH(z_empty_val),
        C2ICons(C2App(z_lc_decl, 3),
        C2ICons(el_seleq_item, C2INil)))))

    -- guard completion (the kind-6 Pratt parse finished)
    eg_done ∈ Bool = (p_done ∧ (_pk_kind = 6) ∧ (¬pr_bad))

    -- branch close (chain): fold the k sel-eq handles + the len-eq
    -- into this branch's conjunction handle B
    el_cj1 ∈ C2Items = C2ICons(C2Op(OpConj), C2INil)
    el_cj2 ∈ C2Items = C2ICons(C2Op(OpConj), el_cj1)
    el_cj3 ∈ C2Items = C2ICons(C2Op(OpConj), el_cj2)
    el_cj4 ∈ C2Items = C2ICons(C2Op(OpConj), el_cj3)
    el_bfold ∈ C2Items = C2ICons(C2LenEqH(_el_cnt),
        (_el_cnt = 0 ? C2INil
        : _el_cnt = 1 ? el_cj1
        : _el_cnt = 2 ? el_cj2
        : _el_cnt = 3 ? el_cj3
        : el_cj4))
    -- chain end: fold ch_n (guard, branch) pairs bottom-up + assert
    ch_l0 ∈ C2Items = C2ICons(C2AssertTop, C2INil)
    ch_l1 ∈ C2Items
    C2ChainLvl(tail ↦ ch_l0, out ↦ ch_l1)
    ch_l2 ∈ C2Items
    C2ChainLvl(tail ↦ ch_l1, out ↦ ch_l2)
    ch_l3 ∈ C2Items
    C2ChainLvl(tail ↦ ch_l2, out ↦ ch_l3)
    ch_l4 ∈ C2Items
    C2ChainLvl(tail ↦ ch_l3, out ↦ ch_l4)
    ch_fold_items ∈ C2Items = (_ch_n = 1 ? ch_l1
        : _ch_n = 2 ? ch_l2
        : _ch_n = 3 ? ch_l3
        : _ch_n ≥ 4 ? ch_l4
        : ch_l0)

    el_lc = (is_first_tick ? 0
        : el_lc_enter ? 1
        : (el_b2 ∨ el_b2e ∨ el_b2_bad) ? 0
        : _el_lc)
    el_lib = (is_first_tick ? "" : el_lc_enter ? el_w_t2s : _el_lib)
    el_fn = (is_first_tick ? "" : el_lc_enter ? el_w_t4s : _el_fn)
    el_cnt = (is_first_tick ? 0
        : d_enter_el ? 0
        : el_open ? 0
        : ((p_done ∧ (¬pr_bad) ∧ _pk_kind = 3) ∨ el_b2 ∨ el_b2e)
            ? _el_cnt + 1
        : _el_cnt)
    el_st = (is_first_tick ? 0
        : d_enter_el ? (c_eff_cond ? 1 : 0)
        : eg_done ? 0
        : el_colon ? 0
        : el_nest ? 1
        : (el_close ∧ _ch_on) ? 2
        : el_rp ? 2
        : _el_st)
    ch_on = (is_first_tick ? false : d_enter_el ? c_eff_cond : _ch_on)
    ch_pd = (is_first_tick ? 0
        : d_enter_el ? (c_eff_cond ? 1 : 0)
        : el_nest ? _ch_pd + 1
        : el_rp ? _ch_pd - 1
        : _ch_pd)
    ch_n = (is_first_tick ? 0
        : d_enter_el ? 0
        : eg_done ? _ch_n + 1
        : _ch_n)

    -- ── pmode 6: match-pin walk (D3 · C4 n-arm · C5 binds+exprs) ──
    -- `name ∈ Type = match <scrut>` + up to THREE arms. scrut is a
    -- plain ident or `last_results [ <int> ]`. Arm HEADS:
    --   `Ctor ( bind ) ⇒`   payload arm head (5 tokens)
    --   `Ctor ⇒`            nullary arm head (2 tokens)
    --   `_ ⇒`               wildcard arm head (2 tokens; ENDS the
    --                       match — later arms are dead, the legacy
    --                       fold rule)
    -- C5: each arm BODY is a FULL Pratt expression — the head tick
    -- latches (ctor, bind, is-wildcard) and re-enters the Pratt FSM
    -- (pk_kind 4); the body expression ends at the first token that
    -- cannot extend it (the next arm's head Ident / the next body
    -- line / EOF). On body completion the previous PENDING arm
    -- promotes into a tested slot and the finished arm becomes
    -- pending; a wildcard body's completion FIRES the match.
    -- The match also ends at the first non-arm-shaped head (the next
    -- body line). The DEFAULT body is the wildcard's body, or — with
    -- no wildcard — the LAST arm's body with its test dropped (the
    -- legacy right-to-left fold contract, translate2_match.ev). At
    -- most 2 TESTED arms (006's 3-arm match = 2 tested + default);
    -- more bails the line. Lowering is the fossil's nested
    -- ite-over-tester shape:
    --   (ite ((_ is C1) scrut) b1 (ite ((_ is C2) scrut) b2 def))
    -- C5 binds: a payload arm's bind name shadows ONLY within its
    -- arm body — the items program brackets the body's C2Process
    -- with C2BindScope(bind, accessor_decl)/C2BindEnd, and the
    -- walker expands every in-scope EIdent(bind) leaf to the
    -- accessor app over the scrutinee (mk_app(acc, scrut) — the
    -- oracle's `(Ctor__f0 scrut)`; oracle-probed: a dropped-test
    -- default arm's bind reads through the accessor too). Accessors
    -- resolve through the uev registry (field-0 decls, harvested by
    -- the ED machine's user run) + the IntResult/StringResult floor.
    -- Testers resolve through uev + the floor as before.
    mp_st ∈ Int
    mp_name ∈ String
    mp_sc ∈ Int
    mp_lr ∈ Bool
    mp_idx ∈ Int
    mp_scrut ∈ String
    -- arm-head latches (C5: the head tick latches these, then the
    -- body parses through the Pratt FSM under pk_kind 4)
    mp_ac ∈ String
    mp_ab ∈ String
    mp_awc ∈ Bool
    -- pending arm (the most recent COMPLETED ctor arm — promoted to
    -- a tested slot when a later arm's body completes, or becomes
    -- the default at end)
    mp_pc ∈ String
    mp_pb ∈ String
    mp_pe ∈ Expr
    mp_hasp ∈ Bool
    -- tested arm slots (promotion order = source order)
    mp_n ∈ Int
    mp_c1 ∈ String
    mp_bd1 ∈ String
    mp_e1 ∈ Expr
    mp_c2 ∈ String
    mp_bd2 ∈ String
    mp_e2 ∈ Expr

    m_act ∈ Bool = (in_parse ∧ (_pmode = 6) ∧ tok_ready)
    mp_s_lr ∈ Bool = (m_act ∧ (_mp_st = 0)
        ∧ (el_head_name = "last_results") ∧ (ww_t1 matches LBracket)
        ∧ (ww_t2 matches IntLit(_)) ∧ (ww_t3 matches RBracket))
    mp_s_id ∈ Bool = (m_act ∧ (_mp_st = 0) ∧ (ww_t0 matches Ident(_))
        ∧ (¬mp_s_lr))
    mp_s_bad ∈ Bool = (m_act ∧ (_mp_st = 0) ∧ (¬mp_s_lr) ∧ (¬mp_s_id))
    mp_idx_v ∈ Int = match ww_t2
        IntLit(n) ⇒ n
        _ ⇒ 0
    mp_w_t2s ∈ String = match ww_t2
        Ident(s) ⇒ s
        _ ⇒ ""
    -- arm-HEAD detection (st 1; bodies parse via Pratt kind 4)
    mp_st1 ∈ Bool = (m_act ∧ (_mp_st = 1))
    mp_arm_pl_h ∈ Bool = (mp_st1 ∧ (ww_t0 matches Ident(_))
        ∧ (el_head_name ≠ "_")
        ∧ (ww_t1 matches LParen) ∧ (ww_t2 matches Ident(_))
        ∧ (ww_t3 matches RParen) ∧ (ww_t4 matches OpImplies))
    mp_arm_nl_h ∈ Bool = (mp_st1 ∧ (ww_t0 matches Ident(_))
        ∧ (el_head_name ≠ "_")
        ∧ (ww_t1 matches OpImplies))
    mp_arm_wc_h ∈ Bool = (mp_st1 ∧ (el_head_name = "_")
        ∧ (ww_t1 matches OpImplies))
    mp_arm_new ∈ Bool = (mp_arm_pl_h ∨ mp_arm_nl_h)
    mp_overflow ∈ Bool = (mp_arm_new ∧ _mp_hasp ∧ (_mp_n ≥ 2))
    mp_take ∈ Bool = (mp_arm_new ∧ (¬mp_overflow))
    mp_wc_over ∈ Bool = (mp_arm_wc_h ∧ _mp_hasp ∧ (_mp_n ≥ 2))
    mp_wc_take ∈ Bool = (mp_arm_wc_h ∧ (¬mp_wc_over))
    mp_benter ∈ Bool = (mp_take ∨ mp_wc_take)
    mp_endt ∈ Bool = (mp_st1 ∧ (¬mp_arm_new) ∧ (¬mp_arm_wc_h))
    mp_fire_end ∈ Bool = (mp_endt ∧ _mp_hasp)
    mp_fire ∈ Bool = mp_fire_end
    mp_bail ∈ Bool = (mp_s_bad ∨ mp_overflow ∨ mp_wc_over
        ∨ (mp_endt ∧ (¬_mp_hasp)))

    -- arm-body completion (the kind-4 Pratt parse finished)
    mq_done ∈ Bool = (p_done ∧ (_pk_kind = 4))
    mq_wc ∈ Bool = (mq_done ∧ (¬pr_bad) ∧ _mp_awc)
    mq_arm ∈ Bool = (mq_done ∧ (¬pr_bad) ∧ (¬_mp_awc))
    mq_promote ∈ Bool = (mq_arm ∧ _mp_hasp)

    mp_st = (is_first_tick ? 0
        : d_enter_match ? 0
        : (mp_s_lr ∨ mp_s_id) ? 1
        : _mp_st)
    mp_name = (is_first_tick ? "" : d_enter_match ? c_dname : _mp_name)
    mp_sc = (is_first_tick ? 0 : d_enter_match ? c_sc : _mp_sc)
    mp_lr = (is_first_tick ? false
        : d_enter_match ? false
        : mp_s_lr ? true
        : _mp_lr)
    mp_idx = (is_first_tick ? 0 : mp_s_lr ? mp_idx_v : _mp_idx)
    mp_scrut = (is_first_tick ? "" : mp_s_id ? el_head_name : _mp_scrut)
    mp_ac = (is_first_tick ? ""
        : mp_take ? el_head_name
        : _mp_ac)
    mp_ab = (is_first_tick ? ""
        : mp_take ? (mp_arm_pl_h ? mp_w_t2s : "")
        : mp_wc_take ? ""
        : _mp_ab)
    mp_awc = (is_first_tick ? false
        : mp_benter ? mp_arm_wc_h
        : _mp_awc)
    mp_pc = (is_first_tick ? ""
        : d_enter_match ? ""
        : mq_arm ? _mp_ac
        : _mp_pc)
    mp_pb = (is_first_tick ? ""
        : d_enter_match ? ""
        : mq_arm ? _mp_ab
        : _mp_pb)
    mp_pe = (is_first_tick ? ENoExpr
        : d_enter_match ? ENoExpr
        : mq_arm ? pr_sres
        : _mp_pe)
    mp_hasp = (is_first_tick ? false
        : d_enter_match ? false
        : mq_arm ? true
        : _mp_hasp)
    mp_n = (is_first_tick ? 0
        : d_enter_match ? 0
        : mq_promote ? _mp_n + 1
        : _mp_n)
    mp_c1 = (is_first_tick ? ""
        : d_enter_match ? ""
        : (mq_promote ∧ _mp_n = 0) ? _mp_pc
        : _mp_c1)
    mp_bd1 = (is_first_tick ? ""
        : d_enter_match ? ""
        : (mq_promote ∧ _mp_n = 0) ? _mp_pb
        : _mp_bd1)
    mp_e1 = (is_first_tick ? ENoExpr
        : d_enter_match ? ENoExpr
        : (mq_promote ∧ _mp_n = 0) ? _mp_pe
        : _mp_e1)
    mp_c2 = (is_first_tick ? ""
        : d_enter_match ? ""
        : (mq_promote ∧ _mp_n = 1) ? _mp_pc
        : _mp_c2)
    mp_bd2 = (is_first_tick ? ""
        : d_enter_match ? ""
        : (mq_promote ∧ _mp_n = 1) ? _mp_pb
        : _mp_bd2)
    mp_e2 = (is_first_tick ? ENoExpr
        : d_enter_match ? ENoExpr
        : (mq_promote ∧ _mp_n = 1) ? _mp_pe
        : _mp_e2)

    -- items program (built on the fire tick — an end-fire head tick
    -- or a wildcard body's mq_wc completion tick). On a wildcard
    -- fire the pending arm promotes COMBINATIONALLY into the last
    -- tested slot; on an end fire the pending arm IS the default
    -- (test dropped — and its bind, if any, still reads through the
    -- accessor: oracle-probed).
    mp_v_n ∈ Int = (mq_wc ? (_mp_hasp ? _mp_n + 1 : _mp_n) : _mp_n)
    mp_v_c1 ∈ String = (_mp_n ≥ 1 ? _mp_c1 : _mp_pc)
    mp_v_b1 ∈ String = (_mp_n ≥ 1 ? _mp_bd1 : _mp_pb)
    mp_v_e1 ∈ Expr = (_mp_n ≥ 1 ? _mp_e1 : _mp_pe)
    mp_v_c2 ∈ String = (_mp_n ≥ 2 ? _mp_c2 : _mp_pc)
    mp_v_b2 ∈ String = (_mp_n ≥ 2 ? _mp_bd2 : _mp_pb)
    mp_v_e2 ∈ Expr = (_mp_n ≥ 2 ? _mp_e2 : _mp_pe)
    mp_v_def ∈ Expr = (mq_wc ? pr_sres : _mp_pe)
    mp_v_db ∈ String = (mq_wc ? "" : _mp_pb)
    mp_v_dc ∈ String = (mq_wc ? "" : _mp_pc)
    mp_t1 ∈ Int = (mp_v_c1 = "IntResult" ? z_irtest
        : mp_v_c1 = "StringResult" ? z_srtest
        : uev_n0 = mp_v_c1 ? uev_t0
        : uev_n1 = mp_v_c1 ? uev_t1
        : uev_n2 = mp_v_c1 ? uev_t2
        : uev_n3 = mp_v_c1 ? uev_t3
        : uev_n4 = mp_v_c1 ? uev_t4
        : uev_n5 = mp_v_c1 ? uev_t5
        : 0)
    mp_t2 ∈ Int = (mp_v_c2 = "IntResult" ? z_irtest
        : mp_v_c2 = "StringResult" ? z_srtest
        : uev_n0 = mp_v_c2 ? uev_t0
        : uev_n1 = mp_v_c2 ? uev_t1
        : uev_n2 = mp_v_c2 ? uev_t2
        : uev_n3 = mp_v_c2 ? uev_t3
        : uev_n4 = mp_v_c2 ? uev_t4
        : uev_n5 = mp_v_c2 ? uev_t5
        : 0)
    mp_acc1 ∈ Int = (mp_v_c1 = "IntResult" ? z_iracc
        : mp_v_c1 = "StringResult" ? z_sracc
        : uev_n0 = mp_v_c1 ? uev_a0
        : uev_n1 = mp_v_c1 ? uev_a1
        : uev_n2 = mp_v_c1 ? uev_a2
        : uev_n3 = mp_v_c1 ? uev_a3
        : uev_n4 = mp_v_c1 ? uev_a4
        : uev_n5 = mp_v_c1 ? uev_a5
        : 0)
    mp_acc2 ∈ Int = (mp_v_c2 = "IntResult" ? z_iracc
        : mp_v_c2 = "StringResult" ? z_sracc
        : uev_n0 = mp_v_c2 ? uev_a0
        : uev_n1 = mp_v_c2 ? uev_a1
        : uev_n2 = mp_v_c2 ? uev_a2
        : uev_n3 = mp_v_c2 ? uev_a3
        : uev_n4 = mp_v_c2 ? uev_a4
        : uev_n5 = mp_v_c2 ? uev_a5
        : 0)
    mp_dacc ∈ Int = (mp_v_dc = "IntResult" ? z_iracc
        : mp_v_dc = "StringResult" ? z_sracc
        : uev_n0 = mp_v_dc ? uev_a0
        : uev_n1 = mp_v_dc ? uev_a1
        : uev_n2 = mp_v_dc ? uev_a2
        : uev_n3 = mp_v_dc ? uev_a3
        : uev_n4 = mp_v_dc ? uev_a4
        : uev_n5 = mp_v_dc ? uev_a5
        : 0)
    mp_tailE ∈ C2Items = C2ICons(C2PinEq,
        C2ICons(C2AssertTop, C2INil))
    mp_tail_i1 ∈ C2Items = C2ICons(C2Ite, mp_tailE)
    mp_tail_i2 ∈ C2Items = C2ICons(C2Ite, C2ICons(C2Ite, mp_tailE))
    -- default seg (innermost): full-expr body, bind-scoped when the
    -- dropped-test pending arm carried a bind
    mp_dtail ∈ C2Items = (mp_v_n = 0 ? mp_tailE
        : mp_v_n = 1 ? mp_tail_i1
        : mp_tail_i2)
    mp_defseg ∈ C2Items = ((mp_v_db ≠ "" ∧ mp_dacc ≠ 0)
        ? C2ICons(C2BindScope(mp_v_db, mp_dacc),
            C2ICons(C2Process(mp_v_def), C2ICons(C2BindEnd, mp_dtail)))
        : C2ICons(C2Process(mp_v_def), mp_dtail))
    -- arm 2 (only reached when mp_v_n = 2)
    mp_b2seg ∈ C2Items = ((mp_v_b2 ≠ "" ∧ mp_acc2 ≠ 0)
        ? C2ICons(C2BindScope(mp_v_b2, mp_acc2),
            C2ICons(C2Process(mp_v_e2), C2ICons(C2BindEnd, mp_defseg)))
        : C2ICons(C2Process(mp_v_e2), mp_defseg))
    mp_c2seg ∈ C2Items = (_mp_lr
        ? C2ICons(C2Process(EIdent("last_results")),
            C2ICons(C2Process(EInt(_mp_idx)),
            C2ICons(C2SelH,
            C2ICons(C2App(mp_t2, 1), mp_b2seg))))
        : C2ICons(C2Process(EIdent(_mp_scrut)),
            C2ICons(C2App(mp_t2, 1), mp_b2seg)))
    -- arm 1
    mp_a1t ∈ C2Items = (mp_v_n ≥ 2 ? mp_c2seg : mp_defseg)
    mp_b1seg ∈ C2Items = ((mp_v_b1 ≠ "" ∧ mp_acc1 ≠ 0)
        ? C2ICons(C2BindScope(mp_v_b1, mp_acc1),
            C2ICons(C2Process(mp_v_e1), C2ICons(C2BindEnd, mp_a1t)))
        : C2ICons(C2Process(mp_v_e1), mp_a1t))
    mp_c1seg ∈ C2Items = (_mp_lr
        ? C2ICons(C2Process(EIdent("last_results")),
            C2ICons(C2Process(EInt(_mp_idx)),
            C2ICons(C2SelH,
            C2ICons(C2App(mp_t1, 1), mp_b1seg))))
        : C2ICons(C2Process(EIdent(_mp_scrut)),
            C2ICons(C2App(mp_t1, 1), mp_b1seg)))
    mp_items ∈ C2Items = C2ICons(C2DeclConst(_mp_name, _mp_sc),
        (mp_v_n = 0 ? mp_defseg : mp_c1seg))

    -- ── pmode 7: set-literal membership walk (C2: 041/042/062) ────
    -- `x ∈ { a, b, … }` / `x ∉ { … }` — one int element per tick,
    -- or-folded into an Expr; the closing `}` asserts it (wrapped in
    -- C2Not for ∉). The empty set lowers to `false` (062: `x ∈ {}`
    -- is UNSAT by construction).
    ms_name ∈ String
    ms_neg ∈ Bool
    ms_e ∈ Expr

    s_act ∈ Bool = (in_parse ∧ (_pmode = 7) ∧ tok_ready)
    ms_elem ∈ Bool = (s_act ∧ (ww_t0 matches IntLit(_)))
    ms_close ∈ Bool = (s_act ∧ (ww_t0 matches RBrace))
    ms_bad ∈ Bool = (s_act ∧ (¬ms_elem) ∧ (¬ms_close))
    ms_v ∈ Int = match ww_t0
        IntLit(n) ⇒ n
        _ ⇒ 0
    ms_eq ∈ Expr = EBinOp(OpEq, EIdent(_ms_name), EInt(ms_v))
    ms_e_n ∈ Expr = ((_ms_e matches ENoExpr) ? ms_eq
        : EBinOp(OpDisj, _ms_e, ms_eq))
    ms_name = (is_first_tick ? "" : d_enter_set ? c_name : _ms_name)
    ms_neg = (is_first_tick ? false : d_enter_set ? c_is_nmem : _ms_neg)
    ms_e = (is_first_tick ? ENoExpr
        : d_enter_set ? ENoExpr
        : ms_elem ? ms_e_n
        : _ms_e)
    ms_body ∈ Expr = ((_ms_e matches ENoExpr) ? EIdent("false") : _ms_e)
    ms_items ∈ C2Items = C2ICons(C2Process(ms_body),
        (_ms_neg ? C2ICons(C2Not, C2ICons(C2AssertTop, C2INil))
            : C2ICons(C2AssertTop, C2INil)))

    -- ── pmode 8: user Seq(Int) literal walk (D2: 051/052/057/065) ──
    -- `s ∈ Seq(Int)` declares TWO consts — `s : (Array Int Int)` and
    -- `s__len : Int` with the `(>= s__len 0)` floor (the oracle's
    -- exact decl shape; manifest `s:Seq(Int)`, two carry declares).
    -- `s = ⟨e0, e1, …⟩` walks one full-Pratt element per `,`
    -- (pk_kind 7), asserting `(= (select s i) e_i)` per element and
    -- `(= s__len n)` at the closing `⟩` — all through EXISTING items
    -- (symtab reads of s / s__len + SelH + PinEq). NOTE: the oracle
    -- emits a degenerate `(= n n)` here (it substitutes a recorded
    -- length for `#s`); the driver pins s__len for real — sat-equal
    -- on every census fixture, and 065's contradiction still lowers
    -- to UNSAT ((= s__len 3) ∧ (= s__len 5)). `#s` lowers to the
    -- s__len const (per-sort `#` dispatch), not str.len. One
    -- registered seq var per compile (the census surface).
    sq_set ∈ Bool
    sq_name ∈ String
    sq_rt ∈ Int
    sq_set = (is_first_tick ? false : d_seq_mem ? true : _sq_set)
    sq_name = (is_first_tick ? ""
        : (d_seq_mem ∧ (¬_sq_set)) ? c_dname
        : _sq_name)
    -- G2: the registered seq var's ELEMENT record type (-1 = Int)
    sq_rt = (is_first_tick ? 0 - 1
        : (d_seq_mem ∧ (¬_sq_set)) ? c_sq_rt
        : _sq_rt)

    -- ── G2: set-var registry (≤ 2 Set(T) vars) + the pmode-14
    -- set-literal walk. A Set(T) membership registers (name, elem
    -- type); `s = {a, b}` folds mk_set_add over mk_empty_set with
    -- each element a C2RecVal ctor app, records the element names
    -- (for ∀-over-set and cardinality), and pins the const.
    stv_cnt ∈ Int
    stv_n0 ∈ String
    stv_k0 ∈ Int
    stv_e0 ∈ String
    stv_c0 ∈ Int
    stv_n1 ∈ String
    stv_k1 ∈ Int
    stv_e1 ∈ String
    stv_c1 ∈ Int
    sv_cur ∈ Int

    d_setmem ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ c_setmem_line)
    stv_cnt = (is_first_tick ? 0
        : (d_setmem ∧ _stv_cnt < 2) ? _stv_cnt + 1
        : _stv_cnt)
    stv_n0 = (is_first_tick ? ""
        : (d_setmem ∧ _stv_cnt = 0) ? c_dname : _stv_n0)
    stv_k0 = (is_first_tick ? 0
        : (d_setmem ∧ _stv_cnt = 0) ? c_sq_rt : _stv_k0)
    stv_n1 = (is_first_tick ? ""
        : (d_setmem ∧ _stv_cnt = 1) ? c_dname : _stv_n1)
    stv_k1 = (is_first_tick ? 0
        : (d_setmem ∧ _stv_cnt = 1) ? c_sq_rt : _stv_k1)

    -- set-literal line: `name = {` with name a registered set var
    c_stv_idx ∈ Int = ((c_name ≠ "" ∧ (_il_pfx ++ c_name) = stv_n0) ? 0
        : (c_name ≠ "" ∧ (_il_pfx ++ c_name) = stv_n1) ? 1
        : (c_name ≠ "" ∧ c_name = stv_n0) ? 0
        : (c_name ≠ "" ∧ c_name = stv_n1) ? 1
        : 0 - 1)
    c_setlit_line ∈ Bool = (c_t0_is_ident ∧ (c_t1 matches Eq)
        ∧ (c_t2 matches LBrace) ∧ (c_stv_idx ≥ 0))
    d_enter_stl ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ (¬c_is_mem)
        ∧ (¬c_is_nmem) ∧ c_setlit_line)
    sv_cur = (is_first_tick ? 0 : d_enter_stl ? c_stv_idx : _sv_cur)
    sv_k ∈ Int = (_sv_cur = 0 ? stv_k0 : stv_k1)
    stl_entry_items ∈ C2Items = C2ICons(
        C2Process(EIdent(c_stv_idx = 0 ? stv_n0 : stv_n1)),
        C2ICons(C2MkEmptySet(c_stv_idx = 0 ? stv_k0 : stv_k1), C2INil))

    -- pmode-14 element walk
    sv_act ∈ Bool = (in_parse ∧ (_pmode = 14) ∧ d_witems_nil ∧ tok_ready)
    stl_elem ∈ Bool = (sv_act ∧ (ww_t0 matches Ident(_)))
    stl_comma ∈ Bool = (sv_act ∧ (ww_t0 matches Comma))
    stl_close ∈ Bool = (sv_act ∧ (ww_t0 matches RBrace))
    stl_bad ∈ Bool = (sv_act ∧ (¬stl_elem) ∧ (¬stl_comma) ∧ (¬stl_close))
    stl_enm ∈ String = match ww_t0
        Ident(s) ⇒ s
        _ ⇒ ""
    stl_elem_items ∈ C2Items = C2ICons(
        C2RecVal(_il_pfx ++ stl_enm, sv_k),
        C2ICons(C2SetAdd, C2INil))
    stl_close_items ∈ C2Items = C2ICons(C2PinEq,
        C2ICons(C2AssertTop, C2INil))
    stl_rec ∈ String = "|" ++ substr((_il_pfx ++ stl_enm) ++ rc_padv, 0, 31)
    stv_e0 = (is_first_tick ? ""
        : (d_enter_stl ∧ c_stv_idx = 0) ? ""
        : (stl_elem ∧ _sv_cur = 0) ? _stv_e0 ++ stl_rec
        : _stv_e0)
    stv_c0 = (is_first_tick ? 0
        : (d_enter_stl ∧ c_stv_idx = 0) ? 0
        : (stl_elem ∧ _sv_cur = 0) ? _stv_c0 + 1
        : _stv_c0)
    stv_e1 = (is_first_tick ? ""
        : (d_enter_stl ∧ c_stv_idx = 1) ? ""
        : (stl_elem ∧ _sv_cur = 1) ? _stv_e1 ++ stl_rec
        : _stv_e1)
    stv_c1 = (is_first_tick ? 0
        : (d_enter_stl ∧ c_stv_idx = 1) ? 0
        : (stl_elem ∧ _sv_cur = 1) ? _stv_c1 + 1
        : _stv_c1)

    -- `a ∈ items` — membership-in-set-var assert (no decl, no field)
    c_smem_idx ∈ Int = ((c_type_str ≠ "" ∧ ((_il_pfx ++ c_type_str) = stv_n0 ∨ c_type_str = stv_n0)) ? 0
        : (c_type_str ≠ "" ∧ ((_il_pfx ++ c_type_str) = stv_n1 ∨ c_type_str = stv_n1)) ? 1
        : 0 - 1)
    c_smem_line ∈ Bool = (c_is_mem ∧ (¬c_eff_line) ∧ (c_smem_idx ≥ 0))
    d_enter_smem ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ (¬c_set_line)
        ∧ c_smem_line)
    c_smem_set ∈ String = (c_smem_idx = 0 ? stv_n0 : stv_n1)
    c_smem_k ∈ Int = (c_smem_idx = 0 ? stv_k0 : stv_k1)
    c_smem_items ∈ C2Items = C2ICons(C2Process(EIdent(c_smem_set)),
        C2ICons(C2RecVal(_il_pfx ++ c_name, c_smem_k),
        C2ICons(C2SelH, C2ICons(C2AssertTop, C2INil))))

    -- `∀ x ∈ small : x ∈ big` — unroll over the source set's
    -- RECORDED literal elements (≤ 3), asserting (select big e_j).
    qset_src ∈ Int = ((c_q_t3nm ≠ "" ∧ c_q_t3nm = stv_n0) ? 0
        : (c_q_t3nm ≠ "" ∧ c_q_t3nm = stv_n1) ? 1
        : 0 - 1)
    qset_b_var ∈ String = match ww_t5
        Ident(s) ⇒ s
        _ ⇒ ""
    qset_b_tgtnm ∈ String = match ww_t7
        Ident(s) ⇒ s
        _ ⇒ ""
    qset_tgt ∈ Int = ((qset_b_tgtnm ≠ "" ∧ qset_b_tgtnm = stv_n0) ? 0
        : (qset_b_tgtnm ≠ "" ∧ qset_b_tgtnm = stv_n1) ? 1
        : 0 - 1)
    d_enter_qset ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ c_q_s1
        ∧ (¬c_q_ex) ∧ (qset_src ≥ 0) ∧ (qset_tgt ≥ 0)
        ∧ (qset_b_var = c_q_var) ∧ (ww_t6 matches OpIn))
    qset_e ∈ String = (qset_src = 0 ? stv_e0 : stv_e1)
    qset_c ∈ Int = (qset_src = 0 ? stv_c0 : stv_c1)
    qset_k ∈ Int = (qset_src = 0 ? stv_k0 : stv_k1)
    qset_tname ∈ String = (qset_tgt = 0 ? stv_n0 : stv_n1)
    qset_e0nm ∈ String
    RtRecName(s ↦ qset_e, i ↦ 0, name ↦ qset_e0nm)
    qset_e1nm ∈ String
    RtRecName(s ↦ qset_e, i ↦ 1, name ↦ qset_e1nm)
    qset_e2nm ∈ String
    RtRecName(s ↦ qset_e, i ↦ 2, name ↦ qset_e2nm)
    qset_seg2 ∈ C2Items = (qset_c ≥ 3
        ? C2ICons(C2Process(EIdent(qset_tname)),
            C2ICons(C2RecVal(qset_e2nm, qset_k),
            C2ICons(C2SelH, C2ICons(C2AssertTop, C2INil))))
        : C2INil)
    qset_seg1 ∈ C2Items = (qset_c ≥ 2
        ? C2ICons(C2Process(EIdent(qset_tname)),
            C2ICons(C2RecVal(qset_e1nm, qset_k),
            C2ICons(C2SelH, C2ICons(C2AssertTop, qset_seg2))))
        : qset_seg2)
    qset_items ∈ C2Items = (qset_c ≥ 1
        ? C2ICons(C2Process(EIdent(qset_tname)),
            C2ICons(C2RecVal(qset_e0nm, qset_k),
            C2ICons(C2SelH, C2ICons(C2AssertTop, qset_seg1))))
        : qset_seg1)

    sl_cnt ∈ Int
    d_in_sl ∈ Bool = (in_parse ∧ (_pmode = 8) ∧ d_witems_nil ∧ tok_ready)
    sl_close ∈ Bool = (d_in_sl ∧ (ww_t0 matches OpSeqClose))
    sl_comma ∈ Bool = (d_in_sl ∧ (ww_t0 matches Comma))
    sl_e_enter ∈ Bool = (d_in_sl ∧ (¬sl_close) ∧ (¬sl_comma))
    sl_done_inc ∈ Bool = (p_done ∧ (¬pr_bad) ∧ (_pk_kind = 7))
    sl_cnt = (is_first_tick ? 0
        : d_enter_sl ? 0
        : sl_done_inc ? _sl_cnt + 1
        : _sl_cnt)
    -- G2: a composite seq's literal element (an IDENT naming a
    -- frame-flattened record instance) builds as a ctor app over its
    -- dotted consts (C2RecVal); Int seqs keep the plain Process.
    sl_e_nm ∈ String = match pr_sres
        EIdent(sen) ⇒ sen
        _ ⇒ ""
    sl_e_item ∈ C2Item = ((_sq_rt ≥ 0 ∧ (pr_sres matches EIdent(_)))
        ? C2RecVal(_il_pfx ++ sl_e_nm, _sq_rt)
        : C2Process(pr_sres))
    sl_elem_items ∈ C2Items = C2ICons(C2Process(EIdent(_sq_name)),
        C2ICons(C2Process(EInt(_sl_cnt)),
        C2ICons(C2SelH,
        C2ICons(sl_e_item,
        C2ICons(C2PinEq, C2ICons(C2AssertTop, C2INil))))))
    sl_close_items ∈ C2Items = C2ICons(C2Process(EIdent(_sq_name ++ "__len")),
        C2ICons(C2Process(EInt(_sl_cnt)),
        C2ICons(C2PinEq, C2ICons(C2AssertTop, C2INil))))

    -- skip machine: walk one token per tick to the next top-level kw.
    d_skipl_nil ∈ Bool = (ww_t0 matches EofTok)
    d_skip_at_tlkw ∈ Bool = ((ww_t0 matches KwEnum) ∨ (ww_t0 matches KwClaim)
        ∨ (ww_t0 matches KwType) ∨ (ww_t0 matches KwFsm) ∨ (ww_t0 matches KwSchema))
    d_skip_stop ∈ Bool = (d_in_skip ∧ (d_skipl_nil ∨ d_skip_at_tlkw))

    -- ── CLAIM WALK state ──────────────────────────────────────────
    witems  ∈ C2Items
    hstk  ∈ C2H
    istep  ∈ Int
    pend  ∈ Int
    tmp_h  ∈ Int
    fstr  ∈ String
    cdstr  ∈ String

    -- pend application (the capture tick of the previous builder).
    d_hstk_in ∈ C2H = (_pend = 1 ? C2HCons(d_cap_int, _hstk) : _hstk)
    d_tmp_in ∈ Int = (_pend = 2 ? d_cap_int : _tmp_h)
    tmp_h = (is_first_tick ? 0 : d_tmp_in)

    -- ── FTI symbol table (B1: corpus scale, 1024 entries) ─────────
    -- Handles live in the calloc'd st_base buffer (8 bytes/entry,
    -- decl order); names live in st_names, a Z3 String of
    -- fixed-width 32-byte records: "|" ++ name padded to 31 with
    -- spaces. "|" never occurs inside a record (idents are
    -- alnum/underscore, padding is spaces), so every index_of match
    -- is 32-aligned and lookup is pure arithmetic:
    -- idx = index_of(st_names, key) / 32; the handle is then ONE
    -- __mem.read_long through the pend=1 capture path. Names longer
    -- than 31 chars would truncate-alias (corpus max is 21).
    -- A decl appends at C2DeclConst istep 2: the const handle (in
    -- tmp) is written to st_base[st_cnt], the name record appends to
    -- st_names, and the handle pushes onto hstk purely — all on the
    -- same tick, so a decl is visible to every later lookup tick.
    -- FTI bounds constraint: st_base holds 8192 symtab handle entries.
    -- st_cnt < 8192 makes a declare past the buffer end UNSAT (the model
    -- refuses it) rather than a native overrun.
    st_cnt  ∈ Int < 8192
    st_names ∈ String
    d_st_add ∈ Bool = (d_processing ∧ d_it_decl ∧ (_istep = 2))
    st_entry ∈ String = "|" ++ substr(d_dc_name ++ "                               ", 0, 31)
    -- D3 pre-seed: slots 0/1 are last_results / is_first_tick (their
    -- handles are written at zstep 31), so the two kernel-provided
    -- names resolve like any declared const.
    d_seed_names ∈ String = ("|" ++ substr("last_results                               ", 0, 31)
        ++ "|" ++ substr("is_first_tick                               ", 0, 31))
    st_cnt = (is_first_tick ? 2 : (d_st_add ? _st_cnt + 1 : _st_cnt))
    st_names = (is_first_tick ? d_seed_names
        : d_st_add ? _st_names ++ st_entry
        : _st_names)

    -- saw flags (D3): a user constraint mentioned last_results /
    -- is_first_tick — the serialized solver body then carries their
    -- declares (+ the Result datatype for last_results), so the
    -- textual prelude must drop the duplicates.
    saw_lr ∈ Bool
    saw_lr = (is_first_tick ? false
        : (d_lk_read ∧ d_lkname = "last_results") ? true
        : _saw_lr)
    saw_ift ∈ Bool
    saw_ift = (is_first_tick ? false
        : (d_lk_read ∧ d_lkname = "is_first_tick") ? true
        : _saw_ift)

    -- handle-stack views (post pend application).
    d_h_top ∈ Int = match d_hstk_in
        C2HCons(h, _) ⇒ h
        C2HNil ⇒ 0
    d_h_t1 ∈ C2H = match d_hstk_in
        C2HCons(_, r) ⇒ r
        C2HNil ⇒ C2HNil
    d_h_2nd ∈ Int = match d_h_t1
        C2HCons(h, _) ⇒ h
        C2HNil ⇒ 0
    d_h_t2 ∈ C2H = match d_h_t1
        C2HCons(_, r) ⇒ r
        C2HNil ⇒ C2HNil
    d_h_3rd ∈ Int = match d_h_t2
        C2HCons(h, _) ⇒ h
        C2HNil ⇒ 0
    d_h_t3 ∈ C2H = match d_h_t2
        C2HCons(_, r) ⇒ r
        C2HNil ⇒ C2HNil
    d_h_4th ∈ Int = match d_h_t3
        C2HCons(h, _) ⇒ h
        C2HNil ⇒ 0
    d_h_t4 ∈ C2H = match d_h_t3
        C2HCons(_, r) ⇒ r
        C2HNil ⇒ C2HNil
    d_h_5th ∈ Int = match d_h_t4
        C2HCons(h, _) ⇒ h
        C2HNil ⇒ 0
    d_h_t5 ∈ C2H = match d_h_t4
        C2HCons(_, r) ⇒ r
        C2HNil ⇒ C2HNil
    d_h_6th ∈ Int = match d_h_t5
        C2HCons(h, _) ⇒ h
        C2HNil ⇒ 0
    d_h_t6 ∈ C2H = match d_h_t5
        C2HCons(_, r) ⇒ r
        C2HNil ⇒ C2HNil

    -- current work item.
    d_witems_nil ∈ Bool = match _witems
        C2INil ⇒ true
        _ ⇒ false
    d_whead ∈ C2Item = match _witems
        C2ICons(h, _) ⇒ h
        C2INil ⇒ C2Drop
    d_wtail ∈ C2Items = match _witems
        C2ICons(_, r) ⇒ r
        C2INil ⇒ C2INil

    -- F2: the param-skip substate (il_ps) suppresses the classifier
    -- until the callee's first-line param list is walked over.
    d_classify   ∈ Bool = (d_in_claim ∧ d_witems_nil ∧ tok_ready
        ∧ (_il_ps = 0) ∧ (¬_fl_on) ∧ (¬_rb_on))
    -- items drain identically under the claim walk, the effects
    -- element walk (pmode 5), the seq-literal walk (pmode 8), the
    -- F1 group walk (pmode 9) and the F2 call walk (pmode 10)
    d_processing ∈ Bool = ((d_in_claim ∨ (in_parse ∧ (_pmode = 5))
        ∨ (in_parse ∧ (_pmode = 8)) ∨ (in_parse ∧ (_pmode = 9))
        ∨ (in_parse ∧ (_pmode = 10)) ∨ (in_parse ∧ (_pmode = 12))
        ∨ (in_parse ∧ (_pmode = 14)))
        ∧ (¬d_witems_nil))

    d_it_proc    ∈ Bool = (d_whead matches C2Process(_))
    d_it_op      ∈ Bool = (d_whead matches C2Op(_))
    d_it_ite     ∈ Bool = (d_whead matches C2Ite)
    d_it_not     ∈ Bool = (d_whead matches C2Not)
    d_it_decl    ∈ Bool = (d_whead matches C2DeclConst(_, _))
    d_it_nat     ∈ Bool = (d_whead matches C2NatBound)
    d_it_pineq   ∈ Bool = (d_whead matches C2PinEq)
    d_it_assert  ∈ Bool = (d_whead matches C2AssertTop)
    d_it_drop    ∈ Bool = (d_whead matches C2Drop)
    d_it_pushh   ∈ Bool = (d_whead matches C2PushH(_))
    d_it_app     ∈ Bool = (d_whead matches C2App(_, _))
    d_it_seleq   ∈ Bool = (d_whead matches C2SelectEq(_))
    d_it_leneq   ∈ Bool = (d_whead matches C2LenEq(_))
    d_it_strop   ∈ Bool = (d_whead matches C2StrOp(_, _))
    d_it_selh    ∈ Bool = (d_whead matches C2SelH)
    d_it_seleqh  ∈ Bool = (d_whead matches C2SelEqH(_))
    d_it_leneqh  ∈ Bool = (d_whead matches C2LenEqH(_))
    d_it_dup3    ∈ Bool = (d_whead matches C2Dup3)
    d_it_swap    ∈ Bool = (d_whead matches C2Swap)
    d_it_rot3    ∈ Bool = (d_whead matches C2Rot3)
    d_it_bsc     ∈ Bool = (d_whead matches C2BindScope(_, _))
    d_it_bend    ∈ Bool = (d_whead matches C2BindEnd)
    d_it_real    ∈ Bool = (d_whead matches C2Real(_, _))
    d_it_mes     ∈ Bool = (d_whead matches C2MkEmptySet(_))
    d_it_sadd    ∈ Bool = (d_whead matches C2SetAdd)
    d_it_recv    ∈ Bool = (d_whead matches C2RecVal(_, _))
    d_it_recd    ∈ Bool = (d_whead matches C2RecDecl(_, _))

    d_pe ∈ Expr = match d_whead
        C2Process(e) ⇒ e
        _ ⇒ ENoExpr
    d_op ∈ Op = match d_whead
        C2Op(o) ⇒ o
        _ ⇒ OpPlus
    d_dc_name ∈ String = match d_whead
        C2DeclConst(n, _) ⇒ n
        _ ⇒ ""
    d_dc_sc ∈ Int = match d_whead
        C2DeclConst(_, s) ⇒ s
        _ ⇒ 0
    d_ph_h ∈ Int = match d_whead
        C2PushH(h) ⇒ h
        _ ⇒ 0
    d_app_d ∈ Int = match d_whead
        C2App(h, _) ⇒ h
        _ ⇒ 0
    d_app_n ∈ Int = match d_whead
        C2App(_, n) ⇒ n
        _ ⇒ 0
    d_sel_i ∈ Int = match d_whead
        C2SelectEq(i) ⇒ i
        C2SelEqH(i2) ⇒ i2
        _ ⇒ 0
    d_len_n ∈ Int = match d_whead
        C2LenEq(n) ⇒ n
        C2LenEqH(n2) ⇒ n2
        _ ⇒ 0
    d_bs_n ∈ String = match d_whead
        C2BindScope(bn, _) ⇒ bn
        _ ⇒ ""
    d_bs_a ∈ Int = match d_whead
        C2BindScope(_, ba) ⇒ ba
        _ ⇒ 0
    d_so_nm ∈ String = match d_whead
        C2StrOp(sn, _) ⇒ sn
        _ ⇒ ""
    d_so_n ∈ Int = match d_whead
        C2StrOp(_, sk) ⇒ sk
        _ ⇒ 0
    d_re_s ∈ Int = match d_whead
        C2Real(rs, _) ⇒ rs
        _ ⇒ 0
    d_re_d ∈ Int = match d_whead
        C2Real(_, rd2) ⇒ rd2
        _ ⇒ 0
    d_mes_k ∈ Int = match d_whead
        C2MkEmptySet(mk2) ⇒ mk2
        _ ⇒ 0
    d_rv_nm ∈ String = match d_whead
        C2RecVal(rn2, _) ⇒ rn2
        C2RecDecl(rn3, _) ⇒ rn3
        _ ⇒ ""
    d_rv_k ∈ Int = match d_whead
        C2RecVal(_, rk2) ⇒ rk2
        C2RecDecl(_, rk3) ⇒ rk3
        _ ⇒ 0

    -- G2: C2RecVal expansion — a record IDENT's value as a ctor app
    -- over its flattened dotted consts; a record-typed FIELD recurses
    -- through a nested C2RecVal (the walk itself is the recursion).
    d_rv_f ∈ String = (d_rv_k = 0 ? rt_f0 : d_rv_k = 1 ? rt_f1 : rt_f2)
    d_rv_t ∈ String = (d_rv_k = 0 ? rt_t0 : d_rv_k = 1 ? rt_t1 : rt_t2)
    d_rv_n ∈ Int = (d_rv_k = 0 ? rt_nf0 : d_rv_k = 1 ? rt_nf1 : rt_nf2)
    d_rv_ctor ∈ Int = (d_rv_k = 0 ? rt_ctor0 : d_rv_k = 1 ? rt_ctor1 : rt_ctor2)
    rv_f0 ∈ String
    RtRecName(s ↦ d_rv_f, i ↦ 0, name ↦ rv_f0)
    rv_f1 ∈ String
    RtRecName(s ↦ d_rv_f, i ↦ 1, name ↦ rv_f1)
    rv_f2 ∈ String
    RtRecName(s ↦ d_rv_f, i ↦ 2, name ↦ rv_f2)
    rv_f3 ∈ String
    RtRecName(s ↦ d_rv_f, i ↦ 3, name ↦ rv_f3)
    rv_f4 ∈ String
    RtRecName(s ↦ d_rv_f, i ↦ 4, name ↦ rv_f4)
    rv_f5 ∈ String
    RtRecName(s ↦ d_rv_f, i ↦ 5, name ↦ rv_f5)
    rv_t0 ∈ String
    RtRecName(s ↦ d_rv_t, i ↦ 0, name ↦ rv_t0)
    rv_t1 ∈ String
    RtRecName(s ↦ d_rv_t, i ↦ 1, name ↦ rv_t1)
    rv_t2 ∈ String
    RtRecName(s ↦ d_rv_t, i ↦ 2, name ↦ rv_t2)
    rv_t3 ∈ String
    RtRecName(s ↦ d_rv_t, i ↦ 3, name ↦ rv_t3)
    rv_t4 ∈ String
    RtRecName(s ↦ d_rv_t, i ↦ 4, name ↦ rv_t4)
    rv_t5 ∈ String
    RtRecName(s ↦ d_rv_t, i ↦ 5, name ↦ rv_t5)
    rv_k0 ∈ Int
    RtIdxOf(nm ↦ rv_t0, n0 ↦ rt_n0, n1 ↦ rt_n1, n2 ↦ rt_n2,
        s0 ↦ rt_sort0, s1 ↦ rt_sort1, s2 ↦ rt_sort2, idx ↦ rv_k0)
    rv_k1 ∈ Int
    RtIdxOf(nm ↦ rv_t1, n0 ↦ rt_n0, n1 ↦ rt_n1, n2 ↦ rt_n2,
        s0 ↦ rt_sort0, s1 ↦ rt_sort1, s2 ↦ rt_sort2, idx ↦ rv_k1)
    rv_k2 ∈ Int
    RtIdxOf(nm ↦ rv_t2, n0 ↦ rt_n0, n1 ↦ rt_n1, n2 ↦ rt_n2,
        s0 ↦ rt_sort0, s1 ↦ rt_sort1, s2 ↦ rt_sort2, idx ↦ rv_k2)
    rv_k3 ∈ Int
    RtIdxOf(nm ↦ rv_t3, n0 ↦ rt_n0, n1 ↦ rt_n1, n2 ↦ rt_n2,
        s0 ↦ rt_sort0, s1 ↦ rt_sort1, s2 ↦ rt_sort2, idx ↦ rv_k3)
    rv_k4 ∈ Int
    RtIdxOf(nm ↦ rv_t4, n0 ↦ rt_n0, n1 ↦ rt_n1, n2 ↦ rt_n2,
        s0 ↦ rt_sort0, s1 ↦ rt_sort1, s2 ↦ rt_sort2, idx ↦ rv_k4)
    rv_k5 ∈ Int
    RtIdxOf(nm ↦ rv_t5, n0 ↦ rt_n0, n1 ↦ rt_n1, n2 ↦ rt_n2,
        s0 ↦ rt_sort0, s1 ↦ rt_sort1, s2 ↦ rt_sort2, idx ↦ rv_k5)
    rv_seg0 ∈ C2Item = (rv_k0 ≥ 0
        ? C2RecVal(d_rv_nm ++ "." ++ rv_f0, rv_k0)
        : C2Process(EIdent(d_rv_nm ++ "." ++ rv_f0)))
    rv_seg1 ∈ C2Item = (rv_k1 ≥ 0
        ? C2RecVal(d_rv_nm ++ "." ++ rv_f1, rv_k1)
        : C2Process(EIdent(d_rv_nm ++ "." ++ rv_f1)))
    rv_seg2 ∈ C2Item = (rv_k2 ≥ 0
        ? C2RecVal(d_rv_nm ++ "." ++ rv_f2, rv_k2)
        : C2Process(EIdent(d_rv_nm ++ "." ++ rv_f2)))
    rv_seg3 ∈ C2Item = (rv_k3 ≥ 0
        ? C2RecVal(d_rv_nm ++ "." ++ rv_f3, rv_k3)
        : C2Process(EIdent(d_rv_nm ++ "." ++ rv_f3)))
    rv_seg4 ∈ C2Item = (rv_k4 ≥ 0
        ? C2RecVal(d_rv_nm ++ "." ++ rv_f4, rv_k4)
        : C2Process(EIdent(d_rv_nm ++ "." ++ rv_f4)))
    rv_seg5 ∈ C2Item = (rv_k5 ≥ 0
        ? C2RecVal(d_rv_nm ++ "." ++ rv_f5, rv_k5)
        : C2Process(EIdent(d_rv_nm ++ "." ++ rv_f5)))
    rv_tail ∈ C2Items = C2ICons(C2App(d_rv_ctor, d_rv_n), d_wtail)
    d_rv_items ∈ C2Items = (d_rv_n = 1
            ? C2ICons(rv_seg0, rv_tail)
        : d_rv_n = 2
            ? C2ICons(rv_seg0, C2ICons(rv_seg1, rv_tail))
        : d_rv_n = 3
            ? C2ICons(rv_seg0, C2ICons(rv_seg1, C2ICons(rv_seg2, rv_tail)))
        : d_rv_n = 4
            ? C2ICons(rv_seg0, C2ICons(rv_seg1, C2ICons(rv_seg2,
                C2ICons(rv_seg3, rv_tail))))
        : d_rv_n = 5
            ? C2ICons(rv_seg0, C2ICons(rv_seg1, C2ICons(rv_seg2,
                C2ICons(rv_seg3, C2ICons(rv_seg4, rv_tail)))))
        : C2ICons(rv_seg0, C2ICons(rv_seg1, C2ICons(rv_seg2,
            C2ICons(rv_seg3, C2ICons(rv_seg4, C2ICons(rv_seg5,
            rv_tail)))))))
    -- G2: C2RecDecl expansion — declare the dotted consts of a
    -- record INSTANCE from the registry (bare type jumps: first-line
    -- params have no body memberships to declare them). Scalar
    -- fields declare directly; record fields recurse one C2RecDecl
    -- level; Seq fields skip (the body's own seq membership declares
    -- them).
    rdc_sc0 ∈ Int = (rv_t0 = "Bool" ? 1 : rv_t0 = "String" ? 3
        : rv_t0 = "Real" ? 6 : 0)
    rdc_sc1 ∈ Int = (rv_t1 = "Bool" ? 1 : rv_t1 = "String" ? 3
        : rv_t1 = "Real" ? 6 : 0)
    rdc_sc2 ∈ Int = (rv_t2 = "Bool" ? 1 : rv_t2 = "String" ? 3
        : rv_t2 = "Real" ? 6 : 0)
    rdc_sc3 ∈ Int = (rv_t3 = "Bool" ? 1 : rv_t3 = "String" ? 3
        : rv_t3 = "Real" ? 6 : 0)
    rdc_sc4 ∈ Int = (rv_t4 = "Bool" ? 1 : rv_t4 = "String" ? 3
        : rv_t4 = "Real" ? 6 : 0)
    rdc_sc5 ∈ Int = (rv_t5 = "Bool" ? 1 : rv_t5 = "String" ? 3
        : rv_t5 = "Real" ? 6 : 0)
    rdc_t5 ∈ C2Items = ((d_rv_n < 6 ∨ rv_t5 = "Seq(Int)") ? d_wtail
        : rv_k5 ≥ 0 ? C2ICons(C2RecDecl(d_rv_nm ++ "." ++ rv_f5, rv_k5), d_wtail)
        : C2ICons(C2DeclConst(d_rv_nm ++ "." ++ rv_f5, rdc_sc5),
            C2ICons(C2Drop, d_wtail)))
    rdc_t4 ∈ C2Items = ((d_rv_n < 5 ∨ rv_t4 = "Seq(Int)") ? rdc_t5
        : rv_k4 ≥ 0 ? C2ICons(C2RecDecl(d_rv_nm ++ "." ++ rv_f4, rv_k4), rdc_t5)
        : C2ICons(C2DeclConst(d_rv_nm ++ "." ++ rv_f4, rdc_sc4),
            C2ICons(C2Drop, rdc_t5)))
    rdc_t3 ∈ C2Items = ((d_rv_n < 4 ∨ rv_t3 = "Seq(Int)") ? rdc_t4
        : rv_k3 ≥ 0 ? C2ICons(C2RecDecl(d_rv_nm ++ "." ++ rv_f3, rv_k3), rdc_t4)
        : C2ICons(C2DeclConst(d_rv_nm ++ "." ++ rv_f3, rdc_sc3),
            C2ICons(C2Drop, rdc_t4)))
    rdc_t2 ∈ C2Items = ((d_rv_n < 3 ∨ rv_t2 = "Seq(Int)") ? rdc_t3
        : rv_k2 ≥ 0 ? C2ICons(C2RecDecl(d_rv_nm ++ "." ++ rv_f2, rv_k2), rdc_t3)
        : C2ICons(C2DeclConst(d_rv_nm ++ "." ++ rv_f2, rdc_sc2),
            C2ICons(C2Drop, rdc_t3)))
    rdc_t1 ∈ C2Items = ((d_rv_n < 2 ∨ rv_t1 = "Seq(Int)") ? rdc_t2
        : rv_k1 ≥ 0 ? C2ICons(C2RecDecl(d_rv_nm ++ "." ++ rv_f1, rv_k1), rdc_t2)
        : C2ICons(C2DeclConst(d_rv_nm ++ "." ++ rv_f1, rdc_sc1),
            C2ICons(C2Drop, rdc_t2)))
    d_rdc_items ∈ C2Items = ((d_rv_n < 1 ∨ rv_t0 = "Seq(Int)") ? rdc_t1
        : rv_k0 ≥ 0 ? C2ICons(C2RecDecl(d_rv_nm ++ "." ++ rv_f0, rv_k0), rdc_t1)
        : C2ICons(C2DeclConst(d_rv_nm ++ "." ++ rv_f0, rdc_sc0),
            C2ICons(C2Drop, rdc_t1)))

    -- Expr-node decomposition via the pass claims.
    d_pe_is_int ∈ Bool = (d_pe matches EInt(_))
    d_pe_is_id  ∈ Bool = (d_pe matches EIdent(_))
    d_pe_is_str ∈ Bool = (d_pe matches EStr(_))
    d_pe_str ∈ String = match d_pe
        EStr(s) ⇒ s
        _ ⇒ ""
    d_lkname ∈ String = match d_pe
        EIdent(s) ⇒ s
        _ ⇒ ""
    d_pe_op ∈ Op
    d_pe_l ∈ Expr
    d_pe_r ∈ Expr
    d_pe_is_bin ∈ Bool
    BoolExprBinopParts(e ↦ d_pe, op ↦ d_pe_op, lhs ↦ d_pe_l,
        rhs ↦ d_pe_r, is_binop ↦ d_pe_is_bin)
    d_pe_c ∈ Expr
    d_pe_t ∈ Expr
    d_pe_e ∈ Expr
    d_pe_is_tern ∈ Bool
    TernaryExprParts(e ↦ d_pe, cond_e ↦ d_pe_c, then_e ↦ d_pe_t,
        else_e ↦ d_pe_e, is_tern ↦ d_pe_is_tern)
    d_pe_ni ∈ Expr
    d_pe_is_not ∈ Bool
    NotExprParts(e ↦ d_pe, inner ↦ d_pe_ni, is_not ↦ d_pe_is_not)
    d_pe_op_ne ∈ Bool = (d_pe_op matches OpNeq)

    -- call-node decomposition (B3): name + up to 3 positional args.
    d_pe_is_c1 ∈ Bool = (d_pe matches ECall1(_, _))
    d_pe_is_c2 ∈ Bool = (d_pe matches ECall2(_, _, _))
    d_pe_is_c3 ∈ Bool = (d_pe matches ECall3(_, _, _, _))
    d_cnm ∈ String = match d_pe
        ECall1(cn1, _) ⇒ cn1
        ECall2(cn2, _, _) ⇒ cn2
        ECall3(cn3, _, _, _) ⇒ cn3
        _ ⇒ ""
    d_ca0 ∈ Expr = match d_pe
        ECall1(_, ca1) ⇒ ca1
        ECall2(_, ca2, _) ⇒ ca2
        ECall3(_, ca3, _, _) ⇒ ca3
        _ ⇒ ENoExpr
    d_ca1 ∈ Expr = match d_pe
        ECall2(_, _, cb2) ⇒ cb2
        ECall3(_, _, cb3, _) ⇒ cb3
        _ ⇒ ENoExpr
    d_ca2 ∈ Expr = match d_pe
        ECall3(_, _, _, cc3) ⇒ cc3
        _ ⇒ ENoExpr

    -- C3: ctor-application dispatch — a call whose name resolves in
    -- the user-enum decl registry lowers to C2App(decl, argc) over
    -- the processed args (mk_app; compound args are handles, so the
    -- legacy dropped-Exit(3+4) class is impossible by construction).
    -- Checked BEFORE the builtin fallthrough (no collision: builtins
    -- are lowercase, variants capitalized).
    d_ctor_d ∈ Int = (uev_n0 = d_cnm ? uev_d0
        : uev_n1 = d_cnm ? uev_d1
        : uev_n2 = d_cnm ? uev_d2
        : uev_n3 = d_cnm ? uev_d3
        : uev_n4 = d_cnm ? uev_d4
        : uev_n5 = d_cnm ? uev_d5
        : 0)

    -- C4: `e matches Ctor` — mk_app of the harvested TESTER decl
    -- (user variants + the IntResult/StringResult floor). A miss
    -- pushes handle 0 (unbound-ident parity).
    d_pe_is_m ∈ Bool = (d_pe matches EMatches(_, _))
    d_m_nm ∈ String = match d_pe
        EMatches(mn, _) ⇒ mn
        _ ⇒ ""
    d_m_in ∈ Expr = match d_pe
        EMatches(_, me) ⇒ me
        _ ⇒ ENoExpr
    d_m_t ∈ Int = (d_m_nm = "IntResult" ? z_irtest
        : d_m_nm = "StringResult" ? z_srtest
        : uev_n0 = d_m_nm ? uev_t0
        : uev_n1 = d_m_nm ? uev_t1
        : uev_n2 = d_m_nm ? uev_t2
        : uev_n3 = d_m_nm ? uev_t3
        : uev_n4 = d_m_nm ? uev_t4
        : uev_n5 = d_m_nm ? uev_t5
        : 0)
    d_m_items ∈ C2Items = (d_m_t ≠ 0
        ? C2ICons(C2Process(d_m_in), C2ICons(C2App(d_m_t, 1), d_wtail))
        : C2ICons(C2PushH(0), d_wtail))

    -- B3 lowering: the legacy surface table (the pinned
    -- bootstrap string_ops.rs dispatch, re-probed against the
    -- oracle 2026-06-07) → translate2_seq.ev's StrOpBuildZ3 keys.
    -- starts_with(text, pre) / ends_with(text, suf) emit
    -- (str.prefixof pre text) / (str.suffixof suf text) — the
    -- ARGS PROCESS IN SWAPPED ORDER so the stack lines up with
    -- StrOpBuildZ3's (a=prefix, b=s) operand order. index_of/2
    -- pushes the cached zero numeral as the offset (the oracle
    -- emits `(str.indexof s sub 0)`). str_from_int expands to the
    -- oracle's negative-safe composite
    -- (ite (>= e 0) (str.from_int e) (str.++ "-" (str.from_int (- 0 e)))).
    -- An unknown call name pushes handle 0 (unbound-ident parity).
    d_sfi_items ∈ C2Items = C2ICons(C2Process(d_ca0),
        C2ICons(C2Process(EInt(0)),
        C2ICons(C2Op(OpGeq),
        C2ICons(C2Process(d_ca0),
        C2ICons(C2StrOp("int_to_str", 1),
        C2ICons(C2Process(EStr("-")),
        C2ICons(C2Process(EInt(0)),
        C2ICons(C2Process(d_ca0),
        C2ICons(C2Op(OpSub),
        C2ICons(C2StrOp("int_to_str", 1),
        C2ICons(C2Op(OpConcat),
        C2ICons(C2Ite, d_wtail))))))))))))
    -- D2: `#` / str_len over the registered Seq var resolves to its
    -- companion __len const (per-sort dispatch), not str.len.
    d_ca0_nm ∈ String = match d_ca0
        EIdent(can) ⇒ can
        _ ⇒ ""
    d_sl_seq ∈ Bool = (_sq_set ∧ ((d_ca0_nm = _sq_name)
        ∨ ((_il_pfx ++ d_ca0_nm) = _sq_name)))
    -- G2: `#setvar` — cardinality over the RECORDED literal: 1 elem
    -- → 1; 2 elems → (ite (= e0 e1) 1 2); ≥ 3 → the literal count
    -- (corpus sets pin their elements pairwise-distinct).
    d_sl_setk ∈ Int = ((d_ca0_nm ≠ "" ∧ ((d_ca0_nm = stv_n0)
            ∨ ((_il_pfx ++ d_ca0_nm) = stv_n0))) ? 0
        : (d_ca0_nm ≠ "" ∧ ((d_ca0_nm = stv_n1)
            ∨ ((_il_pfx ++ d_ca0_nm) = stv_n1))) ? 1
        : 0 - 1)
    d_slc_e ∈ String = (d_sl_setk = 0 ? stv_e0 : stv_e1)
    d_slc_c ∈ Int = (d_sl_setk = 0 ? stv_c0 : stv_c1)
    d_slc_k ∈ Int = (d_sl_setk = 0 ? stv_k0 : stv_k1)
    d_slc_e0 ∈ String
    RtRecName(s ↦ d_slc_e, i ↦ 0, name ↦ d_slc_e0)
    d_slc_e1 ∈ String
    RtRecName(s ↦ d_slc_e, i ↦ 1, name ↦ d_slc_e1)
    d_card_items ∈ C2Items = (d_slc_c = 1
            ? C2ICons(C2Process(EInt(1)), d_wtail)
        : d_slc_c = 2
            ? C2ICons(C2RecVal(d_slc_e0, d_slc_k),
                C2ICons(C2RecVal(d_slc_e1, d_slc_k),
                C2ICons(C2Op(OpEq),
                C2ICons(C2Process(EInt(1)),
                C2ICons(C2Process(EInt(2)),
                C2ICons(C2Ite, d_wtail))))))
        : C2ICons(C2Process(EInt(d_slc_c)), d_wtail))
    d_c1_items ∈ C2Items = (d_cnm = "str_len"
            ? (d_sl_seq
                ? C2ICons(C2Process(EIdent(_sq_name ++ "__len")), d_wtail)
                : d_sl_setk ≥ 0
                ? d_card_items
                : C2ICons(C2Process(d_ca0), C2ICons(C2StrOp("len", 1), d_wtail)))
        : d_cnm = "str_from_int" ? d_sfi_items
        : d_ctor_d ≠ 0
            ? C2ICons(C2Process(d_ca0),
                C2ICons(C2App(d_ctor_d, 1), d_wtail))
        : C2ICons(C2PushH(0), d_wtail))
    -- G2: `__real` (the FloatLit atom) → one mk_numeral tick.
    d_rl_s ∈ Int = match d_ca0
        EInt(n) ⇒ n
        _ ⇒ 0
    d_rl_d ∈ Int = match d_ca1
        EInt(n) ⇒ n
        _ ⇒ 0
    -- G2: `__field` (postfix `.name` over a non-ident operand —
    -- seq-of-composite chains like `groups[0].items`) → process the
    -- base, then ONE mk_app of the accessor decl resolved by FIELD
    -- NAME across the record registry (first hit wins; the corpus
    -- is unambiguous).
    d_fld_nm ∈ String = match d_ca1
        EIdent(s) ⇒ s
        _ ⇒ ""
    d_fld_acc ∈ Int
    RtFieldAcc(fname ↦ d_fld_nm,
        f0 ↦ rt_f0, f1 ↦ rt_f1, f2 ↦ rt_f2,
        a00 ↦ rt_a00, a01 ↦ rt_a01, a02 ↦ rt_a02, a03 ↦ rt_a03,
        a04 ↦ rt_a04, a05 ↦ rt_a05,
        a10 ↦ rt_a10, a11 ↦ rt_a11, a12 ↦ rt_a12, a13 ↦ rt_a13,
        a14 ↦ rt_a14, a15 ↦ rt_a15,
        a20 ↦ rt_a20, a21 ↦ rt_a21, a22 ↦ rt_a22, a23 ↦ rt_a23,
        a24 ↦ rt_a24, a25 ↦ rt_a25,
        acc ↦ d_fld_acc)
    d_c2_items ∈ C2Items = (d_cnm = "__real"
            ? C2ICons(C2Real(d_rl_s, d_rl_d), d_wtail)
        : d_cnm = "__field"
            ? C2ICons(C2Process(d_ca0),
                C2ICons(C2App(d_fld_acc, 1), d_wtail))
        : d_cnm = "__index"
            ? C2ICons(C2Process(d_ca0), C2ICons(C2Process(d_ca1),
                C2ICons(C2SelH, d_wtail)))
        : d_cnm = "char_at"
            ? C2ICons(C2Process(d_ca0), C2ICons(C2Process(d_ca1),
                C2ICons(C2StrOp("char_at", 2), d_wtail)))
        : d_cnm = "index_of"
            ? C2ICons(C2Process(d_ca0), C2ICons(C2Process(d_ca1),
                C2ICons(C2PushH(z_zero),
                C2ICons(C2StrOp("indexof", 3), d_wtail))))
        : d_cnm = "str_contains"
            ? C2ICons(C2Process(d_ca0), C2ICons(C2Process(d_ca1),
                C2ICons(C2StrOp("contains", 2), d_wtail)))
        : d_cnm = "starts_with"
            ? C2ICons(C2Process(d_ca1), C2ICons(C2Process(d_ca0),
                C2ICons(C2StrOp("prefixof", 2), d_wtail)))
        : d_cnm = "ends_with"
            ? C2ICons(C2Process(d_ca1), C2ICons(C2Process(d_ca0),
                C2ICons(C2StrOp("suffixof", 2), d_wtail)))
        : d_ctor_d ≠ 0
            ? C2ICons(C2Process(d_ca0), C2ICons(C2Process(d_ca1),
                C2ICons(C2App(d_ctor_d, 2), d_wtail)))
        : C2ICons(C2PushH(0), d_wtail))
    d_c3_items ∈ C2Items = (d_cnm = "replace"
            ? C2ICons(C2Process(d_ca0), C2ICons(C2Process(d_ca1),
                C2ICons(C2Process(d_ca2),
                C2ICons(C2StrOp("replace", 3), d_wtail))))
        : d_cnm = "substr"
            ? C2ICons(C2Process(d_ca0), C2ICons(C2Process(d_ca1),
                C2ICons(C2Process(d_ca2),
                C2ICons(C2StrOp("substr", 3), d_wtail))))
        : d_cnm = "index_of"
            ? C2ICons(C2Process(d_ca0), C2ICons(C2Process(d_ca1),
                C2ICons(C2Process(d_ca2),
                C2ICons(C2StrOp("indexof", 3), d_wtail))))
        : d_ctor_d ≠ 0
            ? C2ICons(C2Process(d_ca0), C2ICons(C2Process(d_ca1),
                C2ICons(C2Process(d_ca2),
                C2ICons(C2App(d_ctor_d, 3), d_wtail))))
        : C2ICons(C2PushH(0), d_wtail))

    -- symbol-table lookup. true/false resolve purely to the cached
    -- Z3_mk_true/Z3_mk_false handles; a name found in st_names
    -- resolves via ONE __mem.read_long of st_base[idx] (pend=1 —
    -- the handle pushes next tick); enum-variant values (evt) and
    -- unknown names (handle 0, fossil parity) stay pure pushes.
    d_lk_key ∈ String = "|" ++ substr(d_lkname ++ "                               ", 0, 31)
    d_lk_pos ∈ Int = index_of(st_names, d_lk_key, 0)
    d_lk_found ∈ Bool = (d_lk_pos ≥ 0)
    d_lk_special ∈ Bool = (d_lkname = "true" ∨ d_lkname = "false")
    -- F2: scoped resolution — a slot bind of the current frame is a
    -- PURE handle push (d_ilb_*); an α-prefixed frame local
    -- ("__cN_" ++ name) takes priority over the plain table.
    d_ilb_found ∈ Bool = ((d_lkname ≠ "") ∧ ((ilb_n0 = d_lkname)
        ∨ (ilb_n1 = d_lkname) ∨ (ilb_n2 = d_lkname)
        ∨ (ilb_n3 = d_lkname) ∨ (ilb_n4 = d_lkname)
        ∨ (ilb_n5 = d_lkname)))
    d_ilb_h ∈ Int = (ilb_n0 = d_lkname ? ilb_h0
        : ilb_n1 = d_lkname ? ilb_h1
        : ilb_n2 = d_lkname ? ilb_h2
        : ilb_n3 = d_lkname ? ilb_h3
        : ilb_n4 = d_lkname ? ilb_h4
        : ilb_h5)
    d_lk_pfx_key ∈ String = "|" ++ substr((_il_pfx ++ d_lkname) ++ "                               ", 0, 31)
    d_lk_pfx_pos ∈ Int = index_of(st_names, d_lk_pfx_key, 0)
    d_lk_pfx_on ∈ Bool = ((_il_pfx ≠ "") ∧ (d_lk_pfx_pos ≥ 0))
    d_lk_pos_eff ∈ Int = (d_lk_pfx_on ? d_lk_pfx_pos : d_lk_pos)
    d_lk_found2 ∈ Bool = (d_lk_pfx_on ∨ d_lk_found)
    d_lk_pure ∈ Bool = (d_lk_special ∨ (¬d_lk_found2))
    d_lk ∈ Int = (d_lkname = "true" ? z_true
        : d_lkname = "false" ? z_false
        : evt_n0 = d_lkname ? evt_v0
        : evt_n1 = d_lkname ? evt_v1
        : evt_n2 = d_lkname ? evt_v2
        : evt_n3 = d_lkname ? evt_v3
        : evt_n4 = d_lkname ? evt_v4
        : evt_n5 = d_lkname ? evt_v5
        : 0)
    d_eff_stread ∈ Effect
    BuildMemReadLong(addr ↦ st_base + (8 * (d_lk_pos_eff / 32)), eff ↦ d_eff_stread)

    -- C5: match-arm bind scope. C2BindScope(bind, acc) arms it for
    -- the items between it and C2BindEnd (an arm body's expansion —
    -- depth-first, so everything the body expands to runs before
    -- the C2BindEnd surfaces). An in-scope EIdent(bind) leaf is NOT
    -- a symtab lookup: it expands to the accessor app over the
    -- scrutinee — mk_app(acc, scrut) = the oracle's (Ctor__f0 scrut).
    bsc_on ∈ Bool
    bsc_n ∈ String
    bsc_acc ∈ Int
    bsc_on = (is_first_tick ? false
        : (d_processing ∧ d_it_bsc) ? true
        : (d_processing ∧ d_it_bend) ? false
        : _bsc_on)
    bsc_n = (is_first_tick ? ""
        : (d_processing ∧ d_it_bsc) ? d_bs_n
        : _bsc_n)
    bsc_acc = (is_first_tick ? 0
        : (d_processing ∧ d_it_bsc) ? d_bs_a
        : _bsc_acc)
    d_bind_hit ∈ Bool = (d_it_proc ∧ d_pe_is_id ∧ _bsc_on
        ∧ (d_lkname = _bsc_n))
    -- G1: quantifier bound-name expansion (range: the element
    -- numeral; seq: (select s i)) — shadows every other resolution.
    d_vb_hit ∈ Bool = (d_it_proc ∧ d_pe_is_id ∧ _fl_on
        ∧ (d_lkname = _fl_var))
    d_vb_items ∈ C2Items = (_fl_kind = 0
        ? C2ICons(C2Process(EInt(_fl_v)), d_wtail)
        : C2ICons(C2Process(EIdent(_fl_seq)),
            C2ICons(C2Process(EInt(_fl_v)),
            C2ICons(C2SelH, d_wtail))))
    -- G2: `t.duration` under ∀-over-a-COMPOSITE-seq — the dotted
    -- bound name expands to mk_app(accessor, (select seq i)).
    d_vb_pfx ∈ String = _fl_var ++ "."
    d_vb_dot ∈ Bool = (d_it_proc ∧ d_pe_is_id ∧ _fl_on
        ∧ (_fl_kind = 1) ∧ (_sq_rt ≥ 0)
        ∧ (substr(d_lkname, 0, #d_vb_pfx) = d_vb_pfx))
    d_vb_fld ∈ String = substr(d_lkname, #d_vb_pfx,
        #d_lkname - #d_vb_pfx)
    d_vb_acc ∈ Int
    RtFieldAcc(fname ↦ d_vb_fld,
        f0 ↦ rt_f0, f1 ↦ rt_f1, f2 ↦ rt_f2,
        a00 ↦ rt_a00, a01 ↦ rt_a01, a02 ↦ rt_a02, a03 ↦ rt_a03,
        a04 ↦ rt_a04, a05 ↦ rt_a05,
        a10 ↦ rt_a10, a11 ↦ rt_a11, a12 ↦ rt_a12, a13 ↦ rt_a13,
        a14 ↦ rt_a14, a15 ↦ rt_a15,
        a20 ↦ rt_a20, a21 ↦ rt_a21, a22 ↦ rt_a22, a23 ↦ rt_a23,
        a24 ↦ rt_a24, a25 ↦ rt_a25,
        acc ↦ d_vb_acc)
    d_vbd_items ∈ C2Items = C2ICons(C2Process(EIdent(_fl_seq)),
        C2ICons(C2Process(EInt(_fl_v)),
        C2ICons(C2SelH,
        C2ICons(C2App(d_vb_acc, 1), d_wtail))))
    -- G2: rb re-walk leaf rewrites — `pos` reads `s.pos.<field>`
    -- when that dotted const exists; a registry-ctor call selects
    -- its field-index argument.
    rb_q_name ∈ String = _il_pfx ++ d_lkname ++ "." ++ rb_f
    rb_q_key ∈ String = "|" ++ substr(rb_q_name ++ "                               ", 0, 31)
    d_rb_hit ∈ Bool = (d_it_proc ∧ d_pe_is_id ∧ _rb_on
        ∧ (index_of(st_names, rb_q_key, 0) ≥ 0))
    d_rb_items ∈ C2Items = C2ICons(C2Process(EIdent(rb_q_name)), d_wtail)
    rbc_rtk ∈ Int
    RtIdxOf(nm ↦ d_cnm, n0 ↦ rt_n0, n1 ↦ rt_n1, n2 ↦ rt_n2,
        s0 ↦ rt_sort0, s1 ↦ rt_sort1, s2 ↦ rt_sort2, idx ↦ rbc_rtk)
    d_rbc_hit ∈ Bool = (d_it_proc ∧ _rb_on ∧ (rbc_rtk ≥ 0)
        ∧ (d_pe_is_c1 ∨ d_pe_is_c2 ∨ d_pe_is_c3))
    d_rbc_items ∈ C2Items = C2ICons(
        C2Process(_rb_v = 0 ? d_ca0 : _rb_v = 1 ? d_ca1 : d_ca2),
        d_wtail)
    d_bind_items ∈ C2Items = (_mp_lr
        ? C2ICons(C2Process(EIdent("last_results")),
            C2ICons(C2Process(EInt(_mp_idx)),
            C2ICons(C2SelH,
            C2ICons(C2App(_bsc_acc, 1), d_wtail))))
        : C2ICons(C2Process(EIdent(_mp_scrut)),
            C2ICons(C2App(_bsc_acc, 1), d_wtail)))

    -- Op family flags (via the pass discriminators).
    d_op_arith_arr ∈ Bool
    BinopIsArray(op ↦ d_op, out ↦ d_op_arith_arr)
    d_op_bool_arr ∈ Bool
    BoolOpIsArray(op ↦ d_op, out ↦ d_op_bool_arr)
    d_op_is_div ∈ Bool = (d_op matches OpDiv)
    d_op_cc ∈ Bool = (d_op matches OpConcat)
    d_op_arr ∈ Bool = (d_op_arith_arr ∨ d_op_bool_arr ∨ d_op_cc)

    -- ── LINE CLASSIFIER + dispatch (see compiler2/driver_classify.ev) ──
    ..DriverClassify
    -- ── G1: bounded quantifier lines — `∀|∃ v ∈ {lo..hi} : body` and
    -- `∀ v ∈ seq : body` (seq = the registered Seq var; its length
    -- comes from the recorded `#seq = k` pin). The body parses ONCE
    -- through the Pratt FSM (pk_kind 9); the fl loop then re-walks
    -- the parsed Expr once per element with the bound name expanding
    -- to the element value (range: the numeral; seq: (select s i)),
    -- and/or-folds, and asserts — the oracle's flat expansion modulo
    -- the accepted 2-ary nesting divergence.
    c_q_ex ∈ Bool = (c_t0 matches OpExists)
    c_q_hd ∈ Bool = ((c_t0 matches OpForall) ∨ c_q_ex)
    c_q_line ∈ Bool = (c_q_hd ∧ (c_t1 matches Ident(_))
        ∧ (c_t2 matches OpIn))
    c_q_var ∈ String = match c_t1
        Ident(s) ⇒ s
        _ ⇒ ""
    c_q_rng ∈ Bool = (c_q_line ∧ (c_t3 matches LBrace)
        ∧ (c_t4 matches IntLit(_)) ∧ (ww_t5 matches Dot)
        ∧ (ww_t6 matches Dot) ∧ (ww_t7 matches IntLit(_)))
    c_q_lo ∈ Int = match c_t4
        IntLit(n) ⇒ n
        _ ⇒ 0
    c_q_hi ∈ Int = match ww_t7
        IntLit(n) ⇒ n
        _ ⇒ 0
    c_q_t3nm ∈ String = match c_t3
        Ident(s) ⇒ s
        _ ⇒ ""
    c_q_t5nm ∈ String = match ww_t5
        Ident(s) ⇒ s
        _ ⇒ ""
    c_q_s1 ∈ Bool = (c_q_line ∧ (c_t3 matches Ident(_))
        ∧ (c_t4 matches Colon))
    c_q_s2 ∈ Bool = (c_q_line ∧ (c_t3 matches Ident(_))
        ∧ (c_t4 matches Dot) ∧ (ww_t5 matches Ident(_))
        ∧ (ww_t6 matches Colon))
    c_q_seq ∈ Bool = (c_q_s1 ∨ c_q_s2)
    c_q_seqnm0 ∈ String = (c_q_s2 ? (c_q_t3nm ++ "." ++ c_q_t5nm) : c_q_t3nm)
    c_q_seqnm ∈ String = (((_il_pfx ++ c_q_seqnm0) = _sq_name)
        ? _sq_name : c_q_seqnm0)
    d_enter_qr ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ c_q_rng)
    d_enter_qs ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ (¬c_q_rng)
        ∧ c_q_seq ∧ _sq_set ∧ (¬d_enter_qset))

    -- pmode 11: the range head's `} :` close (the 8-token classify
    -- bite latched lo/hi; the brace close enters the body parse)
    q_act ∈ Bool = (in_parse ∧ (_pmode = 11) ∧ d_witems_nil ∧ tok_ready)
    q_close ∈ Bool = (q_act ∧ (ww_t0 matches RBrace)
        ∧ (ww_t1 matches Colon))
    q_bail ∈ Bool = (q_act ∧ (¬q_close))

    -- fl: the quantifier expansion loop (one body re-walk per element)
    fl_on ∈ Bool
    fl_ex ∈ Bool
    fl_var ∈ String
    fl_kind ∈ Int
    fl_lo ∈ Int
    fl_hi ∈ Int
    fl_seq ∈ String
    fl_body ∈ Expr
    fl_nx ∈ Int
    fl_v ∈ Int
    fq_done ∈ Bool = (p_done ∧ (_pk_kind = 9) ∧ (¬pr_bad))
    fx_disp ∈ Bool = (d_in_claim ∧ _fl_on ∧ d_witems_nil
        ∧ (_il_ps = 0) ∧ tok_ready)
    fx_more ∈ Bool = (fx_disp ∧ (_fl_nx ≤ _fl_hi))
    fx_fin ∈ Bool = (fx_disp ∧ (_fl_nx > _fl_hi))
    fl_ex = (is_first_tick ? false
        : (d_enter_qr ∨ d_enter_qs) ? c_q_ex : _fl_ex)
    fl_var = (is_first_tick ? ""
        : (d_enter_qr ∨ d_enter_qs) ? c_q_var : _fl_var)
    fl_kind = (is_first_tick ? 0
        : d_enter_qr ? 0 : d_enter_qs ? 1 : _fl_kind)
    fl_lo = (is_first_tick ? 0
        : d_enter_qr ? c_q_lo : d_enter_qs ? 0 : _fl_lo)
    fl_hi = (is_first_tick ? 0
        : d_enter_qr ? c_q_hi : d_enter_qs ? _sv_len - 1 : _fl_hi)
    fl_seq = (is_first_tick ? "" : d_enter_qs ? c_q_seqnm : _fl_seq)
    fl_body = (is_first_tick ? ENoExpr : fq_done ? pr_sres : _fl_body)
    fl_on = (is_first_tick ? false
        : fq_done ? true
        : fx_fin ? false
        : _fl_on)
    fl_nx = (is_first_tick ? 0
        : (d_enter_qr ∨ d_enter_qs) ? (d_enter_qr ? c_q_lo : 0)
        : fx_more ? _fl_nx + 1
        : _fl_nx)
    fl_v = (is_first_tick ? 0 : fx_more ? _fl_nx : _fl_v)
    fx_fold ∈ Op = (_fl_ex ? OpDisj : OpConj)
    fx_items ∈ C2Items = C2ICons(C2Process(_fl_body),
        ((_fl_nx > _fl_lo) ? C2ICons(C2Op(fx_fold), C2INil) : C2INil))
    fx_fin_items ∈ C2Items = C2ICons(C2AssertTop, C2INil)

    -- sv: the registered seq var's recorded literal length (`#s = k`
    -- pins, recognized at parse completion) — feeds ∀-over-seq.
    sv_len ∈ Int
    svr_l_c1 ∈ Bool = (gc_l matches ECall1(_, _))
    svr_nm ∈ String = match gc_l
        ECall1(n, _) ⇒ n
        _ ⇒ ""
    svr_arg ∈ Expr = match gc_l
        ECall1(_, a) ⇒ a
        _ ⇒ ENoExpr
    svr_argnm ∈ String = match svr_arg
        EIdent(s) ⇒ s
        _ ⇒ ""
    svr_k ∈ Int = match gc_r
        EInt(n) ⇒ n
        _ ⇒ 0 - 1
    svr_hit ∈ Bool = (p_done ∧ (_pk_kind = 2) ∧ (¬pr_bad) ∧ gc_bin
        ∧ (gc_op matches OpEq) ∧ svr_l_c1 ∧ (svr_nm = "str_len")
        ∧ (svr_k ≥ 0) ∧ _sq_set
        ∧ ((svr_argnm = _sq_name) ∨ ((_il_pfx ++ svr_argnm) = _sq_name)))
    sv_len = (is_first_tick ? 0 : svr_hit ? svr_k : _sv_len)

    -- ── G2: rb — the record-pin BROADCAST loop. A membership pinned
    -- to a record expression re-walks the parsed body once per FIELD
    -- of the record type: `offset_pos ∈ IVec2 = pos + IVec2(10, 20)`
    -- becomes per-field declare+pin (s.offset_pos.x = s.pos.x + 10).
    -- During a re-walk, an IDENT whose field-qualified dotted name
    -- resolves in the symtab reads through it, and a REGISTRY-ctor
    -- call (`IVec2(10, 20)`) selects its field-index argument.
    rb_on ∈ Bool
    rb_k ∈ Int
    rb_nm ∈ String
    rb_body ∈ Expr
    rb_fi ∈ Int
    rb_v ∈ Int
    rq_done ∈ Bool = (p_done ∧ (_pk_kind = 1) ∧ (¬pr_bad)
        ∧ (_pk_rec ≥ 0))
    rb_nf ∈ Int = (_rb_k = 0 ? rt_nf0 : _rb_k = 1 ? rt_nf1 : rt_nf2)
    rb_fs ∈ String = (_rb_k = 0 ? rt_f0 : _rb_k = 1 ? rt_f1 : rt_f2)
    rbx_disp ∈ Bool = (d_in_claim ∧ _rb_on ∧ d_witems_nil
        ∧ (_il_ps = 0) ∧ tok_ready)
    rbx_more ∈ Bool = (rbx_disp ∧ (_rb_fi < rb_nf))
    rbx_fin ∈ Bool = (rbx_disp ∧ (_rb_fi ≥ rb_nf))
    rb_on = (is_first_tick ? false
        : rq_done ? true
        : rbx_fin ? false
        : _rb_on)
    rb_k = (is_first_tick ? 0 : rq_done ? _pk_rec : _rb_k)
    rb_nm = (is_first_tick ? "" : rq_done ? _pk_name : _rb_nm)
    rb_body = (is_first_tick ? ENoExpr : rq_done ? pr_sres : _rb_body)
    rb_fi = (is_first_tick ? 0
        : rq_done ? 0
        : rbx_more ? _rb_fi + 1
        : _rb_fi)
    rb_v = (is_first_tick ? 0 : rbx_more ? _rb_fi : _rb_v)
    rb_f ∈ String
    RtRecName(s ↦ rb_fs, i ↦ _rb_v, name ↦ rb_f)
    rbx_f ∈ String
    RtRecName(s ↦ rb_fs, i ↦ _rb_fi, name ↦ rbx_f)
    rb_dname ∈ String = _rb_nm ++ "." ++ rbx_f
    rb_dup ∈ Bool = (index_of(st_names,
        "|" ++ substr(rb_dname ++ "                               ", 0, 31),
        0) ≥ 0)
    rb_head ∈ C2Item = (rb_dup ? C2Process(EIdent(rb_dname))
        : C2DeclConst(rb_dname, 0))
    rbx_items ∈ C2Items = C2ICons(rb_head,
        C2ICons(C2Process(_rb_body),
        C2ICons(C2PinEq, C2ICons(C2AssertTop, C2INil))))

    -- D2: a Seq(Int) membership declares the array const + its
    -- companion `<name>__len` Int const + the `(>= len 0)` floor —
    -- all through existing items (the two handles stay on the stack
    -- through the NatBound/AssertTop pair, then drop).
    c_seqmem_items ∈ C2Items = C2ICons(
        C2DeclConst(c_dname, (c_sq_rt ≥ 0 ? 10 + c_sq_rt : 5)),
        C2ICons(C2DeclConst(c_dname ++ "__len", 0),
        C2ICons(C2NatBound, C2ICons(C2AssertTop,
        C2ICons(C2Drop, C2ICons(C2Drop, C2INil))))))
    -- G2: a Set(T) membership declares ONE set-sorted const; no
    -- __len companion (cardinality reads the recorded literal).
    c_setmem_items ∈ C2Items = C2ICons(
        C2DeclConst(c_dname, 20 + c_sq_rt),
        C2ICons(C2Drop, C2INil))
    d_new_items ∈ C2Items = ((d_line_end ∨ d_enter_pratt0 ∨ d_enter_el
        ∨ d_enter_set ∨ d_enter_match ∨ d_enter_sl ∨ c_comp_line
        ∨ c_ty_line ∨ d_enter_qr ∨ d_enter_qs ∨ pcl_tup ∨ pcl_stmt)
        ? C2INil
        : pcl_meth ? pcl_recv_items
        : d_enter_si ? c_si_items
        : d_enter_qset ? qset_items
        : d_enter_stl ? stl_entry_items
        : d_enter_smem ? c_smem_items
        : d_setmem ? c_setmem_items
        : d_seq_mem ? c_seqmem_items
        : c_mem_items)
    -- a direct (non-pratt) membership line consumes `x ∈ Type` = 3
    -- tokens, or 5 with a single `op atom` bound; a Seq membership
    -- `s ∈ Seq ( Int )` is 6.
    d_mem_line ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ (¬d_enter_pratt0)
        ∧ (¬d_enter_el) ∧ (¬d_enter_set) ∧ (¬d_enter_match)
        ∧ (¬d_enter_sl) ∧ (¬d_enter_mn) ∧ (¬c_comp_line)
        ∧ (¬c_strin_line) ∧ (¬c_ty_line) ∧ (¬c_q_line)
        ∧ (¬pcl_line))
    d_mem_cons ∈ Int = (d_seq_mem ? 6 : c_bound ? 5 : 3)
    c_sq_eltnm ∈ String = (c_sq_rt = 0 ? rt_n0
        : c_sq_rt = 1 ? rt_n1
        : rt_n2)
    c_tyname ∈ String = (c_sc = 1 ? "Bool"
        : c_sc = 2 ? c_type_str
        : c_sc = 3 ? "String"
        : c_sc = 4 ? "Result"
        : (c_sc = 5 ∧ c_sq_rt ≥ 0) ? ("Seq(" ++ c_sq_eltnm ++ ")")
        : c_sc = 5 ? "Seq(Int)"
        : c_sc = 6 ? "Real"
        : c_setmem_line ? ("Set(" ++ c_sq_eltnm ++ ")")
        : "Int")
    c_field ∈ String = c_dname ++ ":" ++ c_tyname
    -- `_<name>` carry-over DECLARES (fossil parity): the kernel pins
    -- `_<name> = <prev>` from tick 1 on — and the functionizer's
    -- verify solves tick 1 even for tick-0-exit programs. Z3 only
    -- serializes consts the asserts mention, so the carries must be
    -- textual lines in the emitted unit. A Seq field carries BOTH
    -- the array const and its __len (the oracle's two lines).
    c_cdecl ∈ String = ((c_sc = 5 ∧ c_sq_rt ≥ 0)
        ? "(declare-fun _" ++ c_dname ++ " () (Array Int " ++ c_sq_eltnm ++ "))\n"
            ++ "(declare-fun _" ++ c_dname ++ "__len () Int)\n"
        : c_sc = 5
        ? "(declare-fun _" ++ c_dname ++ " () (Array Int Int))\n"
            ++ "(declare-fun _" ++ c_dname ++ "__len () Int)\n"
        : c_setmem_line
        ? "(declare-fun _" ++ c_dname ++ " () (Array " ++ c_sq_eltnm ++ " Bool))\n"
        : "(declare-fun _" ++ c_dname ++ " () " ++ c_tyname ++ ")\n")

    -- ── F1: pmode-9 GROUP walk (first-line param lists + body
    -- multi-name memberships) ─────────────────────────────────────
    -- Two flavors share one FSM. PARAM (`claim main(a, b ∈ Int,
    -- ok ∈ Bool)`): groups separated by `,`, list closed by `)`.
    -- BODY (`x, y, z ∈ Nat`): one group, no separator after the
    -- type. Collect substate (pg_st 0): one `Ident ,` per tick
    -- pushes the name; the `Ident ∈ Type` tick declares the LAST
    -- name through the classifier's own c_mem_items/c_field/c_cdecl
    -- (same window positions as a plain membership) and latches the
    -- group type. Drain substate (pg_st 1): one pending name per
    -- tick declares through pg_drain_items with the latched type.
    -- Scalar types only (Int/Nat/Bool/String/Result/the user enum);
    -- Seq(...) params and bounds/pins on group lines are descoped
    -- (zero corpus occurrences of either).
    pg_pend ∈ TokenList
    pg_st ∈ Int
    pg_param ∈ Bool
    pg_close ∈ Bool
    pg_sc ∈ Int
    pg_nat ∈ Bool
    pg_ty ∈ String

    pg_active ∈ Bool = (in_parse ∧ (_pmode = 9) ∧ d_witems_nil
        ∧ tok_ready)
    pg_collect ∈ Bool = (pg_active ∧ (_pg_st = 0))
    pg_take2 ∈ Bool = (pg_collect ∧ (ww_t0 matches Ident(_))
        ∧ (ww_t1 matches Comma))
    pg_ty_tick ∈ Bool = (pg_collect ∧ (ww_t0 matches Ident(_))
        ∧ c_is_mem)
    pg_bail ∈ Bool = (pg_collect ∧ (¬pg_take2) ∧ (¬pg_ty_tick))
    pg_drain ∈ Bool = (pg_active ∧ (_pg_st = 1))

    pg_have_pend ∈ Bool = (¬(_pg_pend matches TLNil))
    pg_hd_t ∈ Token = match _pg_pend
        TLCons(t, _) ⇒ t
        TLNil ⇒ EofTok
    pg_hd_nm ∈ String = match pg_hd_t
        Ident(s) ⇒ s
        _ ⇒ ""
    pg_tail ∈ TokenList = match _pg_pend
        TLCons(_, r) ⇒ r
        TLNil ⇒ TLNil
    pg_last ∈ Bool = (pg_tail matches TLNil)

    -- group-end bookkeeping on the type tick: PARAM flavor also
    -- consumes the separator (`,` next group / `)` list end).
    pg_ty_cons ∈ Int = (_pg_param ? 4 : 3)
    pg_ty_close ∈ Bool = (ww_t3 matches RParen)
    -- where the walk goes when the current group is fully declared
    pg_group_done_mode ∈ Int = ((¬_pg_param) ? 2
        : _pg_close ? 2
        : 9)
    pg_ty_exit_mode ∈ Int = ((¬_pg_param) ? 2
        : pg_ty_close ? 2
        : 9)

    pg_pend = (is_first_tick ? TLNil
        : d_enter_claimp ? TLNil
        : d_enter_mn ? TLCons(c_t0, TLNil)
        : pg_take2 ? TLCons(ww_t0, _pg_pend)
        : pg_drain ? pg_tail
        : _pg_pend)
    pg_st = (is_first_tick ? 0
        : (d_enter_claimp ∨ d_enter_mn) ? 0
        : pg_ty_tick ? (pg_have_pend ? 1 : 0)
        : (pg_drain ∧ pg_last) ? 0
        : _pg_st)
    pg_param = (is_first_tick ? false
        : d_enter_claimp ? true
        : d_enter_mn ? false
        : _pg_param)
    pg_close = (is_first_tick ? false
        : d_enter_claimp ? false
        : (pg_ty_tick ∧ _pg_param) ? pg_ty_close
        : _pg_close)
    pg_sc = (is_first_tick ? 0 : pg_ty_tick ? c_sc : _pg_sc)
    pg_nat = (is_first_tick ? false : pg_ty_tick ? c_is_nat : _pg_nat)
    pg_ty = (is_first_tick ? "" : pg_ty_tick ? c_tyname : _pg_ty)

    pg_field ∈ String = pg_hd_nm ++ ":" ++ _pg_ty
    pg_cdecl ∈ String = ("(declare-fun _" ++ pg_hd_nm ++ " () "
        ++ _pg_ty ++ ")\n")
    pg_drain_items ∈ C2Items = C2ICons(C2DeclConst(pg_hd_nm, _pg_sc),
        (_pg_nat
            ? C2ICons(C2NatBound, C2ICons(C2AssertTop,
                C2ICons(C2Drop, C2INil)))
            : C2ICons(C2Drop, C2INil)))

    -- ── F2: composition inlining (see compiler2/driver_compose.ev) ──
    ..DriverCompose
    -- ── PRATT FSM state (pmode 3; reads the shared window) ────────
    d_in_pratt ∈ Bool = (in_parse ∧ (_pmode = 3) ∧ tok_ready)

    p_out ∈ ExprList
    p_ops ∈ PrOps
    p_expop ∈ Bool
    p_pd ∈ Int
    p_qd ∈ Int
    p_cd ∈ Int
    pk_kind ∈ Int
    pk_name ∈ String
    pk_sc ∈ Int
    pk_nat ∈ Bool
    pk_nodecl ∈ Bool
    pk_pn ∈ String
    pk_rec ∈ Int

    d_cb_pad ∈ String = "                               "
    d_cb_names ∈ String = ("|" ++ substr("str_len" ++ d_cb_pad, 0, 31)
        ++ "|" ++ substr("str_from_int" ++ d_cb_pad, 0, 31)
        ++ "|" ++ substr("substr" ++ d_cb_pad, 0, 31)
        ++ "|" ++ substr("char_at" ++ d_cb_pad, 0, 31)
        ++ "|" ++ substr("index_of" ++ d_cb_pad, 0, 31)
        ++ "|" ++ substr("str_contains" ++ d_cb_pad, 0, 31)
        ++ "|" ++ substr("starts_with" ++ d_cb_pad, 0, 31)
        ++ "|" ++ substr("ends_with" ++ d_cb_pad, 0, 31)
        ++ "|" ++ substr("replace" ++ d_cb_pad, 0, 31)
        ++ ((uev_n0 ≠ "") ? ("|" ++ substr(uev_n0 ++ d_cb_pad, 0, 31)) : "")
        ++ ((uev_n1 ≠ "") ? ("|" ++ substr(uev_n1 ++ d_cb_pad, 0, 31)) : "")
        ++ ((uev_n2 ≠ "") ? ("|" ++ substr(uev_n2 ++ d_cb_pad, 0, 31)) : "")
        ++ ((uev_n3 ≠ "") ? ("|" ++ substr(uev_n3 ++ d_cb_pad, 0, 31)) : "")
        ++ ((uev_n4 ≠ "") ? ("|" ++ substr(uev_n4 ++ d_cb_pad, 0, 31)) : "")
        ++ ((uev_n5 ≠ "") ? ("|" ++ substr(uev_n5 ++ d_cb_pad, 0, 31)) : "")
        ++ ((rt_n0 ≠ "" ∧ rt_sort0 ≠ 0) ? ("|" ++ substr(rt_n0 ++ d_cb_pad, 0, 31)) : "")
        ++ ((rt_n1 ≠ "" ∧ rt_sort1 ≠ 0) ? ("|" ++ substr(rt_n1 ++ d_cb_pad, 0, 31)) : "")
        ++ ((rt_n2 ≠ "" ∧ rt_sort2 ≠ 0) ? ("|" ++ substr(rt_n2 ++ d_cb_pad, 0, 31)) : ""))
    pr_ntoks ∈ TokenList
    pr_nouts ∈ ExprList
    pr_nops ∈ PrOps
    pr_nexpop ∈ Bool
    pr_npd ∈ Int
    pr_nqd ∈ Int
    pr_ncd ∈ Int
    pr_sdone ∈ Bool
    pr_sres ∈ Expr
    pr_scons ∈ Int
    C2PrattStep(toks ↦ _wtoks, outs ↦ _p_out, ops ↦ _p_ops,
        expop ↦ _p_expop, pd ↦ _p_pd, qd ↦ _p_qd, cd ↦ _p_cd,
        qstop ↦ _pq_qstop, calls ↦ d_cb_names,
        ntoks ↦ pr_ntoks, nouts ↦ pr_nouts, nops ↦ pr_nops,
        nexpop ↦ pr_nexpop, npd ↦ pr_npd, nqd ↦ pr_nqd, ncd ↦ pr_ncd,
        sdone ↦ pr_sdone, sres ↦ pr_sres, scons ↦ pr_scons)

    p_out = (is_first_tick ? ELNil
        : d_enter_pratt ? ELNil
        : d_in_pratt ? pr_nouts
        : _p_out)
    p_ops = (is_first_tick ? PrNil
        : d_enter_pratt ? PrNil
        : d_in_pratt ? pr_nops
        : _p_ops)
    p_expop = (is_first_tick ? true
        : d_enter_pratt ? true
        : d_in_pratt ? pr_nexpop
        : _p_expop)
    p_pd = (is_first_tick ? 0
        : d_enter_pratt ? 0
        : d_in_pratt ? pr_npd
        : _p_pd)
    p_qd = (is_first_tick ? 0
        : d_enter_pratt ? 0
        : d_in_pratt ? pr_nqd
        : _p_qd)
    p_cd = (is_first_tick ? 0
        : d_enter_pratt ? 0
        : d_in_pratt ? pr_ncd
        : _p_cd)
    pk_kind = (is_first_tick ? 0 : d_enter_pratt ? d_pratt_kind0 : _pk_kind)
    pk_name = (is_first_tick ? "" : d_enter_pratt ? c_dname : _pk_name)
    pk_sc = (is_first_tick ? 0 : d_enter_pratt ? c_sc : _pk_sc)
    pk_nat = (is_first_tick ? false : d_enter_pratt ? c_is_nat : _pk_nat)
    pk_nodecl = (is_first_tick ? false : d_enter_pratt ? c_nodecl : _pk_nodecl)
    pk_pn = (is_first_tick ? "" : d_enter_pratt ? c_pn : _pk_pn)
    -- G2: record-pinned membership (`offset_pos ∈ IVec2 = <expr>`)
    -- arms the rb broadcast loop at parse completion.
    c_pin_rtk ∈ Int = ((c_pinned ∧ c_is_mem) ? c_ty_rtk : 0 - 1)
    pk_rec = (is_first_tick ? 0 - 1
        : d_enter_pratt ? c_pin_rtk
        : _pk_rec)

    -- parse completion → build the line's work-item program.
    p_done ∈ Bool = (d_in_pratt ∧ pr_sdone)
    pr_bad ∈ Bool = (p_done ∧ (pr_sres matches ENoExpr))

    -- ── G1: conditional inline `cond ⇒ ClaimName` — a standalone
    -- line whose parsed root is (=> guard EIdent(Name)) with Name in
    -- the claim index splices Name's body with every asserted
    -- constraint wrapped in (=> guard …) — the oracle's shape.
    -- The guard expression builds to a HANDLE first (its items run
    -- under pmode 10, cw_st 3→4), then the jump fires with il_guard
    -- armed; the matching frame pop disarms it. ONE active guard
    -- (no nested guarded splices — zero corpus occurrences).
    gc_op ∈ Op
    gc_l ∈ Expr
    gc_r ∈ Expr
    gc_bin ∈ Bool
    BoolExprBinopParts(e ↦ pr_sres, op ↦ gc_op, lhs ↦ gc_l,
        rhs ↦ gc_r, is_binop ↦ gc_bin)
    gc_rnm ∈ String = match gc_r
        EIdent(s) ⇒ s
        _ ⇒ ""
    gc_key ∈ String = "|" ++ substr(gc_rnm ++ "                               ", 0, 31)
    gc_pos ∈ Int = index_of(ci_names, gc_key, 0)
    gc_hit ∈ Bool = (p_done ∧ (_pk_kind = 2) ∧ (¬pr_bad) ∧ gc_bin
        ∧ (gc_op matches OpImpl) ∧ (gc_rnm ≠ "") ∧ (gc_pos ≥ 0)
        ∧ (_il_depth < 8))
    e_gcr ∈ Effect
    BuildMemReadLong(addr ↦ ci_base + (8 * (gc_pos / 32)), eff ↦ e_gcr)
    gj_cap ∈ Bool = (in_parse ∧ (_pmode = 10) ∧ (_cw_st = 3))
    gj_fire ∈ Bool = (in_parse ∧ (_pmode = 10) ∧ (_cw_st = 4)
        ∧ d_witems_nil)
    il_guard ∈ Int
    il_gd ∈ Int
    gj_unguard ∈ Bool = (il_pop ∧ (_il_depth = _il_gd))
    il_guard = (is_first_tick ? 0
        : cw_reset ? 0
        : gj_fire ? d_h_top
        : gj_unguard ? 0
        : _il_guard)
    il_gd = (is_first_tick ? 0
        : cw_reset ? 0
        : gj_fire ? _il_depth + 1
        : gj_unguard ? 0
        : _il_gd)
    d_guard_on ∈ Bool = (_il_guard ≠ 0)

    -- ── G1: positional binding — `(e1, e2, e3) ∈ add` tuple-in,
    -- `recv.add(args)` method calls (bare or dotted receiver),
    -- statement calls `add(2, 3, mid)`, and `(args) ∈ recv.add`
    -- method-tuple-in. Elements parse to HANDLES (Pratt kind 10);
    -- a lone UNDECLARED ident element declares an Int const first
    -- (arg inference — the oracle's mid:Int). The jump pushes a
    -- fresh "__cN_" frame; the param-skip walk COLLECTS the
    -- callee's param names (pn) and ips_done zips them with the
    -- held handles into il_binds (receiver = first param).
    pt_st ∈ Int
    pt_callee ∈ String
    pc_k ∈ Int
    pj ∈ Bool
    pj_recv ∈ Bool

    -- entry shapes (classify tick; comp/membership kinds take priority)
    pcl_t2nm ∈ String = match c_t2
        Ident(s) ⇒ s
        _ ⇒ ""
    pcl_t4nm ∈ String = match c_t4
        Ident(s) ⇒ s
        _ ⇒ ""
    pcl_stmt ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ c_t0_is_ident
        ∧ (c_t1 matches LParen) ∧ (¬(c_t3 matches OpMapsto))
        ∧ c_comp_found ∧ (¬c_dd_shape) ∧ (_il_depth < 8))
    pcl_m1key ∈ String = "|" ++ substr(pcl_t2nm ++ "                               ", 0, 31)
    pcl_m1 ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ c_t0_is_ident
        ∧ (c_t1 matches Dot) ∧ (c_t2 matches Ident(_))
        ∧ (c_t3 matches LParen)
        ∧ (index_of(ci_names, pcl_m1key, 0) ≥ 0) ∧ (_il_depth < 8))
    pcl_m2key ∈ String = "|" ++ substr(pcl_t4nm ++ "                               ", 0, 31)
    pcl_m2 ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ c_t0_is_ident
        ∧ (c_t1 matches Dot) ∧ (c_t2 matches Ident(_))
        ∧ (c_t3 matches Dot) ∧ (c_t4 matches Ident(_))
        ∧ (ww_t5 matches LParen)
        ∧ (index_of(ci_names, pcl_m2key, 0) ≥ 0) ∧ (_il_depth < 8))
    pcl_meth ∈ Bool = (pcl_m1 ∨ pcl_m2)
    pcl_recv_nm ∈ String = (pcl_m2 ? (c_name ++ "." ++ pcl_t2nm) : c_name)
    pcl_tup ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ (c_t0 matches LParen)
        ∧ (c_t2 matches Comma) ∧ (_il_depth < 8))
    pcl_line ∈ Bool = (pcl_stmt ∨ pcl_meth ∨ pcl_tup)
    pcl_recv_items ∈ C2Items = C2ICons(C2Process(EIdent(pcl_recv_nm)), C2INil)

    -- element walk (pt_st 0)
    pe_act ∈ Bool = (in_parse ∧ (_pmode = 12) ∧ (_pt_st = 0)
        ∧ d_witems_nil ∧ tok_ready)
    pt_comma ∈ Bool = (pe_act ∧ (ww_t0 matches Comma))
    pt_rp ∈ Bool = (pe_act ∧ (ww_t0 matches RParen))
    -- G2: a TUPLE element `( atom , atom )` — one 5-token bite; its
    -- two handles bind to the record param's FIELD NAMES at the zip
    -- (tuple→record coercion), or the first handle binds a scalar
    -- param (092's only-when-record contract).
    ptt_e0 ∈ Expr
    ptt_ok0 ∈ Bool
    C2AtomE(t ↦ ww_t1, e ↦ ptt_e0, ok ↦ ptt_ok0)
    ptt_e1 ∈ Expr
    ptt_ok1 ∈ Bool
    C2AtomE(t ↦ ww_t3, e ↦ ptt_e1, ok ↦ ptt_ok1)
    pt_tup_b ∈ Bool = (pe_act ∧ (ww_t0 matches LParen) ∧ ptt_ok0
        ∧ (ww_t2 matches Comma) ∧ ptt_ok1 ∧ (ww_t4 matches RParen)
        ∧ (¬_pt_tup))
    ptt_items ∈ C2Items = C2ICons(C2Process(ptt_e0),
        C2ICons(C2Process(ptt_e1), C2INil))
    pt_tup ∈ Bool
    pt_ts ∈ Int
    pt_tup = (is_first_tick ? false
        : pcl_line ? false
        : pt_tup_b ? true
        : _pt_tup)
    pt_ts = (is_first_tick ? 0 : pt_tup_b ? _pc_k : _pt_ts)
    pt_elem ∈ Bool = (pe_act ∧ (¬pt_comma) ∧ (¬pt_rp) ∧ (¬pt_tup_b))
    -- close flavors
    ptc_w2nm ∈ String = match ww_t2
        Ident(s) ⇒ s
        _ ⇒ ""
    ptc_w4nm ∈ String = match ww_t4
        Ident(s) ⇒ s
        _ ⇒ ""
    ptc_n ∈ Bool = (pt_rp ∧ (_pt_callee ≠ ""))
    ptc_tm ∈ Bool = (pt_rp ∧ (_pt_callee = "") ∧ (ww_t1 matches OpIn)
        ∧ (ww_t2 matches Ident(_)) ∧ (ww_t3 matches Dot)
        ∧ (ww_t4 matches Ident(_)))
    ptc_t ∈ Bool = (pt_rp ∧ (_pt_callee = "") ∧ (ww_t1 matches OpIn)
        ∧ (ww_t2 matches Ident(_)) ∧ (¬ptc_tm))
    ptc_nm ∈ String = (ptc_n ? _pt_callee : ptc_tm ? ptc_w4nm : ptc_w2nm)
    ptc_key ∈ String = "|" ++ substr(ptc_nm ++ "                               ", 0, 31)
    ptc_pos ∈ Int = index_of(ci_names, ptc_key, 0)
    ptc_ok ∈ Bool = ((ptc_n ∨ ptc_t ∨ ptc_tm) ∧ (ptc_pos ≥ 0))
    pt_close ∈ Bool = ptc_ok
    pt_bail ∈ Bool = (pt_rp ∧ (¬ptc_ok))
    e_pcr ∈ Effect
    BuildMemReadLong(addr ↦ ci_base + (8 * (ptc_pos / 32)), eff ↦ e_pcr)
    ptc_recv_items ∈ C2Items = C2ICons(C2Process(EIdent(ptc_w2nm)), C2INil)

    -- capture + fire
    ptj_cap ∈ Bool = (in_parse ∧ (_pmode = 12) ∧ (_pt_st = 2))
    ptj_fire ∈ Bool = (in_parse ∧ (_pmode = 12) ∧ (_pt_st = 3)
        ∧ d_witems_nil)

    pt_st = (is_first_tick ? 0
        : pcl_line ? 0
        : pt_close ? 2
        : ptj_cap ? 3
        : ptj_fire ? 0
        : _pt_st)
    pt_callee = (is_first_tick ? ""
        : pcl_stmt ? c_name
        : pcl_m1 ? pcl_t2nm
        : pcl_m2 ? pcl_t4nm
        : pcl_tup ? ""
        : _pt_callee)
    pi_done ∈ Bool = (p_done ∧ (_pk_kind = 10) ∧ (¬pr_bad))
    pc_k = (is_first_tick ? 0
        : (pcl_stmt ∨ pcl_tup) ? 0
        : pcl_meth ? 1
        : pi_done ? _pc_k + 1
        : pt_tup_b ? _pc_k + 1
        : (pt_close ∧ ptc_tm) ? _pc_k + 1
        : _pc_k)
    pj = (is_first_tick ? false
        : cw_reset ? false
        : ptj_fire ? true
        : (pz_act ∨ ips_off) ? false
        : _pj)
    pj_recv = (is_first_tick ? false
        : pcl_meth ? false
        : pcl_line ? false
        : (pt_close ∧ ptc_tm) ? true
        : _pj_recv)

    -- arg inference: a lone UNDECLARED ident element declares an
    -- Int const (manifest field + carry, oracle parity)
    pi_nm ∈ String = match pr_sres
        EIdent(s) ⇒ s
        _ ⇒ ""
    pi_skey ∈ String = "|" ++ substr((_il_pfx ++ pi_nm) ++ "                               ", 0, 31)
    pi_pkey ∈ String = "|" ++ substr(pi_nm ++ "                               ", 0, 31)
    pi_evt ∈ Bool = ((evt_n0 = pi_nm) ∨ (evt_n1 = pi_nm)
        ∨ (evt_n2 = pi_nm) ∨ (evt_n3 = pi_nm) ∨ (evt_n4 = pi_nm)
        ∨ (evt_n5 = pi_nm))
    pi_ilb ∈ Bool = ((ilb_n0 = pi_nm) ∨ (ilb_n1 = pi_nm)
        ∨ (ilb_n2 = pi_nm) ∨ (ilb_n3 = pi_nm) ∨ (ilb_n4 = pi_nm)
        ∨ (ilb_n5 = pi_nm))
    pi_unres ∈ Bool = ((pi_nm ≠ "") ∧ (pi_nm ≠ "true")
        ∧ (pi_nm ≠ "false") ∧ (¬pi_evt) ∧ (¬pi_ilb)
        ∧ (index_of(st_names, pi_skey, 0) < 0)
        ∧ (index_of(st_names, pi_pkey, 0) < 0))
    pi_decl ∈ Bool = (pi_done ∧ pi_unres)
    pi_dname ∈ String = _il_pfx ++ pi_nm
    pi_field ∈ String = pi_dname ++ ":Int"
    pi_cdecl ∈ String = "(declare-fun _" ++ pi_dname ++ " () Int)\n"
    pi_items ∈ C2Items = (pi_decl
        ? C2ICons(C2DeclConst(pi_dname, 0), C2INil)
        : C2ICons(C2Process(pr_sres), C2INil))

    -- param-name collection during the param-skip walk
    pn_k ∈ Int
    pn_prev ∈ Int
    pn0 ∈ String
    pn1 ∈ String
    pn2 ∈ String
    pn3 ∈ String
    pn4 ∈ String
    pn5 ∈ String
    pn_take ∈ Bool = (ips_skp ∧ (ww_t0 matches Ident(_))
        ∧ (_pn_prev = 1))
    -- G2: each param's TYPE (the Ident after its `∈`) — needed to
    -- decide tuple→record coercion at the zip.
    pty_take ∈ Bool = (ips_skp ∧ (ww_t0 matches OpIn)
        ∧ (ww_t1 matches Ident(_)) ∧ (_il_pd = 1))
    pty_nm ∈ String = match ww_t1
        Ident(s) ⇒ s
        _ ⇒ ""
    pty0 ∈ String
    pty1 ∈ String
    pty2 ∈ String
    pty3 ∈ String
    pty0 = (is_first_tick ? "" : il_jump ? ""
        : (pty_take ∧ _pn_k = 1) ? pty_nm : _pty0)
    pty1 = (is_first_tick ? "" : il_jump ? ""
        : (pty_take ∧ _pn_k = 2) ? pty_nm : _pty1)
    pty2 = (is_first_tick ? "" : il_jump ? ""
        : (pty_take ∧ _pn_k = 3) ? pty_nm : _pty2)
    pty3 = (is_first_tick ? "" : il_jump ? ""
        : (pty_take ∧ _pn_k = 4) ? pty_nm : _pty3)
    pn_nm ∈ String = match ww_t0
        Ident(s) ⇒ s
        _ ⇒ ""
    pn_prev = (is_first_tick ? 0
        : ips_open ? 1
        : ips_skp ? (((ww_t0 matches Comma) ∧ (_il_pd = 1)) ? 1 : 0)
        : _pn_prev)
    pn_k = (is_first_tick ? 0
        : il_jump ? 0
        : pn_take ? _pn_k + 1
        : _pn_k)
    pn0 = (is_first_tick ? "" : (pn_take ∧ _pn_k = 0) ? pn_nm : _pn0)
    pn1 = (is_first_tick ? "" : (pn_take ∧ _pn_k = 1) ? pn_nm : _pn1)
    pn2 = (is_first_tick ? "" : (pn_take ∧ _pn_k = 2) ? pn_nm : _pn2)
    pn3 = (is_first_tick ? "" : (pn_take ∧ _pn_k = 3) ? pn_nm : _pn3)
    pn4 = (is_first_tick ? "" : (pn_take ∧ _pn_k = 4) ? pn_nm : _pn4)
    pn5 = (is_first_tick ? "" : (pn_take ∧ _pn_k = 5) ? pn_nm : _pn5)

    -- zip at param-list end: pn names ↦ the held element handles
    pz_act ∈ Bool = (ips_done ∧ _pj)
    pz_v0 ∈ Int = (_pj_recv ? d_h_top
        : _pc_k = 1 ? d_h_top : _pc_k = 2 ? d_h_2nd
        : _pc_k = 3 ? d_h_3rd : d_h_4th)
    pz_v1 ∈ Int = (_pj_recv
        ? (_pc_k = 2 ? d_h_2nd : _pc_k = 3 ? d_h_3rd : d_h_4th)
        : (_pc_k = 2 ? d_h_top : _pc_k = 3 ? d_h_2nd : d_h_3rd))
    pz_v2 ∈ Int = (_pj_recv
        ? (_pc_k = 3 ? d_h_2nd : d_h_3rd)
        : (_pc_k = 3 ? d_h_top : d_h_2nd))
    pz_v3 ∈ Int = (_pj_recv ? d_h_2nd : d_h_top)
    -- G2: tuple-aware zip. The tuple's two handles sit consecutively
    -- in the push order at slot _pt_ts; a record-typed param binds
    -- them to its first two FIELD NAMES, a scalar param binds the
    -- FIRST handle only. Supported shapes (corpus): pc_k 2 ts 0,
    -- pc_k 3 ts 0, pc_k 3 ts 1 (method receiver first), pc_k 1.
    pzt_pty ∈ String = (_pt_ts = 0 ? _pty0
        : _pt_ts = 1 ? _pty1
        : _pt_ts = 2 ? _pty2
        : _pty3)
    pzt_k ∈ Int
    RtIdxOf(nm ↦ pzt_pty, n0 ↦ rt_n0, n1 ↦ rt_n1, n2 ↦ rt_n2,
        s0 ↦ rt_sort0, s1 ↦ rt_sort1, s2 ↦ rt_sort2, idx ↦ pzt_k)
    pzt_fs ∈ String = (pzt_k = 0 ? rt_f0 : pzt_k = 1 ? rt_f1 : rt_f2)
    pzt_f0 ∈ String
    RtRecName(s ↦ pzt_fs, i ↦ 0, name ↦ pzt_f0)
    pzt_f1 ∈ String
    RtRecName(s ↦ pzt_fs, i ↦ 1, name ↦ pzt_f1)
    pzt_pn ∈ String = (_pt_ts = 0 ? _pn0
        : _pt_ts = 1 ? _pn1
        : _pt_ts = 2 ? _pn2
        : _pn3)
    -- tuple handle pair (first pushed = deeper) per supported shape
    pzt_h0 ∈ Int = (_pc_k = 1 ? d_h_2nd
        : (_pc_k = 2 ∧ _pt_ts = 0) ? d_h_3rd
        : (_pc_k = 3 ∧ _pt_ts = 0) ? d_h_4th
        : d_h_3rd)
    pzt_h1 ∈ Int = (_pc_k = 1 ? d_h_top
        : (_pc_k = 2 ∧ _pt_ts = 0) ? d_h_2nd
        : (_pc_k = 3 ∧ _pt_ts = 0) ? d_h_3rd
        : d_h_2nd)
    pzt_tb ∈ C2Binds = (pzt_k ≥ 0
        ? CBCons(pzt_pn ++ "." ++ pzt_f0, pzt_h0,
            CBCons(pzt_pn ++ "." ++ pzt_f1, pzt_h1, CBNil))
        : CBCons(pzt_pn, pzt_h0, CBNil))
    pzt_app1 ∈ C2Binds = (_pc_k = 2
        ? CBCons(_pn1, d_h_top, pzt_tb)
        : _pc_k = 3
        ? (_pt_ts = 0
            ? CBCons(_pn1, d_h_2nd, CBCons(_pn2, d_h_top, pzt_tb))
            : CBCons(_pn0, d_h_4th, CBCons(_pn2, d_h_top, pzt_tb)))
        : pzt_tb)
    pz_binds_nt ∈ C2Binds = (_pc_k = 1 ? CBCons(_pn0, pz_v0, CBNil)
        : _pc_k = 2 ? CBCons(_pn0, pz_v0, CBCons(_pn1, pz_v1, CBNil))
        : _pc_k = 3 ? CBCons(_pn0, pz_v0, CBCons(_pn1, pz_v1,
            CBCons(_pn2, pz_v2, CBNil)))
        : _pc_k = 4 ? CBCons(_pn0, pz_v0, CBCons(_pn1, pz_v1,
            CBCons(_pn2, pz_v2, CBCons(_pn3, pz_v3, CBNil))))
        : CBNil)
    pz_binds ∈ C2Binds = (_pt_tup ? pzt_app1 : pz_binds_nt)
    pz_pop ∈ C2H = (_pt_tup
        ? (_pc_k = 1 ? d_h_t2
            : _pc_k = 2 ? d_h_t3
            : _pc_k = 3 ? d_h_t4
            : d_h_t5)
        : _pc_k = 1 ? d_h_t1
        : _pc_k = 2 ? d_h_t2
        : _pc_k = 3 ? d_h_t3
        : _pc_k = 4 ? d_h_t4
        : d_hstk_in)
    d_pk_pinseg ∈ C2Items = C2ICons(C2Process(pr_sres),
        C2ICons(C2PinEq, C2ICons(C2AssertTop, C2INil)))
    d_pk_natseg ∈ C2Items = (_pk_nat
        ? C2ICons(C2NatBound, C2ICons(C2AssertTop, d_pk_pinseg))
        : d_pk_pinseg)
    -- F2: a membership pin of a BOUND/already-declared name resolves
    -- the existing handle instead of redeclaring (the dup head).
    d_pk_head ∈ C2Item = (_pk_nodecl ? C2Process(EIdent(_pk_pn))
        : C2DeclConst(_pk_name, _pk_sc))
    d_pratt_items ∈ C2Items = (pr_bad ? C2INil
        : _pk_kind = 3 ? C2ICons(C2Process(pr_sres),
            C2ICons(C2App(z_exitdecl, 1),
            C2ICons(el_seleq_item, C2INil)))
        : _pk_kind = 4 ? (mq_wc ? mp_items : C2INil)
        : _pk_kind = 6 ? C2ICons(C2Process(pr_sres), C2INil)
        : _pk_kind = 7 ? sl_elem_items
        : _pk_kind = 8 ? C2ICons(C2Process(pr_sres), C2INil)
        : _pk_kind = 9 ? C2INil
        : _pk_kind = 10 ? pi_items
        : _pk_kind = 1 ? (_pk_rec ≥ 0 ? C2INil
            : C2ICons(d_pk_head, d_pk_natseg))
        : gc_hit ? C2ICons(C2Process(gc_l), C2INil)
        : C2ICons(C2Process(pr_sres), C2ICons(C2AssertTop, C2INil)))
    -- kind 3: the Exit argument closes with `)` — consume it; the
    -- element walk (pmode 5) handles the following `,` / `⟩`.
    -- kind 6: the guard ends at the chain's `?` — consume it.
    -- kind 8: a slot value ends at the call's `,` / `)` — the call
    -- walk (pmode 10) consumes those. On a malformed line skip one
    -- token so the walk always progresses.
    d_done_cons ∈ Int = (pr_bad ? 1
        : _pk_kind = 3 ? 1
        : _pk_kind = 6 ? 1
        : 0)

    -- ── state transitions ─────────────────────────────────────────
    d_pops ∈ Int = (¬d_processing ? 0
        : d_it_proc ? 0
        : d_it_op ? (d_op_arr ? (_istep = 2 ? 2 : 0) : 2)
        : d_it_ite ? 3
        : d_it_not ? 1
        : d_it_pineq ? 2
        : d_it_assert ? (d_guard_on ? (_istep = 1 ? 1 : 0) : 1)
        : d_it_drop ? 1
        : d_it_app ? (_istep = d_app_n ? d_app_n : 0)
        : d_it_seleq ? (_istep = 1 ? 1 : 0)
        : d_it_seleqh ? (_istep = 1 ? 1 : 0)
        : d_it_strop ? d_so_n
        : d_it_selh ? 2
        : d_it_sadd ? 2
        : 0)
    d_ilb_push ∈ Bool = (d_processing ∧ d_it_proc ∧ d_pe_is_id
        ∧ d_ilb_found ∧ (¬d_bind_hit) ∧ (¬d_vb_hit) ∧ (¬d_vb_dot)
        ∧ (¬d_rb_hit))
    d_push_ident ∈ Bool = (d_processing ∧ d_it_proc ∧ d_pe_is_id
        ∧ d_lk_pure ∧ (¬d_bind_hit) ∧ (¬d_ilb_found) ∧ (¬d_vb_hit)
        ∧ (¬d_vb_dot) ∧ (¬d_rb_hit) ∧ (¬d_rbc_hit))
    d_lk_read ∈ Bool = (d_processing ∧ d_it_proc ∧ d_pe_is_id
        ∧ (¬d_lk_pure) ∧ (¬d_bind_hit) ∧ (¬d_ilb_found) ∧ (¬d_vb_hit)
        ∧ (¬d_vb_dot) ∧ (¬d_rb_hit))
    d_push_h ∈ Bool = (d_processing ∧ d_it_pushh)
    d_push_decl ∈ Bool = (d_processing ∧ d_it_decl ∧ (_istep = 2))
    d_stk_dup3 ∈ Bool = (d_processing ∧ d_it_dup3)
    d_stk_swap ∈ Bool = (d_processing ∧ d_it_swap)
    d_stk_rot3 ∈ Bool = (d_processing ∧ d_it_rot3)

    hstk = (is_first_tick ? C2HNil
        : (d_enter_claim ∨ d_enter_claimp) ? C2HNil
        : cw_fire ? cw_pop_stk
        : gj_fire ? d_h_t1
        : pz_act ? pz_pop
        : d_ilb_push ? C2HCons(d_ilb_h, d_hstk_in)
        : d_push_ident ? C2HCons(d_lk, d_hstk_in)
        : d_push_h ? C2HCons(d_ph_h, d_hstk_in)
        : d_push_decl ? C2HCons(d_tmp_in, d_hstk_in)
        : d_stk_dup3 ? C2HCons(d_h_3rd, d_hstk_in)
        : d_stk_swap ? C2HCons(d_h_2nd, C2HCons(d_h_top, d_h_t2))
        : d_stk_rot3 ? C2HCons(d_h_2nd, C2HCons(d_h_3rd,
            C2HCons(d_h_top, d_h_t3)))
        : d_pops = 6 ? d_h_t6
        : d_pops = 5 ? d_h_t5
        : d_pops = 4 ? d_h_t4
        : d_pops = 3 ? d_h_t3
        : d_pops = 2 ? d_h_t2
        : d_pops = 1 ? d_h_t1
        : d_hstk_in)

    witems = (is_first_tick ? C2INil
        : (d_enter_claim ∨ d_enter_claimp) ? C2INil
        : d_classify ? d_new_items
        : p_done ? d_pratt_items
        : el_b2 ? el_lc_items
        : el_b2e ? el_lce_items
        : el_close ? (_ch_on ? el_bfold : C2ICons(C2LenEq(_el_cnt), C2INil))
        : ch_fire ? ch_fold_items
        : mp_fire ? mp_items
        : ms_close ? ms_items
        : sl_close ? sl_close_items
        : stl_elem ? stl_elem_items
        : stl_close ? stl_close_items
        : (cw_fire ∧ _cw_ty) ? tyc_items
        : (cw_bjump ∧ _cw_ty ∧ (_ts_k ≥ 0)) ? tsb_items
        : pg_ty_tick ? c_mem_items
        : pg_drain ? pg_drain_items
        : (pt_close ∧ ptc_tm) ? ptc_recv_items
        : pt_tup_b ? ptt_items
        : fx_more ? fx_items
        : fx_fin ? fx_fin_items
        : rbx_more ? rbx_items
        : rbx_fin ? C2INil
        : ¬d_processing ? _witems
        : d_it_proc ∧ d_pe_is_bin ∧ d_pe_op_ne ? C2ICons(C2Process(d_pe_l), C2ICons(C2Process(d_pe_r), C2ICons(C2Op(OpEq), C2ICons(C2Not, d_wtail))))
        : d_it_proc ∧ d_pe_is_bin ? C2ICons(C2Process(d_pe_l), C2ICons(C2Process(d_pe_r), C2ICons(C2Op(d_pe_op), d_wtail)))
        : d_it_proc ∧ d_pe_is_tern ? C2ICons(C2Process(d_pe_c), C2ICons(C2Process(d_pe_t), C2ICons(C2Process(d_pe_e), C2ICons(C2Ite, d_wtail))))
        : d_it_proc ∧ d_pe_is_not ? C2ICons(C2Process(d_pe_ni), C2ICons(C2Not, d_wtail))
        : d_it_proc ∧ d_pe_is_m ? d_m_items
        : d_it_proc ∧ d_vb_hit ? d_vb_items
        : d_it_proc ∧ d_vb_dot ? d_vbd_items
        : d_rb_hit ? d_rb_items
        : d_rbc_hit ? d_rbc_items
        : d_it_proc ∧ d_bind_hit ? d_bind_items
        : d_it_proc ∧ d_pe_is_c1 ? d_c1_items
        : d_it_proc ∧ d_pe_is_c2 ? d_c2_items
        : d_it_proc ∧ d_pe_is_c3 ? d_c3_items
        : d_it_proc ? d_wtail
        : d_it_recv ? d_rv_items
        : d_it_recd ? d_rdc_items
        : d_it_op ? (d_op_arr ? (_istep = 2 ? d_wtail : _witems) : d_wtail)
        : d_it_decl ? (_istep = 2 ? d_wtail : _witems)
        : d_it_app ? (_istep = d_app_n ? d_wtail : _witems)
        : d_it_seleq ? (_istep = 2 ? d_wtail : _witems)
        : d_it_seleqh ? (_istep = 1 ? d_wtail : _witems)
        : d_it_leneq ? (_istep = 1 ? d_wtail : _witems)
        : d_it_assert ? ((d_guard_on ∧ (_istep = 0)) ? _witems : d_wtail)
        : d_wtail)

    d_multi_cont ∈ Bool = (d_processing ∧
        ((d_it_op ∧ d_op_arr ∧ (_istep < 2))
        ∨ (d_it_assert ∧ d_guard_on ∧ (_istep < 1))
        ∨ (d_it_decl ∧ (_istep < 2))
        ∨ (d_it_app ∧ (_istep < d_app_n))
        ∨ (d_it_seleq ∧ (_istep < 2))
        ∨ (d_it_seleqh ∧ (_istep < 1))
        ∨ (d_it_leneq ∧ (_istep < 1))))
    istep = (is_first_tick ? 0
        : d_multi_cont ? _istep + 1
        : 0)

    pend = (is_first_tick ? 0
        : ¬d_processing ? 0
        : d_it_proc ? ((d_pe_is_int ∨ d_pe_is_str ∨ d_lk_read) ? 1 : 0)
        : d_it_op ? (d_op_arr ? (_istep = 2 ? 1 : 0) : 1)
        : d_it_ite ? 1
        : d_it_not ? 1
        : d_it_decl ? (_istep = 2 ? 0 : 2)
        : d_it_nat ? 1
        : d_it_pineq ? 1
        : d_it_assert ? ((d_guard_on ∧ (_istep = 0)) ? 2 : 0)
        : d_it_app ? (_istep = d_app_n ? 1 : 0)
        : d_it_seleq ? ((_istep = 0 ∨ _istep = 1) ? 2 : 0)
        : d_it_seleqh ? (_istep = 0 ? 2 : 1)
        : d_it_leneq ? (_istep = 0 ? 2 : 0)
        : d_it_leneqh ? 1
        : d_it_strop ? 1
        : d_it_selh ? 1
        : d_it_real ? 1
        : d_it_mes ? 1
        : d_it_sadd ? 1
        : 0)

    -- ── token consumption (cursor arithmetic + window tail) ───────
    -- Exactly one consumer acts per tick (mode bools are mutually
    -- exclusive and tok_ready-gated); fetch ticks consume nothing.
    dcons ∈ Int = (d_enter_claim ? 2
        : d_enter_claimp ? 3
        : d_enter_edecl ? 3
        : d_enter_skip ? 1
        : (d_in_skip ∧ (¬d_skip_stop)) ? 1
        : ec_bail ? 1
        : ec_take ? ec_cons
        : d_enter_el ? 8
        : el_lc_enter ? 6
        : el_b2 ? 7
        : el_b2e ? 3
        : (el_comma ∨ el_close) ? 1
        : el_open ? 1
        : el_nest ? 1
        : (el_colon ∨ el_rp ∨ el_st2_bad) ? 1
        : d_enter_set ? 3
        : d_enter_match ? 5
        : mp_s_lr ? 4
        : (mp_s_id ∨ mp_s_bad) ? 1
        : (mp_overflow ∨ mp_wc_over) ? 1
        : ms_elem ? ((ww_t1 matches Comma) ? 2 : 1)
        : (ms_close ∨ ms_bad) ? 1
        : d_enter_sl ? 3
        : (sl_close ∨ sl_comma) ? 1
        : d_enter_mn ? 2
        : pg_take2 ? 2
        : pg_ty_tick ? pg_ty_cons
        : pg_bail ? 1
        : c_comp_call ? 2
        : c_comp_bare ? 1
        : c_comp_dd ? 3
        : c_ty_call ? 4
        : c_ty_bare ? 3
        : d_enter_si ? 3
        : d_enter_qr ? 8
        : d_enter_qset ? 8
        : d_enter_stl ? 3
        : d_enter_smem ? 3
        : d_setmem ? 6
        : (stl_elem ∨ stl_comma ∨ stl_close ∨ stl_bad) ? 1
        : q_bail ? 1
        : pcl_stmt ? 2
        : pcl_m1 ? 4
        : pcl_m2 ? 6
        : pcl_tup ? 1
        : pt_comma ? 1
        : pt_tup_b ? 5
        : (pt_close ∨ pt_bail) ? (ptc_tm ? 5 : (ptc_t ∨ (pt_bail ∧ (ww_t1 matches OpIn))) ? 3 : 1)
        : (cw_comma ∨ cw_fire ∨ cw_bail) ? 1
        : (ips_open ∨ ips_skp) ? 1
        : d_enter_pratt ? d_pratt_cons0
        : d_mem_line ? d_mem_cons
        : p_done ? d_done_cons
        : (d_in_pratt ∧ (pr_scons ≥ 1)) ? pr_scons
        : 0)
    -- F2: a composition jump / frame pop OVERRIDES the cursor and
    -- invalidates the window (wend = tcur ⇒ w_rem 0 ⇒ refetch).
    tcur = (is_first_tick ? 0
        : il_jump ? il_tgt_v
        : il_pop ? fr_ret
        : _tcur + dcons)
    wend = (is_first_tick ? 0
        : il_jump ? il_tgt_v
        : il_pop ? fr_ret
        : _fmode = 2 ? _tcur + 8 : _wend)
    w_after ∈ TokenList = (dcons = 0 ? _wtoks
        : dcons = 1 ? ww_l1
        : dcons = 2 ? ww_l2
        : dcons = 3 ? ww_l3
        : dcons = 4 ? ww_l4
        : dcons = 5 ? ww_l5
        : dcons = 6 ? ww_l6
        : dcons = 7 ? ww_l7
        : TLNil)
    wtoks = (is_first_tick ? TLNil
        : (il_jump ∨ il_pop) ? TLNil
        : _fmode = 2 ? f_built
        : w_after)

    -- set-membership lines (`x ∈ {…}`) constrain an EXISTING var —
    -- no decl, no state field, no carry.
    -- E1: a `_`-prefixed membership (`_count ∈ Int`, the corpus's
    -- explicit carry declaration — the oracle REQUIRES it, probed:
    -- an unbound `_count` mention is a dropped constraint) declares
    -- a build-context const + symtab entry like any membership but
    -- is NOT a state field and gets NO `__name` carry of its own.
    c_field_add ∈ Bool = (d_classify ∧ (¬d_line_end) ∧ c_is_mem
        ∧ (¬c_eff_line) ∧ (¬c_set_line) ∧ (¬c_is_carry)
        ∧ (¬c_nodecl) ∧ (¬c_strin_line) ∧ (¬c_ty_line)
        ∧ (¬c_smem_line)
        ∧ (¬c_in_ty))
    -- E1: the first time a `_name` const is MENTIONED in an
    -- expression (d_lk_read of a carry name), the solver
    -- serialization will carry its declare-fun — so the textual
    -- carry line the base field appended must be spliced out of
    -- cdstr or the unit gets a duplicate declare. The search key
    -- ends at " () " so `_count` can't prefix-match `_count2`;
    -- later mentions find nothing (cs_pos = -1) and no-op.
    d_carry_strip ∈ Bool = (d_lk_read ∧ (substr(d_lkname, 0, 1) = "_"))
    cs_pos ∈ Int = index_of(_cdstr, "(declare-fun " ++ d_lkname ++ " () ", 0)
    cs_nl ∈ Int = index_of(_cdstr, "\n", cs_pos)
    cs_cut ∈ String = (substr(_cdstr, 0, cs_pos)
        ++ substr(_cdstr, cs_nl + 1, #_cdstr - (cs_nl + 1)))
    fstr = (is_first_tick ? ""
        : (pi_decl ∧ (¬c_in_ty)) ? (_fstr = "" ? pi_field : _fstr ++ " " ++ pi_field)
        : c_field_add ? (_fstr = "" ? c_field : _fstr ++ " " ++ c_field)
        : pg_ty_tick ? (_fstr = "" ? c_field : _fstr ++ " " ++ c_field)
        : pg_drain ? (_fstr = "" ? pg_field : _fstr ++ " " ++ pg_field)
        : _fstr)
    cdstr = (is_first_tick ? ""
        : (pi_decl ∧ (¬c_in_ty)) ? _cdstr ++ pi_cdecl
        : c_field_add ? _cdstr ++ c_cdecl
        : pg_ty_tick ? _cdstr ++ c_cdecl
        : pg_drain ? _cdstr ++ pg_cdecl
        : (d_carry_strip ∧ (cs_pos ≥ 0)) ? cs_cut
        : _cdstr)

    pmode = (is_first_tick ? 0
        : entering_parse ? 0
        : d_enter_claim ? 2
        : d_enter_claimp ? 9
        : d_enter_edecl ? 4
        : d_enter_skip ? 1
        : rd_go ? 13
        : rd_fin ? 0
        : d_skip_stop ? 0
        : d_claim_end ? 0
        : (c_comp_line ∨ c_ty_line) ? 10
        : gc_hit ? 10
        : gj_fire ? 2
        : (cw_bjump ∨ cw_fire ∨ cw_bail) ? 2
        : d_enter_qr ? 11
        : q_bail ? 2
        : pcl_line ? 12
        : pt_bail ? 2
        : ptj_fire ? 2
        : d_enter_el ? 5
        : d_enter_set ? 7
        : d_enter_match ? 6
        : d_enter_sl ? 8
        : d_enter_stl ? 14
        : (stl_close ∨ stl_bad) ? 2
        : d_enter_mn ? 9
        : pg_bail ? 2
        : pg_ty_tick ? (pg_have_pend ? 9 : pg_ty_exit_mode)
        : (pg_drain ∧ pg_last) ? pg_group_done_mode
        : d_enter_pratt ? 3
        : p_done ? (_pk_kind = 3 ? 5
            : _pk_kind = 4 ? ((pr_bad ∨ mq_wc) ? 2 : 6)
            : _pk_kind = 6 ? (pr_bad ? 2 : 5)
            : _pk_kind = 7 ? (pr_bad ? 2 : 8)
            : _pk_kind = 8 ? (pr_bad ? 2 : 10)
            : _pk_kind = 10 ? (pr_bad ? 2 : 12)
            : 2)
        : (ec_active ∧ ec_payload ∧ (¬ec_p_ok)) ? 1
        : (ec_active ∧ (¬ec_v_ok)) ? 0
        : ed_done_user ? 0
        : ch_fire ? 2
        : el_close ? (_ch_on ? 5 : 2)
        : (el_bad ∨ el_b2_bad ∨ el_st2_bad) ? 2
        : (mp_fire ∨ mp_bail) ? 2
        : (ms_close ∨ ms_bad) ? 2
        : sl_close ? 2
        : _pmode)

    phase = (is_first_tick ? 0
        : (_phase = 0 ? (lex_done ? 2 : 0)
        : (_phase = 2 ? (d_all_done ? 3 : 2)
        : 3)))

    -- ── per-item build effects (pass-claim dispatch) ──────────────
    d_eff_mkint ∈ Effect
    d_atom_ok ∈ Bool
    AtomBuildZ3(ctx_h ↦ z_ctx, int_sort_h ↦ z_isort, sym_h ↦ 0,
        e ↦ d_pe, eff ↦ d_eff_mkint, ok ↦ d_atom_ok)
    d_eff_cmp ∈ Effect
    d_cmp_ok ∈ Bool
    d_cmp_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op, l_h ↦ d_h_2nd, r_h ↦ d_h_top,
        eff ↦ d_eff_cmp, ok ↦ d_cmp_ok, needs_not ↦ d_cmp_nn)
    d_eff_arith ∈ Effect
    d_arith_ok ∈ Bool
    ArithBinopBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op,
        l_h ↦ d_h_2nd, r_h ↦ d_h_top, args_arr_ptr ↦ z_arena + 200,
        eff ↦ d_eff_arith, ok ↦ d_arith_ok)
    d_eff_nary ∈ Effect
    d_nary_ok ∈ Bool
    BoolNaryBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op, num_args ↦ 2,
        args_arr_ptr ↦ z_arena + 200, eff ↦ d_eff_nary, ok ↦ d_nary_ok)
    -- `++` → (str.++ l r) via the same 2-slot args buffer
    d_eff_concat ∈ Effect
    BuildZ3MkSeqConcat(ctx_h ↦ z_ctx, num_args ↦ 2,
        args_arr_ptr ↦ z_arena + 200, eff ↦ d_eff_concat)
    d_eff_ite ∈ Effect
    TernaryBuildZ3(ctx_h ↦ z_ctx, cond_h ↦ d_h_3rd, then_h ↦ d_h_2nd,
        else_h ↦ d_h_top, eff ↦ d_eff_ite)
    d_eff_not ∈ Effect
    BoolNotBuildZ3(ctx_h ↦ z_ctx, x_h ↦ d_h_top, eff ↦ d_eff_not)
    d_eff_wl0 ∈ Effect
    BuildMemWriteLong(addr ↦ z_arena + 200, value ↦ d_h_2nd, eff ↦ d_eff_wl0)
    d_eff_wl1 ∈ Effect
    BuildMemWriteLong(addr ↦ z_arena + 208, value ↦ d_h_top, eff ↦ d_eff_wl1)
    d_eff_mkstring ∈ Effect
    BuildZ3MkString(ctx_h ↦ z_ctx, s ↦ d_pe_str, eff ↦ d_eff_mkstring)
    -- C2StrOp (B3): one tick — pops d_so_n operand handles, builds
    -- the str.* node. Operand mapping per arity (post-order: the
    -- stack top is the LAST arg): 1 → (top) · 2 → (2nd, top) ·
    -- 3 → (3rd, 2nd, top). "len" goes to Z3_mk_seq_length (str.len
    -- on a string-sorted operand); everything else through
    -- translate2_seq.ev's StrOpBuildZ3 name table.
    d_so_a ∈ Int = (d_so_n = 3 ? d_h_3rd : d_so_n = 2 ? d_h_2nd : d_h_top)
    d_so_b ∈ Int = (d_so_n = 3 ? d_h_2nd : d_so_n = 2 ? d_h_top : 0)
    d_so_c ∈ Int = (d_so_n = 3 ? d_h_top : 0)
    d_eff_slen ∈ Effect
    BuildZ3MkSeqLength(ctx_h ↦ z_ctx, s_h ↦ d_h_top, eff ↦ d_eff_slen)
    d_eff_strop ∈ Effect
    d_strop_ok ∈ Bool
    StrOpBuildZ3(ctx_h ↦ z_ctx, op_name ↦ d_so_nm, a_h ↦ d_so_a,
        b_h ↦ d_so_b, c_h ↦ d_so_c, eff ↦ d_eff_strop, ok ↦ d_strop_ok)
    d_eff_sym ∈ Effect
    BuildZ3MkStringSymbol(ctx_h ↦ z_ctx, name ↦ d_dc_name, eff ↦ d_eff_sym)
    d_eff_const ∈ Effect
    BuildZ3MkConst(ctx_h ↦ z_ctx, sym_h ↦ d_tmp_in,
        sort_h ↦ (d_dc_sc = 1 ? z_bsort
            : d_dc_sc = 2 ? ue_sort
            : d_dc_sc = 3 ? z_ssort
            : d_dc_sc = 4 ? z_ressort
            : d_dc_sc = 5 ? z_iarr
            : d_dc_sc = 6 ? z_rsort
            : d_dc_sc = 10 ? rt_asort0
            : d_dc_sc = 11 ? rt_asort1
            : d_dc_sc = 12 ? rt_asort2
            : d_dc_sc = 20 ? rt_ssort0
            : d_dc_sc = 21 ? rt_ssort1
            : d_dc_sc = 22 ? rt_ssort2
            : z_isort), eff ↦ d_eff_const)
    -- decl istep 2: park the const handle (in tmp) at st_base[st_cnt]
    d_eff_stwr ∈ Effect
    BuildMemWriteLong(addr ↦ st_base + (8 * _st_cnt), value ↦ d_tmp_in,
        eff ↦ d_eff_stwr)
    -- oracle gap: a ctor literal in a slot binding breaks the callee's
    -- `matches` translation — pass pinned body vars instead.
    d_op_geq ∈ Op = OpGeq
    d_op_eq ∈ Op = OpEq
    d_op_impl ∈ Op = OpImpl
    -- G1: guarded assert — (=> il_guard top), then assert the tmp.
    d_eff_gimpl ∈ Effect
    d_gimp_ok ∈ Bool
    d_gimp_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op_impl, l_h ↦ _il_guard,
        r_h ↦ d_h_top, eff ↦ d_eff_gimpl, ok ↦ d_gimp_ok,
        needs_not ↦ d_gimp_nn)
    d_eff_natge ∈ Effect
    d_nat_ok ∈ Bool
    d_nat_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op_geq, l_h ↦ d_h_top, r_h ↦ z_zero,
        eff ↦ d_eff_natge, ok ↦ d_nat_ok, needs_not ↦ d_nat_nn)
    d_eff_pineq ∈ Effect
    d_pin_ok2 ∈ Bool
    d_pin_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op_eq, l_h ↦ d_h_2nd, r_h ↦ d_h_top,
        eff ↦ d_eff_pineq, ok ↦ d_pin_ok2, needs_not ↦ d_pin_nn)
    d_eff_assert ∈ Effect
    BuildZ3SolverAssert(ctx_h ↦ z_ctx, solver_h ↦ z_sol, ast_h ↦ d_h_top,
        eff ↦ d_eff_assert)
    d_eff_asserttmp ∈ Effect
    BuildZ3SolverAssert(ctx_h ↦ z_ctx, solver_h ↦ z_sol, ast_h ↦ d_tmp_in,
        eff ↦ d_eff_asserttmp)
    -- C2App: istep k < n writes args[n-1-k] from stack depth k
    -- (top/2nd/3rd — post-order means the TOP is the LAST arg);
    -- istep n applies the harvested decl over the args array.
    d_app_arg ∈ Int = (_istep = 0 ? d_h_top
        : _istep = 1 ? d_h_2nd
        : _istep = 2 ? d_h_3rd
        : _istep = 3 ? d_h_4th
        : _istep = 4 ? d_h_5th
        : d_h_6th)
    d_eff_caw ∈ Effect
    CtorArgWriteStep(args_p ↦ z_arena + 224, idx ↦ d_app_n - 1 - _istep,
        arg_h ↦ d_app_arg, eff ↦ d_eff_caw)
    d_eff_app ∈ Effect
    CtorAppStep(ctx_h ↦ z_ctx, ctor_decl_h ↦ d_app_d, n_args ↦ d_app_n,
        args_p ↦ z_arena + 224, eff ↦ d_eff_app)
    d_sel_idx_h ∈ Int = (d_sel_i = 0 ? z_zero
        : d_sel_i = 1 ? z_one
        : d_sel_i = 2 ? z_two
        : z_three)
    d_eff_sel ∈ Effect
    BuildZ3MkSelect(ctx_h ↦ z_ctx, arr_h ↦ z_effs, idx_h ↦ d_sel_idx_h,
        eff ↦ d_eff_sel)
    -- C2SelH (D3): generic select — pops (arr, idx) off the handle
    -- stack, pushes (select arr idx).
    d_eff_selh ∈ Effect
    BuildZ3MkSelect(ctx_h ↦ z_ctx, arr_h ↦ d_h_2nd, idx_h ↦ d_h_top,
        eff ↦ d_eff_selh)
    -- G2: Real literal — mk_numeral of the rational "scaled/10^d".
    d_re_den ∈ String = (d_re_d = 1 ? "10"
        : d_re_d = 2 ? "100"
        : d_re_d = 3 ? "1000"
        : d_re_d = 4 ? "10000"
        : d_re_d = 5 ? "100000"
        : d_re_d = 6 ? "1000000"
        : "1")
    d_re_str ∈ String = str_from_int(d_re_s) ++ "/" ++ d_re_den
    d_eff_real ∈ Effect
    BuildZ3MkNumeral(ctx_h ↦ z_ctx, num ↦ d_re_str, sort_h ↦ z_rsort,
        eff ↦ d_eff_real)
    -- G2: set builders — empty set of the registry elem sort; set_add
    -- pops (set, elem) and pushes the grown set.
    d_mes_sort ∈ Int = (d_mes_k = 0 ? rt_sort0
        : d_mes_k = 1 ? rt_sort1
        : rt_sort2)
    d_eff_mes ∈ Effect = LibCall("libz3", "Z3_mk_empty_set",
        ⟨ArgInt(z_ctx), ArgInt(d_mes_sort)⟩)
    d_eff_sadd ∈ Effect = LibCall("libz3", "Z3_mk_set_add",
        ⟨ArgInt(z_ctx), ArgInt(d_h_2nd), ArgInt(d_h_top)⟩)
    d_eff_seleq ∈ Effect
    d_seleq_ok ∈ Bool
    d_seleq_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op_eq, l_h ↦ d_tmp_in, r_h ↦ d_h_top,
        eff ↦ d_eff_seleq, ok ↦ d_seleq_ok, needs_not ↦ d_seleq_nn)
    d_len_n_h ∈ Int = (d_len_n = 1 ? z_one
        : d_len_n = 2 ? z_two
        : d_len_n = 3 ? z_three
        : d_len_n = 4 ? z_four
        : z_zero)
    d_eff_leneq ∈ Effect
    d_leneq_ok ∈ Bool
    d_leneq_nn ∈ Bool
    BoolCmpBuildZ3(ctx_h ↦ z_ctx, op ↦ d_op_eq, l_h ↦ z_elen, r_h ↦ d_len_n_h,
        eff ↦ d_eff_leneq, ok ↦ d_leneq_ok, needs_not ↦ d_leneq_nn)
    d_eff_filler ∈ Effect = LibCall("libc", "getpid", ⟨⟩)

    d_eff_lib ∈ Effect = (d_it_proc ∧ d_pe_is_int ? d_eff_mkint
        : d_it_proc ∧ d_pe_is_str ? d_eff_mkstring
        : d_lk_read ? d_eff_stread
        : d_it_op ∧ d_op_arr ∧ (_istep = 0) ? d_eff_wl0
        : d_it_op ∧ d_op_arr ∧ (_istep = 1) ? d_eff_wl1
        : d_it_op ∧ d_op_arr ? (d_op_bool_arr ? d_eff_nary
            : d_op_cc ? d_eff_concat
            : d_eff_arith)
        : d_it_op ∧ d_op_is_div ? d_eff_arith
        : d_it_op ? d_eff_cmp
        : d_it_ite ? d_eff_ite
        : d_it_not ? d_eff_not
        : d_it_decl ? (_istep = 0 ? d_eff_sym
            : _istep = 1 ? d_eff_const
            : d_eff_stwr)
        : d_it_nat ? d_eff_natge
        : d_it_pineq ? d_eff_pineq
        : d_it_assert ? (d_guard_on
            ? (_istep = 0 ? d_eff_gimpl : d_eff_asserttmp)
            : d_eff_assert)
        : d_it_app ? (_istep < d_app_n ? d_eff_caw : d_eff_app)
        : d_it_seleq ? (_istep = 0 ? d_eff_sel
            : _istep = 1 ? d_eff_seleq
            : d_eff_asserttmp)
        : d_it_seleqh ? (_istep = 0 ? d_eff_sel : d_eff_seleq)
        : d_it_leneq ? (_istep = 0 ? d_eff_leneq : d_eff_asserttmp)
        : d_it_leneqh ? d_eff_leneq
        : d_it_strop ? (d_so_nm = "len" ? d_eff_slen : d_eff_strop)
        : d_it_selh ? d_eff_selh
        : d_it_real ? d_eff_real
        : d_it_mes ? d_eff_mes
        : d_it_sadd ? d_eff_sadd
        : d_eff_filler)

    -- ── EMIT ──────────────────────────────────────────────────────
    estep  ∈ Int
    estep = (is_first_tick ? 0 - 1
        : _estep ≥ 0 ? (_estep < 5 ? _estep + 1 : _estep)
        : d_all_done ? 0
        : 0 - 1)

    sptr  ∈ Int
    sptr = (is_first_tick ? 0 : estep = 1 ? d_cap_int : _sptr)
    rendered  ∈ String
    rendered = (is_first_tick ? "" : estep = 2 ? d_cap_str : _rendered)

    e_s2s ∈ Effect
    BuildZ3SolverToString(ctx_h ↦ z_ctx, solver_h ↦ z_sol, eff ↦ e_s2s)
    e_copy ∈ Effect
    BuildCstrCopy(addr ↦ sptr, eff ↦ e_copy)

    d_manifest ∈ String = (";; manifest: state-fields = " ++ _fstr ++ "\n"
        ++ ";; manifest: effects-name = effects\n"
        ++ ";; manifest: effect-enum-name = Effect\n"
        ++ ";; manifest: result-enum-name = Result\n"
        ++ ";; manifest: max-effects = 16")
    -- D3: the last_results__len floor assert lives in the BUILD
    -- context now, so its declare + assert always come out in the
    -- rendered serialization (textual lines dropped). The Result
    -- datatype + last_results declares stay textual UNLESS a user
    -- constraint mentioned last_results (then the serialization
    -- carries them and the textual copies would be duplicate-sort
    -- errors — sample.ev's `_saw_result` dance). Same for the
    -- is_first_tick declare keyed off saw_ift.
    d_prelude ∈ String = ((_saw_lr ? ""
            : "(declare-datatypes ((Result 0)) (((NoResult) (IntResult (IntResult__f0 Int)) (StringResult (StringResult__f0 String)) (RealResult (RealResult__f0 Real)) (EofResult) (ErrorResult (ErrorResult__f0 String)))))\n"
              ++ "(declare-fun last_results () (Array Int Result))\n")
        ++ (_saw_ift ? "" : "(declare-fun is_first_tick () Bool)\n"))
    -- carry declares go AFTER the solver body: an enum-typed carry
    -- (`_c () Color`) needs its sort, and the declare-datatypes live
    -- in the rendered serialization.
    d_unit ∈ String = d_manifest ++ "\n\n" ++ d_prelude ++ rendered ++ cdstr

    e_puts ∈ Effect
    BuildPrintln(s ↦ d_unit, eff ↦ e_puts)
    e_free_tbuf ∈ Effect = LibCall("libc", "free", ⟨ArgInt(tbase)⟩)
    e_free_sbuf ∈ Effect = LibCall("libc", "free", ⟨ArgInt(st_base)⟩)
    e_free_cibuf ∈ Effect = LibCall("libc", "free", ⟨ArgInt(ci_base)⟩)

    -- ── effects schedule ──────────────────────────────────────────
    effects ∈ Seq(Effect) = (is_first_tick ? ⟨ReadLine, ReadLine⟩
        : (¬_got_path) ? ⟨ReadFile(src_path)⟩
        : zstep = 0 ? ⟨ze_cfg⟩
        : zstep = 1 ? ⟨ze_ctx⟩
        : zstep = 2 ? ⟨ze_sol⟩
        : zstep = 3 ? ⟨ze_sinc⟩
        : zstep = 4 ? ⟨ze_isort⟩
        : zstep = 5 ? ⟨ze_bsort⟩
        : zstep = 6 ? ⟨ze_ssort⟩
        : zstep = 7 ? ⟨ze_rsort⟩
        : zstep = 8 ? ⟨ze_arena⟩
        : ed_running ? (ed_w5
            ? (ed_n = 1 ? ⟨edw_fn0, edw_fs0, edw_sr01⟩
              : ed_n = 2 ? ⟨edw_fn0, edw_fn1, edw_fs0, edw_fs1, edw_sr01⟩
              : ⟨edw_fn0, edw_fn1, edw_fn2, edw_fs0, edw_fs1, edw_fs2,
                 edw_sr01, edw_sr2⟩)
            : ed_w2 ? ⟨edw_nm, edw_cl⟩
            : ed_w3u ? ⟨ede_app0, ede_rdtest⟩
            : ⟨ed_eff1⟩)
        : zstep = 10 ? ⟨ze_arrsort⟩
        : zstep = 11 ? ⟨ze_sym_effs⟩
        : zstep = 12 ? ⟨ze_effs⟩
        : zstep = 13 ? ⟨ze_sym_elen⟩
        : zstep = 14 ? ⟨ze_elen⟩
        : zstep = 15 ? ⟨ze_zero⟩
        : zstep = 16 ? ⟨ze_one⟩
        : zstep = 17 ? ⟨ze_two⟩
        : zstep = 18 ? ⟨ze_true⟩
        : zstep = 19 ? ⟨ze_false⟩
        : zstep = 20 ? ⟨ze_tbuf⟩
        : zstep = 21 ? ⟨ze_sbuf⟩
        : zstep = 22 ? ⟨ze_lrarr⟩
        : zstep = 23 ? ⟨ze_sym_lr⟩
        : zstep = 24 ? ⟨ze_lastres⟩
        : zstep = 25 ? ⟨ze_sym_lrl⟩
        : zstep = 26 ? ⟨ze_lrlen⟩
        : zstep = 27 ? ⟨ze_sym_ift⟩
        : zstep = 28 ? ⟨ze_ift⟩
        : zstep = 29 ? ⟨ze_lrge⟩
        : zstep = 30 ? ⟨ze_lrassert⟩
        : zstep = 31 ? ⟨ze_seed0, ze_seed1⟩
        : zstep = 32 ? ⟨ze_three⟩
        : zstep = 33 ? ⟨ze_four⟩
        : zstep = 34 ? ⟨ze_iarr⟩
        : zstep = 35 ? ⟨ze_ege⟩
        : zstep = 36 ? ⟨ze_eassert⟩
        : zstep = 37 ? ⟨ze_cibuf⟩
        : entering_parse ? (lx_have_pend ? ⟨w_pend, w_eof⟩ : ⟨w_eof⟩)
        : estep = 0 ? ⟨e_s2s⟩
        : estep = 1 ? ⟨e_copy⟩
        : estep ≥ 2 ? ⟨e_free_tbuf, e_free_sbuf, e_free_cibuf, e_puts, Exit(0)⟩
        : fetch_go ? ⟨rd_t0, rd_q0, rd_t1, rd_q1, rd_t2, rd_q2,
            rd_t3, rd_q3, rd_t4, rd_q4, rd_t5, rd_q5, rd_t6, rd_q6,
            rd_t7, rd_q7⟩
        : _fmode = 1 ? ⟨cp0, cp1, cp2, cp3, cp4, cp5, cp6, cp7⟩
        : ci_add ? ⟨e_ciw⟩
        : il_rdcur ? ⟨e_cir⟩
        : gc_hit ? ⟨e_gcr⟩
        : pt_close ? ⟨e_pcr⟩
        : rd_act_now ? (rd_eff_st = 2
            ? ⟨rde_wfn0, rde_wfn1, rde_wfn2, rde_wfn3, rde_wfn4,
               rde_wfn5, rde_wfs0, rde_wfs1, rde_wfs2, rde_wfs3,
               rde_wfs4, rde_wfs5⟩
            : ⟨rd_eff1⟩)
        : d_processing ? ⟨d_eff_lib⟩
        : (float_fin ∧ float_op) ? ⟨w_ftag, w_fp0, w_fop⟩
        : float_fin ? ⟨w_ftag, w_fp0⟩
        : (k_kind = 1 ∧ lx_have_pend) ? ⟨w_pend, w_tag0e⟩
        : k_kind = 1 ? ⟨w_tag0e⟩
        : k_kind = 2 ? ⟨w_tag0e, w_p0e⟩
        : k_kind = 3 ? ⟨e_dup, w_tag0e⟩
        : k_kind = 4 ? ⟨w_tag0e, w_tag1e⟩
        : k_kind = 5 ? ⟨e_dup, w_tag0e, w_tag1e⟩
        : k_kind = 6 ? ⟨w_tag0e, w_p0e, w_tag1e⟩
        : lx_have_pend ? ⟨w_pend⟩
        : ⟨d_eff_filler⟩)
