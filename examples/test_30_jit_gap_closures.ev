-- 30_jit_gap_closures — a program that would NOT have JIT-compiled
-- before session-T, now compiling end-to-end (comp=N/N) and beating Z3.
--
-- Session T (commit 226b502) closed three real Cranelift JIT codegen
-- gaps. Each one used to force its whole component to fall back to a
-- full Z3 solve; now each lowers to native code. This demo wires all
-- three — plus the Seq-bodied guarded step the same session fixed —
-- into one FSM so you can watch them JIT together.
--
-- ─────────────────────────────────────────────────────────────────
-- WHICH GAP EACH SECTION EXERCISES
-- ─────────────────────────────────────────────────────────────────
--   GAP 1  integer division `/`  → `world.half = _world.n / 2`, and the
--          deep div/mod chain (`d01..d40`) — the benchmark workload.
--   GAP 1  integer modulo `mod`  → `world.quad = mod(_world.n, 4)`, and
--          the many `mod(…)` steps inside the chain.
--   GAP 3  string concat `++`    → `world.trail = "." ++ _world.trail`
--          (a growing progress bar; also in every Println payload).
--   GAP 2  guarded Seq(Effect)   → `effects = match state ⇒ ⟨…⟩`
--          (per-tick effect list; arm length varies by branch).
--
-- Before session T the Cranelift backend bailed each of these:
--   * `emit_write_value`'s arithmetic arm listed only ADD/SUB/MUL/UMINUS,
--     so a top-level `(div …)` / `(mod …)` Scalar write hit `_ => None`.
--   * `emit_write_value` had no `SEQ_CONCAT` arm, so `"." ++ x` bailed.
--   * `compile_program` refused ANY program containing a `Guarded` step,
--     the shape `match state ⇒ ⟨…⟩` lowers to — so the effects component
--     of essentially every FSM never reached codegen.
-- See docs/jit-codegen-gaps.md for the full audit (gaps #1, #2, #3).
--
-- ─────────────────────────────────────────────────────────────────
-- comp=N/N — every component compiles
-- ─────────────────────────────────────────────────────────────────
-- The `gaps` FSM decomposes into SEVEN independent components — the five
-- `world.*` writes (incl. the deep chain → `digest`), `state_next`, and
-- `effects`. Run with the stats on:
--
--   EVIDENT_FUNCTIONIZE_STATS=1 \
--     ./runtime/target/release/evident effect-run \
--     examples/test_30_jit_gap_closures.ev 2>&1 | grep -E "comp=|fn✓"
--
--   gaps   z3=[… stp=48 …] comp=7/7 z3-fz✓ fn✓
--
-- comp=7/7 is the point: ALL seven components are native code — the div,
-- the mod, the string concat, and the guarded effect list included.
-- Before session T at least four of these components bailed to Z3: the
-- bare `div`/`mod` writes (`half`, `quad`), the `++` concat (`trail`),
-- and the guarded `effects`. `stp=48` confirms the 40-step chain is
-- genuinely absorbed into the compiled program — computed natively, not
-- pruned. (The chain's steps wrap div/mod as *operands* of ITE/+/*, the
-- shape that already compiled; it's the bare top-level div/mod write —
-- `half`/`quad` — that gap #1 unblocked.)
--
-- The FSM reads previous-tick state via `_world.X` (the seeded initial
-- world is supplied as a `given` even at tick 0), so there is no tick-0
-- bootstrap bail — one analysis (an=1) compiles, then every later tick
-- is a plan-cache hit. Contrast test_29, stuck at comp=3/4 because its
-- `_tick` LOCAL prev-value is absent at tick 0.
--
-- ─────────────────────────────────────────────────────────────────
-- BENCHMARK  (Apple M4, scripts/bench-demo.sh -s 1, medians; 21 ticks)
-- ─────────────────────────────────────────────────────────────────
--   Mode          | wall    | tick0  | wall_post | steady/tick
--   --------------+---------+--------+-----------+------------
--   JIT default   |  4.97ms |  4.26ms|   0.72ms  |  0.01 ms
--   FUNCTIONIZE=0 | 15.68ms |  0.83ms|  14.82ms  |  0.70 ms
--
-- → ~70× faster per-tick steady-state (0.01 vs 0.70 ms): the deep
--   div/mod chain is native code under the JIT (a flat run of sdiv/srem
--   + branch), while FUNCTIONIZE=0 re-solves all 40 branch-dependent
--   steps in Z3 every tick. wall_post drops ~20× (0.72 vs 14.82 ms).
-- → tick0 is higher under JIT (4.26 vs 0.83 ms): that's the one-shot
--   Cranelift compile, amortized over every later tick.
--
--   reproduce:
--     scripts/bench-demo.sh examples/test_30_jit_gap_closures.ev -n 5
--     scripts/bench-demo.sh examples/test_30_jit_gap_closures.ev -n 5 EVIDENT_FUNCTIONIZE=0

import "stdlib/runtime.ev"

enum Phase = Running | Halting

type World
    n      ∈ Int       -- tick counter (user-written; given at tick 0 as 0)
    half   ∈ Int       -- n / 2     (GAP 1: integer division)
    quad   ∈ Int       -- n mod 4   (GAP 1: integer modulo)
    trail  ∈ String    -- progress bar (GAP 3: string concat accumulator)
    digest ∈ Int       -- deep div/mod chain output (the benchmark workload)

fsm gaps(state ∈ Phase, world ∈ World)
    -- pure-int counter component — the JIT's home turf.
    world.n = _world.n + 1

    -- GAP 1 — integer division + modulo as top-level Scalar writes.
    world.half = _world.n / 2
    world.quad = mod(_world.n, 4)

    -- GAP 3 — String concat: prepend a '.' to the trail each tick.
    world.trail = "." ++ _world.trail

    -- GAP 1 AT SCALE — a deep, branch-dependent div/mod chain. Each step
    -- divides or takes a modulus of the running value, picking the next
    -- transform on a threshold. Z3 can't fold this to a closed form, so
    -- FUNCTIONIZE=0 re-solves all 40 steps every tick; the JIT compiles them
    -- once to native sdiv/srem + branch and runs flat. This is what makes
    -- the benchmark win meaningful (see BENCHMARK above).
    d_seed ∈ Int = _world.n * 1000 + 7
    d01 ∈ Int = (d_seed > 500 ? d_seed / 3 + 1 : d_seed * 2 + 1)
    d02 ∈ Int = (d01 > 300 ? mod(d01, 97) + 8 : d01 / 2 + 12)
    d03 ∈ Int = (d02 > 200 ? d02 / 5 + 15 : d02 * 3 + mod(d02, 33))
    d04 ∈ Int = (d03 > 400 ? mod(d03, 17) * 2 : d03 / 2 + 22)
    d05 ∈ Int = (d04 > 500 ? d04 / 3 + 6 : d04 * 2 + 11)
    d06 ∈ Int = (d05 > 300 ? mod(d05, 97) + 13 : d05 / 2 + 5)
    d07 ∈ Int = (d06 > 200 ? d06 / 5 + 20 : d06 * 3 + mod(d06, 27))
    d08 ∈ Int = (d07 > 400 ? mod(d07, 11) * 2 : d07 / 2 + 4)
    d09 ∈ Int = (d08 > 500 ? d08 / 3 + 11 : d08 * 2 + 4)
    d10 ∈ Int = (d09 > 300 ? mod(d09, 97) + 18 : d09 / 2 + 15)
    d11 ∈ Int = (d10 > 200 ? d10 / 5 + 2 : d10 * 3 + mod(d10, 21))
    d12 ∈ Int = (d11 > 400 ? mod(d11, 34) * 2 : d11 / 2 + 9)
    d13 ∈ Int = (d12 > 500 ? d12 / 3 + 16 : d12 * 2 + 14)
    d14 ∈ Int = (d13 > 300 ? mod(d13, 97) + 23 : d13 / 2 + 8)
    d15 ∈ Int = (d14 > 200 ? d14 / 5 + 7 : d14 * 3 + mod(d14, 15))
    d16 ∈ Int = (d15 > 400 ? mod(d15, 28) * 2 : d15 / 2 + 14)
    d17 ∈ Int = (d16 > 500 ? d16 / 3 + 21 : d16 * 2 + 7)
    d18 ∈ Int = (d17 > 300 ? mod(d17, 97) + 5 : d17 / 2 + 1)
    d19 ∈ Int = (d18 > 200 ? d18 / 5 + 12 : d18 * 3 + mod(d18, 9))
    d20 ∈ Int = (d19 > 400 ? mod(d19, 22) * 2 : d19 / 2 + 19)
    d21 ∈ Int = (d20 > 500 ? d20 / 3 + 3 : d20 * 2 + 17)
    d22 ∈ Int = (d21 > 300 ? mod(d21, 97) + 10 : d21 / 2 + 11)
    d23 ∈ Int = (d22 > 200 ? d22 / 5 + 17 : d22 * 3 + mod(d22, 32))
    d24 ∈ Int = (d23 > 400 ? mod(d23, 16) * 2 : d23 / 2 + 1)
    d25 ∈ Int = (d24 > 500 ? d24 / 3 + 8 : d24 * 2 + 10)
    d26 ∈ Int = (d25 > 300 ? mod(d25, 97) + 15 : d25 / 2 + 4)
    d27 ∈ Int = (d26 > 200 ? d26 / 5 + 22 : d26 * 3 + mod(d26, 26))
    d28 ∈ Int = (d27 > 400 ? mod(d27, 10) * 2 : d27 / 2 + 6)
    d29 ∈ Int = (d28 > 500 ? d28 / 3 + 13 : d28 * 2 + 3)
    d30 ∈ Int = (d29 > 300 ? mod(d29, 97) + 20 : d29 / 2 + 14)
    d31 ∈ Int = (d30 > 200 ? d30 / 5 + 4 : d30 * 3 + mod(d30, 20))
    d32 ∈ Int = (d31 > 400 ? mod(d31, 33) * 2 : d31 / 2 + 11)
    d33 ∈ Int = (d32 > 500 ? d32 / 3 + 18 : d32 * 2 + 13)
    d34 ∈ Int = (d33 > 300 ? mod(d33, 97) + 2 : d33 / 2 + 7)
    d35 ∈ Int = (d34 > 200 ? d34 / 5 + 9 : d34 * 3 + mod(d34, 14))
    d36 ∈ Int = (d35 > 400 ? mod(d35, 27) * 2 : d35 / 2 + 16)
    d37 ∈ Int = (d36 > 500 ? d36 / 3 + 23 : d36 * 2 + 6)
    d38 ∈ Int = (d37 > 300 ? mod(d37, 97) + 7 : d37 / 2 + 17)
    d39 ∈ Int = (d38 > 200 ? d38 / 5 + 14 : d38 * 3 + mod(d38, 8))
    d40 ∈ Int = (d39 > 400 ? mod(d39, 21) * 2 : d39 / 2 + 21)
    world.digest = d40

    -- Counter-driven transition. Reads `_world.n` (a given) rather than a
    -- local `_var`, so no component sees an absent prev-value at tick 0.
    state_next = (_world.n ≥ 19 ? Halting : Running)

    -- GAP 2 — guarded Seq(Effect): `match state` over the Phase enum, with
    -- the arm length varying per branch (Running emits 1 effect, Halting 2).
    effects = match state
        Halting ⇒ ⟨Println("jit-gap demo: done" ++ _world.trail), Exit(0)⟩
        Running ⇒ ⟨Println("tick" ++ _world.trail)⟩

-- ── Static tests ─────────────────────────────────────────────────
-- One per gap, pinning the input and asserting the computed output. In
-- a static claim the `_world.X` read resolves to the pinned `world.X`
-- and the current-tick write surfaces as `world_next.X`.

-- GAP 1: division + modulo. n=10 → 10/2 = 5, 10 mod 4 = 2.
claim sat_div_mod
    world ∈ World
    world_next ∈ World
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state ∈ Phase
    state_next ∈ Phase
    world.n = 10
    gaps
    world_next.half = 5
    world_next.quad = 2

-- GAP 1 at scale: the deep div/mod chain is computed correctly. For
-- world.n = 6 the 40-step chain lands on 65 (verified independently).
claim sat_chain_digest
    world ∈ World
    world_next ∈ World
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state ∈ Phase
    state_next ∈ Phase
    world.n = 6
    gaps
    world_next.digest = 65

-- GAP 3: string concat prepends one '.' per tick.
claim sat_trail_grows
    world ∈ World
    world_next ∈ World
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state ∈ Phase
    state_next ∈ Phase
    world.trail = "abc"
    gaps
    world_next.trail = ".abc"

-- GAP 2: guarded Seq — once state is Halting the effects carry Exit(0).
claim sat_halting_exits
    world ∈ World
    world_next ∈ World
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state ∈ Phase
    state_next ∈ Phase
    state = Halting
    world.trail = ""
    gaps
    effects = ⟨Println("jit-gap demo: done"), Exit(0)⟩
