-- 02_counter — multi-step state transition; prints `tick N` each
-- step using to_str and `++` (string concat).
--
-- COUNTEREXAMPLE NOTE: enum's first variant must be nullary so
-- the runtime can seed tick-0 state. If we wrote
-- `enum CountState = Count(Int) | Done`, Z3 would pick the
-- simplest satisfying state on tick 0 (Done) and the program
-- would exit immediately. The Start nullary variant works
-- around this — but the runtime should ideally seed payload
-- first-variants too.
--
-- to_str(n) formats the Int inline (same tick), so there's no
-- emit-on-tick-K / read-on-tick-K+1 dance: one Count state both
-- formats and prints.

import "stdlib/runtime.ev"

enum CountState = Start | Count(Int) | Done

fsm counter(state ∈ CountState)
    state_next = match state
        Start     ⇒ Count(5)
        Count(n)  ⇒ (n ≤ 1 ? Done : Count(n - 1))
        Done      ⇒ Done

    n_str ∈ String = match state
        Count(n) ⇒ to_str(n)
        _        ⇒ "?"

    effects = match state
        Start     ⇒ ⟨Println("starting count")⟩
        Count(_)  ⇒ ⟨Println("tick " ++ n_str)⟩
        Done      ⇒ ⟨Println("bye"), Exit(0)⟩

claim sat_start_seeds_count_five
    state ∈ CountState
    state_next ∈ CountState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state = Start
    counter
    state_next = Count(5)

claim sat_count_prints_tick
    state ∈ CountState
    state_next ∈ CountState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state = Count(3)
    counter
    effects = ⟨Println("tick 3")⟩

claim sat_count_one_goes_done
    state ∈ CountState
    state_next ∈ CountState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state = Count(1)
    counter
    state_next = Done

claim unsat_count_increments
    state ∈ CountState
    state_next ∈ CountState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state = Count(3)
    counter
    state_next = Count(4)
