-- 02_counter — multi-step state transition; prints `tick N` each
-- step using to_str and `++` (string concat).
--
-- State carries via `_state` (the previous tick's `state`): the next
-- enum is a function of the previous one. On the first tick there is
-- no previous, so `is_first_tick ⇒ state = Start` seeds it; every
-- later tick takes `state = match _state`.
--
-- to_str(n) formats the Int inline (same tick), so there's no
-- emit-on-tick-K / read-on-tick-K+1 dance: one Count state both
-- formats and prints.

import "stdlib/runtime.ev"

enum CountState = Start | Count(Int) | Done

fsm counter
    state ∈ CountState := Start
    ¬is_first_tick ⇒
        state = match _state
            Start     ⇒ Count(5)
            Count(n)  ⇒ (n ≤ 1 ? Done : Count(n - 1))
            Done      ⇒ Done

    n_str ∈ String = match state
        Count(n) ⇒ to_str(n)
        _        ⇒ "?"

    effects = match state
        Start     ⇒ ⟨Println("starting count")⟩
        Count(_)  ⇒ ⟨Println("tick " ++ n_str)⟩
        Done      ⇒ ⟨Println("bye"), Exit(0)⟩

-- ── Static tests ─────────────────────────────────────────────

-- On the first tick the state seeds to Start.
claim sat_first_tick_seeds_start
    _state ∈ CountState
    state ∈ CountState
    is_first_tick ∈ Bool
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    is_first_tick = true
    counter
    state = Start

-- Start transitions to Count(5).
claim sat_start_goes_count_five
    _state ∈ CountState
    state ∈ CountState
    is_first_tick ∈ Bool
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    is_first_tick = false
    _state = Start
    counter
    state = Count(5)

-- A Count state prints its tick line: _state = Count(4) ⇒ state = Count(3).
claim sat_count_prints_tick
    _state ∈ CountState
    state ∈ CountState
    is_first_tick ∈ Bool
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    is_first_tick = false
    _state = Count(4)
    counter
    effects = ⟨Println("tick 3")⟩

-- Count(1) drops to Done.
claim sat_count_one_goes_done
    _state ∈ CountState
    state ∈ CountState
    is_first_tick ∈ Bool
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    is_first_tick = false
    _state = Count(1)
    counter
    state = Done

-- The count strictly decreases — Count(3) never goes to Count(4).
claim unsat_count_increments
    _state ∈ CountState
    state ∈ CountState
    is_first_tick ∈ Bool
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    is_first_tick = false
    _state = Count(3)
    counter
    state = Count(4)
