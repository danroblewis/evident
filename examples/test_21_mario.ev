import "stdlib/runtime.ev"
import "packages/sdl/window.ev"
import "packages/sdl/render.ev"

type World
    pos ∈ IVec2
    key_left ∈ Int
    key_right ∈ Int
    key_up ∈ Int
    tick ∈ Int

fsm game(world ∈ World)
    game_clock = _world.tick

    on_ground = (_world.pos.y ≥ 400)
    walk_vx = (_world.key_left > 0 ? 0 - 5
                : (_world.key_right > 0 ? 5 : 0))
    jump_vy = (on_ground ∧ _world.key_up > 0 ? 0 - 14 : _vel.y + 2)

    tent ∈ IVec2 = _world.pos + IVec2(walk_vx, jump_vy)

    clamped = IVec2(
        (tent.x < 0 ? 0 : (tent.x > 608 ? 608 : tent.x)),
        (tent.y > 400 ? 400 : tent.y))

    next_vel = IVec2(
        walk_vx,
        (tent.y > 400 ? 0 : jump_vy))

    world.pos = IVec2((is_first_tick ? 304 : clamped.x),
                       (is_first_tick ? 100 : clamped.y))
    vel = IVec2((is_first_tick ? 0 : next_vel.x),
                (is_first_tick ? 0 : next_vel.y))

fsm display(world ∈ World)
    win ∈ SDL_Window (title ↦ "Mario", width ↦ 640, height ↦ 480)

    frame = (is_first_tick ? 0 : _frame + 1)

    key_left_raw = match last_results[14]
        IntResult(n) ⇒ n
        _           ⇒ 0
    key_right_raw = match last_results[15]
        IntResult(n) ⇒ n
        _           ⇒ 0
    key_up_raw = match last_results[16]
        IntResult(n) ⇒ n
        _           ⇒ 0

    world.key_left  = (is_first_tick ? 0 : key_left_raw)
    world.key_right = (is_first_tick ? 0 : key_right_raw)
    world.key_up    = (is_first_tick ? 0 : key_up_raw)
    world.tick      = frame

    ground ∈ Rect = Rect((60, 140, 60, 255), (0, 432), (640, 48))
    hat    ∈ Rect = Rect((220, 40, 40, 255), _world.pos, (32, 6))
    face   ∈ Rect = Rect((240, 200, 160, 255),
                          IVec2(_world.pos.x + 4, _world.pos.y + 6),
                          (24, 10))
    shirt  ∈ Rect = Rect((220, 40, 40, 255),
                          IVec2(_world.pos.x, _world.pos.y + 16),
                          (32, 10))
    pants  ∈ Rect = Rect((40, 70, 200, 255),
                          IVec2(_world.pos.x + 4, _world.pos.y + 26),
                          (24, 6))

    -- Per-rect effects, each `win.draw_rect` asserts a (color, fill)
    -- pair of LibCalls.
    win.set_draw_color((80, 160, 220, 255), sky_eff)
    win.render_clear(clear_eff)
    win.draw_rect(ground, ground_color_eff, ground_fill_eff)
    win.draw_rect(hat,    hat_color_eff,    hat_fill_eff)
    win.draw_rect(face,   face_color_eff,   face_fill_eff)
    win.draw_rect(shirt,  shirt_color_eff,  shirt_fill_eff)
    win.draw_rect(pants,  pants_color_eff,  pants_fill_eff)
    win.render_present(present_eff)
    sdl_pump_events(pump_eff)
    key_left_eff  = ReadByte(win.keyboard_state, 80)
    key_right_eff = ReadByte(win.keyboard_state, 79)
    key_up_eff    = ReadByte(win.keyboard_state, 82)
    sdl_delay(16, delay_eff)

    -- The frame's effects, by intent. `++` is Seq concat; the
    -- runtime flattens these into one sequence at load time.
    sky_clear   ∈ Seq(Effect) = ⟨sky_eff, clear_eff⟩
    scene_draws ∈ Seq(Effect) = ⟨ground_color_eff, ground_fill_eff,
                                  hat_color_eff,    hat_fill_eff,
                                  face_color_eff,   face_fill_eff,
                                  shirt_color_eff,  shirt_fill_eff,
                                  pants_color_eff,  pants_fill_eff⟩
    input_poll  ∈ Seq(Effect) = ⟨pump_eff,
                                  key_left_eff, key_right_eff, key_up_eff⟩

    effects = (frame ≥ 240
        ? ⟨Println("mario done"), Exit(0)⟩
        : sky_clear ++ scene_draws ++ ⟨present_eff⟩
            ++ input_poll ++ ⟨delay_eff⟩)
