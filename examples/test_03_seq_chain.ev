-- 03_seq_chain — multi-effect emission in one tick.
--
-- The top-level effects emission IS the atomic batch — every
-- effect dispatches in order within a single Z3 solve. Later
-- effects can reference earlier ones' results via
-- ArgPriorResult(N). Before Phase 6.4 this required wrapping
-- the list in an Effect::Seq variant; now the wrapper is gone
-- and the top-level list does the same job.

import "stdlib/runtime.ev"

enum SeqState = Init | Done

fsm seq_demo(state ∈ SeqState)
    state_next = match state
        Init ⇒ Done
        Done ⇒ Done

    effects = match state
        Init ⇒ ⟨Println("first"), Println("second"), Println("third"), Exit(0)⟩
        Done ⇒ ⟨⟩

-- Init emits all four effects in one tick.
claim sat_init_emits_chain_then_exit
    state ∈ SeqState
    state_next ∈ SeqState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state = Init
    seq_demo
    effects = ⟨Println("first"), Println("second"), Println("third"), Exit(0)⟩
