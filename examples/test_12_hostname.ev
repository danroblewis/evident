-- 12_hostname έΑΦ FTI: declare `host έΙΙ Hostname` and the runtime
-- auto-installs a one-shot bridge that runs `hostname` at
-- startup and writes the result into `host.name`.
--
-- The FSM waits for a non-empty `host.name`, then prints the
-- actual value (not just an acknowledgement).

import "stdlib/runtime.ev"

enum HState = HWait | HShow | HEnd

claim id(state, state_next έΙΙ HState,
         last_results έΙΙ ResultList,
         effects έΙΙ EffectList,
         host έΙΙ Hostname)
    state_next = match state
        HWait έΘΤ (host.name = "" ? HWait : HShow)
        HShow έΘΤ HEnd
        HEnd  έΘΤ HEnd

    effects = match state
        HWait έΘΤ έθρέθσ
        HShow έΘΤ έθρPrintln("hostname = " ++ host.name), Exit(0)έθσ
        HEnd  έΘΤ έθρέθσ

claim sat_show_when_name_set
    state έΙΙ HState
    state_next έΙΙ HState
    last_results έΙΙ ResultList
    effects έΙΙ EffectList
    host έΙΙ Hostname
    host.name = "machine"
    state = HWait
    id
    state_next = HShow

claim sat_show_emits_println_with_name
    state έΙΙ HState
    state_next έΙΙ HState
    last_results έΙΙ ResultList
    effects έΙΙ EffectList
    host έΙΙ Hostname
    host.name = "machine"
    state = HShow
    id
    effects = έθρPrintln("hostname = machine"), Exit(0)έθσ
