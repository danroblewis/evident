-- 07_time — Effect::Time returns IntResult(elapsed_ms_since_runtime_start).
--
-- Three-state pipeline:
--   Ask:    emit Time
--   Format: take last_results' IntResult, emit IntToStr
--   Show:   take last_results' StringResult, Println, Exit
--
-- Demonstrates that one-shot Effect results round-trip through
-- last_results from one tick to the next, even when chained
-- (Time → IntToStr → Println).
--
-- The runtime convention here is elapsed-ms-from-start, NOT
-- unix epoch — the docstring on `runtime.ev` is silent on
-- which.

import "stdlib/runtime.ev"

enum TState = Ask | Format | Show | Done

fsm time_demo(state ∈ TState)
    state_next = match state
        Ask    ⇒ Format
        Format ⇒ Show
        Show   ⇒ Done
        Done   ⇒ Done

    -- In Format state, last_results carries the Time IntResult.
    n_int ∈ Int
    n_int = match last_results[0]
        IntResult(n) ⇒ n
        _            ⇒ -1

    -- In Show state, last_results carries IntToStr's StringResult.
    n_str ∈ String
    n_str = match last_results[0]
        StringResult(s) ⇒ s
        _               ⇒ "?"

    effects = match state
        Ask    ⇒ ⟨Time⟩
        Format ⇒ ⟨IntToStr(n_int)⟩
        Show   ⇒ ⟨Println("elapsed_ms = " ++ n_str), Exit(0)⟩
        Done   ⇒ ⟨⟩

claim sat_ask_emits_time
    state ∈ TState
    state_next ∈ TState
    last_results ∈ Seq(Result)
    effects ∈ EffectList
    state = Ask
    time_demo
    effects = ⟨Time⟩

claim sat_format_emits_int_to_str_of_int_result
    state ∈ TState
    state_next ∈ TState
    last_results ∈ Seq(Result)
    effects ∈ EffectList
    state = Format
    last_results = ⟨IntResult(42)⟩
    time_demo
    effects = ⟨IntToStr(42)⟩
