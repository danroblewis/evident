-- 24_sdl_mixer — SDL2_mixer audio: load a WAV, play it ~1s, exit.
--
-- The `SDL_Mixer` FTI bridge opens the audio device and loads
-- examples/assets/tone.wav (a 0.5s 440Hz tone) at install time,
-- threading the Mix_Chunk* handle into `mixer.chunk`. Tick 0
-- plays it once; the FSM then idles for ~20 frames (a 50ms
-- sdl_delay each tick paces it to ~1s of audio) before halting
-- all channels, closing the mixer, and exiting cleanly.
--
-- Zero raw LibCall / FFICall / hardcoded dylib paths in this file —
-- all FFI lives behind the packages/sdl/mixer.ev wrappers. Audio
-- output isn't asserted (a headless box may have no device); the
-- gate is a clean exit, and a missing device degrades to silence
-- (Mix_LoadWAV → NULL → handle 0; Mix_PlayChannel just returns -1).

import "stdlib/runtime.ev"
import "packages/sdl/window.ev"
import "packages/sdl/mixer.ev"

enum AState = Start | Playing(Int) | Stop

fsm tone(state ∈ AState)
    mixer ∈ SDL_Mixer (sample_path ↦ "examples/assets/tone.wav")

    state_next = match state
        Start      ⇒ Playing(20)
        Playing(n) ⇒ (n ≤ 1 ? Stop : Playing(n - 1))
        Stop       ⇒ Stop

    play_eff ∈ Effect
    mixer.play(0, play_eff)            -- loops=0 → play once
    delay_eff ∈ Effect
    sdl_delay(50, delay_eff)
    halt_eff ∈ Effect
    mixer.halt(halt_eff)               -- stop all channels
    close_eff ∈ Effect
    mix_close_audio(close_eff)

    effects = match state
        Start      ⇒ ⟨play_eff, delay_eff⟩
        Playing(n) ⇒ (n > 0 ? ⟨delay_eff⟩ : ⟨⟩)
        Stop       ⇒ ⟨halt_eff, close_eff, Println("done"), Exit(0)⟩

claim sat_start_advances_to_playing
    state ∈ AState
    state_next ∈ AState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state = Start
    tone
    state_next = Playing(20)

claim sat_playing_counts_down
    state ∈ AState
    state_next ∈ AState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state = Playing(2)
    tone
    state_next = Playing(1)

claim sat_last_play_advances_to_stop
    state ∈ AState
    state_next ∈ AState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    state = Playing(1)
    tone
    state_next = Stop
