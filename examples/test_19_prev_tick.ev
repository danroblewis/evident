-- 19_prev_tick вҖ” `_var` time-shift convention.
--
-- A counter that uses `_count` (the previous tick's `count`) and
-- `is_first_tick` (true on tick 0, false thereafter, auto-injected
-- when any `_var` is referenced). Demonstrates that the runtime's
-- time-shift semantics work: every variable's previous-tick value
-- is available as `_var` for free.
--
-- The discrete `state` is a pure function of the carried scalar
-- `count` (`state вҲҲ CounterState = (count вүҘ 3 ? Done : Counting)`),
-- so it needs no `_state` вҖ” it reflects THIS tick's count directly.

import "stdlib/runtime.ev"

enum CounterState = Counting | Done

fsm counter
    count вҲҲ Int := 0
    О”count = 1

    state вҲҲ CounterState = (count вүҘ 3 ? Done : Counting)

    cur_str вҲҲ String = to_str(count)

    effects = match state
        Counting вҮ’ вҹЁPrintln("count = " ++ cur_str)вҹ©
        Done     вҮ’ вҹЁPrintln("done"), Exit(0)вҹ©

-- в”Җв”Җ Static tests в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

-- On tick 0, `is_first_tick` is true вҶ’ count = 0.
claim sat_first_tick_count_is_zero
    state вҲҲ CounterState
    last_results вҲҲ Seq(Result)
    effects вҲҲ Seq(Effect)
    count вҲҲ Int
    _count вҲҲ Int
    is_first_tick вҲҲ Bool
    cur_str вҲҲ String

    is_first_tick = true
    counter
    count = 0

-- On tick 1+, count = _count + 1.
claim sat_subsequent_tick_increments
    state вҲҲ CounterState
    last_results вҲҲ Seq(Result)
    effects вҲҲ Seq(Effect)
    count вҲҲ Int
    _count вҲҲ Int
    is_first_tick вҲҲ Bool
    cur_str вҲҲ String

    is_first_tick = false
    _count = 7
    counter
    count = 8
