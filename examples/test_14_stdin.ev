-- 14_stdin — Plugin-as-writer: declare `stdin_line ∈ String`
-- in World and the runtime auto-installs StdinSource which
-- writes one line per Enter to that field. `stdin_seq` (also
-- written) increments per line — the FSM uses it to detect
-- "this is a new line, not a re-tick on the same value."
--
-- Each new line is echoed back. Type `quit` (or close stdin /
-- send EOF) to terminate.
--
-- Run interactively:
--   evident effect-run examples/test_14_stdin.ev
-- Or pipe stdin:
--   printf "hi\nworld\nquit\n" | evident effect-run examples/test_14_stdin.ev

import "stdlib/runtime.ev"

type World
    stdin_line ∈ String
    stdin_seq  ∈ Int

-- Start is a nullary first variant (so the runtime can seed
-- tick 0); Listening(Int) carries the last-echoed seq.
enum EState = Start | Listening(Int) | Done

fsm echo(world ∈ World,
           state ∈ EState)
    last_seq ∈ Int
    last_seq = match state
        Start         ⇒ 0
        Listening(s)  ⇒ s
        Done          ⇒ 0

    fresh ∈ Bool
    fresh = (world.stdin_seq > last_seq)

    quit_now ∈ Bool
    quit_now = (fresh ∧ (world.stdin_line = "quit" ∨ world.stdin_line = ""))

    state_next = match state
        Start         ⇒ Listening(0)
        Listening(_)  ⇒ (quit_now ? Done : Listening(world.stdin_seq))
        Done          ⇒ Done

    has_line ∈ Bool
    has_line = (fresh ∧ world.stdin_line ≠ "" ∧ world.stdin_line ≠ "quit")

    effects = match state
        Start        ⇒ ⟨⟩
        Listening(_) ⇒ (quit_now ? ⟨Println("bye"), Exit(0)⟩
                         : (has_line ? ⟨Println(world.stdin_line)⟩ : ⟨⟩))
        Done         ⇒ ⟨⟩

claim sat_echoes_first_line
    world ∈ World
    state ∈ EState
    state_next ∈ EState
    last_results ∈ Seq(Result)
    effects ∈ EffectList
    world.stdin_line = "hello"
    world.stdin_seq = 1
    state = Listening(0)
    echo
    effects = ⟨Println("hello")⟩

claim sat_quits_on_quit_command
    world ∈ World
    state ∈ EState
    state_next ∈ EState
    last_results ∈ Seq(Result)
    effects ∈ EffectList
    world.stdin_line = "quit"
    world.stdin_seq = 5
    state = Listening(4)
    echo
    state_next = Done

claim sat_skips_re_tick_with_same_seq
    world ∈ World
    state ∈ EState
    state_next ∈ EState
    last_results ∈ Seq(Result)
    effects ∈ EffectList
    world.stdin_line = "stale"
    world.stdin_seq = 5
    state = Listening(5)
    echo
    effects = ⟨⟩
