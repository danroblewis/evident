-- 22_prev_record — `_var` time-shift convention through RECORD
-- types. Verifies that `_pos.x` and `_pos.y` get pinned from the
-- previous tick's `pos.x` and `pos.y` bindings.
--
-- The fix landed in commit c88d613 — before that, the parser
-- collapsed `_pos.x` into `Identifier("_pos.x")` and the
-- prev-tick walker stripped the full underscore prefix and tried
-- to look up `pos.x` in declared memberships (which only had the
-- bare `pos`). Result: `_pos ∈ IVec2` never got injected and
-- translation failed with "dropped constraint."
--
-- This test pins the fsm down to a small enough scope that we
-- can verify the time-shift end-to-end without SDL or other
-- runtime dependencies.

import "stdlib/runtime.ev"

type IVec2(x, y ∈ Int)

-- Diagonal walker — both axes advance by their previous-tick
-- values. The intermediate `step ∈ IVec2 = _pos + IVec2(1, 2)`
-- uses componentwise record-lift in equation context (CLAUDE.md
-- "Records as vectors"); the ternary then lives inside the
-- final IVec2 ctor since record-lift through ternary isn't
-- supported on both arms.
fsm walker
    step ∈ IVec2 = _pos + IVec2(1, 2)
    pos ∈ IVec2 = IVec2((is_first_tick ? 0 : step.x),
                        (is_first_tick ? 0 : step.y))

    halt ∈ Bool
    halt = (pos.x ≥ 3)

    sum ∈ Effect
    sum = IntToStr(pos.x + pos.y)

    -- Read the previous tick's IntToStr output. On tick 0
    -- last_results is empty; we gate the print on having a
    -- prior result so the first frame just emits IntToStr
    -- without trying to print yet.
    have_prior ∈ Bool
    have_prior = (#last_results > 0)
    s ∈ String
    s = match last_results[0]
        StringResult(v) ⇒ v
        _               ⇒ "?"

    effects = (halt
        ? ⟨Println("walker done at " ++ s), Exit(0)⟩
        : (have_prior
            ? ⟨sum, Println("pos.x+pos.y = " ++ s)⟩
            : ⟨sum⟩))

-- ── Static tests ─────────────────────────────────────────────

-- On tick 0, `is_first_tick = true` → pos = (0, 0).
claim sat_first_tick_origin
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    pos ∈ IVec2
    _pos ∈ IVec2
    is_first_tick ∈ Bool
    halt ∈ Bool
    sum ∈ Effect
    s ∈ String

    is_first_tick = true
    walker
    pos = IVec2(0, 0)

-- After tick 0 (_pos = (0, 0)), pos = (0+1, 0+2) = (1, 2).
claim sat_second_tick_advances_diagonal
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    pos ∈ IVec2
    _pos ∈ IVec2
    is_first_tick ∈ Bool
    halt ∈ Bool
    sum ∈ Effect
    s ∈ String

    is_first_tick = false
    _pos = IVec2(0, 0)
    walker
    pos = IVec2(1, 2)

-- _pos.x and _pos.y can be pinned independently — verifying
-- that the runtime's per-field record-prev-tick pin works.
claim sat_independent_field_pins
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    pos ∈ IVec2
    _pos ∈ IVec2
    is_first_tick ∈ Bool
    halt ∈ Bool
    sum ∈ Effect
    s ∈ String

    is_first_tick = false
    _pos.x = 7
    _pos.y = 11
    walker
    pos.x = 8 ∧ pos.y = 13
