-- Mario demo — Super Mario Bros. inspired side-scroller.
--
-- World is 1920 px wide. Camera follows Mario. Stompable Goombas
-- (encoded as enemy.pos.x = -1000 when dead, so the existing
-- Seq(Mover) layout still works). Lives + death + respawn.

import "stdlib/runtime.ev"
import "stdlib/toposort.ev"
import "packages/sdl/window.ev"
import "packages/sdl/render.ev"

type AABB(pos ∈ IVec2, size ∈ IVec2)
type Mover(pos ∈ IVec2, vel ∈ IVec2)
type Body(aabb ∈ AABB, color ∈ Color)
type EnemyInit(pos ∈ IVec2, vel ∈ IVec2, patrol_lo ∈ Int, patrol_hi ∈ Int)
type Coin(pos ∈ IVec2, collected ∈ Bool)
type CoinInit(pos ∈ IVec2)

enum MarioForm = SmallM | BigM

type MarioSprite(pos ∈ IVec2, is_big ∈ Bool)
    rects ∈ Seq(Rect)
    #rects = 4
    -- Small Mario: 32×32. Big Mario: 32×52 — last (foot) rect taller.
    rects[0] = Rect(Color(220, 40,  40,  255), pos,                IVec2(32, 6))
    rects[1] = Rect(Color(240, 200, 160, 255), pos + IVec2(4, 6),  IVec2(24, 10))
    rects[2] = Rect(Color(220, 40,  40,  255), pos + IVec2(0, 16), IVec2(32, 10))
    rects[3] = Rect(Color(40,  70,  200, 255), pos + IVec2(4, 26),
                     IVec2(24, (is_big ? 26 : 6)))

type Level
    bounds         ∈ AABB  = AABB(IVec2(0, 0), IVec2(1920, 480))
    screen_w       ∈ Int   = 640
    screen_h       ∈ Int   = 480
    p_size         ∈ IVec2 = IVec2(32, 32)
    enemy_size     ∈ IVec2 = IVec2(28, 28)
    grav           ∈ Int   = 2
    walk_speed     ∈ Int   = 5
    jump_strength  ∈ Int   = 14
    enemy_speed    ∈ Int   = 2

    PLAT_W         ∈ Int = 120
    PLAT_H         ∈ Int = 16
    GROUND_Y       ∈ Int = 432
    LEVEL_W        ∈ Int = 1920

    -- Pit gap at world.x ∈ [700, 800] — Mario falls in and dies.
    -- Split ground into two sections to make the pit.
    PIT_X1 ∈ Int = 700
    PIT_X2 ∈ Int = 800
    platforms ∈ Seq(Body)
    #platforms = 7
    platforms[0] = Body(AABB(IVec2(0, GROUND_Y), IVec2(PIT_X1, 48)),
                         Color(60,  140, 60, 255))
    platforms[1] = Body(AABB(IVec2(PIT_X2, GROUND_Y),
                              IVec2(LEVEL_W - PIT_X2, 48)),
                         Color(60,  140, 60, 255))
    platforms[2] = Body(AABB(IVec2(280, 360), IVec2(PLAT_W, PLAT_H)),
                         Color(150, 100, 60, 255))
    platforms[3] = Body(AABB(IVec2(540, 280), IVec2(PLAT_W, PLAT_H)),
                         Color(150, 100, 60, 255))
    platforms[4] = Body(AABB(IVec2(1080, 280), IVec2(PLAT_W, PLAT_H)),
                         Color(150, 100, 60, 255))
    platforms[5] = Body(AABB(IVec2(1340, 360), IVec2(PLAT_W, PLAT_H)),
                         Color(150, 100, 60, 255))
    platforms[6] = Body(AABB(IVec2(1600, 280), IVec2(PLAT_W, PLAT_H)),
                         Color(150, 100, 60, 255))

    e_init ∈ Seq(EnemyInit)
    #e_init = 3
    e_init[0] = EnemyInit(IVec2(400,  404), IVec2(2,     0), 350,  650)
    e_init[1] = EnemyInit(IVec2(900,  404), IVec2(0 - 2, 0), 850,  1150)
    e_init[2] = EnemyInit(IVec2(1500, 404), IVec2(2,     0), 1400, 1750)

    -- 5 coins scattered across the level, mostly above platforms.
    c_init ∈ Seq(CoinInit)
    #c_init = 5
    c_init[0] = CoinInit(IVec2(320, 320))
    c_init[1] = CoinInit(IVec2(580, 240))
    c_init[2] = CoinInit(IVec2(860, 320))
    c_init[3] = CoinInit(IVec2(1120, 240))
    c_init[4] = CoinInit(IVec2(1380, 320))

    -- End-of-level flag.
    FLAG_X ∈ Int = 1800
    FLAG_Y ∈ Int = 240

type World
    player        ∈ Mover
    enemies       ∈ Seq(Mover)
    coins         ∈ Seq(Coin)
    keys          ∈ IVec2
    tick          ∈ Int
    camera_x      ∈ Int
    lives         ∈ Int
    dead          ∈ Bool
    coin_count    ∈ Int
    won           ∈ Bool
    -- Mario gets Big after collecting 3 coins, becomes Small after death.
    is_big        ∈ Bool

fsm game(world ∈ World)
    ..Level
    #_world.enemies = 3
    #world.enemies  = 3
    #_world.coins   = 5
    #world.coins    = 5

    -- Empty effects so the scheduler dispatches nothing for game.
    effects = ⟨⟩

    game_clock ∈ Int = (is_first_tick ? 0 : _game_clock + 1)
    tick_anchor ∈ Int = _world.tick

    prev_lives ∈ Int  = (is_first_tick ? 3 : _world.lives)
    prev_dead  ∈ Bool = ((¬is_first_tick) ∧ _world.dead)
    respawning ∈ Bool = prev_dead

    on_ground ∈ Bool
    ∀ p ∈ platforms :
        (((_world.player.pos.y + p_size.y = p.aabb.pos.y)
          ∧ (_world.player.pos.x + p_size.x > p.aabb.pos.x)
          ∧ (_world.player.pos.x < p.aabb.pos.x + p.aabb.size.x))
         ⇒ on_ground)
    ¬on_ground ⇒ (∀ p ∈ platforms :
        ¬((_world.player.pos.y + p_size.y = p.aabb.pos.y)
          ∧ (_world.player.pos.x + p_size.x > p.aabb.pos.x)
          ∧ (_world.player.pos.x < p.aabb.pos.x + p.aabb.size.x)))

    will_jump ∈ Bool = (on_ground ∧ (_world.keys.y > 0))
    intent_vx ∈ Int = _world.keys.x * walk_speed
    intent_vy ∈ Int = (will_jump ? 0 - jump_strength
                       : _world.player.vel.y + grav)
    tent ∈ IVec2 = _world.player.pos + IVec2(intent_vx, intent_vy)

    x_min ∈ Int = 0
    x_max ∈ Int = LEVEL_W - p_size.x
    res_x ∈ Int = (tent.x < x_min ? x_min
                   : (tent.x > x_max ? x_max : tent.x))

    new_py ∈ Int
    new_vy ∈ Int

    any_landing ∈ Bool
    ∀ p ∈ platforms :
        (((res_x + p_size.x > p.aabb.pos.x)
          ∧ (res_x < p.aabb.pos.x + p.aabb.size.x)
          ∧ (_world.player.pos.y + p_size.y ≤ p.aabb.pos.y)
          ∧ (tent.y + p_size.y > p.aabb.pos.y))
         ⇒ any_landing)
    ¬any_landing ⇒ (∀ p ∈ platforms :
        ¬((res_x + p_size.x > p.aabb.pos.x)
          ∧ (res_x < p.aabb.pos.x + p.aabb.size.x)
          ∧ (_world.player.pos.y + p_size.y ≤ p.aabb.pos.y)
          ∧ (tent.y + p_size.y > p.aabb.pos.y)))
    ∀ p ∈ platforms : (((res_x + p_size.x > p.aabb.pos.x)
         ∧ (res_x < p.aabb.pos.x + p.aabb.size.x)
         ∧ (_world.player.pos.y + p_size.y ≤ p.aabb.pos.y)
         ∧ (tent.y + p_size.y > p.aabb.pos.y))
        ⇒ (new_py + p_size.y ≤ p.aabb.pos.y))
    any_landing ⇒ (∃ p ∈ platforms :
        (res_x + p_size.x > p.aabb.pos.x)
        ∧ (res_x < p.aabb.pos.x + p.aabb.size.x)
        ∧ (_world.player.pos.y + p_size.y ≤ p.aabb.pos.y)
        ∧ (tent.y + p_size.y > p.aabb.pos.y)
        ∧ (new_py + p_size.y = p.aabb.pos.y))
    ¬any_landing ⇒ (new_py = tent.y)
    any_landing  ⇒ (new_vy = 0)
    ¬any_landing ⇒ (new_vy = intent_vy)

    -- Per-enemy stomp/side checks (alive = pos.x ≥ 0).
    e0 ∈ Mover = _world.enemies[0]
    e0_alive ∈ Bool = (e0.pos.x ≥ 0)
    e0_x_ovl ∈ Bool = (((tent.x + 32) > e0.pos.x) ∧ (tent.x < (e0.pos.x + 28)))
    e0_was_above ∈ Bool = ((_world.player.pos.y + 32) ≤ (e0.pos.y + 4))
    e0_y_ovl ∈ Bool = (((tent.y + 32) > e0.pos.y) ∧ (tent.y < (e0.pos.y + 28)))
    s0 ∈ Bool = (e0_alive ∧ e0_x_ovl ∧ e0_was_above ∧ e0_y_ovl ∧ (intent_vy > 0))
    h0 ∈ Bool = (e0_alive ∧ e0_x_ovl ∧ e0_y_ovl ∧ ¬s0)

    e1 ∈ Mover = _world.enemies[1]
    e1_alive ∈ Bool = (e1.pos.x ≥ 0)
    e1_x_ovl ∈ Bool = (((tent.x + 32) > e1.pos.x) ∧ (tent.x < (e1.pos.x + 28)))
    e1_was_above ∈ Bool = ((_world.player.pos.y + 32) ≤ (e1.pos.y + 4))
    e1_y_ovl ∈ Bool = (((tent.y + 32) > e1.pos.y) ∧ (tent.y < (e1.pos.y + 28)))
    s1 ∈ Bool = (e1_alive ∧ e1_x_ovl ∧ e1_was_above ∧ e1_y_ovl ∧ (intent_vy > 0))
    h1 ∈ Bool = (e1_alive ∧ e1_x_ovl ∧ e1_y_ovl ∧ ¬s1)

    e2 ∈ Mover = _world.enemies[2]
    e2_alive ∈ Bool = (e2.pos.x ≥ 0)
    e2_x_ovl ∈ Bool = (((tent.x + 32) > e2.pos.x) ∧ (tent.x < (e2.pos.x + 28)))
    e2_was_above ∈ Bool = ((_world.player.pos.y + 32) ≤ (e2.pos.y + 4))
    e2_y_ovl ∈ Bool = (((tent.y + 32) > e2.pos.y) ∧ (tent.y < (e2.pos.y + 28)))
    s2 ∈ Bool = (e2_alive ∧ e2_x_ovl ∧ e2_was_above ∧ e2_y_ovl ∧ (intent_vy > 0))
    h2 ∈ Bool = (e2_alive ∧ e2_x_ovl ∧ e2_y_ovl ∧ ¬s2)

    any_stomp ∈ Bool = (s0 ∨ s1 ∨ s2)
    side_hit  ∈ Bool = (h0 ∨ h1 ∨ h2)
    -- Fall death: Mario's y exceeds the screen.
    fell_off  ∈ Bool = (tent.y > screen_h)
    just_died ∈ Bool = ((¬is_first_tick) ∧ (¬prev_dead) ∧ (side_hit ∨ fell_off))
    game_over ∈ Bool = (prev_lives ≤ 0)

    world.dead = just_died
    world.lives = (just_died ? prev_lives - 1 : prev_lives)

    -- Mario position: respawn after death.
    new_px ∈ Int = (is_first_tick ? 100
                    : (respawning ∧ ¬game_over ? 100 : res_x))
    is_first_tick ⇒ (new_py = 100)
    is_first_tick ⇒ (new_vy = 0)
    final_py ∈ Int = (respawning ∧ ¬game_over ? 100 : new_py)
    final_vx ∈ Int = (respawning ? 0
                      : (is_first_tick ? 0 : intent_vx))
    final_vy ∈ Int = (respawning ? 0
                      : (any_stomp ? 0 - 10 : new_vy))

    world.player = Mover(IVec2(new_px, final_py),
                          IVec2(final_vx, final_vy))

    cam_tent ∈ Int = new_px - 304
    cam_min  ∈ Int = 0
    cam_max  ∈ Int = LEVEL_W - screen_w
    world.camera_x = (cam_tent < cam_min ? cam_min
                      : (cam_tent > cam_max ? cam_max : cam_tent))

    -- Per-coin pickup detection.
    c0 ∈ Coin = _world.coins[0]
    c0_hit ∈ Bool = ((¬c0.collected)
                     ∧ ((new_px + 32) > c0.pos.x)
                     ∧ (new_px < (c0.pos.x + 16))
                     ∧ ((final_py + 32) > c0.pos.y)
                     ∧ (final_py < (c0.pos.y + 16)))
    c1 ∈ Coin = _world.coins[1]
    c1_hit ∈ Bool = ((¬c1.collected)
                     ∧ ((new_px + 32) > c1.pos.x)
                     ∧ (new_px < (c1.pos.x + 16))
                     ∧ ((final_py + 32) > c1.pos.y)
                     ∧ (final_py < (c1.pos.y + 16)))
    c2 ∈ Coin = _world.coins[2]
    c2_hit ∈ Bool = ((¬c2.collected)
                     ∧ ((new_px + 32) > c2.pos.x)
                     ∧ (new_px < (c2.pos.x + 16))
                     ∧ ((final_py + 32) > c2.pos.y)
                     ∧ (final_py < (c2.pos.y + 16)))
    c3 ∈ Coin = _world.coins[3]
    c3_hit ∈ Bool = ((¬c3.collected)
                     ∧ ((new_px + 32) > c3.pos.x)
                     ∧ (new_px < (c3.pos.x + 16))
                     ∧ ((final_py + 32) > c3.pos.y)
                     ∧ (final_py < (c3.pos.y + 16)))
    c4 ∈ Coin = _world.coins[4]
    c4_hit ∈ Bool = ((¬c4.collected)
                     ∧ ((new_px + 32) > c4.pos.x)
                     ∧ (new_px < (c4.pos.x + 16))
                     ∧ ((final_py + 32) > c4.pos.y)
                     ∧ (final_py < (c4.pos.y + 16)))

    prev_coin_count ∈ Int = (is_first_tick ? 0 : _world.coin_count)
    coin_delta ∈ Int = ((c0_hit ? 1 : 0)
                        + (c1_hit ? 1 : 0)
                        + (c2_hit ? 1 : 0)
                        + (c3_hit ? 1 : 0)
                        + (c4_hit ? 1 : 0))
    world.coin_count = prev_coin_count + coin_delta
    -- Mario grows after collecting 3 coins; shrinks on death.
    prev_big ∈ Bool = ((¬is_first_tick) ∧ _world.is_big)
    world.is_big = (just_died ? false
                    : (prev_big ∨ (prev_coin_count + coin_delta ≥ 3)))

    -- Coin state updates (initialize / mark collected).
    is_first_tick ⇒ (world.coins[0] = Coin(c_init[0].pos, false))
    (¬is_first_tick ∧ (_world.coins[0].collected ∨ c0_hit)) ⇒
        (world.coins[0] = Coin(c_init[0].pos, true))
    (¬is_first_tick ∧ (¬_world.coins[0].collected) ∧ (¬c0_hit)) ⇒
        (world.coins[0] = Coin(c_init[0].pos, false))
    is_first_tick ⇒ (world.coins[1] = Coin(c_init[1].pos, false))
    (¬is_first_tick ∧ (_world.coins[1].collected ∨ c1_hit)) ⇒
        (world.coins[1] = Coin(c_init[1].pos, true))
    (¬is_first_tick ∧ (¬_world.coins[1].collected) ∧ (¬c1_hit)) ⇒
        (world.coins[1] = Coin(c_init[1].pos, false))
    is_first_tick ⇒ (world.coins[2] = Coin(c_init[2].pos, false))
    (¬is_first_tick ∧ (_world.coins[2].collected ∨ c2_hit)) ⇒
        (world.coins[2] = Coin(c_init[2].pos, true))
    (¬is_first_tick ∧ (¬_world.coins[2].collected) ∧ (¬c2_hit)) ⇒
        (world.coins[2] = Coin(c_init[2].pos, false))
    is_first_tick ⇒ (world.coins[3] = Coin(c_init[3].pos, false))
    (¬is_first_tick ∧ (_world.coins[3].collected ∨ c3_hit)) ⇒
        (world.coins[3] = Coin(c_init[3].pos, true))
    (¬is_first_tick ∧ (¬_world.coins[3].collected) ∧ (¬c3_hit)) ⇒
        (world.coins[3] = Coin(c_init[3].pos, false))
    is_first_tick ⇒ (world.coins[4] = Coin(c_init[4].pos, false))
    (¬is_first_tick ∧ (_world.coins[4].collected ∨ c4_hit)) ⇒
        (world.coins[4] = Coin(c_init[4].pos, true))
    (¬is_first_tick ∧ (¬_world.coins[4].collected) ∧ (¬c4_hit)) ⇒
        (world.coins[4] = Coin(c_init[4].pos, false))

    -- End-of-level flag detection.
    prev_won ∈ Bool = ((¬is_first_tick) ∧ _world.won)
    flag_touch ∈ Bool = (((new_px + 32) > FLAG_X)
                         ∧ (new_px < (FLAG_X + 16))
                         ∧ ((final_py + 32) > FLAG_Y)
                         ∧ (final_py < (GROUND_Y + 16)))
    world.won = (prev_won ∨ flag_touch)

    -- Enemy 0
    is_first_tick ⇒ (world.enemies[0] = Mover(e_init[0].pos, e_init[0].vel))
    (¬is_first_tick ∧ s0) ⇒
        (world.enemies[0] = Mover(IVec2(0 - 1000, 0 - 1000), IVec2(0, 0)))
    (¬is_first_tick ∧ ¬s0 ∧ ¬e0_alive) ⇒
        (world.enemies[0] = Mover(IVec2(0 - 1000, 0 - 1000), IVec2(0, 0)))
    (¬is_first_tick ∧ ¬s0 ∧ e0_alive ∧ e0.pos.x ≤ e_init[0].patrol_lo) ⇒
        (world.enemies[0] = Mover(IVec2(e0.pos.x + enemy_speed, e0.pos.y),
                                   IVec2(enemy_speed, 0)))
    (¬is_first_tick ∧ ¬s0 ∧ e0_alive ∧ e0.pos.x ≥ e_init[0].patrol_hi) ⇒
        (world.enemies[0] = Mover(IVec2(e0.pos.x + 0 - enemy_speed, e0.pos.y),
                                   IVec2(0 - enemy_speed, 0)))
    (¬is_first_tick ∧ ¬s0 ∧ e0_alive ∧ e0.pos.x > e_init[0].patrol_lo
        ∧ e0.pos.x < e_init[0].patrol_hi) ⇒
        (world.enemies[0] = Mover(IVec2(e0.pos.x + e0.vel.x, e0.pos.y),
                                   IVec2(e0.vel.x, 0)))

    -- Enemy 1
    is_first_tick ⇒ (world.enemies[1] = Mover(e_init[1].pos, e_init[1].vel))
    (¬is_first_tick ∧ s1) ⇒
        (world.enemies[1] = Mover(IVec2(0 - 1000, 0 - 1000), IVec2(0, 0)))
    (¬is_first_tick ∧ ¬s1 ∧ ¬e1_alive) ⇒
        (world.enemies[1] = Mover(IVec2(0 - 1000, 0 - 1000), IVec2(0, 0)))
    (¬is_first_tick ∧ ¬s1 ∧ e1_alive ∧ e1.pos.x ≤ e_init[1].patrol_lo) ⇒
        (world.enemies[1] = Mover(IVec2(e1.pos.x + enemy_speed, e1.pos.y),
                                   IVec2(enemy_speed, 0)))
    (¬is_first_tick ∧ ¬s1 ∧ e1_alive ∧ e1.pos.x ≥ e_init[1].patrol_hi) ⇒
        (world.enemies[1] = Mover(IVec2(e1.pos.x + 0 - enemy_speed, e1.pos.y),
                                   IVec2(0 - enemy_speed, 0)))
    (¬is_first_tick ∧ ¬s1 ∧ e1_alive ∧ e1.pos.x > e_init[1].patrol_lo
        ∧ e1.pos.x < e_init[1].patrol_hi) ⇒
        (world.enemies[1] = Mover(IVec2(e1.pos.x + e1.vel.x, e1.pos.y),
                                   IVec2(e1.vel.x, 0)))

    -- Enemy 2
    is_first_tick ⇒ (world.enemies[2] = Mover(e_init[2].pos, e_init[2].vel))
    (¬is_first_tick ∧ s2) ⇒
        (world.enemies[2] = Mover(IVec2(0 - 1000, 0 - 1000), IVec2(0, 0)))
    (¬is_first_tick ∧ ¬s2 ∧ ¬e2_alive) ⇒
        (world.enemies[2] = Mover(IVec2(0 - 1000, 0 - 1000), IVec2(0, 0)))
    (¬is_first_tick ∧ ¬s2 ∧ e2_alive ∧ e2.pos.x ≤ e_init[2].patrol_lo) ⇒
        (world.enemies[2] = Mover(IVec2(e2.pos.x + enemy_speed, e2.pos.y),
                                   IVec2(enemy_speed, 0)))
    (¬is_first_tick ∧ ¬s2 ∧ e2_alive ∧ e2.pos.x ≥ e_init[2].patrol_hi) ⇒
        (world.enemies[2] = Mover(IVec2(e2.pos.x + 0 - enemy_speed, e2.pos.y),
                                   IVec2(0 - enemy_speed, 0)))
    (¬is_first_tick ∧ ¬s2 ∧ e2_alive ∧ e2.pos.x > e_init[2].patrol_lo
        ∧ e2.pos.x < e_init[2].patrol_hi) ⇒
        (world.enemies[2] = Mover(IVec2(e2.pos.x + e2.vel.x, e2.pos.y),
                                   IVec2(e2.vel.x, 0)))

fsm keyboard(world ∈ World)
    win ∈ SDL_Window (title ↦ "Mario", width ↦ 640, height ↦ 480)
    tick_anchor ∈ Int = _world.tick
    kb_frame ∈ Int = (is_first_tick ? 0 : _kb_frame + 1)
    sdl_pump_events(pump_eff)
    key_left_eff  = ReadByte(win.keyboard_state, 80)
    key_right_eff = ReadByte(win.keyboard_state, 79)
    key_up_eff    = ReadByte(win.keyboard_state, 82)

    key_left_raw  ∈ Int = match last_results[1]
        IntResult(n) ⇒ n
        _           ⇒ 0
    key_right_raw ∈ Int = match last_results[2]
        IntResult(n) ⇒ n
        _           ⇒ 0
    key_up_raw    ∈ Int = match last_results[3]
        IntResult(n) ⇒ n
        _           ⇒ 0

    world.keys.x = (is_first_tick ? 0
                    : (key_left_raw > 0 ∧ key_right_raw = 0 ? 0 - 1
                       : (key_right_raw > 0 ∧ key_left_raw = 0 ? 1 : 0)))
    world.keys.y = (is_first_tick ? 0 : key_up_raw)

    effects = ⟨pump_eff, key_left_eff, key_right_eff, key_up_eff⟩

fsm display(world ∈ World)
    ..Level
    #_world.enemies = 3
    #_world.coins   = 5

    cam_x ∈ Int = _world.camera_x

    win ∈ SDL_Window (title ↦ "Mario", width ↦ 640, height ↦ 480)

    frame ∈ Int = (is_first_tick ? 0 : _frame + 1)
    world.tick = frame

    sdl_delay(16, delay_eff)
    win.set_draw_color((80, 160, 220, 255), sky_eff)
    win.render_clear(clear_eff)

    plat_effs ∈ Seq(EffectPair)
    #plat_effs = 7
    ∀ (p, b) ∈ coindexed(platforms, plat_effs) :
        win.draw_rect(Rect(p.color,
                            IVec2(p.aabb.pos.x - cam_x, p.aabb.pos.y),
                            p.aabb.size), b.effs)

    mario_screen_pos ∈ IVec2 = IVec2(_world.player.pos.x - cam_x,
                                       _world.player.pos.y)
    mario ∈ MarioSprite (pos ↦ mario_screen_pos, is_big ↦ _world.is_big)
    mario_effs ∈ Seq(EffectPair)
    #mario_effs = 4
    ∀ (r, b) ∈ coindexed(mario.rects, mario_effs) :
        win.draw_rect(r, b.effs)

    enemy_effs ∈ Seq(EffectPair)
    #enemy_effs = 3
    ∀ (m, b) ∈ coindexed(_world.enemies, enemy_effs) :
        win.draw_rect(Rect(Color(200, 80, 220, 255),
                            IVec2(m.pos.x - cam_x, m.pos.y),
                            IVec2(28, 28)), b.effs)

    -- Coins (gold rects). Collected coins are stored with their
    -- original pos but rendered off-screen via game FSM marking
    -- — see coin_screen_x_N below.
    coin_effs ∈ Seq(EffectPair)
    #coin_effs = 5
    coin_sx_0 ∈ Int = (_world.coins[0].collected ? 0 - 1000
                       : _world.coins[0].pos.x - cam_x)
    coin_sx_1 ∈ Int = (_world.coins[1].collected ? 0 - 1000
                       : _world.coins[1].pos.x - cam_x)
    coin_sx_2 ∈ Int = (_world.coins[2].collected ? 0 - 1000
                       : _world.coins[2].pos.x - cam_x)
    coin_sx_3 ∈ Int = (_world.coins[3].collected ? 0 - 1000
                       : _world.coins[3].pos.x - cam_x)
    coin_sx_4 ∈ Int = (_world.coins[4].collected ? 0 - 1000
                       : _world.coins[4].pos.x - cam_x)
    win.draw_rect(Rect(Color(240, 200, 60, 255),
                        IVec2(coin_sx_0, _world.coins[0].pos.y),
                        IVec2(16, 16)), coin_effs[0].effs)
    win.draw_rect(Rect(Color(240, 200, 60, 255),
                        IVec2(coin_sx_1, _world.coins[1].pos.y),
                        IVec2(16, 16)), coin_effs[1].effs)
    win.draw_rect(Rect(Color(240, 200, 60, 255),
                        IVec2(coin_sx_2, _world.coins[2].pos.y),
                        IVec2(16, 16)), coin_effs[2].effs)
    win.draw_rect(Rect(Color(240, 200, 60, 255),
                        IVec2(coin_sx_3, _world.coins[3].pos.y),
                        IVec2(16, 16)), coin_effs[3].effs)
    win.draw_rect(Rect(Color(240, 200, 60, 255),
                        IVec2(coin_sx_4, _world.coins[4].pos.y),
                        IVec2(16, 16)), coin_effs[4].effs)

    -- Flag pole (white vertical bar) + flag triangle (red rect).
    win.set_draw_color((240, 240, 240, 255), flag_pole_color_eff)
    win.render_fill_rect(IVec2(FLAG_X - cam_x, FLAG_Y),
                         IVec2(4, GROUND_Y - FLAG_Y), flag_pole_fill_eff)
    win.set_draw_color((220, 40, 40, 255), flag_color_eff)
    win.render_fill_rect(IVec2(FLAG_X - cam_x + 4, FLAG_Y),
                         IVec2(28, 16), flag_fill_eff)

    -- Castle: grey rectangle with battlements at end of level.
    win.set_draw_color((140, 140, 140, 255), castle_color_eff)
    win.render_fill_rect(IVec2(FLAG_X - cam_x + 60, GROUND_Y - 80),
                         IVec2(96, 80), castle_fill_eff)
    win.set_draw_color((80, 80, 80, 255), castle_door_color_eff)
    win.render_fill_rect(IVec2(FLAG_X - cam_x + 96, GROUND_Y - 40),
                         IVec2(24, 40), castle_door_fill_eff)

    -- HUD: lives indicator (top-left, one square per life).
    hud_effs ∈ Seq(EffectPair)
    #hud_effs = 3
    ∀ i ∈ {0..2} :
        win.draw_rect(Rect(
            (_world.lives > i ? Color(220, 40, 40, 255)
                              : Color(60, 60, 60, 255)),
            IVec2(8 + i * 24, 8),
            IVec2(16, 16)), hud_effs[i].effs)

    -- Coin counter HUD: row of small gold squares (one per coin collected).
    coin_hud_effs ∈ Seq(EffectPair)
    #coin_hud_effs = 5
    ∀ i ∈ {0..4} :
        win.draw_rect(Rect(
            (_world.coin_count > i ? Color(240, 200, 60, 255)
                                   : Color(60, 60, 60, 255)),
            IVec2(120 + i * 18, 10),
            IVec2(12, 12)), coin_hud_effs[i].effs)

    -- Won banner: green rectangle drawn off-screen when not yet won.
    win.set_draw_color((60, 200, 80, 255), win_color_eff)
    win_banner_x ∈ Int = (_world.won ? 240 : 0 - 1000)
    win.render_fill_rect(IVec2(win_banner_x, 4), IVec2(160, 28), win_fill_eff)

    win.render_present(present_eff)

    -- Keep the original tick-based exit (frame ≥ 240) so the
    -- demos test passes. Lives/won are visualized in the HUD/banner.
    done_print ∈ Effect = (frame ≥ 240 ? Println("mario done") : NoEffect)
    done_exit  ∈ Effect = (frame ≥ 240 ? Exit(0) : NoEffect)

    phase_chain ∈ Seq(Effect) = ⟨
        sky_eff,                clear_eff,
        plat_effs[0].effs[0],   plat_effs[0].effs[1],
        plat_effs[1].effs[0],   plat_effs[1].effs[1],
        plat_effs[2].effs[0],   plat_effs[2].effs[1],
        plat_effs[3].effs[0],   plat_effs[3].effs[1],
        plat_effs[4].effs[0],   plat_effs[4].effs[1],
        plat_effs[5].effs[0],   plat_effs[5].effs[1],
        plat_effs[6].effs[0],   plat_effs[6].effs[1],
        coin_effs[0].effs[0],   coin_effs[0].effs[1],
        coin_effs[1].effs[0],   coin_effs[1].effs[1],
        coin_effs[2].effs[0],   coin_effs[2].effs[1],
        coin_effs[3].effs[0],   coin_effs[3].effs[1],
        coin_effs[4].effs[0],   coin_effs[4].effs[1],
        flag_pole_color_eff,    flag_pole_fill_eff,
        flag_color_eff,         flag_fill_eff,
        castle_color_eff,       castle_fill_eff,
        castle_door_color_eff,  castle_door_fill_eff,
        enemy_effs[0].effs[0],  enemy_effs[0].effs[1],
        enemy_effs[1].effs[0],  enemy_effs[1].effs[1],
        enemy_effs[2].effs[0],  enemy_effs[2].effs[1],
        mario_effs[0].effs[0],  mario_effs[0].effs[1],
        mario_effs[1].effs[0],  mario_effs[1].effs[1],
        mario_effs[2].effs[0],  mario_effs[2].effs[1],
        mario_effs[3].effs[0],  mario_effs[3].effs[1],
        hud_effs[0].effs[0],    hud_effs[0].effs[1],
        hud_effs[1].effs[0],    hud_effs[1].effs[1],
        hud_effs[2].effs[0],    hud_effs[2].effs[1],
        coin_hud_effs[0].effs[0], coin_hud_effs[0].effs[1],
        coin_hud_effs[1].effs[0], coin_hud_effs[1].effs[1],
        coin_hud_effs[2].effs[0], coin_hud_effs[2].effs[1],
        coin_hud_effs[3].effs[0], coin_hud_effs[3].effs[1],
        coin_hud_effs[4].effs[0], coin_hud_effs[4].effs[1],
        win_color_eff,          win_fill_eff,
        present_eff,            delay_eff,
        done_print,             done_exit
    ⟩
