-- Constraint-based placement for Mario's 3 elevated platforms.
-- Run:
--     evident query examples/test_21_mario/level_gen.ev LevelGen --json
-- and feed the resulting `plat_x` / `plat_y` arrays back into
-- main.ev's `platforms[1..3]` definitions. The ground (platforms[0])
-- is hand-pinned; only the elevated platforms are solved here.
--
-- The level is a constraint problem: every platform must fit in
-- the world, none may overlap, every platform must be reachable
-- by a jump from the ground or from another platform below it,
-- and the layout must have some vertical/horizontal spread so
-- the game feels like a level instead of three rectangles in
-- a row. Z3 picks the coordinates.

claim LevelGen
    -- Physics-derived constants.
    PLAT_W ∈ Int = 120
    PLAT_H ∈ Int = 16
    GROUND_Y ∈ Int = 432
    -- Max y the player can climb in one jump from the ground.
    -- Derivable from grav=2 and jump_strength=14:
    --   apex time = jump_strength / grav = 7 ticks
    --   rise = sum k=0..6 of (jump_strength - k*grav) ≈ 49 + … ≈ 196 px
    MAX_JUMP_RISE ∈ Int = 196
    MIN_GAP ∈ Int = 40

    plat_x ∈ Seq(Int)
    plat_y ∈ Seq(Int)
    #plat_x = 3
    #plat_y = 3

    -- Each platform fits in the world horizontally and sits within
    -- a sensible vertical band (above the ground, below the ceiling,
    -- not so low it's basically the ground).
    ∀ i ∈ {0..2} :
        0 ≤ plat_x[i] ∧ plat_x[i] ≤ 640 - PLAT_W
        GROUND_Y - MAX_JUMP_RISE ≤ plat_y[i] ∧ plat_y[i] ≤ GROUND_Y - PLAT_H - 24

    -- Pairwise non-overlap with at least MIN_GAP separation on some axis.
    ∀ i ∈ {0..2} : ∀ j ∈ {0..2} : i < j ⇒
        (plat_x[i] + PLAT_W + MIN_GAP ≤ plat_x[j]
         ∨ plat_x[j] + PLAT_W + MIN_GAP ≤ plat_x[i]
         ∨ plat_y[i] + PLAT_H + MIN_GAP ≤ plat_y[j]
         ∨ plat_y[j] + PLAT_H + MIN_GAP ≤ plat_y[i])

    -- Reachability: each platform is jump-reachable from the
    -- ground OR from another platform below it whose x-range
    -- overlaps the candidate's (cheap-arc approximation — a
    -- tighter version would solve the parabolic arc explicitly).
    reachable ∈ Seq(Bool)
    #reachable = 3
    ∀ i ∈ {0..2} : reachable[i]
    ∀ i ∈ {0..2} : reachable[i] = ((GROUND_Y - plat_y[i] ≤ MAX_JUMP_RISE) ∨ (∃ j ∈ {0..2} : i ≠ j ∧ plat_y[j] > plat_y[i] ∧ plat_y[j] - plat_y[i] ≤ MAX_JUMP_RISE ∧ ¬(plat_x[j] + PLAT_W < plat_x[i] ∨ plat_x[i] + PLAT_W < plat_x[j])))

    -- Layout-quality constraints: spread the platforms across the
    -- screen so the level reads as a level, not three rectangles
    -- clustered in one corner. These are "soft" in spirit but
    -- expressed as hard constraints because Z3 doesn't optimize.
    --
    -- At least one platform high up, at least one near the ground.
    ∃ i ∈ {0..2} : plat_y[i] ≤ 300
    ∃ i ∈ {0..2} : plat_y[i] ≥ 350
    -- At least one on the left half, at least one on the right half.
    ∃ i ∈ {0..2} : plat_x[i] + PLAT_W ≤ 320
    ∃ i ∈ {0..2} : plat_x[i] ≥ 320
