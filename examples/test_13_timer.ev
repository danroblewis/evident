-- 13_timer — FTI: per-instance configurable Timer with
-- `interval_ms ↦ N` pin set at the declaration site.
--
-- COUNTEREXAMPLE NOTE: FTI pins go in the claim BODY, not the
-- signature. `claim x(t ∈ Timer (interval_ms ↦ 50))` is a parse
-- error; declaring `t ∈ Timer (interval_ms ↦ 50)` in the body
-- works.
--
-- COUNTEREXAMPLE NOTE 2: gate exit on `t.tick_count` directly
-- in `effects`, not via a `match state` transition (FTI pins
-- don't seem to flow into state-transition constraints).

import "stdlib/runtime.ev"

enum T = Watching

fsm slow(state ∈ T)
    t ∈ Timer (interval_ms ↦ 50)

    state_next = Watching
    effects = (t.tick_count ≥ 3
               ? ⟨Println("3 timer ticks observed"), Exit(0)⟩
               : ⟨⟩)

claim sat_exits_at_three_ticks
    state ∈ T
    state_next ∈ T
    last_results ∈ Seq(Result)
    effects ∈ EffectList
    t ∈ Timer
    t.tick_count = 3
    state = Watching
    slow
    effects = ⟨Println("3 timer ticks observed"), Exit(0)⟩
