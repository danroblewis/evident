-- 17_sdl_triangle — SDL Renderer triangle.
--
-- Single-tick render: init, create window + renderer, draw the
-- triangle 5 times (with delays between), and halt — all
-- emitted as one atomic top-level effects list. This is the
-- only render pattern known to work in this runtime today
-- (see COUNTEREXAMPLES.md #7 and #9 for why per-tick rendering
-- can't carry the renderer pointer across ticks).
--
-- All FFI is in stdlib helpers; the demo file has zero
-- LibCall / dylib paths.

import "stdlib/runtime.ev"
import "packages/sdl/window.ev"
import "packages/sdl/render.ev"

enum TState = Init | Done

fsm triangle
    state ∈ TState := Init
    ¬is_first_tick ⇒
        state = match _state
            Init ⇒ Done
            Done ⇒ Done

    -- Triangle vertices: red top, green bottom-left, blue
    -- bottom-right. Colors interpolate across the face. Build
    -- the packed-field stream by chaining `sdl_vertex` calls
    -- — each one prepends its 8 fields to the prior tail.
    verts2 ∈ PackedFieldList
    sdl_vertex(560.0, 400.0,  80,  80, 240, 255, 0.0, 0.0, PfNil,  verts2)
    verts1 ∈ PackedFieldList
    sdl_vertex( 80.0, 400.0,  80, 240,  80, 255, 0.0, 0.0, verts2, verts1)
    verts ∈ PackedFieldList
    sdl_vertex(320.0,  80.0, 240,  80,  80, 255, 0.0, 0.0, verts1, verts)

    bg ∈ Color
    bg = Color(20, 20, 30, 255)

    -- The top-level effects list IS the atomic batch: init →
    -- window → renderer → frame loop → halt. PriorResult indices
    -- are positional in the top-level emission.
    init_eff ∈ Effect
    sdl_init(32, init_eff)
    create_win_eff ∈ Effect
    sdl_create_window("Triangle", 805240832, 805240832, 640, 480, 4, create_win_eff)
    show_eff ∈ Effect
    sdl_show_window_after(1, show_eff)
    raise_eff ∈ Effect
    sdl_raise_window_after(1, raise_eff)
    create_ren_eff ∈ Effect
    create_renderer_after(1, create_ren_eff)

    -- After init/win/show/raise/renderer, the renderer is at
    -- Seq position 4. Per-frame ops reference PriorResult(4).
    color_eff ∈ Effect
    set_draw_color_after(4, bg, color_eff)
    clear_eff ∈ Effect
    render_clear_after(4, clear_eff)
    geom_eff ∈ Effect
    render_geometry_after(4, verts, 3, geom_eff)
    present_eff ∈ Effect
    render_present_after(4, present_eff)
    pump_eff ∈ Effect
    sdl_pump_events(pump_eff)
    delay_eff ∈ Effect
    sdl_delay(500, delay_eff)

    -- Setup (5 effects: init, create_win, show, raise,
    -- create_ren) + 5 inlined frame iterations, then Println +
    -- Exit. The whole list dispatches atomically — earlier
    -- effects' results stay accessible to later ones via
    -- ArgPriorResult.
    effects = match state
        Init ⇒ ⟨init_eff, create_win_eff, show_eff, raise_eff, create_ren_eff,
                color_eff, clear_eff, geom_eff, present_eff, pump_eff, delay_eff,
                color_eff, clear_eff, geom_eff, present_eff, pump_eff, delay_eff,
                color_eff, clear_eff, geom_eff, present_eff, pump_eff, delay_eff,
                color_eff, clear_eff, geom_eff, present_eff, pump_eff, delay_eff,
                color_eff, clear_eff, geom_eff, present_eff, pump_eff, delay_eff,
                Println("done"), Exit(0)⟩
        Done ⇒ ⟨⟩

claim sat_init_emits_full_seq_then_exit
    _state ∈ TState
    state ∈ TState
    is_first_tick ∈ Bool
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    is_first_tick = false
    _state = Init
    triangle
    state = Done
