-- 20_pure_counter — unified state model: an fsm with no state
-- enum at all. The whole "state" is `count ∈ Int`, advanced via
-- the `_var` time-shift convention (`_count + 1`). No enum, no
-- ceremony — just the one carried scalar.
--
-- Compare test_02_counter: that demo encodes its state machine
-- explicitly with an enum. This one expresses the same shape with
-- a plain Int counter and `is_first_tick`.
--
-- to_str(count) formats the Int in the same tick, so the line
-- prints THIS tick's count directly — no emit-then-read dance.
--
-- See docs/design/state-machines-as-relations.md.

import "stdlib/runtime.ev"

fsm counter
    count ∈ Int = (is_first_tick ? 0 : _count + 1)

    fmt_str ∈ String = to_str(count)

    effects = (count = 0   ? ⟨Println("starting"), Println("count = " ++ fmt_str)⟩
            : (count ≤ 3   ? ⟨Println("count = " ++ fmt_str)⟩
                           : ⟨Exit(0)⟩))

-- ── Static tests ─────────────────────────────────────────────

claim sat_first_tick_starts_at_zero
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    count ∈ Int
    _count ∈ Int
    is_first_tick ∈ Bool
    fmt_str ∈ String

    is_first_tick = true
    counter
    count = 0

claim sat_second_tick_is_one
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    count ∈ Int
    _count ∈ Int
    is_first_tick ∈ Bool
    fmt_str ∈ String

    is_first_tick = false
    _count = 0
    counter
    count = 1
