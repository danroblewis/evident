-- 32_llm_functionizer — showcase the LLM-driven Functionizer strategy.
--
-- WHAT THIS TARGETS
-- -----------------
-- This demo classifies HTTP method names (piped on stdin, one per line)
-- as "safe" (read-only / no side effects: GET, HEAD, OPTIONS, TRACE) or
-- "unsafe" (POST, PUT, DELETE, PATCH).
--
-- The classifier is a single pure constraint:
--
--     is_safe ∈ Bool = (world.stdin_line = "GET"  ∨ world.stdin_line = "HEAD"
--                       ∨ world.stdin_line = "OPTIONS" ∨ world.stdin_line = "TRACE")
--
-- This is a *String → Bool* function whose body is string equality. The
-- Cranelift JIT REFUSES to compile string equality (it can't reduce a
-- String operand to an i64 in its comparison codegen — see
-- docs/jit-codegen-gaps.md, deferred gap D2). So with the default
-- functionizer this component falls through to a full Z3 solve every
-- call. It is exactly the class of shape the LLM functionizer exists for:
-- something the native JIT can't emit code for, but that an LLM can write
-- a fast, idiomatic Rust function for (`matches!(m, "GET"|"HEAD"|…)`).
--
-- HOW THE LLM PATH WORKS (and its validation gate)
-- ------------------------------------------------
-- With `EVIDENT_FUNCTIONIZER=llm` AND a valid `ANTHROPIC_API_KEY`, the
-- runtime (functionize/llm.rs):
--   1. Samples input→output pairs by solving this constraint with Z3 —
--      Z3 is the ground-truth ORACLE (e.g. ("GET", true), ("POST", false),
--      ("zzz", false), …).
--   2. Splits them into a training set (shown to the LLM in the prompt)
--      and a HELD-OUT validation set (never shown).
--   3. Asks the LLM to write `fn compute(world_stdin_line: &str) -> bool`,
--      compiles it with `rustc` into a cdylib, and `dlopen`s it.
--   4. Accepts the function ONLY if it reproduces Z3 on EVERY held-out
--      pair. Any miss → reject → fall through to Z3. This validation gate
--      is the sole guard against a hallucinated function: wrong logic
--      can't pass because Z3 disagrees with it on the held-out set.
--
-- HONEST COST / QUALITY TRADE-OFF
-- -------------------------------
-- The LLM path is SLOW (a network round-trip + an out-of-process `rustc`
-- compile), EXPENSIVE (one API call per cache miss — the compiled
-- function is cached per claim, so it's one call per program shape, not
-- per tick), and UNCERTAIN (the model can hallucinate; that's why every
-- candidate is validated against Z3 and rejected on any mismatch). It is
-- worth paying ONLY when no cheaper functionizer (Cranelift) can compile
-- the shape — string manipulation, regex-like classification, and other
-- domain transforms the arithmetic JIT has no codegen for.
--
-- NO-API-KEY BEHAVIOR (the CI path)
-- ---------------------------------
-- Without a key the LLM generator declines (no network call), `compile`
-- returns None, and the runtime falls through to its normal path — the
-- Cranelift JIT for the arithmetic components and a Z3 solve for the
-- string classifier. The program runs identically and exits 0; only the
-- *how* of the classifier changes. Selecting `EVIDENT_FUNCTIONIZER=llm`
-- with no key prints a clear "LLM functionizer requires ANTHROPIC_API_KEY,
-- skipping" message and uses the fallback. This file's CI row exercises
-- exactly that fallback path.
--
-- Run it:
--   printf 'GET\nPOST\nPUT\nHEAD\nDELETE\nOPTIONS\nTRACE\nPATCH\n\n' \
--     | evident effect-run examples/test_32_llm_functionizer.ev
--   # compile the classifier via the LLM (needs a key + rustc on PATH):
--   ANTHROPIC_API_KEY=… EVIDENT_FUNCTIONIZER=llm evident effect-run \
--     examples/test_32_llm_functionizer.ev   < methods.txt

import "stdlib/runtime.ev"

-- StdinSource auto-installs on this World shape: it writes one line per
-- Enter (or piped newline) to `stdin_line` and bumps `stdin_seq`.
type World
    stdin_line ∈ String
    stdin_seq  ∈ Int

-- Start: nullary first variant so the runtime can seed tick 0.
-- Listening(Int): carries the last-classified line's seq.
enum CState = Start | Listening(Int) | Done

fsm classify(world ∈ World, state ∈ CState)
    last_seq ∈ Int
    last_seq = match state
        Start        ⇒ 0
        Listening(s) ⇒ s
        Done         ⇒ 0

    -- A new line arrived iff the source bumped the seq past what we last saw.
    fresh ∈ Bool
    fresh = (world.stdin_seq > last_seq)

    -- A blank line (or piped trailing newline) is the end-of-input sentinel.
    at_end ∈ Bool
    at_end = (fresh ∧ (world.stdin_line = ""))

    has_method ∈ Bool
    has_method = (fresh ∧ world.stdin_line ≠ "")

    -- ⭐ THE LLM-TARGETED COMPONENT — a pure String → Bool classifier.
    -- Its only free input is the given `world.stdin_line`; no other body
    -- variable reads `is_safe`, so it decomposes into its own component.
    -- Cranelift bails (string equality, gap D2); Z3 solves it (the
    -- sampling oracle); with a key the LLM compiles it to native code.
    is_safe ∈ Bool = (world.stdin_line = "GET" ∨ world.stdin_line = "HEAD"
                      ∨ world.stdin_line = "OPTIONS" ∨ world.stdin_line = "TRACE")

    state_next = match state
        Start        ⇒ Listening(0)
        Listening(_) ⇒ (at_end ? Done : Listening(world.stdin_seq))
        Done         ⇒ Done

    effects = match state
        Start        ⇒ ⟨Println("HTTP method safety classifier — LLM functionizer demo"),
                        Println("(no ANTHROPIC_API_KEY → Z3 solves the string classifier;"),
                        Println(" set ANTHROPIC_API_KEY + EVIDENT_FUNCTIONIZER=llm to compile it via the LLM)")⟩
        Listening(_) ⇒ (at_end ? ⟨Println("done — classified every method"), Exit(0)⟩
                         : (has_method ? ⟨Println(world.stdin_line ++ (is_safe ? " safe" : " unsafe"))⟩
                                       : ⟨⟩))
        Done         ⇒ ⟨⟩

-- ── Static tests ─────────────────────────────────────────────

-- A safe method classifies as safe …
claim sat_get_is_safe
    world ∈ World
    state ∈ CState
    state_next ∈ CState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    is_safe ∈ Bool
    world.stdin_line = "GET"
    world.stdin_seq = 1
    state = Listening(0)
    classify
    is_safe = true

-- … and prints with the " safe" suffix.
claim sat_get_prints_safe
    world ∈ World
    state ∈ CState
    state_next ∈ CState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    world.stdin_line = "GET"
    world.stdin_seq = 1
    state = Listening(0)
    classify
    effects = ⟨Println("GET safe")⟩

-- An unsafe method classifies as unsafe and prints the " unsafe" suffix.
claim sat_post_is_unsafe
    world ∈ World
    state ∈ CState
    state_next ∈ CState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    is_safe ∈ Bool
    world.stdin_line = "POST"
    world.stdin_seq = 1
    state = Listening(0)
    classify
    is_safe = false

claim sat_post_prints_unsafe
    world ∈ World
    state ∈ CState
    state_next ∈ CState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    world.stdin_line = "POST"
    world.stdin_seq = 1
    state = Listening(0)
    classify
    effects = ⟨Println("POST unsafe")⟩

-- A blank line ends input: transition to Done and emit Exit(0).
claim sat_blank_line_exits
    world ∈ World
    state ∈ CState
    state_next ∈ CState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    world.stdin_line = ""
    world.stdin_seq = 9
    state = Listening(3)
    classify
    state_next = Done

-- TRACE is one of the four safe methods (not just GET) — guards against a
-- classifier that only recognizes the first listed method.
claim sat_trace_is_safe
    world ∈ World
    state ∈ CState
    state_next ∈ CState
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    is_safe ∈ Bool
    world.stdin_line = "TRACE"
    world.stdin_seq = 1
    state = Listening(0)
    classify
    is_safe = true
