-- 30_satisfier — probabilistic-programming-style sampling.
--
-- Each tick spawns a batch of particles whose initial position is
-- sampled from the window bounds (a RANGE sampler) and whose colour is
-- sampled from an enum (an ENUM sampler). None of these variables is
-- otherwise constrained, so there is nothing to "compute" — the runtime
-- has to *pick* a satisfying value. That is exactly what Z3 does on the
-- slow path; the SatisfierFunctionizer instead draws it with a seeded
-- SplitMix64 PRNG (≈ 5 native instructions per var) and computes the
-- derived quantities (energy, warmth) via the normal Cranelift JIT.
--
-- The architectural frame is probabilistic programming: an
-- unbound-but-bounded variable is a distribution, and a query returns a
-- satisfying sample. Determinism is preserved — the draw is seeded from
-- (EVIDENT_DISPATCH_SEED, program shape, given values) — so repeated
-- queries (and the cross-tick value cache) stay consistent.
--
-- Run it with the satisfier enabled:
--     EVIDENT_SATISFIER=1 evident effect-run examples/test_30_satisfier.ev
-- The default (Cranelift) run still works — the sampler vars just route
-- to a full Z3 solve each tick, which is what we benchmark against.
--
-- ─────────────────────────────────────────────────────────────────
-- BENCHMARK  (Apple M-series, scripts/bench-demo.sh -s 1 -n 5, 21
--             ticks; 12 range samplers + 6 enum samplers per tick)
-- ─────────────────────────────────────────────────────────────────
--   Mode                | wall    | tick0  | wall_post | steady/tick
--   --------------------+---------+--------+-----------+------------
--   EVIDENT_SATISFIER=1 |  3.84ms | 1.80ms |   2.05ms  |  0.01 ms
--   EVIDENT_FUNCTIONIZE=0| 16.53ms | 1.22ms |  15.27ms  |  0.72 ms
--   (FUNCTIONIZE=0 = slow-path Z3 picking values from the same bounds)
--
-- → ~72× faster steady-state per tick (0.01 vs 0.72 ms): drawing 18
--   bounded values is an 18-deep PRNG fan-out for the satisfier
--   (sub-µs) but a real solve cycle for Z3 (~0.7 ms).
-- → ~7.4× faster wall_post (2.05 vs 15.27 ms): the satisfier's wall is
--   now dominated by dispatch (the per-tick Println), not solving.
-- → tick0 is slightly higher under the satisfier (1.80 vs 1.22 ms) —
--   that's the one-shot Cranelift compile of the derived arithmetic,
--   amortized over every later tick.
--
-- (Run with EVIDENT_FUNCTIONIZE_STATS=1 + EVIDENT_SATISFIER=1 to see the
-- per-claim component/compile counts and confirm the samplers fired.)

import "stdlib/runtime.ev"

enum Hue      = Crimson | Emerald | Azure
enum SimState = Running | Done

fsm spawn(state ∈ SimState)
    tick ∈ Int = (is_first_tick ? 0 : _tick + 1)
    state_next = (tick ≥ 19 ? Done : Running)

    -- Six particles. Each position is sampled from the window bounds
    -- (range samplers); each hue is sampled from the enum (enum
    -- samplers). Declared + bounded in one line via chained-membership.
    0 ≤ p0x ∈ Int ≤ 640
    0 ≤ p0y ∈ Int ≤ 480
    0 ≤ p1x ∈ Int ≤ 640
    0 ≤ p1y ∈ Int ≤ 480
    0 ≤ p2x ∈ Int ≤ 640
    0 ≤ p2y ∈ Int ≤ 480
    0 ≤ p3x ∈ Int ≤ 640
    0 ≤ p3y ∈ Int ≤ 480
    0 ≤ p4x ∈ Int ≤ 640
    0 ≤ p4y ∈ Int ≤ 480
    0 ≤ p5x ∈ Int ≤ 640
    0 ≤ p5y ∈ Int ≤ 480

    h0 ∈ Hue
    h1 ∈ Hue
    h2 ∈ Hue
    h3 ∈ Hue
    h4 ∈ Hue
    h5 ∈ Hue

    -- Derived from the samples — compiles to native arithmetic, with
    -- the sampled positions/hues as inputs. `energy` is the total
    -- Manhattan distance from the origin; `warmth` tallies the hues.
    e0 ∈ Int = p0x + p0y
    e1 ∈ Int = p1x + p1y
    e2 ∈ Int = p2x + p2y
    e3 ∈ Int = p3x + p3y
    e4 ∈ Int = p4x + p4y
    e5 ∈ Int = p5x + p5y
    energy ∈ Int = e0 + e1 + e2 + e3 + e4 + e5

    w0 ∈ Int = (h0 = Crimson ? 3 : (h0 = Emerald ? 2 : 1))
    w1 ∈ Int = (h1 = Crimson ? 3 : (h1 = Emerald ? 2 : 1))
    w2 ∈ Int = (h2 = Crimson ? 3 : (h2 = Emerald ? 2 : 1))
    w3 ∈ Int = (h3 = Crimson ? 3 : (h3 = Emerald ? 2 : 1))
    w4 ∈ Int = (h4 = Crimson ? 3 : (h4 = Emerald ? 2 : 1))
    w5 ∈ Int = (h5 = Crimson ? 3 : (h5 = Emerald ? 2 : 1))
    warmth ∈ Int = w0 + w1 + w2 + w3 + w4 + w5

    -- Structural output only — it depends on `state`/`tick`, never on
    -- the sampled values, so it's identical whether the satisfier or
    -- the slow Z3 path produced the draw.
    effects = match state
        Running ⇒ ⟨Println("spawned batch")⟩
        Done    ⇒ ⟨Println("simulation complete"), Exit(0)⟩

-- ── static checks ────────────────────────────────────────────────

claim sat_particle_energy_consistent
    p0x ∈ Int
    p0y ∈ Int
    p0x = 100
    0 ≤ p0x ≤ 640
    p0y = 200
    0 ≤ p0y ≤ 480
    e0 ∈ Int = p0x + p0y
    e0 = 300

claim sat_hue_warmth
    h0 ∈ Hue
    h0 = Emerald
    w0 ∈ Int = (h0 = Crimson ? 3 : (h0 = Emerald ? 2 : 1))
    w0 = 2

claim unsat_particle_out_of_bounds
    p0x ∈ Int
    p0x = 700
    0 ≤ p0x ≤ 640
