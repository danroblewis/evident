-- 26_value_cache — showcase session C's cross-tick value cache.
--
-- Session C added a cross-tick value cache: per claim, the runtime
-- memoizes `(given-values) → bindings`, so when an FSM's `given` is
-- byte-identical to a previous tick it returns the prior result and
-- skips the whole Z3 solve. (`EVIDENT_VALUE_CACHE=0` disables it.)
--
-- WHY MARIO CAN'T SHOW THIS. Every Mario FSM threads a monotonic
-- `_frame` / counter into its `given`, so its input is a fresh value
-- on every single tick — the cache key never repeats and the cache
-- can't hit. The win only appears when an FSM's input genuinely
-- repeats across ticks. This demo is built to do exactly that.
--
-- THE SHAPE. A trivial `driver` rotates `world.signal` through four
-- values in 8-tick windows; for 7 of every 8 ticks signal is left
-- untouched. The `expensive` consumer reads ONLY `world.signal` (no
-- `_var`, no state enum, no `last_results`), so its `given` is exactly
-- {world.signal} — stable within a window. Its body is a heavy
-- nonlinear Z3 solve (three coupled integer square roots), so a cache
-- hit skips real work.
--
-- BENCHMARK (Apple M4, scripts/bench-demo.sh, medians over the demo's
-- 98 ticks; "steady" excludes tick 0):
--   Mode               | wall     | tick0  | steady/tick
--   -------------------+----------+--------+------------
--   Cache default      |  34.15ms | 0.90ms |  0.18 ms
--   EVIDENT_VALUE_CACHE=0|240.34ms | 0.90ms |  3.64 ms
--
-- → 20× faster per tick steady-state, 7× faster wall.
--
-- tick 0 is identical (~0.9 ms) — the very first tick has to solve
-- regardless. After that the cache returns prior bindings whenever
-- the signal hasn't changed. Per the stats output:
--   expensive  vh=45  an=1  h=3   → 45 of 49 ticks (92%) are cache hits
-- (Z3's nlsat timing varies several percent run-to-run; the steady
-- per-tick ratio is consistently 15-25×.)
--
-- Reproduce:
--   EVIDENT_FUNCTIONIZE_STATS=1 ./.../evident effect-run \
--     examples/test_26_value_cache.ev --timing
--   EVIDENT_VALUE_CACHE=0 EVIDENT_FUNCTIONIZE_STATS=1 ./.../evident \
--     effect-run examples/test_26_value_cache.ev --timing

import "stdlib/runtime.ev"

type World
    signal ∈ Int

-- Driver: advances a private tick counter and rotates world.signal
-- through 4 values in 8-tick windows (integer division `n / 8` picks
-- the window; Evident has no modulo). Windows 4–5 reuse windows 0–1's
-- signals so the consumer's cache is shown reusing a result computed
-- in an earlier, non-adjacent window. Self-schedules each tick via a
-- NoEffect heartbeat, announces each new window, and exits at 48.
--
-- The driver's own `given` changes every tick (monotonic `_n`), so it
-- never hits the value cache — but the driver is trivial, so that
-- doesn't matter.
fsm driver(world, world_next ∈ World)
    n ∈ Int = (is_first_tick ? 0 : _n + 1)

    window      ∈ Int  = n / 8
    prev_window ∈ Int  = _n / 8
    new_window  ∈ Bool = (is_first_tick ? true : (window > prev_window))
    halting     ∈ Bool = (n ≥ 48)

    world_next.signal = (window ≤ 0 ? 10
                      : (window = 1 ? 20
                      : (window = 2 ? 30
                      : (window = 3 ? 40
                      : (window = 4 ? 10
                      :               20)))))

    msg ∈ String = (window ≤ 0 ? "signal=10 (window 0)"
                 : (window = 1 ? "signal=20 (window 1)"
                 : (window = 2 ? "signal=30 (window 2)"
                 : (window = 3 ? "signal=40 (window 3)"
                 : (window = 4 ? "signal=10 (window 4 — cache reuse)"
                 :               "signal=20 (window 5 — cache reuse)")))))

    effects = (halting    ? ⟨Println("driver done"), Exit(0)⟩
            : (new_window ? ⟨Println(msg)⟩
                          : ⟨NoEffect⟩))

-- Expensive consumer: reads ONLY world.signal. No `_var`, no state
-- enum, no `last_results` read — so its `given` is exactly
-- {world.signal}. For 7 of every 8 ticks the driver leaves signal
-- alone, so the consumer's `given` is byte-identical to the prior
-- tick and the cross-tick value cache returns the prior bindings,
-- skipping the whole Z3 solve.
--
-- The work: three coupled integer square roots parameterized by
-- world.signal. Each rₖ = ⌊√(·)⌋ is uniquely determined (so the
-- output is deterministic) but only *implicitly* constrained — Z3's
-- nonlinear solver must search for it, and the functionizer can't
-- extract a closed form, so this component falls to a scoped Z3 solve
-- of several hundred µs. The coupling (each root feeds the next) keeps
-- it one connected solve. Self-schedules via NoEffect (silent).
fsm expensive(world ∈ World)
    base ∈ Int = world.signal + 60

    r ∈ Int
    r ≥ 0
    r * r ≤ base
    base < (r + 1) * (r + 1)

    s ∈ Int
    s ≥ 0
    s * s ≤ base * 3 + r
    base * 3 + r < (s + 1) * (s + 1)

    t ∈ Int
    t ≥ 0
    t * t ≤ base * 7 + s
    base * 7 + s < (t + 1) * (t + 1)

    effects = ⟨NoEffect⟩

-- ── Static tests ─────────────────────────────────────────────

-- signal=10 → base=70.  r=⌊√70⌋=8; s=⌊√(210+8)⌋=⌊√218⌋=14;
-- t=⌊√(490+14)⌋=⌊√504⌋=22.
claim sat_roots_for_signal_10
    world ∈ World
    effects ∈ Seq(Effect)
    base ∈ Int
    r ∈ Int
    s ∈ Int
    t ∈ Int
    world.signal = 10
    expensive
    r = 8 ∧ s = 14 ∧ t = 22

claim unsat_roots_off_by_one
    world ∈ World
    effects ∈ Seq(Effect)
    base ∈ Int
    r ∈ Int
    s ∈ Int
    t ∈ Int
    world.signal = 10
    expensive
    r = 9
