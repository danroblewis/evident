-- 15_signal — Plugin-as-writer: declare `signal_received ∈ Int`
-- in World and the runtime auto-installs SigintSource which
-- increments the field on Ctrl-C.
--
-- The FSM watches signal_received; once it sees a count > 0 it
-- prints "shutting down" and exits cleanly. Models the
-- classic "Ctrl-C runs cleanup" pattern.
--
-- Run:    evident effect-run examples/test_15_signal.ev
-- Then:   ^C — should see "shutting down" and exit.

import "stdlib/runtime.ev"

type World
    signal_received ∈ Int

enum SState = Running | Done

fsm guard(world ∈ World,
            state ∈ SState)
    state_next = match state
        Running ⇒ (world.signal_received > 0 ? Done : Running)
        Done    ⇒ Done

    effects = match state
        Running ⇒ ⟨⟩
        Done    ⇒ ⟨Println("shutting down"), Exit(0)⟩

claim sat_done_on_signal
    world ∈ World
    state ∈ SState
    state_next ∈ SState
    last_results ∈ Seq(Result)
    effects ∈ EffectList
    world.signal_received = 1
    state = Running
    guard
    state_next = Done
