-- 29_jit_heavy_compute — a workload where the JIT actually WINS
-- meaningfully over Z3, not just breaks even.
--
-- The other JIT demos (test_25) use trivial arithmetic that Z3's
-- simplify pass folds away cheaply, so JIT and Z3 end up tied. This
-- demo exercises a shape Z3 finds genuinely expensive but a JIT
-- compiles in one pass:
--
--   * A 30-step "conditional-update" chain. Each step's update rule
--     depends on the previous value via a ternary. Z3 can't fold the
--     chain into a closed form because each layer adds a branch that
--     depends on the running state. The JIT just emits 30 compare +
--     branch + arith instructions.
--   * Repeated for a few independent inputs per tick (different
--     starting points), so the JIT-compiled function has real work
--     to do, not just a 5-instruction body.
--
-- The body deliberately uses pure-Int arithmetic + ternaries so the
-- whole thing is JIT-compilable. No Seqs, no records, no enums.
--
-- ─────────────────────────────────────────────────────────────────
-- BENCHMARK (Apple M4, scripts/bench-demo.sh -s 1 -n 5, 21 ticks total)
-- ─────────────────────────────────────────────────────────────────
--   Mode          | wall    | tick0  | wall_post | steady/tick
--   --------------+---------+--------+-----------+------------
--   JIT default   | 16.14ms | 6.35ms |   9.79ms  |  0.01 ms
--   FUNCTIONIZE=0 | 20.93ms | 1.44ms |  19.50ms  |  0.93 ms
--
-- → ~90× faster per-tick steady-state with JIT (0.01 vs 0.93 ms):
--   in steady state both decomposed components (the arithmetic chains
--   AND the `match state` effects) are native code, so Z3 does ~no
--   per-tick work.
-- → 2.0× faster wall_post (9.79 vs 19.50) — the remaining wall is now
--   dispatch cost (Println effects × N ticks), not solving.
-- → tick0 is higher under JIT (6.35 vs 1.44 ms): that's the one-shot
--   Cranelift compile, amortized over every later tick.
--
-- Why JIT wins here but not in test_25: this body has ~196 simplified
-- assertions (vs 16 in test_25) of branch-dependent state, which Z3's
-- simplify can't fold into a polynomial. The JIT compiles each step
-- to a few cmp/branch/arith instructions and the per-tick steady
-- cost is dominated by per-call boilerplate, NOT the body — which
-- is exactly what we want from a JIT.
--
-- Note: `comp=3/4` (session T, was 1/4). Two analyses (tick 0 +
-- steady) × two components = 4 compile attempts. The `effects` step
-- (`match state ⇒ ⟨…⟩`) is a Seq-bodied `Guarded` step that the JIT
-- now compiles (a runtime bail flag covers the no-branch-matched case
-- — see runtime/src/functionize/cranelift.rs + docs/jit-codegen-gaps.md).
-- The deep nested-ITE chains were NEVER the gap — they compile fine.
-- The one component that still doesn't compile is the tick-0 bootstrap
-- chains (its `_tick` prev-value is absent at tick 0, so the unsafe-
-- free check in query.rs routes it to the scoped slow solve); in
-- steady state it compiles, which is why steady cost ≈ 0.
--
-- (Run with EVIDENT_FUNCTIONIZE_STATS=1 to see comp=3/4 and confirm
-- which components the JIT picked up.)

import "stdlib/runtime.ev"

enum St = Looping | Done

fsm heavy(state ∈ St)
    -- 20 ticks then stop.
    tick ∈ Int = (is_first_tick ? 0 : _tick + 1)
    state_next = (tick ≥ 19 ? Done : Looping)

    -- Three independent starting points — three disjoint chains the
    -- runtime can decompose into separate components.
    seed_a ∈ Int = tick * 7 + 3
    seed_b ∈ Int = tick * 11 + 5
    seed_c ∈ Int = tick * 13 + 9

    -- Chain A: 30 conditional updates. Each step picks one of two
    -- arithmetic transforms based on whether the running value
    -- crosses a threshold. Z3 can't fold this into a polynomial
    -- because the branch chosen depends on the running state.
    a01 ∈ Int = (seed_a > 50 ? seed_a - 7 : seed_a * 2 + 11)
    a02 ∈ Int = (a01 > 100 ? a01 - 13 : a01 * 3 + 7)
    a03 ∈ Int = (a02 > 75  ? a02 + 19 : a02 - 5)
    a04 ∈ Int = (a03 > 200 ? a03  - 100 : a03 + 23)
    a05 ∈ Int = (a04 > 50  ? a04 - 7 : a04 * 2 + 11)
    a06 ∈ Int = (a05 > 100 ? a05 - 13 : a05 * 3 + 7)
    a07 ∈ Int = (a06 > 75  ? a06 + 19 : a06 - 5)
    a08 ∈ Int = (a07 > 200 ? a07  - 100 : a07 + 23)
    a09 ∈ Int = (a08 > 50  ? a08 - 7 : a08 * 2 + 11)
    a10 ∈ Int = (a09 > 100 ? a09 - 13 : a09 * 3 + 7)
    a11 ∈ Int = (a10 > 75  ? a10 + 19 : a10 - 5)
    a12 ∈ Int = (a11 > 200 ? a11  - 100 : a11 + 23)
    a13 ∈ Int = (a12 > 50  ? a12 - 7 : a12 * 2 + 11)
    a14 ∈ Int = (a13 > 100 ? a13 - 13 : a13 * 3 + 7)
    a15 ∈ Int = (a14 > 75  ? a14 + 19 : a14 - 5)
    a16 ∈ Int = (a15 > 200 ? a15  - 100 : a15 + 23)
    a17 ∈ Int = (a16 > 50  ? a16 - 7 : a16 * 2 + 11)
    a18 ∈ Int = (a17 > 100 ? a17 - 13 : a17 * 3 + 7)
    a19 ∈ Int = (a18 > 75  ? a18 + 19 : a18 - 5)
    a20 ∈ Int = (a19 > 200 ? a19  - 100 : a19 + 23)
    a21 ∈ Int = (a20 > 50  ? a20 - 7 : a20 * 2 + 11)
    a22 ∈ Int = (a21 > 100 ? a21 - 13 : a21 * 3 + 7)
    a23 ∈ Int = (a22 > 75  ? a22 + 19 : a22 - 5)
    a24 ∈ Int = (a23 > 200 ? a23  - 100 : a23 + 23)
    a25 ∈ Int = (a24 > 50  ? a24 - 7 : a24 * 2 + 11)
    a26 ∈ Int = (a25 > 100 ? a25 - 13 : a25 * 3 + 7)
    a27 ∈ Int = (a26 > 75  ? a26 + 19 : a26 - 5)
    a28 ∈ Int = (a27 > 200 ? a27  - 100 : a27 + 23)
    a29 ∈ Int = (a28 > 50  ? a28 - 7 : a28 * 2 + 11)
    a30 ∈ Int = (a29 > 100 ? a29 - 13 : a29 * 3 + 7)

    -- Chain B (independent of A — different coefficients).
    b01 ∈ Int = (seed_b > 60 ? seed_b - 9 : seed_b * 2 + 13)
    b02 ∈ Int = (b01 > 120 ? b01 - 11 : b01 * 3 + 9)
    b03 ∈ Int = (b02 > 80  ? b02 + 17 : b02 - 3)
    b04 ∈ Int = (b03 > 240 ? b03  - 100 : b03 + 19)
    b05 ∈ Int = (b04 > 60  ? b04 - 9 : b04 * 2 + 13)
    b06 ∈ Int = (b05 > 120 ? b05 - 11 : b05 * 3 + 9)
    b07 ∈ Int = (b06 > 80  ? b06 + 17 : b06 - 3)
    b08 ∈ Int = (b07 > 240 ? b07  - 100 : b07 + 19)
    b09 ∈ Int = (b08 > 60  ? b08 - 9 : b08 * 2 + 13)
    b10 ∈ Int = (b09 > 120 ? b09 - 11 : b09 * 3 + 9)
    b11 ∈ Int = (b10 > 80  ? b10 + 17 : b10 - 3)
    b12 ∈ Int = (b11 > 240 ? b11  - 100 : b11 + 19)
    b13 ∈ Int = (b12 > 60  ? b12 - 9 : b12 * 2 + 13)
    b14 ∈ Int = (b13 > 120 ? b13 - 11 : b13 * 3 + 9)
    b15 ∈ Int = (b14 > 80  ? b14 + 17 : b14 - 3)
    b16 ∈ Int = (b15 > 240 ? b15  - 100 : b15 + 19)
    b17 ∈ Int = (b16 > 60  ? b16 - 9 : b16 * 2 + 13)
    b18 ∈ Int = (b17 > 120 ? b17 - 11 : b17 * 3 + 9)
    b19 ∈ Int = (b18 > 80  ? b18 + 17 : b18 - 3)
    b20 ∈ Int = (b19 > 240 ? b19  - 100 : b19 + 19)
    b21 ∈ Int = (b20 > 60  ? b20 - 9 : b20 * 2 + 13)
    b22 ∈ Int = (b21 > 120 ? b21 - 11 : b21 * 3 + 9)
    b23 ∈ Int = (b22 > 80  ? b22 + 17 : b22 - 3)
    b24 ∈ Int = (b23 > 240 ? b23  - 100 : b23 + 19)
    b25 ∈ Int = (b24 > 60  ? b24 - 9 : b24 * 2 + 13)
    b26 ∈ Int = (b25 > 120 ? b25 - 11 : b25 * 3 + 9)
    b27 ∈ Int = (b26 > 80  ? b26 + 17 : b26 - 3)
    b28 ∈ Int = (b27 > 240 ? b27  - 100 : b27 + 19)
    b29 ∈ Int = (b28 > 60  ? b28 - 9 : b28 * 2 + 13)
    b30 ∈ Int = (b29 > 120 ? b29 - 11 : b29 * 3 + 9)

    -- Chain C (independent of A and B).
    c01 ∈ Int = (seed_c > 70 ? seed_c - 11 : seed_c * 2 + 17)
    c02 ∈ Int = (c01 > 140 ? c01 - 7  : c01 * 3 + 11)
    c03 ∈ Int = (c02 > 90  ? c02 + 13 : c02 - 7)
    c04 ∈ Int = (c03 > 280 ? c03  - 100 : c03 + 17)
    c05 ∈ Int = (c04 > 70  ? c04 - 11 : c04 * 2 + 17)
    c06 ∈ Int = (c05 > 140 ? c05 - 7  : c05 * 3 + 11)
    c07 ∈ Int = (c06 > 90  ? c06 + 13 : c06 - 7)
    c08 ∈ Int = (c07 > 280 ? c07  - 100 : c07 + 17)
    c09 ∈ Int = (c08 > 70  ? c08 - 11 : c08 * 2 + 17)
    c10 ∈ Int = (c09 > 140 ? c09 - 7  : c09 * 3 + 11)
    c11 ∈ Int = (c10 > 90  ? c10 + 13 : c10 - 7)
    c12 ∈ Int = (c11 > 280 ? c11  - 100 : c11 + 17)
    c13 ∈ Int = (c12 > 70  ? c12 - 11 : c12 * 2 + 17)
    c14 ∈ Int = (c13 > 140 ? c13 - 7  : c13 * 3 + 11)
    c15 ∈ Int = (c14 > 90  ? c14 + 13 : c14 - 7)
    c16 ∈ Int = (c15 > 280 ? c15  - 100 : c15 + 17)
    c17 ∈ Int = (c16 > 70  ? c16 - 11 : c16 * 2 + 17)
    c18 ∈ Int = (c17 > 140 ? c17 - 7  : c17 * 3 + 11)
    c19 ∈ Int = (c18 > 90  ? c18 + 13 : c18 - 7)
    c20 ∈ Int = (c19 > 280 ? c19  - 100 : c19 + 17)
    c21 ∈ Int = (c20 > 70  ? c20 - 11 : c20 * 2 + 17)
    c22 ∈ Int = (c21 > 140 ? c21 - 7  : c21 * 3 + 11)
    c23 ∈ Int = (c22 > 90  ? c22 + 13 : c22 - 7)
    c24 ∈ Int = (c23 > 280 ? c23  - 100 : c23 + 17)
    c25 ∈ Int = (c24 > 70  ? c24 - 11 : c24 * 2 + 17)
    c26 ∈ Int = (c25 > 140 ? c25 - 7  : c25 * 3 + 11)
    c27 ∈ Int = (c26 > 90  ? c26 + 13 : c26 - 7)
    c28 ∈ Int = (c27 > 280 ? c27  - 100 : c27 + 17)
    c29 ∈ Int = (c28 > 70  ? c28 - 11 : c28 * 2 + 17)
    c30 ∈ Int = (c29 > 140 ? c29 - 7  : c29 * 3 + 11)

    effects = match state
        Looping ⇒ ⟨Println("step")⟩
        Done    ⇒ ⟨Println("heavy compute: done"), Exit(0)⟩

claim sat_initial_step_typechecks
    -- A trivial reachability check; the heavy stuff is in `coloring`.
    tick ∈ Int
    tick = 0
    seed_a ∈ Int = tick * 7 + 3
    a01 ∈ Int = (seed_a > 50 ? seed_a - 7 : seed_a * 2 + 11)
