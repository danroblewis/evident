-- 16_sdl_red — SDL Renderer (Metal-backed, NOT raw OpenGL).
-- Window opens, fills red, redraws each frame, closes after 60.
--
-- Zero LibCall / FFICall / hardcoded dylib paths in this file —
-- the rule from CLAUDE.md. All FFI is in stdlib helpers; the
-- demo emits each tick's effects as one atomic top-level list,
-- where the `*_after` variants take a prior-result index for the
-- renderer handle (which exists at position 2 of the setup tick
-- after SDL_CreateRenderer fires).

import "stdlib/runtime.ev"
import "packages/sdl/window.ev"
import "packages/sdl/render.ev"

enum RState = Init | Loop(Int) | Done

fsm red_window
    state ∈ RState := Init
    ¬is_first_tick ⇒
        state = match _state
            Init    ⇒ Loop(60)
            Loop(n) ⇒ (n ≤ 1 ? Done : Loop(n - 1))
            Done    ⇒ Done

    -- Setup tick (Init state):
    --   [0] sdl_init(SDL_INIT_VIDEO)
    --   [1] sdl_create_window      → window pointer
    --   [2] create_renderer_after(1) → renderer pointer
    --   [3] set_draw_color_after(2, red)
    --   [4] render_clear_after(2)
    --   [5] render_present_after(2)
    init_eff ∈ Effect
    sdl_init(32, init_eff)             -- SDL_INIT_VIDEO=32
    create_win_eff ∈ Effect
    sdl_create_window("Red", 805240832, 805240832, 640, 480, 4, create_win_eff)
    create_ren_eff ∈ Effect
    create_renderer_after(1, create_ren_eff)

    red ∈ Color
    red = Color(220, 40, 60, 255)
    set_color_setup ∈ Effect
    set_draw_color_after(2, red, set_color_setup)
    clear_setup ∈ Effect
    render_clear_after(2, clear_setup)
    present_setup ∈ Effect
    render_present_after(2, present_setup)

    -- Per-frame tick (Loop(n)): re-create the renderer (libffi
    -- caches dlopen/dlsym; macOS SDL re-creates an accelerated
    -- renderer cheaply), then reference position 0 for the rest
    -- of the frame. COUNTEREXAMPLES.md #8: there's no way to
    -- carry a renderer handle across ticks without an FTI bridge.
    frame_create_ren ∈ Effect
    create_renderer_after(0, frame_create_ren)
    frame_set_color ∈ Effect
    set_draw_color_after(0, red, frame_set_color)
    frame_clear ∈ Effect
    render_clear_after(0, frame_clear)
    frame_present ∈ Effect
    render_present_after(0, frame_present)
    pump_eff ∈ Effect
    sdl_pump_events(pump_eff)
    delay_eff ∈ Effect
    sdl_delay(33, delay_eff)

    effects = match state
        Init    ⇒ ⟨init_eff, create_win_eff, create_ren_eff,
                   set_color_setup, clear_setup, present_setup⟩
        Loop(n) ⇒ (n > 0 ? ⟨frame_create_ren, frame_set_color, frame_clear,
                            frame_present, pump_eff, delay_eff⟩
                         : ⟨⟩)
        Done    ⇒ ⟨Println("done"), Exit(0)⟩

claim sat_init_advances_to_loop_60
    _state ∈ RState
    state ∈ RState
    is_first_tick ∈ Bool
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    is_first_tick = false
    _state = Init
    red_window
    state = Loop(60)
