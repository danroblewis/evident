-- 05_int_to_str — Effect::IntToStr and a Println roundtrip.
--
-- Issues IntToStr(42), then on the next tick reads last_results
-- and prints the StringResult — proving the runtime can format
-- Ints without a separate stdlib call.

import "stdlib/runtime.ev"

enum FmtState = Issue | Show | Halt

claim fmt_demo(state, state_next ∈ FmtState,
               last_results ∈ ResultList,
               effects ∈ EffectList)
    state_next = match state
        Issue ⇒ Show
        Show ⇒ Halt
        Halt  ⇒ Halt

    formatted ∈ String
    formatted = match last_results
        ResCons(r, _) ⇒ match r
            StringResult(s) ⇒ s
            _               ⇒ "<no string>"
        _             ⇒ "<no result>"

    effects = match state
        Issue ⇒ ⟨IntToStr(42)⟩
        Show ⇒ ⟨Println(formatted), Exit(0)⟩
        Halt  ⇒ ⟨⟩

claim sat_issue_emits_int_to_str
    state ∈ FmtState
    state_next ∈ FmtState
    last_results ∈ ResultList
    effects ∈ EffectList
    state = Issue
    fmt_demo
    effects = ⟨IntToStr(42)⟩
