-- 05_int_to_str — to_str(n) as a pure expression op.
--
-- to_str is a same-tick int→string transform (Z3 str.from_int with a sign
-- wrapper for negatives), not an effect: `s ∈ String = to_str(42)` is "42"
-- in the same tick. The FSM formats inline, Println's it, and exits — no
-- last_results dance.

import "stdlib/runtime.ev"

fsm fmt_demo
    formatted ∈ String = to_str(42)
    negative  ∈ String = to_str(0 - 7)

    effects = ⟨Println(formatted), Println(negative), Exit(0)⟩

claim sat_formats_positive
    to_str(42) = "42"

claim sat_formats_negative
    to_str(0 - 7) = "-7"

claim sat_formats_zero
    to_str(0) = "0"
