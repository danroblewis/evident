-- 11_frameclock — FTI: declare `clock ∈ FrameClock` and the
-- runtime auto-installs a bridge that ticks clock.tick_count
-- at 100ms intervals (default; configurable via EVIDENT_TICK_MS).
--
-- This demo uses the SAME pattern that the lang test 15 uses:
-- a single nullary state, exit-condition in `effects` directly.
--
-- COUNTEREXAMPLE NOTE: Trying to use `clock.tick_count` inside
-- a `match state` for state transitions instead of inline in
-- `effects` doesn't fire — Z3 picks Watching forever even when
-- the threshold is reached. Probably the per-FSM view doesn't
-- propagate FTI pins into the state-transition constraint.
-- Workaround: gate exit on `clock.tick_count` directly in
-- `effects`, not via `state_next = match state`.

import "stdlib/runtime.ev"

enum F = Watching

fsm watcher(clock ∈ FrameClock,
              state ∈ F)
    state_next = Watching
    effects = (clock.tick_count ≥ 3
               ? ⟨Println("3 clock ticks observed"), Exit(0)⟩
               : ⟨⟩)

claim sat_exits_at_three_ticks
    clock ∈ FrameClock
    state ∈ F
    state_next ∈ F
    last_results ∈ Seq(Result)
    effects ∈ Seq(Effect)
    clock.tick_count = 3
    state = Watching
    watcher
    effects = ⟨Println("3 clock ticks observed"), Exit(0)⟩
