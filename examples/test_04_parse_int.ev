-- 04_parse_int — parse_int(s) as a pure expression op.
--
-- parse_int is a same-tick string→int transform (Z3 str.to_int), not an
-- effect: `m ∈ Int = parse_int("42")` is 42 in the same tick. Non-numeric
-- strings yield the -1 sentinel (Z3 str.to_int semantics). The FSM computes
-- both inline, Println's the verdicts, and exits — no last_results dance.

import "stdlib/runtime.ev"

fsm parse_demo
    good ∈ Int = parse_int("42")
    bad  ∈ Int = parse_int("not-a-number")

    good_msg ∈ String = (good = 42 ? "good: parsed an Int" : "good: WRONG")
    bad_msg  ∈ String = (bad = 0 - 1 ? "bad: sentinel was correct" : "bad: WRONG")

    effects = ⟨Println(good_msg), Println(bad_msg), Exit(0)⟩

claim sat_parses_42
    parse_int("42") = 42

claim sat_nonnumeric_is_sentinel
    parse_int("not-a-number") = 0 - 1

claim unsat_nonnumeric_not_42
    parse_int("not-a-number") = 42
