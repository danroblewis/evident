-- Topological sort as a constraint problem — generic over node type.
--
-- `Edge<T>` carries a directed dependency between two nodes of type
-- `T`. `Toposort<T>` solves for a permutation of items where every
-- edge respects ordering. Domain types in, domain types out —
-- indices stay inside `position_of`, never at the interface.
--
-- Interface:
--   * `items ∈ Set(T)`        — the nodes (unordered).
--   * `edges ∈ Seq(Edge<T>)`  — directed dependencies. Endpoints are
--                                MATCHED to items by Z3 value
--                                equality, not by position.
-- Output:
--   * `sorted ∈ Seq(T)`       — items ordered so every edge
--                                from→to has from appearing earlier.
--
-- SAT iff the graph is acyclic; UNSAT iff a cycle exists.
--
-- Identity is by Z3 value equality on T. If two items are
-- structurally equal, they're the same vertex. Use distinct values
-- if you need to distinguish two otherwise-equal nodes.

import "stdlib/combinatorics.ev"

type Edge<T>(from, to ∈ T)

-- ── How this is encoded ──────────────────────────────────────────
--
-- Two clauses, almost reading as the math:
--   1. `sorted` is a permutation of `items` — delegated to
--      `Permutation<T>` (see stdlib/permutation.ev).
--   2. Every edge has `from`'s position in sorted < `to`'s.
--      `position_of(seq, x)` returns the index of x in seq
--      (chained-ITE under the hood); the comparison is the
--      partial-order constraint, one per edge, no nested
--      quantifiers.
--
-- Domain types in, domain types out — indices live entirely
-- inside `position_of` and never touch the interface.

claim Toposort<T>(items ∈ Set(T), edges ∈ Seq(Edge<T>), sorted ∈ Seq(T))
    -- Cardinality pin surfaced here (not just inside Permutation) so
    -- `collect_seq_lengths` resolves `#sorted = #items` for direct
    -- queries without a separate `#sorted = N` from the caller.
    #items = #sorted
    Permutation<T>(items, sorted)
    ∀ e ∈ edges : position_of(sorted, e.from) < position_of(sorted, e.to)

-- ── Integer-rank fast path (runtime effect dispatcher) ───────────
--
-- The generic `Toposort<T>` above is the clean domain-typed API, but its
-- `position_of(sorted, x)` is a depth-n chained ITE evaluated twice per
-- edge — O(n·#edges) Z3 terms — which blows up at the runtime effect
-- dispatcher's scale (a Mario frame is ~70 nodes / ~96 edges → tens of
-- thousands of ITE terms, tens of seconds to solve).
--
-- `ToposortRanks` is the dispatcher's internal encoding. Nodes are the
-- contiguous integers `0..n-1` (the dispatcher maps its node names to
-- these), and `pos[k]` is the OUTPUT RANK of node k. An edge then indexes
-- `pos` DIRECTLY — `pos[e.from] < pos[e.to]` — a single array select per
-- endpoint, O(1) per edge, no ITE chain. Identity is still by value
-- (distinct node ids), and `pos` is a permutation of `0..n-1`, so sorting
-- the node ids by ascending `pos` recovers a valid topological order.
--
-- This is NOT a public interface: the integers here are opaque node
-- identities the runtime assigns during marshaling, never surfaced to a
-- user program (see CLAUDE.md "Indices in interfaces are a leak" — that
-- rule governs public claims; this is runtime-internal). SAT iff acyclic.

-- `n` is given as a concrete Nat by the dispatcher, so `#pos = n` resolves
-- `pos`'s length up front and `distinct` / the range ∀ unroll. (Correctness
-- is pinned in `runtime/tests/toposort_correctness.rs`, which drives this
-- exactly as the dispatcher does — `rt.query("ToposortRanks", {n, edges})`.)
claim ToposortRanks(n ∈ Nat, edges ∈ Seq(Edge<Int>), pos ∈ Seq(Int))
    #pos = n
    ∀ i ∈ {0..n-1} : 0 ≤ pos[i] < n
    distinct(pos)
    ∀ e ∈ edges : pos[e.from] < pos[e.to]

-- ── Tests ────────────────────────────────────────────────────────

claim sat_two_edges_4_nodes
    items ∈ Set(Int)
    edges ∈ Seq(Edge<Int>)
    sorted ∈ Seq(Int)
    items = {10, 20, 30, 40}
    #sorted = 4
    #edges = 2
    edges[0] = Edge<Int>(10, 30)
    edges[1] = Edge<Int>(20, 40)
    Toposort<Int>(items, edges, sorted)

claim sat_linear_chain_forces_unique_order
    items ∈ Set(Int)
    edges ∈ Seq(Edge<Int>)
    sorted ∈ Seq(Int)
    items = {100, 200, 300}
    #sorted = 3
    #edges = 2
    edges[0] = Edge<Int>(100, 200)
    edges[1] = Edge<Int>(200, 300)
    Toposort<Int>(items, edges, sorted)
    sorted = ⟨100, 200, 300⟩

claim unsat_three_cycle
    items ∈ Set(Int)
    edges ∈ Seq(Edge<Int>)
    sorted ∈ Seq(Int)
    items = {1, 2, 3}
    #sorted = 3
    #edges = 3
    edges[0] = Edge<Int>(1, 2)
    edges[1] = Edge<Int>(2, 3)
    edges[2] = Edge<Int>(3, 1)
    Toposort<Int>(items, edges, sorted)

claim sat_empty_edges
    items ∈ Set(Int)
    edges ∈ Seq(Edge<Int>)
    sorted ∈ Seq(Int)
    items = {1, 2, 3}
    #sorted = 3
    #edges = 0
    Toposort<Int>(items, edges, sorted)

-- ── String monomorphization ─────────────────────────────────────
-- Forces `Toposort<String>` (and its Edge<String> / Permutation<String>
-- transitive monos) to materialize at load time. The dispatcher's
-- self-hosted toposort path queries this schema by name; without
-- this anchor the generic template never produces a String instance.

claim sat_toposort_string_mono
    items ∈ Set(String)
    edges ∈ Seq(Edge<String>)
    sorted ∈ Seq(String)
    items = {"a", "b"}
    #sorted = 2
    #edges = 1
    edges[0] = Edge<String>("a", "b")
    Toposort<String>(items, edges, sorted)
    sorted = ⟨"a", "b"⟩
